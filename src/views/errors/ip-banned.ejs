<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Access Denied</title>
    <link rel="stylesheet" href="/assets/css/style.css" nonce="<%= nonce %>">
</head>
<body class="min-h-screen bg-slate-900 flex items-center justify-center p-4">
    <div class="max-w-md w-full text-center">
        <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-8">
            <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-white mb-2">Access Denied</h1>
            <p class="text-slate-400 mb-6">Your IP address has been banned from accessing this service.</p>
            
            <% if (typeof reason !== 'undefined' && reason) { %>
            <div class="bg-slate-800/50 rounded-lg p-4 mb-4">
                <p class="text-xs font-bold text-slate-500 uppercase mb-1">Reason</p>
                <p class="text-slate-300 text-sm"><%= reason %></p>
            </div>
            <% } %>
            
            <% if (typeof expiresAt !== 'undefined' && expiresAt) { %>
            <div class="bg-slate-800/50 rounded-lg p-4 mb-4">
                <p class="text-xs font-bold text-slate-500 uppercase mb-1">Ban Expires</p>
                <p class="text-slate-300 text-sm"><%= new Date(expiresAt).toLocaleString() %></p>
            </div>
            <% } else { %>
            <p class="text-slate-500 text-xs">This ban is permanent.</p>
            <% } %>
            
            <div class="mt-8 pt-6 border-t border-slate-700">
                <p class="text-slate-500 text-xs">If you believe this is an error, please contact support.</p>
            </div>
        </div>
    </div>
</body>
</html>
