<!-- RECOMMENDATIONS (UPSELL) -->
<% 
    const recs = branding.model?.recommendations || []; 
    const theme = branding.themeData || {};
%>
<div class="mt-6 font-sans">
    <div class="flex justify-between items-end mb-4">
        <div>
            <div class="text-[13px] font-bold text-slate-800" :style="'color: ' + theme.text">🎯 Recommended for You</div>
            <div class="text-[10px] text-gray-400 mt-0.5">Personalized based on your order & purchase history</div>
        </div>
        <span class="text-[9px] font-bold px-2 py-1 rounded-md tracking-wide uppercase" 
              :style="'color: ' + theme.primary + '; background: ' + theme.light">AI-Powered</span>
    </div>
    
    <!-- DESKTOP / TABLET VIEW (Grid) -->
    <div class="hidden md:grid md:grid-cols-3 gap-4">
        <% recs.forEach(rec => { %>
            <div class="bg-white rounded-xl p-4 shadow-sm border transition-all relative overflow-hidden group hover:shadow-md flex flex-col h-full"
                 :style="'border-color: ' + (addedItems.includes(<%= rec.id %>) ? theme.primary : '#e5e7eb')">
                 
                 <!-- Match Score -->
                 <div class="absolute top-3 right-3 w-8 h-8 opacity-90">
                     <svg width="32" height="32" viewBox="0 0 38 38">
                        <circle cx="19" cy="19" r="15" fill="none" stroke="#F3F4F6" stroke-width="4"></circle>
                        <circle cx="19" cy="19" r="15" fill="none" :stroke="theme.primary" stroke-width="4"
                                :stroke-dasharray="(<%= rec.match %> / 100) * 94.25 + ' 94.25'" stroke-linecap="round" transform="rotate(-90 19 19)"></circle>
                        <text x="19" y="23.5" text-anchor="middle" font-size="10" font-weight="bold" :fill="theme.primary"><%= rec.match %></text>
                     </svg>
                 </div>

                <div class="flex items-start gap-3 mb-3">
                    <div class="w-12 h-12 rounded-lg flex items-center justify-center text-2xl bg-gray-50 shrink-0" 
                         :style="'background: ' + theme.light"><%= rec.img %></div>
                    <div class="flex-1 pr-8">
                        <div class="text-[13px] font-bold leading-tight mb-1" :style="'color: ' + theme.text"><%= rec.name %></div>
                        <div class="text-[12px] font-bold" :style="'color: ' + theme.primary">$<%= rec.price.toFixed(2) %></div>
                    </div>
                </div>

                <div class="text-[10px] text-gray-500 bg-gray-50 rounded-lg px-2.5 py-2 mb-3 leading-relaxed border border-gray-100 flex-grow">
                    💡 <span><%= rec.reason %></span>
                </div>

                <div class="flex justify-between items-center mb-3">
                    <span class="text-[9px] font-bold px-2 py-0.5 rounded text-white uppercase tracking-wider" 
                          :style="'background: ' + theme.accent + '; color: ' + theme.primary"><%= rec.badge %></span>
                    <span class="text-[9px] text-gray-400 font-medium"><%= rec.sales %></span>
                </div>

                <button @click="toggleAdd(<%= rec.id %>)" 
                        class="w-full py-2.5 rounded-lg text-[11px] font-bold transition-all border-none cursor-pointer flex items-center justify-center gap-2 group-hover:scale-[1.02] mt-auto"
                        :style="addedItems.includes(<%= rec.id %>) ? 'background: ' + theme.accent + '; color: ' + theme.primary : 'background: ' + theme.gradient + '; color: #fff'">
                    <span x-show="!addedItems.includes(<%= rec.id %>)" class="text-xs">+</span>
                    <span x-show="addedItems.includes(<%= rec.id %>)" class="text-xs">✓</span>
                    <span x-text="addedItems.includes(<%= rec.id %>) ? 'Added' : 'Add to Order'"></span>
                </button>
            </div>
        <% }); %>
    </div>

    <!-- MOBILE VIEW (Compact List) -->
    <div class="md:hidden flex flex-col gap-3">
        <% recs.forEach(rec => { %>
            <div class="bg-white rounded-lg p-3 shadow-sm border flex items-center gap-3 transition-colors"
                 :style="'border-color: ' + (addedItems.includes(<%= rec.id %>) ? theme.primary : '#f3f4f6')">
                
                <!-- Thumb -->
                <div class="w-10 h-10 rounded-md flex items-center justify-center text-xl bg-gray-50 shrink-0" 
                     :style="'background: ' + theme.light"><%= rec.img %></div>
                
                <!-- Info -->
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <div class="text-[12px] font-bold truncate leading-tight" :style="'color: ' + theme.text"><%= rec.name %></div>
                        <span class="text-[8px] font-bold px-1.5 py-0.5 rounded text-white uppercase" 
                              :style="'background: ' + theme.accent + '; color: ' + theme.primary"><%= rec.badge %></span>
                    </div>
                    <div class="flex items-center gap-2 mt-0.5">
                        <span class="text-[11px] font-bold" :style="'color: ' + theme.primary">$<%= rec.price.toFixed(2) %></span>
                        <span class="text-[9px] text-gray-400"><%= rec.match %>% Match</span>
                    </div>
                </div>

                <!-- Action (Compact) -->
                <button @click="toggleAdd(<%= rec.id %>)" 
                        class="w-8 h-8 rounded-full flex items-center justify-center transition-all border-none cursor-pointer shrink-0"
                        :style="addedItems.includes(<%= rec.id %>) ? 'background: ' + theme.accent + '; color: ' + theme.primary : 'background: ' + theme.light + '; color: ' + theme.primary">
                    <span x-text="addedItems.includes(<%= rec.id %>) ? '✓' : '+'" class="font-bold text-sm"></span>
                </button>
            </div>
        <% }); %>
    </div>
</div>
