<!-- RECOMMENDATIONS (UPSELL) — Dual Layout v3.0 -->
<% 
    const recs = branding.model?.recommendations || []; 
    const theme = branding.themeData || {};
    const recLayout = branding.components?.product_recommendations?.config?.layout || 'grid';
%>
<div class="mt-4 font-sans">
    <!-- Header Row -->
    <div class="flex justify-between items-center mb-2.5">
        <div class="flex items-center gap-1.5">
            <span class="text-[12px] font-bold text-slate-800" :style="'color: ' + theme.text">🎯 Recommended for You</span>
            <span class="text-[8px] font-bold px-1.5 py-0.5 rounded-md tracking-wide uppercase" 
                  :style="'color: ' + theme.primary + '; background: ' + theme.light">AI-Powered</span>
        </div>
        <span class="text-[9px] text-gray-400">Personalized for your order</span>
    </div>
    
    <% if (recLayout === 'grid') { %>
    <!-- ============ GRID LAYOUT (Compact Tiles) ============ -->
    <div class="grid grid-cols-3 gap-2">
        <% recs.forEach(rec => { %>
            <div class="bg-white rounded-lg border overflow-hidden transition-all hover:shadow-sm"
                 :style="'border-color: ' + (addedItems.includes(<%= rec.id %>) ? theme.primary : '#e5e7eb')">
                
                <!-- Product Image -->
                <div class="w-full h-16 bg-gray-50 overflow-hidden">
                    <img src="<%= rec.img %>" 
                         alt="<%= rec.name %>" 
                         class="w-full h-full object-cover"
                         onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-2xl bg-gray-50\'>📦</div>';">
                </div>

                <!-- Info -->
                <div class="px-2 py-1.5">
                    <div class="text-[10px] font-bold leading-tight truncate" :style="'color: ' + theme.text"><%= rec.name %></div>
                    <div class="flex items-center justify-between mt-1">
                        <span class="text-[11px] font-bold" :style="'color: ' + theme.primary">$<%= rec.price.toFixed(2) %></span>
                        <span class="text-[7px] font-bold px-1 py-0.5 rounded uppercase tracking-wider" 
                              :style="'background: ' + theme.accent + '; color: ' + theme.primary"><%= rec.badge %></span>
                    </div>
                    <div class="text-[8px] text-gray-400 mt-0.5 truncate">💡 <%= rec.reason %></div>
                </div>

                <!-- Add Button -->
                <div class="px-2 pb-2">
                    <button @click="toggleAdd(<%= rec.id %>)" 
                            class="w-full py-1 rounded text-[9px] font-bold transition-all border-none cursor-pointer"
                            :style="addedItems.includes(<%= rec.id %>) ? 'background: ' + theme.accent + '; color: ' + theme.primary : 'background: ' + theme.gradient + '; color: #fff'">
                        <span x-text="addedItems.includes(<%= rec.id %>) ? '✓ Added' : '+ Add'"></span>
                    </button>
                </div>
            </div>
        <% }); %>
    </div>

    <% } else { %>
    <!-- ============ LIST LAYOUT (Compact Rows) ============ -->
    <div class="border rounded-lg overflow-hidden" style="border-color: #e5e7eb;">
        <% recs.forEach((rec, idx) => { %>
            <div class="flex items-center gap-2.5 px-2.5 py-2 bg-white transition-colors<%= idx < recs.length - 1 ? ' border-b' : '' %>"
                 style="<%= idx < recs.length - 1 ? 'border-color: #f3f4f6;' : '' %>"
                 :style="addedItems.includes(<%= rec.id %>) ? { background: theme.light } : {}">
                
                <!-- Product Thumbnail -->
                <div class="w-8 h-8 rounded overflow-hidden shrink-0 bg-gray-50">
                    <img src="<%= rec.img %>" 
                         alt="<%= rec.name %>" 
                         class="w-full h-full object-cover"
                         onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'w-full h-full flex items-center justify-center text-sm bg-gray-50\'>📦</div>';">
                </div>
                
                <!-- Info -->
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1.5">
                        <span class="text-[10px] font-bold truncate" :style="'color: ' + theme.text"><%= rec.name %></span>
                        <span class="text-[7px] font-bold px-1 py-0.5 rounded uppercase tracking-wider shrink-0" 
                              :style="'background: ' + theme.accent + '; color: ' + theme.primary"><%= rec.badge %></span>
                    </div>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="text-[10px] font-bold" :style="'color: ' + theme.primary">$<%= rec.price.toFixed(2) %></span>
                        <span class="text-[8px] text-gray-400">· <%= rec.match %>% match</span>
                        <span class="text-[8px] text-gray-400 truncate">· <%= rec.reason %></span>
                    </div>
                </div>

                <!-- Action -->
                <button @click="toggleAdd(<%= rec.id %>)" 
                        class="shrink-0 px-2.5 py-1 rounded text-[9px] font-bold transition-all border-none cursor-pointer"
                        :style="addedItems.includes(<%= rec.id %>) ? 'background: ' + theme.accent + '; color: ' + theme.primary : 'background: ' + theme.gradient + '; color: #fff'">
                    <span x-text="addedItems.includes(<%= rec.id %>) ? '✓' : '+ Add'"></span>
                </button>
            </div>
        <% }); %>
    </div>
    <% } %>
</div>
