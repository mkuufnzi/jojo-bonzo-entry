<!-- Referral Program Widget -->
<div class="mx-8 mt-6 bg-gradient-to-r from-emerald-50 to-teal-50 rounded-xl p-6 border border-emerald-100">
    <div class="flex items-center justify-between">
        <div>
            <div class="font-semibold text-emerald-800 mb-1">Share the love, get rewarded</div>
            <div class="text-sm text-emerald-700">Give $20, Get $20 when friends make their first purchase</div>
            <div class="mt-2 flex items-center gap-2">
                <input type="text" readonly value="https://ref.yourcompany.com/ABC123" 
                       class="text-xs bg-white border border-emerald-200 rounded px-3 py-1.5 w-64 font-mono">
                <a href="<%= branding.generateActionLink('referral_click') %>" target="_blank" class="bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1.5 rounded text-xs font-semibold no-print decoration-none">
                    Copy Link
                </a>
            </div>
        </div>
    </div>
</div>
