<!-- Review Request Widget -->
<div class="mx-8 mt-6 bg-gradient-to-r from-sky-50 to-blue-50 rounded-xl p-6 border border-sky-100">
    <div class="text-center">
        <div class="font-semibold text-sky-800 mb-2">How was your experience?</div>
        <!-- Alpine Rating if enabled, or just static links -->
        <div class="flex justify-center gap-1 mb-3">
            <% for(let i = 0; i < 5; i++) { %>
            <a href="<%= branding.generateActionLink('review_prompt', { rating: i + 1 }) %>" 
               target="_blank"
               class="text-3xl hover:scale-110 transition-transform no-print decoration-none">
                <span class="text-yellow-400">★</span>
            </a>
            <% } %>
        </div>
        <div class="text-sm text-sky-600">Your feedback helps us improve</div>
        <a href="<%= branding.generateActionLink('review_prompt') %>" 
           target="_blank"
           class="mt-3 text-sky-700 hover:text-sky-800 text-sm font-semibold underline no-print">
            Write a detailed review →
        </a>
    </div>
</div>
