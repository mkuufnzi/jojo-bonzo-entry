<%- include('../partials/head', { title: 'Transactional Branding Analytics' }) %>
<%- include('../partials/sidebar') %>

<main class="flex-1 overflow-y-auto bg-slate-50 p-4 md:p-6 lg:p-8">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">Transactional Branding Analytics</h1>
                <p class="text-slate-500 mt-1">Revenue & processing metrics for branded documents</p>
            </div>
            <div class="flex items-center gap-3 mt-4 md:mt-0">
                <form method="GET" class="flex items-center gap-2">
                    <input type="date" name="startDate" value="<%= dateRange.start %>" 
                           class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                    <span class="text-slate-400">to</span>
                    <input type="date" name="endDate" value="<%= dateRange.end %>" 
                           class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent">
                    <button type="submit" class="px-4 py-2 bg-purple-600 text-white rounded-lg text-sm font-medium hover:bg-purple-700 transition">
                        Apply
                    </button>
                </form>
            </div>
        </div>

        <!-- Revenue KPI Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <!-- Today -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-slate-500">Today</span>
                    <span class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </span>
                </div>
                <p class="text-3xl font-bold text-slate-900 mt-2">$<%= Number(revenueOverview.today).toFixed(2) %></p>
            </div>

            <!-- This Week -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-slate-500">This Week</span>
                    <span class="text-xs px-2 py-1 rounded-full <%= revenueOverview.growth.weekOverWeek >= 0 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                        <%= revenueOverview.growth.weekOverWeek >= 0 ? '+' : '' %><%= revenueOverview.growth.weekOverWeek %>%
                    </span>
                </div>
                <p class="text-3xl font-bold text-slate-900 mt-2">$<%= Number(revenueOverview.thisWeek).toFixed(2) %></p>
            </div>

            <!-- This Month -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-slate-500">This Month</span>
                    <span class="text-xs px-2 py-1 rounded-full <%= revenueOverview.growth.monthOverMonth >= 0 ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                        <%= revenueOverview.growth.monthOverMonth >= 0 ? '+' : '' %><%= revenueOverview.growth.monthOverMonth %>%
                    </span>
                </div>
                <p class="text-3xl font-bold text-slate-900 mt-2">$<%= Number(revenueOverview.thisMonth).toFixed(2) %></p>
            </div>

            <!-- All Time -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-slate-500">All Time</span>
                    <span class="text-xs text-slate-400">ARPD: $<%= Number(revenueOverview.arpd).toFixed(2) %></span>
                </div>
                <p class="text-3xl font-bold text-purple-600 mt-2">$<%= Number(revenueOverview.allTime).toFixed(2) %></p>
            </div>
        </div>

        <!-- Processing Stats -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <!-- Document Processing Card -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Processing Stats
                </h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500">Total Processed</span>
                        <span class="font-bold text-slate-900"><%= processingStats.total %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500">Successful</span>
                        <span class="font-bold text-green-600"><%= processingStats.successful %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500">Failed</span>
                        <span class="font-bold text-red-600"><%= processingStats.failed %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500">Pending</span>
                        <span class="font-bold text-amber-600"><%= processingStats.pending %></span>
                    </div>
                    <div class="pt-4 border-t border-slate-100">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-500">Success Rate</span>
                            <span class="font-bold <%= processingStats.successRate >= 95 ? 'text-green-600' : processingStats.successRate >= 80 ? 'text-amber-600' : 'text-red-600' %>">
                                <%= processingStats.successRate %>%
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Document Types -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
                    </svg>
                    Document Types
                </h3>
                <div class="space-y-3">
                    <% documentsByType.forEach(doc => { %>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-slate-700"><%= doc.type %></span>
                            <span class="text-slate-500"><%= doc.count %> (<%= doc.percentOfTotal %>%)</span>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div class="bg-purple-600 h-2 rounded-full" style="width: <%= doc.percentOfTotal %>%"></div>
                        </div>
                    </div>
                    <% }); %>
                    <% if (documentsByType.length === 0) { %>
                    <p class="text-slate-400 text-sm">No documents processed yet</p>
                    <% } %>
                </div>
            </div>

            <!-- Top Templates -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
                    </svg>
                    Top Templates
                </h3>
                <div class="space-y-3">
                    <% revenueByTemplate.forEach((template, idx) => { %>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold flex items-center justify-center"><%= idx + 1 %></span>
                            <span class="text-sm text-slate-700 truncate max-w-[120px]"><%= template.templateName %></span>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-slate-900">$<%= template.totalRevenue.toFixed(2) %></p>
                            <p class="text-xs text-slate-400"><%= template.documentsProcessed %> docs</p>
                        </div>
                    </div>
                    <% }); %>
                    <% if (revenueByTemplate.length === 0) { %>
                    <p class="text-slate-400 text-sm">No template data yet</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Bottom Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Top Customers -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    Top Customers
                </h3>
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-slate-100">
                                <th class="text-left py-2 text-slate-500 font-medium">Customer</th>
                                <th class="text-right py-2 text-slate-500 font-medium">Docs</th>
                                <th class="text-right py-2 text-slate-500 font-medium">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% topCustomers.forEach(customer => { %>
                            <tr class="border-b border-slate-50">
                                <td class="py-3">
                                    <p class="font-medium text-slate-900"><%= customer.name || 'Unknown' %></p>
                                    <p class="text-xs text-slate-400"><%= customer.email %></p>
                                </td>
                                <td class="text-right">
                                    <span class="text-slate-700"><%= customer.documentsProcessed %></span>
                                </td>
                                <td class="text-right">
                                    <span class="font-bold text-green-600">$<%= customer.totalRevenue.toFixed(2) %></span>
                                </td>
                            </tr>
                            <% }); %>
                            <% if (topCustomers.length === 0) { %>
                            <tr>
                                <td colspan="3" class="text-center py-8 text-slate-400">No customer data yet</td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Integration Breakdown -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                    </svg>
                    Documents by Provider
                </h3>
                <div class="space-y-4">
                    <% revenueByProvider.forEach(item => { %>
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <div class="flex items-center gap-2">
                                <% if (item.provider === 'quickbooks') { %>
                                <span class="w-8 h-8 rounded bg-green-100 flex items-center justify-center text-green-700 font-bold text-xs">QB</span>
                                <% } else if (item.provider === 'xero') { %>
                                <span class="w-8 h-8 rounded bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-xs">XE</span>
                                <% } else if (item.provider === 'zoho') { %>
                                <span class="w-8 h-8 rounded bg-red-100 flex items-center justify-center text-red-700 font-bold text-xs">ZO</span>
                                <% } else { %>
                                <span class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-slate-700 font-bold text-xs"><%= item.provider.substring(0, 2).toUpperCase() %></span>
                                <% } %>
                                <span class="font-medium text-slate-700 capitalize"><%= item.provider %></span>
                            </div>
                            <div class="text-right">
                                <p class="font-bold text-slate-900"><%= item.documentsProcessed %> docs</p>
                                <p class="text-xs text-slate-400"><%= item.percentOfTotal %>%</p>
                            </div>
                        </div>
                        <div class="w-full bg-slate-100 rounded-full h-2">
                            <div class="bg-blue-600 h-2 rounded-full" style="width: <%= item.percentOfTotal %>%"></div>
                        </div>
                    </div>
                    <% }); %>
                    <% if (revenueByProvider.length === 0) { %>
                    <p class="text-slate-400 text-sm text-center py-4">No provider data yet</p>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Revenue Trend Chart Placeholder -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6 mt-8">
            <h3 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
                </svg>
                Revenue Trend
            </h3>
            <div id="revenue-chart" class="h-64 flex items-center justify-center text-slate-400">
                <% if (revenueTrend && revenueTrend.length > 0) { %>
                <script>
                    window.revenueTrendData = <%- JSON.stringify(revenueTrend) %>;
                </script>
                <div class="w-full h-full" id="chart-container"></div>
                <% } else { %>
                <p>No trend data available for the selected period</p>
                <% } %>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
