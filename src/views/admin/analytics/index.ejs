<%- include('../../partials/head', { title: 'Usage Analytics - Admin' }) %>

<body class="bg-slate-50 min-h-screen font-sans">
    <%- include('../../partials/admin-sidebar') %>

    <div id="mainContent" class="flex flex-col min-h-screen ">
        <%- include('../../partials/dashboard-header', {title: 'Usage Analytics', user: user }) %>

        <main class="flex-1 p-6 pb-24 overflow-y-auto custom-scrollbar">
            <div class="max-w-7xl mx-auto space-y-6">
                
                <!-- KPI Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group">
                        <div class="absolute right-0 top-0 h-full w-1 bg-gradient-to-b from-blue-500 to-blue-600"></div>
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Total Requests</div>
                        <div class="text-3xl font-black text-slate-900 dark:text-white mb-1 group-hover:scale-105 transition-transform origin-left"><%= totalRequests.toLocaleString() %></div>
                        <div class="text-[0.625rem] font-bold text-slate-400">IN SELECTED PERIOD</div>
                    </div>
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group">
                        <div class="absolute right-0 top-0 h-full w-1 bg-gradient-to-b from-red-500 to-red-600"></div>
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Errors</div>
                        <div class="text-3xl font-black <%= errorCount > 0 ? 'text-red-600' : 'text-slate-900 dark:text-white' %> mb-1 group-hover:scale-105 transition-transform origin-left"><%= errorCount.toLocaleString() %></div>
                        <div class="text-[0.625rem] font-bold text-slate-400">FAILED REQUESTS</div>
                    </div>
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group">
                        <div class="absolute right-0 top-0 h-full w-1 bg-gradient-to-b from-emerald-500 to-emerald-600"></div>
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Error Rate</div>
                        <div class="text-3xl font-black <%= parseFloat(errorRate) > 5 ? 'text-red-600' : 'text-emerald-600' %> mb-1 group-hover:scale-105 transition-transform origin-left"><%= errorRate %>%</div>
                        <div class="text-[0.625rem] font-bold text-slate-400">SYSTEM HEALTH</div>
                    </div>
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm relative overflow-hidden group">
                        <div class="absolute right-0 top-0 h-full w-1 bg-gradient-to-b from-purple-500 to-purple-600"></div>
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Avg Response Time</div>
                        <div class="text-3xl font-black text-slate-900 dark:text-white mb-1 group-hover:scale-105 transition-transform origin-left"><%= avgDuration %>ms</div>
                        <div class="text-[0.625rem] font-bold text-slate-400">AVERAGE DURATION</div>
                    </div>
                </div>

                <!-- Charts Grid -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Usage Trend (Full Width) -->
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm lg:col-span-2">
                        <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-6">Request Volume Trend</h3>
                        <div class="h-64 relative">
                            <canvas id="usageTrendChart"></canvas>
                        </div>
                    </div>

                    <!-- Status Breakdown (Doughnut) -->
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
                        <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-6">Request Status</h3>
                        <div class="h-64 relative flex items-center justify-center">
                            <canvas id="statusChart"></canvas>
                        </div>
                    </div>
                </div>

                <!-- Service Usage (Bar Chart + Table) -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Bar Chart -->
                    <div class="bg-white dark:bg-slate-800 p-6 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm">
                        <h3 class="text-sm font-bold text-slate-900 dark:text-white uppercase tracking-wider mb-6">Usage by Service</h3>
                        <div class="h-64 relative">
                            <canvas id="serviceChart"></canvas>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
                            <h3 class="font-bold text-slate-900 dark:text-white">Service Breakdown</h3>
                        </div>
                        <div class="overflow-x-auto max-h-64 overflow-y-auto">
                            <table class="min-w-full divide-y divide-slate-100 dark:divide-slate-700">
                                <thead class="bg-slate-50 dark:bg-slate-800/50 sticky top-0">
                                    <tr>
                                        <th class="px-6 py-3 text-left text-[0.625rem] font-bold text-slate-400 uppercase tracking-wider">Service</th>
                                        <th class="px-6 py-3 text-left text-[0.625rem] font-bold text-slate-400 uppercase tracking-wider">Requests</th>
                                        <th class="px-6 py-3 text-left text-[0.625rem] font-bold text-slate-400 uppercase tracking-wider">Usage %</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 dark:divide-slate-700 bg-white dark:bg-slate-800">
                                    <% usageByService.forEach(service => { 
                                        const percentage = totalRequests > 0 ? ((service._count / totalRequests) * 100).toFixed(1) : 0;
                                    %>
                                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors">
                                        <td class="px-6 py-3 text-sm font-bold text-slate-900 dark:text-white"><%= service.resourceType || 'Unknown' %></td>
                                        <td class="px-6 py-3 text-sm text-slate-700 dark:text-slate-300"><%= service._count.toLocaleString() %></td>
                                        <td class="px-6 py-3 text-sm">
                                            <div class="flex items-center gap-2">
                                                <div class="flex-1 bg-slate-100 dark:bg-slate-700 rounded-full h-2 max-w-[100px]">
                                                    <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percentage %>%"></div>
                                                </div>
                                                <span class="text-slate-500 dark:text-slate-400 text-xs font-bold w-12"><%= percentage %>%</span>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js" nonce="<%= nonce %>"></script>
    <script nonce="<%= nonce %>">
        document.addEventListener('DOMContentLoaded', () => {
            const usageTrend = <%- JSON.stringify(usageTrend) %>;
            const statusStats = <%- JSON.stringify(statusStats) %>;
            const usageByService = <%- JSON.stringify(usageByService) %>;
            
            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = '#94a3b8';
            
            // 1. Usage Trend (Line with Error overlay)
            new Chart(document.getElementById('usageTrendChart'), {
                type: 'line',
                data: {
                    labels: usageTrend.map(d => d.date),
                    datasets: [
                        {
                            label: 'Total Requests',
                            data: usageTrend.map(d => d.total),
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 3,
                            pointHoverRadius: 5
                        },
                        {
                            label: 'Errors',
                            data: usageTrend.map(d => d.errors),
                            borderColor: '#ef4444',
                            backgroundColor: 'rgba(239, 68, 68, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 3,
                            pointHoverRadius: 5
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: { display: true, position: 'top', align: 'end' },
                        tooltip: { enabled: true }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: 'rgba(148, 163, 184, 0.1)' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Status Breakdown (Doughnut)
            new Chart(document.getElementById('statusChart'), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(statusStats).map(s => s.charAt(0).toUpperCase() + s.slice(1)),
                    datasets: [{
                        data: Object.values(statusStats),
                        backgroundColor: Object.keys(statusStats).map(s => {
                            if (s === 'success') return '#10b981';
                            if (s === 'error') return '#ef4444';
                            if (s === 'pending') return '#f59e0b';
                            return '#64748b';
                        }),
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { display: true, position: 'right', labels: { boxWidth: 12, font: { size: 11 } } },
                        tooltip: { enabled: true }
                    }
                }
            });

            // 3. Service Usage (Horizontal Bar)
            new Chart(document.getElementById('serviceChart'), {
                type: 'bar',
                data: {
                    labels: usageByService.map(s => s.resourceType || 'Unknown'),
                    datasets: [{
                        label: 'Requests',
                        data: usageByService.map(s => s._count),
                        backgroundColor: ['#3b82f6', '#8b5cf6', '#06b6d4', '#ec4899', '#f59e0b', '#10b981', '#6366f1', '#14b8a6', '#f43f5e', '#84cc16'],
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { enabled: true }
                    },
                    scales: {
                        x: { beginAtZero: true, grid: { color: 'rgba(148, 163, 184, 0.1)' } },
                        y: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
    <%- include('../../partials/sidebar-script') %>
</body>
</html>
