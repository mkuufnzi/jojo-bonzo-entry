<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Plan - Admin</title>
    <script src="https://cdn.tailwindcss.com" nonce="<%= nonce %>"></script>
</head>
<body class="bg-gray-100 font-sans">
    <%- include('../../partials/admin-sidebar') %>
    
    <div id="mainContent" class="flex flex-col min-h-screen ">
        <%- include('../../partials/dashboard-header', {title: 'Edit Plan: ' + plan.name, user: user}) %>
        
        <main class="flex-1 p-6">
            <div class="max-w-3xl mx-auto">
                <a href="/admin/plans" class="inline-flex items-center text-sm text-slate-500 hover:text-slate-700 mb-6">
                    <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                    Back to Plans
                </a>

                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
                    <form action="/admin/plans/<%= plan.id %>/update" method="POST" class="space-y-6">
                        <!-- Identity -->
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-1">Plan Name</label>
                            <input type="text" name="name" value="<%= plan.name %>" required class="w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500">
                        </div>

                        <!-- Pricing -->
                        <!-- Pricing (Synced) -->
                         <div class="grid grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1">Price <span class="text-xs font-normal text-slate-400 bg-slate-100 px-1.5 py-0.5 rounded ml-2">Synced from Stripe</span></label>
                                <div class="relative group">
                                    <span class="absolute left-3 top-2 text-slate-400">$</span>
                                    <input type="number" step="0.01" name="price" value="<%= plan.price %>" readonly class="pl-6 w-full rounded-lg border-slate-200 bg-slate-100 text-slate-500 cursor-not-allowed focus:ring-0 focus:border-slate-200" title="To change price, update in Stripe and click 'Sync'">
                                    
                                    <!-- Tooltip/Warning -->
                                    <div class="hidden group-hover:block absolute z-10 top-full left-0 mt-1 w-64 p-2 bg-slate-800 text-white text-xs rounded shadow-lg">
                                        Pricing is managed in Stripe. Update it there and use the dashboard "Sync" button.
                                    </div>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-slate-700 mb-1">Stripe Price ID</label>
                                <input type="text" name="stripePriceId" value="<%= plan.stripePriceId || '' %>" readonly class="w-full rounded-lg border-slate-200 bg-slate-100 text-slate-500 cursor-not-allowed focus:ring-0 focus:border-slate-200 font-mono text-sm">
                            </div>
                        </div>

                        <!-- Limits -->
                        <div class="grid grid-cols-3 gap-6 p-4 bg-slate-50 rounded-lg">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Req Limit</label>
                                <input type="number" name="requestLimit" value="<%= plan.requestLimit %>" class="w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500">
                            </div>
                             <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">PDF Quota</label>
                                <input type="number" name="pdfQuota" value="<%= plan.pdfQuota %>" class="w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500">
                            </div>
                             <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase mb-1">AI Quota</label>
                                <input type="number" name="aiQuota" value="<%= plan.aiQuota %>" class="w-full rounded-lg border-slate-300 focus:ring-blue-500 focus:border-blue-500">
                            </div>
                        </div>
                        
                        <!-- Features -->
                        <div class="space-y-4">
                            <h3 class="text-sm font-bold text-slate-700">Plan Features</h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                                <% 
                                // Group features by category
                                const categories = [...new Set(allFeatures.map(f => f.category))];
                                categories.forEach(category => {
                                    const categoryFeatures = allFeatures.filter(f => f.category === category);
                                %>
                                <div class="bg-slate-50 p-4 rounded-lg border border-slate-100">
                                    <h4 class="text-xs font-bold text-slate-500 uppercase mb-3"><%= category %></h4>
                                    <div class="space-y-2">
                                        <% categoryFeatures.forEach(feature => { 
                                            const isEnabled = plan.planFeatures.some(pf => pf.featureId === feature.id && pf.isEnabled);
                                        %>
                                        <label class="flex items-center space-x-2 cursor-pointer">
                                            <input type="checkbox" name="features" value="<%= feature.id %>" 
                                                class="w-4 h-4 text-blue-600 border-slate-300 rounded focus:ring-blue-500"
                                                <%= isEnabled ? 'checked' : '' %>>
                                            <span class="text-sm text-slate-700 font-medium"><%= feature.name %></span>
                                        </label>
                                        <% }); %>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        </div>

                        <div class="pt-6 border-t border-slate-100 flex justify-end gap-3">
                            <a href="/admin/plans" class="px-4 py-2 text-slate-700 hover:bg-slate-50 font-bold rounded-lg transition-colors">Cancel</a>
                            <button type="submit" class="px-6 py-2 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors">
                                Save Plan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
    <%- include('../../partials/sidebar-script') %>
</body>
</html>
