<%- include('../../partials/head', { title: 'Manage Plans - Admin Console' }) %>

<body class="bg-slate-50 min-h-screen font-sans">
    <%- include('../../partials/admin-sidebar') %>

    <div id="mainContent" class="flex flex-col h-screen  bg-slate-50 overflow-hidden">
        <%- include('../../partials/dashboard-header', {title: 'Manage Plans', user: user}) %>
        
        <div class="flex-1 overflow-hidden relative">
            <div class="grid grid-cols-12 h-full">
                
                <!-- LEFT: Main Plans Content -->
                <div class="col-span-12 lg:col-span-9 h-full overflow-y-auto p-6 pb-32 custom-scrollbar">
                    <div class="max-w-6xl mx-auto">
                        
                        <!-- Header & Filters -->
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                            <div>
                                <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Subscription Plans</h1>
                                <p class="text-slate-500 text-sm mt-1">Manage pricing tiers and feature access.</p>
                            </div>
                            
                            <!-- Filters & Actions -->
                            <div class="flex items-center gap-4">
                                <!-- Sync Action -->
                                <form action="/admin/plans/sync" method="POST" onsubmit="return confirm('This will pull all prices from Stripe and update/create local plans. Continue?');">
                                    <button type="submit" class="flex items-center gap-2 px-3 py-1.5 text-sm font-bold rounded-md bg-white text-slate-700 border border-slate-300 hover:bg-slate-50 hover:text-blue-600 hover:border-blue-400 transition-all shadow-sm">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                                        Sync from Stripe
                                    </button>
                                </form>

                                <div class="h-6 w-px bg-slate-200"></div>

                                <div class="flex items-center gap-2 bg-white p-1 rounded-lg border border-slate-200 shadow-sm">
                                    <button onclick="filterPlans('all')" class="filter-btn px-3 py-1.5 text-sm font-bold rounded-md bg-slate-100 text-slate-900 transition-all" data-filter="all">All Plans</button>
                                    <button onclick="filterPlans('active')" class="filter-btn px-3 py-1.5 text-sm font-bold rounded-md text-slate-500 hover:bg-slate-50 transition-all" data-filter="active">Active</button>
                                    <button onclick="filterPlans('archived')" class="filter-btn px-3 py-1.5 text-sm font-bold rounded-md text-slate-500 hover:bg-slate-50 transition-all" data-filter="archived">Archived</button>
                                </div>
                            </div>
                        </div>

                        <!-- Responsive Grid: 1 col mobile, 2 col tablet, 3 col desktop -->
                        <!-- Designed to FIT content without hiding it -->
                        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" id="plansGrid">
                             <% if (plans && plans.length > 0) { %>
                                <% plans.forEach(p => { 
                                    // Schema doesn't have isActive yet, so assume true (default to Live)
                                    // This fixes the "All plans archived" bug
                                    const isActive = true; 
                                %>
                                    <div class="plan-card flex flex-col bg-white rounded-lg border border-slate-200 shadow-sm hover:border-blue-400 transition-all duration-200 group relative" data-status="active">
                                        
                                        <!-- Header: Name, Price, Badge -->
                                        <div class="p-4 border-b border-slate-50 relative">
                                            <div class="flex justify-between items-start mb-2">
                                                <div class="pr-2">
                                                    <h3 class="text-base font-bold text-slate-900 leading-tight mb-0.5" title="<%= p.name %>"><%= p.name %></h3>
                                                    <p class="text-[11px] text-slate-500 font-bold uppercase tracking-wider"><%= p.interval || 'Month' %></p>
                                                </div>
                                                <!-- Badge moved to flex container to prevent overlap -->
                                                <span class="inline-flex flex-shrink-0 items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase bg-green-100 text-green-700 border border-green-200">
                                                    Live
                                                </span>
                                            </div>
                                            <div class="mt-1">
                                                <span class="text-xl font-black text-slate-900 tracking-tight">$<%= p.price %></span>
                                            </div>
                                        </div>

                                        <!-- Body: Technical Details (Dense) -->
                                        <div class="p-4 flex-1 space-y-3 bg-slate-50/30">
                                             <!-- Stripe ID -->
                                             <div class="flex flex-col gap-0.5">
                                                <span class="text-[10px] uppercase font-bold text-slate-400">Stripe Price ID</span>
                                                <% if (p.stripePriceId) { %>
                                                    <div class="flex items-center gap-1 group/copy cursor-pointer" onclick="navigator.clipboard.writeText('<%= p.stripePriceId %>'); window.showToast && window.showToast('Success', 'ID Copied to clipboard', 'success')">
                                                        <code class="text-[11px] bg-white border border-slate-200 text-slate-600 px-1.5 py-0.5 rounded font-mono break-all hover:border-blue-300 transition-colors"><%= p.stripePriceId %></code>
                                                        <svg class="w-3 h-3 text-slate-300 group-hover/copy:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a2 2 0 011.414.414l2.586 2.586A2 2 0 0119 6.586V7h-1M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path></svg>
                                                    </div>
                                                <% } else { %>
                                                    <span class="text-[11px] text-slate-400 italic">Not Synced</span>
                                                <% } %>
                                             </div>
                                             
                                             <!-- Subscribers -->
                                             <div class="flex flex-col gap-0.5">
                                                <span class="text-[10px] uppercase font-bold text-slate-400">Subscribers</span>
                                                <span class="text-sm font-bold text-slate-700 flex items-center gap-1">
                                                    <%= p._count ? p._count.subscriptions : 0 %> 
                                                    <span class="text-[10px] font-normal text-slate-500">Active Users</span>
                                                </span>
                                             </div>
                                        </div>

                                        <!-- Footer: Actions -->
                                        <div class="p-3 border-t border-slate-100 bg-white">
                                            <a href="/admin/plans/<%= p.id %>/edit" class="flex items-center justify-center w-full gap-2 text-xs font-bold bg-slate-50 hover:bg-blue-600 hover:text-white border border-slate-200 hover:border-blue-600 text-slate-700 px-3 py-2 rounded transition-all shadow-sm group/btn">
                                                Edit Configuration
                                                <svg class="w-3 h-3 text-slate-400 group-hover/btn:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                            </a>
                                        </div>
                                    </div>
                                <% }); %>
                             <% } else { %>
                                <div class="col-span-3 text-center py-12 bg-white rounded-xl border border-dashed border-slate-300">
                                    <div class="text-slate-400 mb-2">
                                        <svg class="w-12 h-12 mx-auto opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                                    </div>
                                    <p class="text-slate-500 font-medium">No subscription plans found in the system.</p>
                                </div>
                             <% } %>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: Help Guide Panel (Fixed) -->
                <div class="hidden lg:block col-span-3 border-l border-slate-200 bg-white h-full relative z-10 shadow-[-4px_0_15px_-3px_rgba(0,0,0,0.05)]">
                    <div id="helpGuideContent" class="h-full">
                        <!-- Loaded via JS -->
                        <div class="flex items-center justify-center h-full text-slate-400 text-sm animate-pulse">
                            Loading Guide...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script nonce="<%= nonce %>">
        // 1. Load Help Guide
        document.addEventListener('DOMContentLoaded', () => {
            fetch('/help/plans-guide.html')
                .then(res => res.text())
                .then(html => {
                    document.getElementById('helpGuideContent').innerHTML = html;
                })
                .catch(err => console.error('Failed to load help guide:', err));
        });

        // 2. Filter Logic
        function filterPlans(status) {
            // Update buttons
            document.querySelectorAll('.filter-btn').forEach(btn => {
                if (btn.dataset.filter === status) {
                    btn.classList.remove('text-slate-500', 'hover:bg-slate-50');
                    btn.classList.add('bg-slate-100', 'text-slate-900');
                } else {
                    btn.classList.add('text-slate-500', 'hover:bg-slate-50');
                    btn.classList.remove('bg-slate-100', 'text-slate-900');
                }
            });

            // Filter items
            const cards = document.querySelectorAll('.plan-card');
            cards.forEach(card => {
                if (status === 'all' || card.dataset.status === status) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
    <%- include('../../partials/sidebar-script') %>
</body>
</html>
