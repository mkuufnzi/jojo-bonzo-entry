<%- include('../partials/head', { title: 'Admin Console - Floovioo ' }) %>

<body class="bg-slate-50 min-h-screen font-sans">
    <%- include('../partials/admin-sidebar') %>

    <div id="mainContent" class="flex flex-col h-screen  bg-slate-50 overflow-hidden">
        <%- include('../partials/dashboard-header', {title: 'Admin Console', user: user}) %>
        
        <div class="flex-1 overflow-hidden relative">
            <div class="flex h-full">
                
                <!-- LEFT: Main Dashboard Content -->
                <div class="flex-1 min-w-0 h-full overflow-y-auto p-6 pb-32 custom-scrollbar">
                    <div class="max-w-6xl mx-auto space-y-8">
                        
                        <!-- 1. Stats Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                            <!-- MRR Card -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">Total MRR</h3>
                                    <div class="p-2 bg-green-50 rounded-lg">
                                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    </div>
                                </div>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-slate-900">$<%= (Number(stats.mrr) || 0).toFixed(2) %></span>
                                    <span class="text-xs font-bold text-green-600 flex items-center">
                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                                        +<%= stats.growth %>%
                                    </span>
                                </div>
                                <p class="text-slate-400 text-xs mt-2">Monthly Recurring Revenue</p>
                            </div>

                            <!-- Active Subs -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">Active Subs</h3>
                                    <div class="p-2 bg-blue-50 rounded-lg">
                                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                    </div>
                                </div>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-slate-900"><%= stats.activeSubs %></span>
                                </div>
                                <p class="text-slate-400 text-xs mt-2">Paying Customers</p>
                            </div>

                            <!-- Total Users -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">Total Users</h3>
                                    <div class="p-2 bg-purple-50 rounded-lg">
                                        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                                    </div>
                                </div>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-slate-900"><%= stats.totalUsers %></span>
                                </div>
                                <p class="text-slate-400 text-xs mt-2">Total Registrations</p>
                            </div>

                            <!-- Churn Rate (Placeholder) -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider">Churn Rate</h3>
                                    <div class="p-2 bg-amber-50 rounded-lg">
                                        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"></path></svg>
                                    </div>
                                </div>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-slate-900">2.4%</span>
                                    <span class="text-xs font-bold text-green-600 flex items-center">
                                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
                                        -0.1%
                                    </span>
                                </div>
                                <p class="text-slate-400 text-xs mt-2">Last 30 Days</p>
                            </div>
                        </div>

                        <!-- 2. Charts Section -->
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <!-- Revenue Trend -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <h3 class="text-lg font-bold text-slate-900 mb-4">Revenue Trend (30 Days)</h3>
                                <div class="h-64">
                                    <canvas id="revenueChart"></canvas>
                                </div>
                            </div>
                            <!-- Signup Trend -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <h3 class="text-lg font-bold text-slate-900 mb-4">New Signups</h3>
                                <div class="h-64">
                                    <canvas id="signupsChart"></canvas>
                                </div>
                            </div>
                        </div>

                        <!-- 3. Recent Activity & Quick Actions -->
                        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                            <!-- Recent Signups (2 Cols) -->
                            <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <h3 class="text-lg font-bold text-slate-900 mb-4">Recent Signups</h3>
                                <div class="overflow-x-auto">
                                    <table class="w-full text-left border-collapse">
                                        <thead>
                                            <tr>
                                                <th class="border-b border-slate-100 py-3 text-xs font-bold text-slate-500 uppercase">User</th>
                                                <th class="border-b border-slate-100 py-3 text-xs font-bold text-slate-500 uppercase">Plan</th>
                                                <th class="border-b border-slate-100 py-3 text-xs font-bold text-slate-500 uppercase">Date</th>
                                                <th class="border-b border-slate-100 py-3 text-xs font-bold text-slate-500 uppercase">Status</th>
                                            </tr>
                                        </thead>
                                        <tbody class="text-sm text-slate-600">
                                            <% if (stats.recentUsers && stats.recentUsers.length > 0) { %>
                                                <% stats.recentUsers.forEach(u => { %>
                                                <tr>
                                                    <td class="py-3 border-b border-slate-50 font-medium text-slate-900"><%= u.email %></td>
                                                    <td class="py-3 border-b border-slate-50">
                                                        <span class="px-2 py-0.5 rounded text-xs font-bold bg-slate-100 text-slate-600">
                                                            <%= u.subscription ? u.subscription.status : 'Free' %>
                                                        </span>
                                                    </td>
                                                    <td class="py-3 border-b border-slate-50"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                                                    <td class="py-3 border-b border-slate-50 text-green-600 font-bold">Active</td>
                                                </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr><td colspan="4" class="py-4 text-center text-slate-400">No recent signups.</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <!-- Quick Actions (1 Col) -->
                            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                                <h3 class="text-lg font-bold text-slate-900 mb-4">Quick Actions</h3>
                                <div class="space-y-3">
                                    <a href="/admin/services" class="block p-4 border border-slate-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition-all group">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div class="p-2 bg-blue-100 rounded text-blue-600 group-hover:bg-blue-200">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                </div>
                                                <span class="font-bold text-slate-700 group-hover:text-slate-900">Manage Services</span>
                                            </div>
                                            <svg class="w-4 h-4 text-slate-400 group-hover:text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                        </div>
                                    </a>

                                    <a href="/admin/plans" class="block p-4 border border-slate-200 rounded-lg hover:border-purple-500 hover:bg-purple-50 transition-all group">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div class="p-2 bg-purple-100 rounded text-purple-600 group-hover:bg-purple-200">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                </div>
                                                <span class="font-bold text-slate-700 group-hover:text-slate-900">Update Pricing</span>
                                            </div>
                                            <svg class="w-4 h-4 text-slate-400 group-hover:text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                        </div>
                                    </a>

                                    <a href="/admin/users" class="block p-4 border border-slate-200 rounded-lg hover:border-green-500 hover:bg-green-50 transition-all group">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-3">
                                                <div class="p-2 bg-green-100 rounded text-green-600 group-hover:bg-green-200">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                                                </div>
                                                <span class="font-bold text-slate-700 group-hover:text-slate-900">Manage Users</span>
                                            </div>
                                            <svg class="w-4 h-4 text-slate-400 group-hover:text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- 4. Queue Health (V2) -->
                        <% if (typeof queueHealth !== 'undefined' && queueHealth.length > 0) { %>
                        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                    System Health (V2 Queues)
                                </h3>
                                <span class="text-xs text-slate-400">Real-time BullMQ Status</span>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                                <% queueHealth.forEach(q => { %>
                                <div class="p-4 border border-slate-200 rounded-lg <%= q.status === 'warning' ? 'bg-amber-50 border-amber-200' : (q.status === 'error' ? 'bg-red-50 border-red-200' : 'bg-slate-50') %>">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="text-xs font-bold text-slate-500 uppercase"><%= q.name %></span>
                                        <span class="w-2 h-2 rounded-full <%= q.status === 'healthy' ? 'bg-green-500' : (q.status === 'warning' ? 'bg-amber-500' : 'bg-red-500') %>"></span>
                                    </div>
                                    <div class="grid grid-cols-2 gap-2 text-sm">
                                        <div>
                                            <span class="text-slate-400">Active:</span>
                                            <span class="font-bold text-slate-700 ml-1"><%= q.active %></span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400">Waiting:</span>
                                            <span class="font-bold text-slate-700 ml-1"><%= q.waiting %></span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400">Done:</span>
                                            <span class="font-bold text-green-600 ml-1"><%= q.completed %></span>
                                        </div>
                                        <div>
                                            <span class="text-slate-400">Failed:</span>
                                            <span class="font-bold <%= q.failed > 0 ? 'text-red-600' : 'text-slate-500' %> ml-1"><%= q.failed %></span>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        </div>
                        <% } %>

                    </div>
                </div>

                <!-- RIGHT: Help Guide Panel (Fixed) -->
                <div class="hidden lg:block w-80 border-l border-slate-200 bg-white h-full relative z-10 shadow-[-4px_0_15px_-3px_rgba(0,0,0,0.05)]">
                    <div id="helpGuideContent" class="h-full">
                        <!-- Loaded via JS -->
                        <div class="flex items-center justify-center h-full text-slate-400 text-sm animate-pulse">
                            Loading Guide...
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <%- include('../partials/sidebar-script') %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js" nonce="<%= nonce %>"></script>
    <script nonce="<%= nonce %>">
        // Load Help Guide on Mount
        document.addEventListener('DOMContentLoaded', () => {
            fetch('/help/admin-dashboard-guide.html')
                .then(res => res.text())
                .then(html => {
                    document.getElementById('helpGuideContent').innerHTML = html;
                })
                .catch(err => {
                    console.error('Failed to load help guide:', err);
                    document.getElementById('helpGuideContent').innerHTML = '<div class="p-6 text-red-500">Failed to load guide.</div>';
                });

            // Chart Data Prep
            const mrr = <%= Number(stats.mrr) || 0 %>;

            // 1. Revenue Chart (Mock Data)
            const ctxRev = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4'],
                    datasets: [{
                        label: 'MRR ($)',
                        data: [mrr * 0.8, mrr * 0.9, mrr * 0.95, mrr],
                        borderColor: '#10b981',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: false, grid: { borderDash: [2, 4] } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Signups Chart (Mock Data)
            const ctxSign = document.getElementById('signupsChart').getContext('2d');
            new Chart(ctxSign, {
                type: 'bar',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Signups',
                        data: [12, 19, 8, 15, 22, 10, 14],
                        backgroundColor: '#6366f1',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [2, 4] } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>

</body>
</html>
