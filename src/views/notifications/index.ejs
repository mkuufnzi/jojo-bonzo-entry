<%- include('../partials/head', { title: 'Notifications - Floovioo ' }) %>

<body class="bg-slate-50 dark:bg-slate-950">
    <div class="flex min-h-screen">
        <%- include('../partials/sidebar', { path: '/notifications' }) %>

        <!-- Main Content -->
        <div id="mainContent" class="flex-1 flex flex-col overflow-hidden  transition-all duration-300">
            <%- include('../partials/dashboard-header', { title: 'Notifications', user: user }) %>

            <main class="flex-1 overflow-x-hidden overflow-y-auto">
                <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                    
                    <!-- Page Header -->
                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
                        <div>
                            <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Notifications</h1>
                            <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
                                Stay updated with your document processing activities
                            </p>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">
                                <%= notifications.filter(n => !n.isRead).length %> unread
                            </span>
                            <button id="markAllReadPageBtn"
                                class="inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-slate-800 text-blue-600 dark:text-blue-400 text-sm font-bold rounded-xl border border-slate-200 dark:border-slate-700 hover:border-blue-300 dark:hover:border-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all shadow-sm">
                                <i data-lucide="check-check" class="w-4 h-4"></i>
                                Mark all read
                            </button>
                        </div>
                    </div>

                    <!-- Notifications List -->
                    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
                        <% if (notifications.length === 0) { %>
                            <!-- Empty State -->
                            <div class="py-16 text-center">
                                <div class="w-16 h-16 bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                    <i data-lucide="inbox" class="w-8 h-8 text-slate-400"></i>
                                </div>
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">All caught up!</h3>
                                <p class="text-sm text-slate-500 dark:text-slate-400 max-w-xs mx-auto">
                                    You have no notifications yet. We'll alert you when your documents are ready.
                                </p>
                            </div>
                        <% } else { %>
                            <ul class="divide-y divide-slate-100 dark:divide-slate-800">
                                <% notifications.forEach(function(notification) { %>
                                    <li class="group relative hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors <%= !notification.isRead ? 'bg-blue-50/50 dark:bg-blue-900/10' : '' %>">
                                        <div class="flex items-start gap-4 p-5">
                                            <!-- Icon -->
                                            <div class="flex-shrink-0">
                                                <% if (notification.type === 'success') { %>
                                                    <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center">
                                                        <i data-lucide="check-circle" class="w-5 h-5 text-green-600 dark:text-green-400"></i>
                                                    </div>
                                                <% } else if (notification.type === 'warning') { %>
                                                    <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/30 rounded-xl flex items-center justify-center">
                                                        <i data-lucide="alert-triangle" class="w-5 h-5 text-amber-600 dark:text-amber-400"></i>
                                                    </div>
                                                <% } else if (notification.type === 'error') { %>
                                                    <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center">
                                                        <i data-lucide="x-circle" class="w-5 h-5 text-red-600 dark:text-red-400"></i>
                                                    </div>
                                                <% } else { %>
                                                    <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center">
                                                        <i data-lucide="info" class="w-5 h-5 text-blue-600 dark:text-blue-400"></i>
                                                    </div>
                                                <% } %>
                                            </div>

                                            <!-- Content -->
                                            <div class="flex-1 min-w-0">
                                                <div class="flex items-start justify-between gap-4">
                                                    <div class="flex-1 min-w-0">
                                                        <div class="flex items-center gap-2">
                                                            <h4 class="text-sm font-bold text-slate-900 dark:text-white truncate">
                                                                <%= notification.title %>
                                                            </h4>
                                                            <% if (!notification.isRead) { %>
                                                                <span class="flex-shrink-0 w-2 h-2 bg-blue-500 rounded-full"></span>
                                                            <% } %>
                                                        </div>
                                                        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
                                                            <%= notification.message %>
                                                        </p>
                                                    </div>
                                                    <div class="flex-shrink-0 text-right">
                                                        <p class="text-xs font-medium text-slate-400">
                                                            <%= new Date(notification.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                                        </p>
                                                        <p class="text-[0.625rem] text-slate-400 mt-0.5">
                                                            <%= new Date(notification.createdAt).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                                                        </p>
                                                    </div>
                                                </div>
                                                
                                                <% if (notification.link) { %>
                                                    <a href="<%= notification.link %>"
                                                        class="inline-flex items-center gap-1 mt-3 text-xs font-bold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">
                                                        View Details
                                                        <i data-lucide="arrow-right" class="w-3 h-3"></i>
                                                    </a>
                                                <% } %>
                                            </div>

                                            <!-- Actions (visible on hover) -->
                                            <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                                                <button onclick="deleteNotification('<%= notification.id %>')" 
                                                    class="p-2 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
                                                    title="Delete notification">
                                                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </li>
                                <% }); %>
                            </ul>
                        <% } %>
                    </div>

                    <!-- Pagination or Load More (if needed later) -->
                    <% if (notifications.length > 0) { %>
                        <div class="mt-6 text-center">
                            <p class="text-xs text-slate-400">
                                Showing <%= notifications.length %> notification<%= notifications.length !== 1 ? 's' : '' %>
                            </p>
                        </div>
                    <% } %>

                </div>
            </main>
        </div>
    </div>

    <script nonce="<%= nonce %>">
        document.addEventListener('DOMContentLoaded', function() {
            // Mark all as read
            document.getElementById('markAllReadPageBtn')?.addEventListener('click', async () => {
                try {
                    await fetch('/notifications/mark-all-read', { method: 'POST' });
                    window.location.reload();
                } catch (err) {
                    console.error(err);
                    if (typeof showToast !== 'undefined') {
                        showToast('Error', 'Failed to mark notifications as read', 'error');
                    }
                }
            });

            // Delete notification
            window.deleteNotification = async function(id) {
                if (!confirm('Delete this notification?')) return;
                try {
                    await fetch(`/notifications/${id}`, { method: 'DELETE' });
                    window.location.reload();
                } catch (err) {
                    console.error(err);
                }
            };

            // Initialize Lucide icons
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
    </script>
    <%- include('../partials/toast') %>
    <%- include('../partials/sidebar-script') %>
</body>

</html>
