<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= branding.model?.number || 'Smart Document' %> | Floovioo Portal</title>
    
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <!-- Unified CSS Stack -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-display { font-family: 'Outfit', sans-serif; }
        [x-cloak] { display: none !important; }
        
        /* Glassmorphism effects */
        .glass {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }
        
        .doc-shadow {
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
        }
        
        .pulse-border {
            animation: pulse-border 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }
        
        @keyframes pulse-border {
            0%, 100% { border-color: rgba(99, 102, 241, 0.2); }
            50% { border-color: rgba(99, 102, 241, 0.6); }
        }
    </style>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '<%= branding.themeData?.primary || "#6366f1" %>',
                        accent: '<%= branding.themeData?.accent || "#6366f1" %>',
                        portal: {
                            bg: '#f8fafc',
                            card: '#ffffff'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        display: ['Outfit', 'sans-serif'],
                    }
                }
            }
        }
    </script>
</head>
<body class="h-full flex flex-col antialiased text-slate-900 overflow-x-hidden" x-data="{ sidebarOpen: false }">

    <!-- Top Navigation Bar (Branded) -->
    <nav class="sticky top-0 z-50 glass border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-4">
                    <% if (branding.themeData?.logoUrl) { %>
                        <img src="<%= branding.themeData.logoUrl %>" alt="Logo" class="h-8 w-auto">
                    <% } else { %>
                        <span class="font-display font-bold text-xl tracking-tight text-primary">FLOOVIOO</span>
                    <% } %>
                    <div class="hidden md:flex flex-col border-l border-slate-200 pl-4">
                        <span class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">Secure Portal</span>
                        <span class="text-sm font-semibold text-slate-700">Powered by Transactional Branding</span>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <button @click="sidebarOpen = true" class="md:hidden p-2 text-slate-500 hover:text-primary transition-colors">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" /></svg>
                    </button>
                    <div class="hidden md:flex items-center gap-4">
                        <a href="#support" class="text-xs font-bold text-slate-500 hover:text-primary transition-colors">SUPPORT</a>
                        <button class="bg-primary text-white px-4 py-2 rounded-lg text-xs font-bold shadow-md hover:bg-opacity-90 transition-all">
                            PAY NOW
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 md:flex gap-8">
        
        <!-- Left: Document Content -->
        <div class="flex-1 relative">
            <div class="bg-white rounded-2xl border border-slate-200 doc-shadow overflow-hidden min-h-[842px]">
                <%- body %>
            </div>
            
            <!-- Mobile Bottom Actions -->
            <div class="md:hidden fixed bottom-6 left-4 right-4 z-40">
                <div class="glass p-4 rounded-2xl shadow-2xl flex justify-around items-center border border-slate-200">
                    <button class="flex flex-col items-center gap-1 text-[10px] font-bold text-slate-500">
                        <span class="text-lg">💬</span> Support
                    </button>
                    <button class="bg-primary text-white px-8 py-3 rounded-xl text-sm font-bold shadow-xl">
                        Complete Action
                    </button>
                    <button class="flex flex-col items-center gap-1 text-[10px] font-bold text-slate-500">
                        <span class="text-lg">✉️</span> Email
                    </button>
                </div>
            </div>
        </div>

        <!-- Right: Smart Sidebar (Desktop) -->
        <aside class="hidden md:block w-80 shrink-0 space-y-6">
            
            <!-- Status Card -->
            <div class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm overflow-hidden relative">
                <div class="absolute top-0 right-0 p-4 opacity-5">
                    <svg class="w-20 h-20 text-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm-1 4a1 1 0 012 0v4h3a1 1 0 110 2h-4a1 1 0 01-1-1V6z"/></svg>
                </div>
                <div class="text-[10px] uppercase tracking-widest text-slate-400 font-bold mb-1">Document Status</div>
                <div class="flex items-center gap-2 mb-4">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-lg font-bold text-slate-800">Ready for Interaction</span>
                </div>
                <p class="text-xs text-slate-500 leading-relaxed mb-6">
                    This document is dynamic. You can add items, chat with support, or request changes directly from this view.
                </p>
                <div class="space-y-3">
                    <button class="w-full bg-primary text-white py-3 rounded-xl text-sm font-bold shadow-lg shadow-indigo-100 hover:-translate-y-0.5 transition-transform">
                        Update Order
                    </button>
                    <button class="w-full bg-slate-50 text-slate-700 py-3 rounded-xl text-sm font-bold border border-slate-200 hover:bg-slate-100 transition-colors">
                        Download PDF
                    </button>
                </div>
            </div>

            <!-- Experience Card (n8n Chat Integration Hub) -->
            <div class="bg-indigo-900 rounded-2xl p-6 text-white shadow-xl relative overflow-hidden group">
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl group-hover:scale-110 transition-transform"></div>
                <div class="relative z-10">
                    <div class="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center text-xl mb-4">🤖</div>
                    <div class="text-lg font-bold mb-1 font-display">Need assistance?</div>
                    <p class="text-xs text-indigo-100 mb-6 opacity-80">
                        Chat with our AI support bot to track your order, request returns, or ask questions.
                    </p>
                    <a href="#support" class="inline-flex items-center gap-2 text-xs font-bold text-white bg-indigo-600/50 hover:bg-indigo-600 p-3 rounded-lg border border-indigo-400/30 transition-all">
                        Open Smart Chat <span class="bg-white/20 px-1.5 py-0.5 rounded text-[8px] animate-pulse">LIVE</span>
                    </a>
                </div>
            </div>

            <!-- Feedback / NPS -->
            <div class="p-6 border-t border-slate-200">
                <div class="text-xs font-bold text-slate-400 mb-2 uppercase tracking-tight">Security ID</div>
                <div class="text-[10px] font-mono whitespace-nowrap overflow-hidden text-ellipsis opacity-40">
                    <%= document.id %>-SIG-HMAC-256
                </div>
            </div>

        </aside>
    </main>

    <!-- Support Portal Modal (n8n Integration) -->
    <div x-show="sidebarOpen" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-[60] bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4"
         x-cloak>
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden flex flex-col h-[600px]" @click.away="sidebarOpen = false">
            <div class="bg-primary p-6 text-white flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center text-xl">💬</div>
                    <div>
                        <div class="font-bold">Customer Support</div>
                        <div class="text-[10px] text-white/70">Powered by n8n Flow Engine</div>
                    </div>
                </div>
                <button @click="sidebarOpen = false" class="text-white/50 hover:text-white transition-colors">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="flex-1 bg-slate-50 relative">
                <!-- n8n Chat Widget Target -->
                <div class="absolute inset-0 flex items-center justify-center flex-col p-8 text-center opacity-40">
                    <div class="text-4xl mb-4">🚀</div>
                    <div class="font-bold text-slate-600">Connecting to Support Hub...</div>
                    <div class="text-xs text-slate-400 mt-2">Initializing secure n8n websocket connection</div>
                </div>
                <!-- Future: Inject n8n chat script here -->
            </div>
            <div class="bg-white p-4 border-t border-slate-100">
                <div class="flex gap-2">
                    <input type="text" placeholder="Type your message..." class="flex-1 bg-slate-100 border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20">
                    <button class="bg-primary text-white p-3 rounded-xl shadow-lg shadow-indigo-100">
                        <svg class="h-5 w-5 rotate-90" fill="currentColor" viewBox="0 0 20 20"><path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-slate-200 py-8">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-2 text-[10px] font-bold text-slate-400 uppercase tracking-widest">
                <span>&copy; 2026 Floovioo Enterprise</span>
                <span class="h-4 w-px bg-slate-200"></span>
                <span>Transactional Branding v2.2</span>
            </div>
            <div class="flex items-center gap-6">
                <a href="#" class="text-xs text-slate-500 hover:text-primary underline">Privacy Policy</a>
                <a href="#" class="text-xs text-slate-500 hover:text-primary underline">Security Standards</a>
            </div>
        </div>
    </footer>
</body>
</html>
