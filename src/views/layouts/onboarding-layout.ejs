<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Floovioo Setup</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/enterprise-theme.css">
    <script src="//unpkg.com/alpinejs" defer></script>
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="h-full font-sans antialiased text-slate-600 bg-slate-50">

    <div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8">
        <div class="sm:mx-auto sm:w-full sm:max-w-md">
            <div class="flex justify-center">
                 <div class="h-12 w-12 bg-brand-blue rounded flex items-center justify-center text-white font-bold text-2xl shadow-glow">F</div>
            </div>
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
                Setup your Business
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Step <%= typeof step !== 'undefined' ? step : 1 %> of 3
            </p>
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-2xl px-4">
            <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
                <%- body %>
            </div>
        </div>
    </div>

</body>
</html>
