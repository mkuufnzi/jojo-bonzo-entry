<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Floovioo Enterprise</title>
    <link rel="stylesheet" href="/assets/css/style.css">
    <link rel="stylesheet" href="/assets/css/mobile-custom.css">
    <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>" src="https://unpkg.com/lucide@latest"></script>
    <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>" src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="//unpkg.com/alpinejs" defer nonce="<%= nonce %>"></script>
    <style nonce="<%= nonce %>">
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="h-full font-sans antialiased bg-background text-text-primary" x-data="{ sidebarOpen: false, miniSidebar: false, aiPanelOpen: false }">
    <% const currentService = typeof activeService !== 'undefined' ? activeService : 'hub'; %>

    <!-- Mobile sidebar backdrop (Visible < 1024px) -->
    <div x-show="sidebarOpen" x-cloak class="fixed inset-0 z-40 flex lg:hidden" role="dialog" aria-modal="true">
        <div x-show="sidebarOpen" x-transition:enter="transition-opacity ease-linear duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-300" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="fixed inset-0 bg-gray-600 bg-opacity-75" @click="sidebarOpen = false"></div>

        <div x-show="sidebarOpen" x-transition:enter="transition ease-in-out duration-300 transform" x-transition:enter-start="-translate-x-full" x-transition:enter-end="translate-x-0" x-transition:leave="transition ease-in-out duration-300 transform" x-transition:leave-start="translate-x-0" x-transition:leave-end="-translate-x-full" class="relative flex-1 flex flex-col max-w-xs w-full bg-slate-900 pt-5 pb-4">
            <div class="absolute top-0 right-0 -mr-12 pt-2">
                <button type="button" class="ml-1 flex items-center justify-center h-10 w-10 rounded-full focus:outline-none focus:ring-2 focus:ring-inset focus:ring-white" @click="sidebarOpen = false">
                    <span class="sr-only">Close sidebar</span>
                    <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="flex-shrink-0 flex items-center px-4">
                <div class="h-8 w-8 bg-brand-blue rounded flex items-center justify-center text-white font-bold mr-2">F</div>
                <span class="text-white font-heading font-bold text-xl">Floovioo</span>
            </div>
            <div class="mt-5 flex-1 h-0 overflow-y-auto">
                <nav class="px-2 space-y-1">
                    <%- include('../partials/dashboard/sidebar-items', { activeService: currentService }) %>
                </nav>
            </div>
        </div>
        <div class="flex-shrink-0 w-14"></div>
    </div>

    <!-- Static sidebar for Desktop and Tablet -->
    <!-- Tablet: Mini sidebar (lg:hidden but md:flex). Desktop: Full sidebar default -->
    <div class="hidden md:flex flex-col fixed inset-y-0 bg-slate-900 border-r border-slate-800 transition-all duration-300 z-30" 
         :class="miniSidebar ? 'w-20' : 'w-64'" 
         @resize.window="miniSidebar = window.innerWidth >= 768 && window.innerWidth < 1024">
        <div class="flex-1 flex flex-col min-h-0 bg-slate-900 overflow-hidden">
            <div class="flex items-center h-16 flex-shrink-0 px-4 bg-slate-900 border-b border-slate-800 justify-center" :class="miniSidebar ? 'px-0' : 'px-4'">
                <div class="h-8 w-8 bg-brand-blue rounded flex items-center justify-center text-white font-bold shadow-glow shrink-0" :class="miniSidebar ? 'mx-auto' : 'mr-2'">F</div>
                <span class="text-white font-heading font-bold text-xl" x-show="!miniSidebar" x-transition.opacity>Floovioo</span>
            </div>
            <div class="flex-1 flex flex-col overflow-y-auto">
                <nav class="flex-1 px-2 py-4 space-y-1">
                     <%- include('../partials/dashboard/sidebar-items', { activeService: currentService }) %>
                </nav>
            </div>
            <a href="/dashboard/profile" class="flex-shrink-0 flex border-t border-slate-800 p-4 hover:bg-slate-800 transition-colors group justify-center" :class="miniSidebar ? 'px-0' : 'p-4'">
                <div class="flex items-center" :class="miniSidebar ? 'justify-center w-full' : ''">
                    <div class="h-8 w-8 rounded-full bg-slate-700 flex items-center justify-center text-white font-bold text-xs group-hover:bg-slate-600 transition-colors shrink-0"><%= user.email[0].toUpperCase() %></div>
                    <div class="ml-3" x-show="!miniSidebar" x-transition.opacity>
                        <p class="text-sm font-medium text-white"><%= user.name || 'User' %></p>
                        <p class="text-xs font-medium text-slate-400 group-hover:text-slate-300">View Profile</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex flex-col flex-1 h-full transition-all duration-300" :class="{'md:pl-20 !lg:pl-64': miniSidebar, 'md:pl-64': !miniSidebar}">
        <!-- Topbar -->
        <div class="sticky top-0 z-10 flex-shrink-0 flex h-16 bg-surface shadow-sm border-b border-border">
            <button type="button" class="px-4 border-r border-border text-text-muted focus:outline-none focus:ring-2 focus:ring-inset focus:ring-primary md:hidden" @click="sidebarOpen = true">
                <span class="sr-only">Open sidebar</span>
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
            <div class="flex-1 px-4 flex justify-between">
                <div class="flex-1 flex items-center">
                    <h1 class="text-2xl font-bold text-gray-900 truncate"><%= title %></h1>
                </div>
                <div class="ml-4 flex items-center md:ml-6">
                    <button @click="miniSidebar = !miniSidebar" class="hidden md:block bg-surface p-1.5 rounded-lg text-text-muted hover:text-text-primary focus:outline-none mr-2 transition-all">
                        <span class="sr-only">Toggle Sidebar</span>
                        <i data-lucide="panel-left-close" class="w-5 h-5"></i>
                    </button>
                    <button @click="aiPanelOpen = true" class="bg-surface p-1.5 rounded-full text-blue-600 hover:text-blue-700 focus:outline-none ml-2 border border-blue-100 hover:border-blue-200 transition-all shadow-sm">
                        <span class="sr-only">Open AI Generator</span>
                        <i data-lucide="sparkles" class="w-5 h-5"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Dynamic Content Slot -->
        <main class="flex-1 overflow-y-auto bg-background p-4 sm:p-6 lg:p-8">
            <%- body %>
        </main>
    </div>

    <!-- Ensure lucide icons are initialized if used anywhere outside of other scripts -->
    <script nonce="<%= typeof nonce !== 'undefined' ? nonce : '' %>">
        document.addEventListener('alpine:init', () => {
             // Initialize mini-sidebar based on window size on load
             const w = window.innerWidth;
             if (w >= 768 && w < 1024) { Alpine.store('sidebarOpen', false); }
        });
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof lucide !== 'undefined') lucide.createIcons();
        });
    </script>
    <%- include('../partials/dashboard/ai-sidepanel') %>

</body>
</html>
