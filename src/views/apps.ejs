<%- include('partials/head', { title: 'Floovioo  - Apps' }) %>

<body class="bg-gray-100 min-h-screen font-sans">

    <%- include('partials/sidebar') %>

        <div id="mainContent" class="flex flex-col min-h-screen ">
            <%- include('partials/dashboard-header', {title: 'Apps & API Keys' , user: user }) %>

                <main class="flex-1">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-6 py-6">
                        <div class="mb-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                            <div>
                                <p class="text-[0.8125rem] font-bold text-gray-400 uppercase tracking-widest mt-1">Applications & API Keys</p>
                            </div>
                            <button id="openCreateAppModalBtn"
                                class="w-full sm:w-auto bg-blue-600 text-white px-3 py-1.5 rounded-md hover:bg-blue-700 transition-colors flex items-center justify-center text-[0.75rem] font-bold uppercase tracking-widest">
                                <i data-lucide="plus-circle" class="w-4 h-4 mr-2"></i>
                                <span>Add Application</span>
                            </button>
                        </div>

                        <% if (locals.error) { %>
                            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6"
                                role="alert">
                                <strong class="font-bold">Error!</strong>
                                <span class="block sm:inline">
                                    <%= error %>
                                </span>
                            </div>
                            <% } %>

                                <div class="grid grid-cols-1 gap-4 items-start">
                                    <% user.apps.forEach(app=> { %>
                                        <div class="minimal-card p-5 bg-white border border-slate-200 rounded-lg shadow-sm hover:shadow-md transition-all duration-200">
                                            <div class="flex items-center justify-between mb-4 pb-4 border-b border-slate-100">
                                                <div class="flex items-center space-x-3">
                                                    <div
                                                        class="w-8 h-8 rounded border border-blue-100 bg-blue-50/50 flex items-center justify-center text-blue-600 shadow-sm">
                                                        <i data-lucide="layers" class="w-4 h-4"></i>
                                                    </div>
                                                    <div>
                                                        <h3 class="text-base font-bold text-gray-900 uppercase tracking-widest">
                                                            <%= app.name %>
                                                        </h3>
                                                        <p class="text-[0.6875rem] font-bold text-slate-400 uppercase tracking-widest">UUID: <%= app.id %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center space-x-2">
                                                    <% 
                                                        const planFeatures = (user.subscription && user.subscription.plan && user.subscription.plan.planFeatures) ? user.subscription.plan.planFeatures : [];
                                                        const hasAnalytics = planFeatures.some(pf => pf.isEnabled && pf.feature && (pf.feature.key === 'analytics' || pf.feature.name === 'Analytics' || pf.feature.name === 'Advanced Analytics'));
                                                    %>
                                                        <% if (hasAnalytics) { %>
                                                            <a href="/analytics/apps/<%= app.id %>"
                                                                class="text-blue-500 hover:text-blue-700 p-1.5 rounded border border-slate-200 hover:bg-blue-50 transition-colors"
                                                                title="Operational Analytics">
                                                                <i data-lucide="bar-chart-3" class="w-3.5 h-3.5"></i>
                                                            </a>
                                                            <% } else { %>
                                                                <div class="group relative">
                                                                    <button disabled
                                                                        class="text-gray-300 cursor-not-allowed p-1.5 rounded border border-gray-100"
                                                                        title="Analytics (Requires Enterprise Tier)">
                                                                        <i data-lucide="lock" class="w-3.5 h-3.5"></i>
                                                                    </button>
                                                                    <div
                                                                        class="hidden group-hover:block absolute bottom-full left-1/2 transform -translate-x-1/2 bg-slate-800 text-white text-[0.625rem] font-bold uppercase tracking-widest rounded py-1 px-2 mb-2 whitespace-nowrap z-10 shadow-lg">
                                                                        Upgrade for Meta-Analytics
                                                                    </div>
                                                                </div>
                                                                <% } %>
                                                                    <form action="/apps/delete" method="POST"
                                                                        onsubmit="return handleConfirm(this);">
                                                                        <input type="hidden" name="confirmMsg" value="Terminate this application instance? This operation is irreversible.">
                                                                        <input type="hidden" name="appId"
                                                                            value="<%= app.id %>">
                                                                        <button type="submit"
                                                                            class="text-red-500 hover:text-red-700 p-1.5 rounded border border-slate-200 hover:bg-red-50 transition-colors">
                                                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                                                                        </button>
                                                                    </form>
                                                </div>
                                            </div>

                                            <div class="mt-4">
                                                <label
                                                    class="block text-[0.6875rem] font-bold text-slate-400 uppercase tracking-widest mb-1.5">API Key</label>
                                                <div class="flex items-center space-x-2 mb-4">
                                                    <code
                                                        class="flex-1 bg-white p-2 rounded border border-slate-200 text-sm font-mono break-all select-all text-gray-700 shadow-minimal"><%= app.apiKey %></code>
                                                    <button onclick="navigator.clipboard.writeText('<%= app.apiKey %>')"
                                                        class="p-2 bg-white border border-slate-200 rounded hover:bg-blue-50 text-slate-400 hover:text-blue-600 transition-all shadow-sm"
                                                        title="Copy Key">
                                                        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                                                    </button>
                                                    <form action="/apps/regenerate-key" method="POST"
                                                        onsubmit="return handleConfirm(this);">
                                                        <input type="hidden" name="confirmMsg" value="Regenerate API Key? This will immediately invalidate the current credential.">
                                                        <input type="hidden" name="appId" value="<%= app.id %>">
                                                        <button type="submit"
                                                            class="p-2 bg-white border border-slate-200 rounded hover:bg-red-50 text-slate-400 hover:text-red-600 transition-all shadow-sm"
                                                            title="Regenerate API Key">
                                                            <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
                                                        </button>
                                                    </form>
                                                    <form action="/apps/toggle-active" method="POST"
                                                        onsubmit="return handleConfirm(this);">
                                                        <input type="hidden" name="confirmMsg" value="<%= app.isActive ? 'Deactivate application?' : 'Activate application instance?' %>">
                                                        <input type="hidden" name="appId" value="<%= app.id %>">
                                                        <input type="hidden" name="isActive"
                                                            value="<%= !app.isActive %>">
                                                        <button type="submit"
                                                            class="p-2 bg-white border border-slate-200 rounded shadow-sm <%= app.isActive ? 'hover:bg-yellow-50 text-yellow-600' : 'hover:bg-green-50 text-green-600' %> transition-all"
                                                            title="<%= app.isActive ? 'Suspend Access' : 'Restore Access' %>">
                                                            <i data-lucide="<%= app.isActive ? 'shield-off' : 'shield-check' %>" class="w-3.5 h-3.5"></i>
                                                        </button>
                                                    </form>
                                                </div>

                                                <% if (!app.isActive) { %>
                                                    <div
                                                        class="mb-4 bg-orange-50 border border-orange-100 text-orange-700 px-3 py-2 rounded text-[0.6875rem] font-bold uppercase tracking-widest flex items-center">
                                                        <i data-lucide="alert-triangle" class="w-4 h-4 mr-2"></i>
                                                        Application Deactivated. All incoming requests will be rejected.
                                                    </div>
                                                    <% } %>

                                                        <details class="group border-t border-slate-100 pt-3">
                                                            <summary
                                                                class="flex items-center justify-between cursor-pointer list-none mb-2 select-none">
                                                                 <span
                                                                    class="text-[0.6875rem] font-bold text-slate-400 uppercase tracking-widest">Manage Services</span>
                                                                <i data-lucide="chevron-down" class="w-3 h-3 text-slate-400 transition-transform duration-200 group-open:rotate-180"></i>
                                                            </summary>
                                                            <div class="space-y-2 pb-2">
                                                                <% if (locals.services) { %>
                                                                    <% services.forEach(service=> { %>
                                                                            <% 
                                                                                const isEnabled = app.services.some(s=> s.serviceId === service.id && s.isEnabled);
                                                                                const isLocked = service.isLocked;
                                                                            %>
                                                                             <div
                                                                                class="flex items-center justify-between bg-slate-50/50 px-3 py-1.5 rounded border border-slate-100 <%= isLocked ? 'opacity-60' : '' %>">
                                                                                <span class="text-[0.6875rem] font-bold text-slate-600 uppercase tracking-widest flex items-center gap-2">
                                                                                    <%= service.name %>
                                                                                    <% if (isLocked) { %> <i data-lucide="lock" class="w-3 h-3 text-slate-400"></i> <% } %>
                                                                                </span>
                                                                                
                                                                                <% if (isLocked) { %>
                                                                                     <div title="Not included in your plan" class="relative inline-flex h-4 w-8 flex-shrink-0 cursor-not-allowed rounded-full border-2 border-transparent bg-slate-200">
                                                                                        <span aria-hidden="true" class="pointer-events-none inline-block h-3 w-3 transform rounded-full bg-white shadow-sm ring-0 translate-x-0"></span>
                                                                                     </div>
                                                                                <% } else { %>
                                                                                <form action="/apps/toggle-service"
                                                                                    method="POST"
                                                                                    class="flex items-center"
                                                                                    onsubmit="return handleConfirm(this);">
                                                                                    <input type="hidden" name="confirmMsg" value="Modify service access for <%= service.name %>?">
                                                                                    <input type="hidden" name="appId"
                                                                                        value="<%= app.id %>">
                                                                                    <input type="hidden"
                                                                                        name="serviceId"
                                                                                        value="<%= service.id %>">
                                                                                    <input type="hidden" name="enabled"
                                                                                        value="<%= !isEnabled %>">
                                                                                    <button type="submit"
                                                                                        class="relative inline-flex h-4 w-8 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none <%= isEnabled ? 'bg-blue-600' : 'bg-slate-200' %>"
                                                                                        role="switch"
                                                                                        aria-checked="<%= isEnabled %>">
                                                                                        <span aria-hidden="true"
                                                                                            class="pointer-events-none inline-block h-3 w-3 transform rounded-full bg-white shadow-sm ring-0 transition duration-200 ease-in-out <%= isEnabled ? 'translate-x-4' : 'translate-x-0' %>"></span>
                                                                                    </button>
                                                                                </form>
                                                                                <% } %>
                                                                            </div>
                                                                            <% }); %>
                                                                                <% } %>
                                                            </div>
                                                        </details>
                                            </div>
                                        </div>
                                        <% }); %>
                                </div>
                    </div>
                </main>
        </div>

         <!-- Generic Confirmation Modal -->
         <div id="confirmationModal"
             class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-slate-900/60 backdrop-blur-md transition-opacity duration-200">
             <div class="bg-white border border-slate-200 rounded-xl w-full max-w-sm shadow-2xl overflow-hidden transform transition-all scale-100 animate-in fade-in zoom-in-95 duration-200">
                 <div class="p-6">
                     <div class="flex items-center gap-3 mb-4">
                         <div class="w-10 h-10 bg-amber-50 rounded-full flex items-center justify-center text-amber-500 border border-amber-100">
                             <i data-lucide="alert-circle" class="w-5 h-5"></i>
                         </div>
                         <h3 class="text-sm font-bold text-slate-900 uppercase tracking-wide">Confirmation Required</h3>
                     </div>
                     <p id="confirmationMessage" class="text-sm font-medium text-slate-500 leading-relaxed mb-6">
                         Are you sure you want to proceed?
                     </p>
                     <div class="flex items-center justify-end gap-3">
                         <button type="button" onclick="closeConfirmationModal()"
                             class="px-4 py-2 text-[0.75rem] font-bold text-slate-500 hover:text-slate-700 bg-slate-50 hover:bg-slate-100 rounded-lg uppercase tracking-widest transition-colors">
                             Cancel
                         </button>
                         <button type="button" id="confirmActionBtn"
                             class="px-4 py-2 text-[0.75rem] font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-lg uppercase tracking-widest shadow-md hover:shadow-lg transition-all">
                             Confirm
                         </button>
                     </div>
                 </div>
             </div>
         </div>

         <!-- Create App Modal -->
         <div id="createAppModal"
             class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 hidden flex items-center justify-center">
             <div class="bg-white rounded-lg border border-slate-200 shadow-2xl p-5 w-full max-w-sm mx-4 animate-in fade-in zoom-in-95 duration-200">
                  <div class="flex items-center gap-2 mb-6">
                     <i data-lucide="plus-square" class="w-4 h-4 text-blue-600"></i>
                     <h2 class="text-sm font-bold text-gray-900 uppercase tracking-widest">Register Application</h2>
                  </div>
                 <form action="/apps/create" method="POST">
                     <div class="mb-5">
                          <label class="block text-[0.6875rem] font-bold text-slate-400 uppercase tracking-widest mb-1.5" for="name">Application Name</label>
                          <input
                              class="w-full bg-slate-50 border border-slate-200 rounded px-3 py-2 text-[0.8125rem] font-bold text-gray-700 focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all uppercase tracking-tight"
                              id="name" name="name" type="text" placeholder="My App Name" required>
                     </div>

                      <div class="mb-6">
                           <label class="block text-[0.8125rem] font-bold text-slate-400 uppercase tracking-widest mb-2">Manage Services</label>
                         <div class="grid grid-cols-1 gap-1.5">
                             <% if (locals.services) { %>
                                 <% services.forEach(service=> { %>
                                      <div class="flex items-center bg-slate-50/50 px-2 py-1.5 rounded border border-slate-100 <%= service.isLocked ? 'opacity-60' : '' %>">
                                          <input type="checkbox" id="service_<%= service.id %>" name="services"
                                              value="<%= service.id %>"
                                              class="h-3.5 w-3.5 text-blue-600 border-slate-300 rounded focus:ring-0 cursor-pointer"
                                              <%= service.isLocked ? 'disabled' : 'checked' %>>
                                          <label for="service_<%= service.id %>" class="ml-2 block text-sm font-bold <%= service.isLocked ? 'text-slate-400' : 'text-slate-700' %> uppercase tracking-widest flex items-center gap-2">
                                              <%= service.name %>
                                              <% if (service.isLocked) { %> <i data-lucide="lock" class="w-3 h-3 text-slate-400"></i> <% } %>
                                          </label>
                                      </div>
                                     <% }); %>
                                         <% } %>
                         </div>
                     </div>

                      <div class="flex items-center justify-end gap-2 pt-4 border-t border-slate-100">
                          <button type="button" id="closeCreateAppModalBtn"
                              class="px-4 py-1.5 text-[0.75rem] font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest transition-colors">
                              Cancel
                          </button>
                          <button type="submit"
                              class="bg-blue-600 text-white px-4 py-1.5 rounded text-[0.75rem] font-bold uppercase tracking-widest hover:bg-blue-700 transition-colors">
                              Create Application
                          </button>
                      </div>
                </form>
            </div>
        </div>


        <script nonce="<%= nonce %>">
            let pendingForm = null;

            function handleConfirm(form) {
                const msgInput = form.querySelector('input[name="confirmMsg"]');
                const message = msgInput ? msgInput.value : 'Confirm critical system action?';
                
                showConfirmationModal(message, form);
                return false; // Prevent immediate submission
            }

            function showConfirmationModal(message, form) {
                const modal = document.getElementById('confirmationModal');
                const msgEl = document.getElementById('confirmationMessage');
                const confirmBtn = document.getElementById('confirmActionBtn');
                
                if (modal && msgEl && confirmBtn) {
                    msgEl.textContent = message;
                    pendingForm = form;
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    
                    // Cleanup previous listeners
                    const newBtn = confirmBtn.cloneNode(true);
                    confirmBtn.parentNode.replaceChild(newBtn, confirmBtn);
                    
                    newBtn.addEventListener('click', () => {
                        if (pendingForm) {
                            pendingForm.submit();
                            closeConfirmationModal();
                        }
                    });
                }
            }

            function closeConfirmationModal() {
                const modal = document.getElementById('confirmationModal');
                if (modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    pendingForm = null;
                }
            }

            function setupModal() {
                const modal = document.getElementById('createAppModal');
                const openBtn = document.getElementById('openCreateAppModalBtn');
                const closeBtn = document.getElementById('closeCreateAppModalBtn');

                if (openBtn && modal) {
                    openBtn.addEventListener('click', () => {
                        modal.classList.remove('hidden');
                    });
                }

                if (closeBtn && modal) {
                    closeBtn.addEventListener('click', () => {
                        modal.classList.add('hidden');
                    });
                }

                // Close on click outside (both modals)
                window.addEventListener('click', (e) => {
                    if (e.target === modal) {
                        modal.classList.add('hidden');
                    }
                    const confirmModal = document.getElementById('confirmationModal');
                    if (e.target === confirmModal) {
                        closeConfirmationModal();
                    }
                });
            }

            // Initialize on load
            document.addEventListener('DOMContentLoaded', () => {
                setupModal();
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        </script>

            <%- include('partials/sidebar-script') %>
</body>

</html>
