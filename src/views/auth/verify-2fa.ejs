<%- include('../partials/head', { title: 'Two-Factor Authentication - Floovioo ' }) %>

<body class="bg-slate-50 min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-sans antialiased text-slate-900">

    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex flex-col items-center justify-center">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-4 shadow-lg shadow-blue-600/20">
                <i data-lucide="shield-check" class="w-6 h-6 text-white"></i>
            </div>
            <h2 class="mt-2 text-center text-3xl font-black tracking-tight text-slate-900">
                Two-Factor Auth
            </h2>
            <p class="mt-2 text-center text-sm font-medium text-slate-600">
                Check your email for the verification code.
            </p>
        </div>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-[400px]">
        <div class="bg-white py-8 px-4 shadow-xl shadow-slate-200/50 sm:rounded-2xl sm:px-10 border border-slate-100">
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-rose-50 border border-rose-100 text-rose-600 rounded-xl p-4 mb-6 flex items-start gap-3" role="alert">
                    <i data-lucide="alert-circle" class="w-5 h-5 shrink-0 mt-0.5"></i>
                    <span class="text-sm font-bold"><%= error %></span>
                </div>
            <% } %>

            <form class="space-y-6" action="/auth/2fa" method="POST">
                <input type="hidden" name="returnUrl" value="<%= typeof returnUrl !== 'undefined' ? returnUrl : '' %>">
                
                <div>
                    <label for="code" class="block text-sm font-bold text-slate-700">Verification Code</label>
                    <div class="mt-2">
                        <input id="code" name="code" type="text" autocomplete="one-time-code" required class="block w-full rounded-xl border-0 py-3 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 text-center font-mono text-xl tracking-widest sm:text-sm sm:leading-6 bg-slate-50/50 focus:bg-white transition-all">
                    </div>
                </div>

                <div>
                    <button type="submit" class="flex w-full justify-center rounded-xl bg-blue-600 px-3 py-3 text-sm font-bold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all uppercase tracking-wide">
                        Verify
                    </button>
                </div>
            </form>

            <div class="mt-6">
                <div class="relative">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-slate-200"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="bg-white px-2 text-slate-500 font-medium">Didn't receive the code?</span>
                    </div>
                </div>

                <div class="mt-6 text-center">
                    <form action="/auth/2fa/resend" method="POST" class="inline">
                         <input type="hidden" name="returnUrl" value="<%= typeof returnUrl !== 'undefined' ? returnUrl : '' %>">
                         <button type="submit" class="bg-transparent border-0 p-0 text-slate-500 hover:text-blue-600 font-medium cursor-pointer transition-colors text-sm">
                             Resend Code
                         </button>
                    </form>
                    <span class="mx-2 text-slate-300">|</span>
                    <a href="/auth/login" class="font-bold text-slate-400 hover:text-slate-600 text-xs uppercase tracking-wider transition-colors">
                        Back to Login
                    </a>
                </div>
            </div>
        </div>
        
        <p class="mt-8 text-center text-xs font-medium text-slate-400">
            &copy; <%= new Date().getFullYear() %> Floovioo . Secure & Encrypted.
        </p>
    </div>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest" nonce="<%= nonce %>"></script>
    <script nonce="<%= nonce %>">
        lucide.createIcons();
    </script>
</body>
</html>
