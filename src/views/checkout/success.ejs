<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50 dark:bg-slate-950">
<%- include('../partials/head') %>
<body class="h-full">
    <div class="min-h-full flex flex-col items-center justify-center p-6 md:p-12 relative overflow-hidden">
        <!-- Abstract Background -->
        <div class="absolute top-0 left-0 w-full h-full -z-10">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-400/10 rounded-full blur-[120px] animate-pulse"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-400/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 1s;"></div>
        </div>

        <div class="max-w-xl w-full bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl shadow-emerald-500/10 border border-slate-100 dark:border-slate-800 p-8 md:p-12 text-center relative overflow-hidden">
            <!-- Glassmorphic Accent -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-500/5 rotate-45 translate-x-16 -translate-y-16 blur-xl"></div>
            
            <div class="relative z-10">
                <!-- Success Icon -->
                <div class="w-24 h-24 bg-emerald-50 dark:bg-emerald-900/20 rounded-full flex items-center justify-center mx-auto mb-8 animate-bounce-subtle">
                    <i data-lucide="check-circle-2" class="w-12 h-12 text-emerald-500"></i>
                </div>

                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-emerald-50 dark:bg-emerald-900/10 text-emerald-600 dark:text-emerald-400 text-xs font-bold uppercase tracking-wider mb-4">
                    <i data-lucide="sparkles" class="w-3.5 h-3.5"></i>
                    <span>Order Confirmed</span>
                </div>

                <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-6">You're All Set!</h1>
                
                <p class="text-slate-500 dark:text-slate-400 text-lg leading-relaxed mb-10">
                    We've successfully added your selection to your account. Your secondary invoice <span class="font-bold text-slate-900 dark:text-white">#<%= invoiceId %></span> has been generated in your portal.
                </p>

                <div class="space-y-4">
                    <a href="<%= url %>" target="_blank" class="block w-full py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-black rounded-2xl shadow-lg shadow-emerald-200 dark:shadow-none transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center group">
                        <span>View Invoice in Portal</span>
                        <i data-lucide="external-link" class="w-5 h-5 ml-2 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i>
                    </a>
                    <button onclick="window.close()" class="block w-full py-4 bg-slate-50 dark:bg-slate-800 hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 font-bold rounded-2xl transition-all">
                        Return to Previous Page
                    </button>
                </div>
            </div>
        </div>

        <div class="mt-12 text-center text-slate-400 text-sm font-medium flex items-center justify-center space-x-2">
            <i data-lucide="shield-check" class="w-4 h-4 text-emerald-500"></i>
            <span>Securely processed by Floovioo Smart Checkout</span>
        </div>
    </div>

    <%- include('../partials/scripts') %>
    <style>
        @keyframes bounce-subtle {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-bounce-subtle {
            animation: bounce-subtle 3s ease-in-out infinite;
        }
    </style>
</body>
</html>
