<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50 dark:bg-slate-950">
<%- include('../partials/head') %>
<body class="h-full">
    <div class="min-h-full flex flex-col items-center justify-center p-6 md:p-12 relative overflow-hidden">
        <!-- Abstract Background -->
        <div class="absolute top-0 left-0 w-full h-full -z-10">
            <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-rose-400/10 rounded-full blur-[120px] animate-pulse"></div>
            <div class="absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-amber-400/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 1.5s;"></div>
        </div>

        <div class="max-w-xl w-full bg-white dark:bg-slate-900 rounded-[2.5rem] shadow-2xl shadow-rose-500/10 border border-slate-100 dark:border-slate-800 p-8 md:p-12 text-center relative overflow-hidden">
            <div class="relative z-10">
                <!-- Error Icon -->
                <div class="w-24 h-24 bg-rose-50 dark:bg-rose-900/20 rounded-full flex items-center justify-center mx-auto mb-8">
                    <i data-lucide="alert-circle" class="w-12 h-12 text-rose-500"></i>
                </div>

                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-rose-50 dark:bg-rose-900/10 text-rose-600 dark:text-rose-400 text-xs font-bold uppercase tracking-wider mb-4">
                    <i data-lucide="x-circle" class="w-3.5 h-3.5"></i>
                    <span>Checkout Problem</span>
                </div>

                <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white tracking-tight mb-6">Something's Not Right</h1>
                
                <p class="text-slate-500 dark:text-slate-400 text-lg leading-relaxed mb-10">
                    <%= message || 'We encountered an error while processing your checkout request.' %>
                </p>

                <div class="space-y-4">
                    <button onclick="window.location.reload()" class="block w-full py-4 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-black rounded-2xl transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center group">
                        <i data-lucide="refresh-cw" class="w-5 h-5 mr-2 group-hover:rotate-180 transition-transform duration-500"></i>
                        <span>Try Again</span>
                    </button>
                    <a href="/" class="block w-full py-4 bg-slate-50 dark:bg-slate-800 hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-400 font-bold rounded-2xl transition-all">
                        Back to Home
                    </a>
                </div>
            </div>
        </div>

        <div class="mt-12 text-center text-slate-400 text-sm font-medium">
            <p>If this persists, please contact <span class="font-bold text-slate-900 dark:text-white">support@floovioo.com</span></p>
        </div>
    </div>

    <%- include('../partials/scripts') %>
</body>
</html>
