<%- include('../partials/head', { title: 'Billing - Floovioo ' }) %>

<body class="bg-gray-100">
    <div class="flex h-screen">

        <%- include('../partials/sidebar', { path: '/billing' }) %>

            <!-- Main Content -->
            <div id="mainContent" class="flex-1 flex flex-col overflow-hidden  transition-all duration-300">
                <%- include('../partials/dashboard-header', { title: 'Billing & Invoices' }) %>

                    <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100">
                        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-6 py-6">

                            <% if (typeof success !=='undefined' && success) { %>
                                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4"
                                    role="alert">
                                    <span class="block sm:inline">
                                        <%= success %>
                                    </span>
                                </div>
                                <% } %>

                                    <% if (typeof error !=='undefined' && error) { %>
                                        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4"
                                            role="alert">
                                            <span class="block sm:inline">
                                                <%= error %>
                                            </span>
                                        </div>
                                        <% } %>


                                            <!-- Tabs -->
                                            <div class="border-b border-slate-200 mb-5">
                                                <nav class="-mb-px flex space-x-6">
                                                    <button onclick="switchTab('usage')" id="tab-usage"
                                                        class="border-blue-600 text-blue-600 whitespace-nowrap py-3 px-1 border-b-2 text-xs font-bold uppercase tracking-widest transition-all">
                                                        Usage Overview
                                                    </button>
                                                    <button onclick="switchTab('payment-methods')" id="tab-payment-methods"
                                                        class="border-transparent text-slate-400 hover:text-slate-600 hover:border-slate-300 whitespace-nowrap py-3 px-1 border-b-2 text-xs font-bold uppercase tracking-widest transition-all">
                                                        Payment Methods
                                                    </button>
                                                    <button onclick="switchTab('invoices')" id="tab-invoices"
                                                        class="border-transparent text-slate-400 hover:text-slate-600 hover:border-slate-300 whitespace-nowrap py-3 px-1 border-b-2 text-xs font-bold uppercase tracking-widest transition-all">
                                                        Billing History
                                                    </button>
                                                </nav>
                                            </div>

                                            <div id="content-usage" class="hidden">
                                                <!-- Financial Overview -->
                                                <div class="minimal-card p-4 mb-6 bg-white border border-slate-200 rounded-xl shadow-sm">
                                                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                                                        <div class="flex items-center gap-4">
                                                            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 shadow-inner">
                                                                <i data-lucide="wallet" class="w-6 h-6"></i>
                                                            </div>
                                                            <div>
                                                                <h3 class="text-xs font-black text-gray-900 uppercase tracking-tighter">Billing Overview</h3>
                                                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">Cycle: <%= new Date().toLocaleString('default', { month: 'long' }) %> <%= new Date().getFullYear() %></p>
                                                            </div>
                                                        </div>
                                                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 flex-1 max-w-2xl">
                                                            <div class="text-center sm:text-left">
                                                                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Active Plan</p>
                                                                <p class="text-xs font-black text-blue-600 uppercase tracking-tighter mt-0.5"><%= planName %></p>
                                                            </div>
                                                            <div class="text-center sm:text-left">
                                                                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Base Cost</p>
                                                                <p class="text-xs font-black text-gray-900 tracking-tighter mt-0.5"><%= currency === 'GBP' ? '£' : '$' %><%= planPrice.toFixed(2) %></p>
                                                            </div>
                                                            <div class="text-center sm:text-left">
                                                                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Usage Cost</p>
                                                                <p class="text-xs font-black text-gray-900 tracking-tighter mt-0.5"><%= currency === 'GBP' ? '£' : '$' %><%= usageCost.toFixed(2) %></p>
                                                            </div>
                                                            <div class="text-center sm:text-left bg-slate-50 rounded-lg p-2 border border-slate-100">
                                                                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Total Due</p>
                                                                <p class="text-xs font-black text-gray-900 tracking-tighter mt-0.5"><%= currency === 'GBP' ? '£' : '$' %><%= (planPrice + usageCost).toFixed(2) %></p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Quota & Detailed Breakdown -->
                                                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6 items-start">
                                                    <!-- Left Column: Quota Progress (Compact List) -->
                                                    <div class="lg:col-span-4 space-y-4">
                                                        <div class="minimal-card p-4 h-full bg-white border border-slate-200 rounded-xl shadow-sm">
                                                            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4 flex items-center">
                                                                <i data-lucide="bar-chart-2" class="w-3 h-3 mr-2"></i>
                                                                Allocation Status
                                                            </h3>
                                                            <div class="space-y-6">
                                                                <!-- PDF Quota -->
                                                                <div>
                                                                    <div class="flex justify-between items-end mb-2">
                                                                        <div>
                                                                            <p class="text-xs font-black text-gray-900 uppercase tracking-tighter">PDF Capacity</p>
                                                                            <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Monthly Translation Volume</p>
                                                                        </div>
                                                                        <span class="text-xs font-black text-blue-600"><%= pdfUsage %> / <%= pdfQuota === -1 ? '∞' : pdfQuota %></span>
                                                                    </div>
                                                                    <% if (pdfQuota !== -1) { %>
                                                                        <% const pdfPercentage = Math.min((pdfUsage / pdfQuota) * 100, 100); %>
                                                                        <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                                                            <div class="progress-bar bg-blue-600 h-1.5 rounded-full transition-all duration-500" data-percentage="<%= pdfPercentage %>"></div>
                                                                        </div>
                                                                    <% } else { %>
                                                                        <div class="h-1.5 bg-blue-50 border border-blue-100/50 rounded-full flex items-center px-1">
                                                                            <div class="w-full h-0.5 bg-blue-200/50 animate-pulse rounded-full"></div>
                                                                        </div>
                                                                    <% } %>
                                                                </div>

                                                                <!-- AI Quota -->
                                                                <div>
                                                                    <div class="flex justify-between items-end mb-2">
                                                                        <div>
                                                                            <p class="text-xs font-black text-gray-900 uppercase tracking-tighter">AI Generation</p>
                                                                            <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Monthly Output Potential</p>
                                                                        </div>
                                                                        <span class="text-xs font-black text-indigo-600"><%= aiUsage %> / <%= aiQuota === -1 ? '∞' : aiQuota %></span>
                                                                    </div>
                                                                    <% if (aiQuota !== -1) { %>
                                                                        <% const aiPercentage = Math.min((aiUsage / aiQuota) * 100, 100); %>
                                                                        <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
                                                                            <div class="progress-bar bg-indigo-600 h-1.5 rounded-full transition-all duration-500" data-percentage="<%= aiPercentage %>"></div>
                                                                        </div>
                                                                    <% } else { %>
                                                                        <div class="h-1.5 bg-indigo-50 border border-indigo-100/50 rounded-full flex items-center px-1">
                                                                            <div class="w-full h-0.5 bg-indigo-200/50 animate-pulse rounded-full"></div>
                                                                        </div>
                                                                    <% } %>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <!-- Right Column: Service Breakdown (Scrollable List) -->
                                                    <div class="lg:col-span-8">
                                                        <div class="minimal-card h-full flex flex-col bg-white border border-slate-200 rounded-xl shadow-sm">
                                                            <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center bg-slate-50/30">
                                                                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center">
                                                                    <i data-lucide="layers" class="w-3 h-3 mr-2 text-slate-400"></i>
                                                                    Usage by Protocol
                                                                </h3>
                                                                <span class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Active Services: <%= usageBreakdown.length %></span>
                                                            </div>
                                                            <div class="flex-1 overflow-y-auto max-h-[18.75rem] lg:max-h-[25rem]">
                                                                <table class="min-w-full divide-y divide-slate-50">
                                                                    <thead class="bg-slate-50/50 sticky top-0 z-10 backdrop-blur-md">
                                                                        <tr>
                                                                            <th class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Service Name</th>
                                                                            <th class="px-4 py-2 text-center text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Requests</th>
                                                                            <th class="px-4 py-2 text-right text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Cost</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="divide-y divide-slate-50">
                                                                        <% if (usageBreakdown.length === 0) { %>
                                                                            <tr>
                                                                                <td colspan="3" class="px-4 py-8 text-center text-[10px] font-bold text-slate-400 uppercase tracking-widest italic">No protocol activity detected in current cycle</td>
                                                                            </tr>
                                                                        <% } %>
                                                                        <% usageBreakdown.forEach(svc => { %>
                                                                            <tr class="hover:bg-slate-50/50 transition-colors">
                                                                                <td class="px-4 py-3">
                                                                                    <div class="flex items-center gap-2">
                                                                                        <div class="w-6 h-6 bg-slate-50 border border-slate-100 rounded-lg flex items-center justify-center">
                                                                                            <i data-lucide="cpu" class="w-3 h-3 text-slate-400"></i>
                                                                                        </div>
                                                                                        <span class="text-[10px] font-black text-gray-900 uppercase tracking-tighter"><%= svc.name %></span>
                                                                                    </div>
                                                                                </td>
                                                                                <td class="px-4 py-3 text-center">
                                                                                    <span class="text-xs font-bold text-slate-600"><%= svc.count %></span>
                                                                                </td>
                                                                                <td class="px-4 py-3 text-right">
                                                                                    <span class="text-xs font-mono font-bold text-gray-900"><%= currency === 'GBP' ? '£' : '$' %><%= svc.cost.toFixed(4) %></span>
                                                                                </td>
                                                                            </tr>
                                                                        <% }) %>
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Service Pricing Reference -->
                                                <div class="minimal-card mb-6 overflow-hidden">
                                                    <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center cursor-pointer hover:bg-slate-50 transition-colors" onclick="document.getElementById('pricing-table').classList.toggle('hidden'); document.getElementById('pricing-chevron').classList.toggle('rotate-180')">
                                                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center">
                                                            <i data-lucide="tag" class="w-3 h-3 mr-2 text-slate-300"></i>
                                                            Service Pricing Matrix
                                                        </h3>
                                                        <i id="pricing-chevron" data-lucide="chevron-down" class="w-3 h-3 text-slate-400 transform transition-transform duration-200"></i>
                                                    </div>
                                                    <div id="pricing-table" class="hidden border-t border-slate-100">
                                                        <div class="overflow-x-auto">
                                                            <table class="min-w-full divide-y divide-slate-100">
                                                                <thead class="bg-slate-50/50">
                                                                    <tr>
                                                                        <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Protocol</th>
                                                                        <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Description</th>
                                                                        <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Unit Cost</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody class="bg-white divide-y divide-slate-50">
                                                                    <% services.forEach(svc => { %>
                                                                        <tr class="hover:bg-slate-50/50 transition-colors">
                                                                            <td class="px-4 py-2 whitespace-nowrap text-xs font-bold text-gray-700 uppercase tracking-tight"><%= svc.name %></td>
                                                                            <td class="px-4 py-2 whitespace-nowrap text-[10px] text-slate-500 font-medium"><%= svc.description || 'Universal API Access' %></td>
                                                                            <td class="px-4 py-2 whitespace-nowrap text-xs font-mono font-bold text-gray-900 text-right">
                                                                                <%= svc.currency === 'GBP' ? '£' : '$' %><%= svc.pricePerRequest.toFixed(4) %>
                                                                            </td>
                                                                        </tr>
                                                                    <% }) %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Filters -->
                                                <div class="minimal-card mb-6 overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm">
                                                    <div class="px-4 py-3 bg-slate-50/30 border-b border-slate-100 flex justify-between items-center">
                                                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center">
                                                            <i data-lucide="filter" class="w-3 h-3 mr-2 text-slate-400"></i>
                                                            Usage Filters
                                                        </h3>
                                                        <% if (filters.serviceId || filters.hideFailed) { %>
                                                            <a href="/billing?tab=usage" class="text-[10px] sm:text-xs font-bold text-red-600 hover:text-red-700 uppercase tracking-widest flex items-center bg-red-50 px-2 py-1 rounded border border-red-100 transition-all">
                                                                <i data-lucide="x" class="w-2.5 h-2.5 mr-1"></i>
                                                                Reset
                                                            </a>
                                                        <% } %>
                                                    </div>
                                                    
                                                    <div class="p-4">
                                                        <form method="GET" action="/billing" class="grid grid-cols-1 md:grid-cols-2 gap-4 items-center">
                                                            <input type="hidden" name="tab" value="usage">
                                                            <!-- Service Filter -->
                                                            <div>
                                                                <label for="serviceId" class="block text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Filter by Service</label>
                                                                <div class="relative">
                                                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                                        <i data-lucide="layers" class="w-3.5 h-3.5 text-slate-400"></i>
                                                                    </div>
                                                                    <select id="serviceId" name="serviceId" onchange="this.form.submit()" class="bg-slate-50 border border-slate-200 rounded-lg px-10 py-2.5 text-[10px] font-black uppercase tracking-tight w-full focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition-all appearance-none cursor-pointer shadow-inner">
                                                                        <option value="">All Services</option>
                                                                        <% services.forEach(svc => { %>
                                                                            <option value="<%= svc.id %>" <%= filters.serviceId === svc.id ? 'selected' : '' %>><%= svc.name %></option>
                                                                        <% }) %>
                                                                    </select>
                                                                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                                                        <i data-lucide="chevron-down" class="w-3.5 h-3.5 text-slate-400"></i>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Hide Failed Toggle -->
                                                            <div class="flex items-center md:justify-end h-full pt-4 md:pt-4">
                                                                <label class="flex items-center cursor-pointer group px-4 py-2.5 rounded-lg border border-slate-100 hover:bg-slate-50 transition-all w-full md:w-auto bg-slate-50/50 shadow-inner">
                                                                    <div class="relative flex items-center">
                                                                        <input id="hideFailed" name="hideFailed" type="checkbox" onchange="this.form.submit()" <%= filters.hideFailed ? 'checked' : '' %> class="h-3.5 w-3.5 text-blue-600 focus:ring-blue-500 border-slate-200 rounded-md cursor-pointer transition-all">
                                                                    </div>
                                                                    <div class="ml-3 text-xs font-black text-slate-500 uppercase tracking-widest group-hover:text-slate-700 transition-colors">Success Only</div>
                                                                </label>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>

                                                <!-- Usage Logs Table -->
                                                <div class="minimal-card mb-6 overflow-hidden bg-white border border-slate-200 rounded-xl shadow-sm">
                                                    <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center bg-slate-50/30">
                                                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest flex items-center">
                                                            <i data-lucide="clipboard-list" class="w-3 h-3 mr-2 text-slate-400"></i>
                                                            Detailed Activity Logs
                                                        </h3>
                                                    </div>
                                                    <div class="flex flex-col">
                                                        <div class="overflow-x-auto">
                                                            <div class="align-middle inline-block min-w-full">
                                                                <table class="min-w-full divide-y divide-slate-100">
                                                                    <thead class="bg-slate-50/50">
                                                                        <tr>
                                                                            <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Date & Time</th>
                                                                            <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Service</th>
                                                                            <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">Activity</th>
                                                                            <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest text-center">Status</th>
                                                                            <th scope="col" class="px-4 py-2 text-left text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Cost</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody class="bg-white divide-y divide-slate-50">
                                                                        <% if (usageLogs.length === 0) { %>
                                                                            <tr>
                                                                                <td colspan="5" class="px-4 py-10 text-center text-xs font-bold text-slate-400 uppercase tracking-widest">No activity signals detected</td>
                                                                            </tr>
                                                                        <% } else { %>
                                                                            <% usageLogs.forEach(log => { %>
                                                                                <tr class="hover:bg-slate-50/50 transition-colors">
                                                                                    <td class="px-4 py-2 whitespace-nowrap text-[10px] font-medium text-slate-500"><%= new Date(log.createdAt).toLocaleString([], {year: 'numeric', month: 'short', day: '2-digit', hour: '2-digit', minute:'2-digit'}) %></td>
                                                                                    <td class="px-4 py-2 whitespace-nowrap text-xs font-bold text-gray-700 uppercase tracking-tight"><%= log.service ? log.service.name : 'Unknown' %></td>
                                                                                    <td class="px-4 py-2 whitespace-nowrap text-[10px] text-slate-500 font-medium"><%= log.action %></td>
                                                                                    <td class="px-4 py-2 whitespace-nowrap text-center">
                                                                                        <span class="px-1.5 py-0.5 inline-flex text-[10px] sm:text-xs font-bold leading-non rounded border uppercase tracking-widest <%= log.status === 'success' ? 'bg-green-50 text-green-700 border-green-100' : 'bg-red-50 text-red-700 border-red-100' %>">
                                                                                            <%= log.status %>
                                                                                        </span>
                                                                                    </td>
                                                                                    <td class="px-4 py-2 whitespace-nowrap text-xs font-mono font-bold text-gray-900 text-right"><%= log.currency === 'GBP' ? '£' : '$' %><%= log.cost.toFixed(4) %></td>
                                                                                </tr>
                                                                            <% }); %>
                                                                        <% } %>
                                                                    </tbody>
                                                                </table>
                                                                
                                                                <!-- Pagination Controls -->
                                                                <% if (pagination.totalPages > 1) { %>
                                                                    <div class="px-4 py-3 flex items-center justify-between border-t border-slate-100">
                                                                        <div class="flex-1 flex justify-between sm:hidden">
                                                                            <% if (pagination.hasPrev) { %>
                                                                                <a href="/billing?page=<%= pagination.page - 1 %><%= filters.serviceId ? '&serviceId=' + filters.serviceId : '' %><%= filters.hideFailed ? '&hideFailed=on' : '' %>" class="relative inline-flex items-center px-3 py-1 border border-slate-200 text-xs font-bold uppercase tracking-widest text-slate-600 bg-white hover:bg-slate-50 rounded"> Prev </a>
                                                                            <% } %>
                                                                            <% if (pagination.hasNext) { %>
                                                                                <a href="/billing?page=<%= pagination.page + 1 %><%= filters.serviceId ? '&serviceId=' + filters.serviceId : '' %><%= filters.hideFailed ? '&hideFailed=on' : '' %>" class="ml-3 relative inline-flex items-center px-3 py-1 border border-slate-200 text-xs font-bold uppercase tracking-widest text-slate-600 bg-white hover:bg-slate-50 rounded"> Next </a>
                                                                            <% } %>
                                                                        </div>
                                                                        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between font-mono">
                                                                            <div>
                                                                                <p class="text-[10px] sm:text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                                    Showing <span class="text-blue-600"><%= (pagination.page - 1) * pagination.limit + 1 %></span> - <span class="text-blue-600"><%= Math.min(pagination.page * pagination.limit, pagination.totalLogs) %></span> of <span class="text-blue-600"><%= pagination.totalLogs %></span> entries
                                                                                </p>
                                                                            </div>
                                                                            <div>
                                                                                <nav class="relative z-0 inline-flex rounded-md shadow-minimal -space-x-px" aria-label="Pagination">
                                                                                    <% if (pagination.hasPrev) { %>
                                                                                        <a href="/billing?page=<%= pagination.page - 1 %><%= filters.serviceId ? '&serviceId=' + filters.serviceId : '' %><%= filters.hideFailed ? '&hideFailed=on' : '' %>" class="relative inline-flex items-center px-2 py-2 rounded-l border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 transition-colors">
                                                                                            <i data-lucide="chevron-left" class="w-3 h-3"></i>
                                                                                        </a>
                                                                                    <% } %>
                                                                                    
                                                                                    <span class="relative inline-flex items-center px-3 py-1 border border-slate-200 bg-blue-50 text-xs font-bold text-blue-600">PAGE.0<%= pagination.page %> </span>
                                                                                    
                                                                                    <% if (pagination.hasNext) { %>
                                                                                        <a href="/billing?page=<%= pagination.page + 1 %><%= filters.serviceId ? '&serviceId=' + filters.serviceId : '' %><%= filters.hideFailed ? '&hideFailed=on' : '' %>" class="relative inline-flex items-center px-2 py-2 rounded-r border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 transition-colors">
                                                                                            <i data-lucide="chevron-right" class="w-3 h-3"></i>
                                                                                        </a>
                                                                                    <% } %>
                                                                                </nav>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Payment Methods Section -->
                                            <div id="content-payment-methods">
                                                <div class="minimal-card mb-6 overflow-hidden">
                                                    <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                                                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center">
                                                            <i data-lucide="credit-card" class="w-3 h-3 mr-2 text-slate-300"></i>
                                                            Active Payment Methods
                                                        </h3>
                                                        <a href="/billing/payment-methods/create"
                                                            class="bg-blue-600 hover:bg-blue-700 text-white text-[10px] sm:text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded transition-all flex items-center shadow-minimal">
                                                            <i data-lucide="plus" class="w-2.5 h-2.5 mr-1.5"></i>
                                                            Add Method
                                                        </a>
                                                    </div>
                                                    <div class="p-4">
                                                        <% if (paymentMethods.length===0) { %>
                                                            <div class="text-center py-10">
                                                                <i data-lucide="wallet" class="w-8 h-8 text-slate-200 mx-auto mb-3"></i>
                                                                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">No active payment protocols found</p>
                                                            </div>
                                                        <% } else { %>
                                                            <div class="space-y-3">
                                                                <% paymentMethods.forEach(method=> { %>
                                                                    <div class="p-3 bg-white rounded-lg border border-slate-200 flex items-center justify-between hover:border-blue-300 transition-all shadow-sm group">
                                                                        <div class="flex items-center">
                                                                            <div class="bg-white border border-slate-200 p-2 rounded shadow-sm mr-4">
                                                                                <i data-lucide="credit-card" class="w-4 h-4 text-slate-400"></i>
                                                                            </div>
                                                                            <div>
                                                                                <div class="flex items-center">
                                                                                    <p class="text-xs font-black text-slate-900 uppercase tracking-widest group-hover:text-blue-700 transition-colors">
                                                                                        <%= method.provider==='mock' ? 'SECURE_TRANSIT' : method.provider.toUpperCase() %> •••• <%= method.last4 %>
                                                                                    </p>
                                                                                    <% if (method.isDefault) { %>
                                                                                        <span class="ml-2 px-1.5 py-0.5 inline-flex text-[10px] font-bold bg-blue-100 text-blue-700 border border-blue-200 rounded uppercase tracking-widest">
                                                                                            Primary
                                                                                        </span>
                                                                                    <% } %>
                                                                                </div>
                                                                                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-0.5">
                                                                                    VAL_EXP: <span class="text-slate-700"><%= method.expiry %></span>
                                                                                </p>
                                                                            </div>
                                                                        </div>
                                                                        <div class="flex items-center space-x-2">
                                                                            <% if (!method.isDefault) { %>
                                                                                <form action="/billing/payment-methods/<%= method.id %>/default" method="POST" class="inline">
                                                                                    <button type="submit" class="text-[10px] sm:text-xs font-bold text-blue-600 hover:text-blue-700 uppercase tracking-widest px-2 py-1 rounded border border-blue-100 hover:bg-blue-50 transition-all">Make Primary</button>
                                                                                </form>
                                                                            <% } %>
                                                                                <form action="/billing/payment-methods/<%= method.id %>/delete" method="POST" class="inline" onsubmit="return confirm('DEREGISTER_PROTOCOL: Confirm critical system action?');">
                                                                                    <button type="submit" class="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded transition-all">
                                                                                        <i data-lucide="trash-2" class="w-3 h-3"></i>
                                                                                    </button>
                                                                                </form>
                                                                        </div>
                                                                    </div>
                                                                <% }); %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- Invoices Section -->
                                            <div id="content-invoices">
                                                <div class="minimal-card mb-6 overflow-hidden">
                                                    <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                                                        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest flex items-center">
                                                            <i data-lucide="file-text" class="w-3.5 h-3.5 mr-2 text-slate-300"></i>
                                                            Billing History
                                                        </h3>
                                                    </div>
                                                    <div class="p-0">
                                                        <% if (invoices.length===0) { %>
                                                            <div class="text-center py-10">
                                                                <i data-lucide="file-minus" class="w-8 h-8 text-slate-200 mx-auto mb-3"></i>
                                                                <p class="text-sm font-bold text-slate-400 uppercase tracking-widest">No billing documents found</p>
                                                            </div>
                                                        <% } else { %>
                                                            <div class="flex flex-col">
                                                                <div class="overflow-x-auto">
                                                                    <div class="align-middle inline-block min-w-full">
                                                                        <table class="min-w-full divide-y divide-slate-100">
                                                                            <thead class="bg-slate-50/50">
                                                                                <tr>
                                                                                    <th scope="col" class="px-4 py-2 text-left text-xs font-bold text-slate-400 uppercase tracking-widest">Date</th>
                                                                                    <th scope="col" class="px-4 py-2 text-left text-xs font-bold text-slate-400 uppercase tracking-widest">Plan / Service</th>
                                                                                    <th scope="col" class="px-4 py-2 text-left text-xs font-bold text-slate-400 uppercase tracking-widest">Amount</th>
                                                                                    <th scope="col" class="px-4 py-2 text-left text-xs font-bold text-slate-400 uppercase tracking-widest text-center">Status</th>
                                                                                    <th scope="col" class="px-4 py-2 text-left text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Download</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody class="bg-white divide-y divide-slate-50">
                                                                                <% invoices.forEach(invoice=> { %>
                                                                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                                                                        <td class="px-4 py-2 whitespace-nowrap text-xs font-medium text-slate-500">
                                                                                            <%= new Date(invoice.createdAt).toLocaleDateString() %>
                                                                                        </td>
                                                                                        <td class="px-4 py-2 whitespace-nowrap text-sm font-bold text-gray-700 uppercase tracking-tight">
                                                                                            <%= invoice.subscription && invoice.subscription.plan ? invoice.subscription.plan.name : 'On-Demand usage' %>
                                                                                        </td>
                                                                                        <td class="px-4 py-2 whitespace-nowrap text-sm font-mono font-bold text-gray-900">
                                                                                            <%= invoice.currency === 'GBP' ? '£' : '$' %><%= invoice.amount.toFixed(2) %>
                                                                                        </td>
                                                                                        <td class="px-4 py-2 whitespace-nowrap text-center">
                                                                                            <span class="px-1.5 py-0.5 inline-flex text-xs font-bold rounded border uppercase tracking-widest <%= invoice.status === 'paid' ? 'bg-green-50 text-green-700 border-green-100' : 'bg-red-50 text-red-700 border-red-100' %>">
                                                                                                <%= invoice.status %>
                                                                                            </span>
                                                                                        </td>
                                                                                        <td class="px-4 py-2 whitespace-nowrap text-right">
                                                                                            <a href="/billing/invoices/<%= invoice.id %>/download"
                                                                                                class="text-blue-600 hover:text-blue-700 transition-colors p-1.5 hover:bg-blue-50 rounded inline-flex items-center">
                                                                                                <i data-lucide="download" class="w-3.5 h-3.5"></i>
                                                                                            </a>
                                                                                        </td>
                                                                                    </tr>
                                                                                <% }); %>
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                    
                                                                    <!-- Invoice Pagination Controls -->
                                                                    <% if (invoicePagination.totalPages > 1) { %>
                                                                        <div class="px-4 py-3 flex items-center justify-between border-t border-slate-100 font-mono">
                                                                            <div class="flex-1 flex justify-between sm:hidden">
                                                                                <% if (invoicePagination.hasPrev) { %>
                                                                                    <a href="/billing?invoicePage=<%= invoicePagination.page - 1 %>" class="relative inline-flex items-center px-3 py-1 border border-slate-200 text-sm font-bold uppercase tracking-widest text-slate-600 bg-white hover:bg-slate-50 rounded"> Prev </a>
                                                                                <% } %>
                                                                                <% if (invoicePagination.hasNext) { %>
                                                                                    <a href="/billing?invoicePage=<%= invoicePagination.page + 1 %>" class="ml-3 relative inline-flex items-center px-3 py-1 border border-slate-200 text-sm font-bold uppercase tracking-widest text-slate-600 bg-white hover:bg-slate-50 rounded"> Next </a>
                                                                                <% } %>
                                                                            </div>
                                                                            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                                                                                <div>
                                                                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                                                        Showing <span class="text-blue-600"><%= (invoicePagination.page - 1) * invoicePagination.limit + 1 %></span> - <span class="text-blue-600"><%= Math.min(invoicePagination.page * invoicePagination.limit, invoicePagination.total) %></span> of <span class="text-blue-600"><%= invoicePagination.total %></span> entries
                                                                                    </p>
                                                                                </div>
                                                                                <div>
                                                                                    <nav class="relative z-0 inline-flex rounded shadow-minimal -space-x-px" aria-label="Pagination">
                                                                                        <% if (invoicePagination.hasPrev) { %>
                                                                                            <a href="/billing?invoicePage=<%= invoicePagination.page - 1 %>" class="relative inline-flex items-center px-2 py-2 rounded-l border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 transition-colors">
                                                                                                <i data-lucide="chevron-left" class="w-3.5 h-3.5"></i>
                                                                                            </a>
                                                                                        <% } %>
                                                                                        
                                                                                        <span class="relative inline-flex items-center px-3 py-1 border border-slate-200 bg-blue-50 text-sm font-bold text-blue-600"> Page <%= invoicePagination.page %> </span>
                                                                                        
                                                                                        <% if (invoicePagination.hasNext) { %>
                                                                                            <a href="/billing?invoicePage=<%= invoicePagination.page + 1 %>" class="relative inline-flex items-center px-2 py-2 rounded-r border border-slate-200 bg-white text-slate-400 hover:bg-slate-50 transition-colors">
                                                                                                <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
                                                                                            </a>
                                                                                        <% } %>
                                                                                    </nav>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    <% } %>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>

                        </div>
                    </main>
            </div>
    </div>
    <%- include('../partials/sidebar-script') %>
    <script nonce="<%= nonce %>">
        function switchTab(tab) {
            // Hide all
            document.getElementById('content-payment-methods').classList.add('hidden');
            document.getElementById('content-invoices').classList.add('hidden');
            document.getElementById('content-usage').classList.add('hidden');
            
            // Show selected
            document.getElementById('content-' + tab).classList.remove('hidden');

            // Apply Progress Bar Widths
            document.querySelectorAll('.progress-bar').forEach(bar => {
                const pct = bar.getAttribute('data-percentage');
                if (pct) bar.style.width = pct + '%';
            });
 
            // Reset tab styles
            const tabs = ['payment-methods', 'invoices', 'usage'];
            tabs.forEach(t => {
                const btn = document.getElementById('tab-' + t);
                btn.classList.remove('border-blue-600', 'text-blue-600');
                btn.classList.add('border-transparent', 'text-slate-400', 'hover:text-slate-600', 'hover:border-slate-300');
            });

            // Set active tab style
            const activeBtn = document.getElementById('tab-' + tab);
            activeBtn.classList.add('border-blue-600', 'text-blue-600');
            activeBtn.classList.remove('border-transparent', 'text-slate-400', 'hover:text-slate-600', 'hover:border-slate-300');
        }

        // Initialize from URL params if present (e.g., for pagination or navigation)
        const urlParams = new URLSearchParams(window.location.search);
        const activeTab = urlParams.get('tab') || 'usage'; // Default to usage
        switchTab(activeTab);

        // Initialize Icons
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
    </script>
</body>

</html>
