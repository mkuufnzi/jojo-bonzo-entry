<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head') %>
    <script src="https://js.stripe.com/v3/" nonce="<%= nonce %>"></script>
</head>

<body class="bg-gray-100">
    <div class="flex h-screen">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', {path: '/billing' }) %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col overflow-hidden md:ml-64 transition-all duration-300">
                <header class="bg-white/80 backdrop-blur-md border-b border-slate-100 z-10">
                    <div class="max-w-7xl mx-auto py-3 px-4 sm:px-6 lg:px-8 flex justify-between items-center">
                        <h1 class="text-[0.75rem] font-black text-gray-900 uppercase tracking-widest flex items-center">
                            <i data-lucide="plus-circle" class="w-3.5 h-3.5 mr-2 text-blue-600"></i>
                            Add Payment Method
                        </h1>
                        <a href="/billing" class="text-[0.625rem] font-bold text-slate-400 hover:text-blue-600 uppercase tracking-widest flex items-center transition-colors">
                            <i data-lucide="arrow-left" class="w-3 h-3 mr-1.5"></i>
                            Back to Billing
                        </a>
                    </div>
                </header>

                <main class="flex-1 overflow-x-hidden overflow-y-auto bg-slate-50/50">
                    <div class="max-w-md mx-auto px-4 py-10">

                        <% if (typeof error !=='undefined' && error) { %>
                            <div class="bg-red-50 border border-red-100 text-red-700 px-3 py-2 rounded text-[0.625rem] font-bold uppercase tracking-widest mb-6 flex items-center" role="alert">
                                <i data-lucide="alert-circle" class="w-3.5 h-3.5 mr-2"></i>
                                <%= error %>
                            </div>
                        <% } %>

                        <% const message=req.query && req.query.message ? req.query.message : null; %>

                        <% if (message) { %>
                            <div class="bg-blue-50 border border-blue-100 text-blue-700 px-3 py-2 rounded text-[0.625rem] font-bold uppercase tracking-widest mb-6 flex items-center" role="alert">
                                <i data-lucide="info" class="w-3.5 h-3.5 mr-2"></i>
                                <%= message %>
                            </div>
                        <% } %>

                        <div class="minimal-card overflow-hidden">
                            <div class="px-4 py-3 border-b border-slate-100 flex items-center bg-slate-50/50">
                                <h3 class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest">
                                    <i data-lucide="shield-check" class="w-3 h-3 mr-2 inline-block text-blue-600"></i>
                                    Secure Payment Setup
                                </h3>
                            </div>
                            <div class="p-4">
                                <form id="payment-form" action="/billing/payment-methods" method="POST">
                                    <div class="space-y-6">
                                        <div id="payment-element" class="bg-white p-2 rounded border border-slate-100 shadow-minimal">
                                            <!-- Stripe Elements -->
                                        </div>
                                        <div id="error-message" class="text-red-600 text-[0.625rem] font-bold uppercase tracking-widest hidden flex items-center">
                                            <i data-lucide="alert-triangle" class="w-3 h-3 mr-1.5"></i>
                                            <span id="error-text"></span>
                                        </div>

                                        <div>
                                            <button id="submit-button" class="w-full flex justify-center py-2 px-4 border border-transparent rounded bg-blue-600 hover:bg-blue-700 text-[0.625rem] font-bold text-white uppercase tracking-widest transition-all shadow-minimal disabled:opacity-50 disabled:cursor-not-allowed">
                                                <i data-lucide="save" class="w-3.5 h-3.5 mr-2" id="save-icon"></i>
                                                <span id="button-text">Add Payment Method</span>
                                            </button>
                                        </div>
                                    </div>
                                    <input type="hidden" name="paymentMethodId" id="paymentMethodId">
                                </form>
                            </div>
                        </div>

                    </div>
                </main>
            </div>
    </div>

    <script nonce="<%= nonce %>">
        const stripePublicKey = '<%= stripePublicKey %>';
        const clientSecret = '<%= clientSecret %>';

        if (!stripePublicKey) {
            document.getElementById('error-message').textContent = 'Stripe Public Key is missing. Please configure it in .env file.';
            document.getElementById('error-message').classList.remove('hidden');
            document.getElementById('submit-button').disabled = true;
        } else if (!clientSecret) {
            document.getElementById('error-message').textContent = 'Failed to initialize payment setup. Please try again.';
            document.getElementById('error-message').classList.remove('hidden');
            document.getElementById('submit-button').disabled = true;
        } else {
            const stripe = Stripe(stripePublicKey);
            const options = {
                clientSecret: clientSecret,
                appearance: {
                    theme: 'stripe',
                },
            };

            const elements = stripe.elements(options);
            const paymentElement = elements.create('payment');
            paymentElement.mount('#payment-element');

            const form = document.getElementById('payment-form');

            form.addEventListener('submit', async (event) => {
                event.preventDefault();

                const submitBtn = document.getElementById('submit-button');
                const btnText = document.getElementById('button-text');

                submitBtn.disabled = true;
                btnText.innerText = 'Processing...';

                const { error, setupIntent } = await stripe.confirmSetup({
                    elements,
                    confirmParams: {
                        return_url: window.location.origin + '/billing',
                    },
                    redirect: 'if_required'
                });

                if (error) {
                    const messageContainer = document.querySelector('#error-message');
                    const errorText = document.querySelector('#error-text');
                    errorText.textContent = error.message;
                    messageContainer.classList.remove('hidden');
                    submitBtn.disabled = false;
                    btnText.innerText = 'Register Protocol';
                    document.getElementById('save-icon').classList.remove('hidden');
                } else {
                    if (setupIntent && setupIntent.status === 'succeeded') {
                        const hiddenInput = document.getElementById('paymentMethodId');
                        hiddenInput.value = setupIntent.payment_method;
                        form.submit();
                    }
                }
            });
        }
    </script>
    <%- include('../partials/sidebar-script') %>
</body>

</html>
