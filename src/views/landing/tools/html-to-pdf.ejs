<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML to PDF Converter - Floovioo </title>
    <script src="https://cdn.tailwindcss.com" nonce="<%= nonce %>"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style nonce="<%= nonce %>">body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gray-50 text-gray-900">

    <%- include('../../partials/landing-nav') %>

    <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
                HTML to PDF Converter
            </h1>
            <p class="mt-4 text-lg text-gray-500 max-w-2xl mx-auto">
                The developer-friendly API for converting raw HTML, CSS, and web pages into high-fidelity PDFs.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
            <!-- Tool Demo -->
            <div class="bg-white rounded-lg shadow-xl overflow-hidden border border-gray-200">
                <div class="bg-gray-50 border-b border-gray-200 px-4 py-3 flex justify-between items-center">
                    <span class="text-sm font-medium text-gray-700">Live Demo</span>
                    <span class="text-xs text-gray-500">Free Guest Mode</span>
                </div>
                <div class="p-6">
                    <div id="tool-interface">
                        <label for="html-content" class="block text-sm font-medium text-gray-700 mb-2">Paste HTML Code</label>
                        <textarea id="html-content" rows="12" class="w-full shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm border-gray-300 rounded-md font-mono text-xs bg-gray-50 p-2" spellcheck="false"><!DOCTYPE html>
<html>
<head>
<style nonce="<%= nonce %>">
  body { font-family: sans-serif; padding: 40px; text-align: center; }
  h1 { color: #2563eb; }
  .box { border: 2px dashed #ccc; padding: 20px; border-radius: 8px; margin-top: 20px; }
</style>
</head>
<body>
  <h1>Hello from Flozino!</h1>
  <p>This PDF was generated from raw HTML.</p>
  <div class="box">
    <strong>Success!</strong> Your conversion works perfectly.
  </div>
</body>
</html></textarea>
                        
                        <div class="mt-4">
                            <button id="convert-btn" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 transition-colors">
                                Convert to PDF
                            </button>
                        </div>
                    </div>

                    <!-- Loading -->
                    <div id="loading-state" class="hidden py-12 text-center">
                         <svg class="animate-spin h-10 w-10 text-blue-600 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <p class="mt-4 text-gray-500 text-sm">Rendering PDF...</p>
                    </div>

                    <!-- Result -->
                    <div id="result-state" class="hidden py-6 text-center">
                        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-green-100 mb-4">
                            <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <h3 class="text-lg font-medium text-gray-900">PDF Ready!</h3>
                        <div class="mt-6 flex justify-center space-x-3">
                            <a id="download-link" href="#" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
                                Download
                            </a>
                            <button onclick="location.reload()" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                Reset
                            </button>
                        </div>
                    </div>
                     <!-- Error State -->
                    <div id="error-state" class="hidden py-6 text-center">
                        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100">
                            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </div>
                        <p id="error-message" class="mt-2 text-sm text-red-600">Something went wrong.</p>
                         <button onclick="location.reload()" class="mt-4 text-sm text-gray-600 underline">Try Again</button>
                    </div>
                </div>
            </div>

            <!-- Docs/Features -->
            <div class="space-y-8">
                <div>
                    <h3 class="text-lg font-medium text-gray-900 mb-4">Key Features</h3>
                    <ul class="space-y-4">
                        <li class="flex items-start">
                            <div class="flex-shrink-0">
                                <svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            </div>
                            <p class="ml-3 text-base text-gray-500">Full CSS3 Support (Flexbox, Grid, Custom Fonts)</p>
                        </li>
                        <li class="flex items-start">
                            <div class="flex-shrink-0">
                                <svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            </div>
                            <p class="ml-3 text-base text-gray-500">Javascript Execution included</p>
                        </li>
                        <li class="flex items-start">
                            <div class="flex-shrink-0">
                                <svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            </div>
                            <p class="ml-3 text-base text-gray-500">A4, Letter, Legal formats supported</p>
                        </li>
                        <li class="flex items-start">
                            <div class="flex-shrink-0">
                                <svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                            </div>
                            <p class="ml-3 text-base text-gray-500">REST API available</p>
                        </li>
                    </ul>
                </div>

                <div class="bg-gray-900 rounded-lg p-6">
                    <h3 class="text-white font-mono text-sm mb-4">API Usage Example</h3>
                    <pre class="text-gray-300 font-mono text-xs overflow-x-auto p-2 bg-gray-800 rounded">
curl -X POST https://api.afstools.com/pdf/convert \
  -H "X-API-Key: YOUR_KEY" \
  -H "Content-Type: application/json" \
  -d '{
    "html": "&lt;h1&gt;Invoice&lt;/h1&gt;",
    "format": "A4"
  }'</pre>
                    <div class="mt-4">
                        <a href="/docs" class="text-blue-400 hover:text-blue-300 text-sm font-medium">Read Documentation &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../../partials/footer') %>

    <script nonce="<%= nonce %>">
        const convertBtn = document.getElementById('convert-btn');
        const toolInterface = document.getElementById('tool-interface');
        const loadingState = document.getElementById('loading-state');
        const resultState = document.getElementById('result-state');
        const errorState = document.getElementById('error-state');
        const downloadLink = document.getElementById('download-link');
        const errorMessage = document.getElementById('error-message');

        if (convertBtn) {
            convertBtn.addEventListener('click', async () => {
                const htmlContent = document.getElementById('html-content').value;
                if (!htmlContent) {
                    showToast('Info', 'Enter HTML content', 'info');
                    return;
                }

                toolInterface.classList.add('hidden');
                loadingState.classList.remove('hidden');

                try {
                    const response = await fetch('/api/pdf/convert', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json', 
                            'X-Public-Guest-Token': 'guest-access-token'
                        },
                        body: JSON.stringify({ html: htmlContent })
                    });
                    if (!response.ok) throw new Error((await response.json()).error || 'Failed');
                    
                    const blob = await response.blob();
                    downloadLink.href = window.URL.createObjectURL(blob);
                    downloadLink.download = 'output.pdf';

                    loadingState.classList.add('hidden');
                    resultState.classList.remove('hidden');
                } catch (e) {
                    errorMessage.textContent = e.message;
                    loadingState.classList.add('hidden');
                    errorState.classList.remove('hidden');
                }
            });
        }
    </script>
    <%- include('../../partials/toast') %>
</body>
</html>
