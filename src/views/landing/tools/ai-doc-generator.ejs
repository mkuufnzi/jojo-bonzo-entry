<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= service.name %> - Floovioo </title>
    <script src="https://cdn.tailwindcss.com" nonce="<%= nonce %>"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style nonce="<%= nonce %>">
        body { font-family: 'Inter', sans-serif; }
        .gradient-text {
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-image: linear-gradient(to right, #2563eb, #7c3aed);
        }
        .hero-pattern {
            background-color: #ffffff;
            background-image: radial-gradient(#eff6ff 1px, transparent 1px);
            background-size: 24px 24px;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">

    <%- include('../../partials/landing-nav') %>

    <!-- Hero Section -->
    <div class="relative overflow-hidden bg-white hero-pattern border-b border-gray-100">
        <div class="max-w-7xl mx-auto">
            <div class="relative z-10 pb-8 bg-white/50 sm:pb-16 md:pb-20 lg:max-w-3xl lg:w-full lg:pb-28 xl:pb-32 pt-20 px-4 sm:px-6 lg:px-8">
                <main class="mt-10 mx-auto max-w-7xl sm:mt-12 md:mt-16 lg:mt-20 xl:mt-28">
                    <div class="sm:text-center lg:text-left">
                        <div class="inline-flex items-center px-4 py-2 rounded-full border border-blue-100 bg-blue-50 text-blue-700 text-sm font-medium mb-6">
                            <span class="flex h-2 w-2 rounded-full bg-blue-600 mr-2"></span>
                            Now with Jiozini Intelligence
                        </div>
                        <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                            <span class="block xl:inline">Generate Documents</span>
                            <span class="block gradient-text">at the Speed of Thought</span>
                        </h1>
                        <p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
                            Create professional invoices, contracts, resumes, and reports instantly using advanced AI. Just describe what you need, and we handles the formatting and design.
                        </p>
                        <div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
                            <div class="rounded-md shadow">
                                <a href="/auth/register" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg transition-all hover:shadow-lg hover:-translate-y-0.5">
                                    Start Generating Free
                                </a>
                            </div>
                            <div class="mt-3 sm:mt-0 sm:ml-3">
                                <a href="#how-it-works" class="w-full flex items-center justify-center px-8 py-3 border border-gray-300 text-base font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 md:py-4 md:text-lg">
                                    View Examples
                                </a>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </div>
        <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2 bg-gray-50 flex items-center justify-center overflow-hidden">
            <div class="relative w-full h-[37.5rem] transform scale-90 origin-center rotate-2 hover:rotate-0 transition-transform duration-500">
                 <!-- Mockup of App Interface -->
                 <div class="absolute inset-0 bg-white rounded-xl shadow-2xl border border-gray-200 overflow-hidden m-8">
                     <div class="bg-gray-50 border-b border-gray-200 p-4 flex items-center gap-2">
                         <div class="w-3 h-3 rounded-full bg-red-400"></div>
                         <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                         <div class="w-3 h-3 rounded-full bg-green-400"></div>
                         <div class="ml-4 bg-white rounded px-3 py-1 text-xs text-gray-400 flex-1">ai-doc-generator.afstools.com</div>
                     </div>
                     <div class="p-8 flex gap-6 h-full">
                         <div class="w-1/3 space-y-4">
                             <div class="h-4 bg-gray-100 rounded w-1/2"></div>
                             <div class="space-y-2">
                                 <div class="h-24 bg-blue-50 rounded border border-blue-100 p-2 text-xs text-blue-800">
                                     "Create a modern invoice for a web design project ($5,000) for client Acme Corp."
                                 </div>
                             </div>
                             <div class="h-8 bg-blue-600 rounded"></div>
                         </div>
                         <div class="w-2/3 shadow-lg border border-gray-100 rounded bg-white p-6 transform scale-95 origin-top-left">
                             <div class="flex justify-between items-start mb-8">
                                 <div>
                                    <div class="h-6 w-32 bg-gray-800 mb-2"></div>
                                    <div class="h-2 w-48 bg-gray-200"></div>
                                 </div>
                                 <div class="text-right">
                                     <div class="h-8 w-20 bg-blue-100 rounded mb-2 text-center text-blue-800 font-bold flex items-center justify-center text-xs">INVOICE</div>
                                 </div>
                             </div>
                             <div class="space-y-4">
                                 <div class="flex justify-between border-b pb-2">
                                     <div class="w-1/2 h-4 bg-gray-100"></div>
                                     <div class="w-1/4 h-4 bg-gray-100"></div>
                                 </div>
                                 <div class="flex justify-between">
                                    <div class="w-1/2 h-4 bg-gray-100"></div>
                                    <div class="w-1/4 h-4 bg-gray-100"></div>
                                </div>
                             </div>
                         </div>
                     </div>
                 </div>
            </div>
        </div>
    </div>

    <!-- Features Grid -->
    <div id="how-it-works" class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="text-base text-blue-600 font-semibold tracking-wide uppercase">Capabilities</h2>
                <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                    Everything you need to create perfect docs
                </p>
                <p class="mt-4 max-w-2xl text-xl text-gray-500 lg:mx-auto">
                    Stop fighting with formatting. Let our AI handle the layout, design, and content structure.
                </p>
            </div>

            <div class="mt-20">
                <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
                    <div class="pt-6">
                        <div class="flow-root bg-gray-50 rounded-2xl px-6 pb-8">
                            <div class="-mt-6">
                                <div>
                                    <span class="inline-flex items-center justify-center p-3 bg-blue-600 rounded-md shadow-lg">
                                        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                                    </span>
                                </div>
                                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">Instant Generation</h3>
                                <p class="mt-5 text-base text-gray-500">
                                    Generate complex documents in seconds. Just type a prompt like "Create a sales contract for a used car" and watch the magic.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="pt-6">
                        <div class="flow-root bg-gray-50 rounded-2xl px-6 pb-8">
                            <div class="-mt-6">
                                <div>
                                    <span class="inline-flex items-center justify-center p-3 bg-purple-600 rounded-md shadow-lg">
                                        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
                                    </span>
                                </div>
                                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">Professional Formatting</h3>
                                <p class="mt-5 text-base text-gray-500">
                                    Outputs clean, semantic HTML and pixel-perfect PDFs. No more broken layouts or messy Word docs.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="pt-6">
                        <div class="flow-root bg-gray-50 rounded-2xl px-6 pb-8">
                            <div class="-mt-6">
                                <div>
                                    <span class="inline-flex items-center justify-center p-3 bg-green-600 rounded-md shadow-lg">
                                        <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                                    </span>
                                </div>
                                <h3 class="mt-8 text-lg font-medium text-gray-900 tracking-tight">Export to PDF</h3>
                                <p class="mt-5 text-base text-gray-500">
                                    One-click export to standard A4 or Letter PDFs. Ready to email, print, or sign immediately.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Use Cases/Templates -->
    <div class="bg-gray-900 py-24">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-extrabold text-white sm:text-4xl">What can you build?</h2>
                <p class="mt-4 text-xl text-gray-400">Our AI understands context for dozens of document types.</p>
            </div>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">📄</div>
                    <h3 class="text-white font-bold">Resumes</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">🧾</div>
                    <h3 class="text-white font-bold">Invoices</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">🤝</div>
                    <h3 class="text-white font-bold">Contracts</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">📊</div>
                    <h3 class="text-white font-bold">Reports</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">📝</div>
                    <h3 class="text-white font-bold">Cover Letters</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">📜</div>
                    <h3 class="text-white font-bold">Certificates</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">✉️</div>
                    <h3 class="text-white font-bold">Newsletters</h3>
                </div>
                <div class="bg-gray-800 rounded-lg p-6 text-center hover:bg-gray-700 transition">
                    <div class="text-4xl mb-4">...</div>
                    <h3 class="text-white font-bold">And More</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-blue-700">
        <div class="max-w-2xl mx-auto text-center py-16 px-4 sm:py-20 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-extrabold text-white sm:text-4xl">
                <span class="block">Ready to get started?</span>
                <span class="block">Create your first document today.</span>
            </h2>
            <p class="mt-4 text-lg leading-6 text-blue-200">
                Join thousands of users automating their paperwork with Floovioo .
            </p>
            <a href="/auth/register" class="mt-8 w-full inline-flex items-center justify-center px-5 py-3 border border-transparent text-base font-medium rounded-md text-blue-600 bg-white hover:bg-blue-50 sm:w-auto">
                Sign up for free
            </a>
        </div>
    </div>
    
    <%- include('../../partials/footer') %>

</body>
</html>
