<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Automation For SMEs - Streamline Your Business</title>
    <script src="https://cdn.tailwindcss.com" nonce="<%= nonce %>"></script>
</head>

<body class="bg-white font-sans text-gray-900">

    <%- include('../partials/navbar') %>

        <!-- Hero Section -->
        <div class="relative bg-green-50 overflow-hidden">
            <div class="max-w-7xl mx-auto">
                <div class="relative z-10 pb-8 bg-green-50 sm:pb-16 md:pb-20 lg:max-w-2xl lg:w-full lg:pb-28 xl:pb-32">
                    <main class="mt-10 mx-auto max-w-7xl px-4 sm:mt-12 sm:px-6 md:mt-16 lg:mt-20 lg:px-8 xl:mt-28">
                        <div class="sm:text-center lg:text-left">
                            <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                                <span class="block xl:inline">Automation For SMEs</span>
                                <span class="block text-green-600">Streamline your business</span>
                            </h1>
                            <p
                                class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
                                Automate repetitive tasks, manage workflows, and save hours every week. Designed
                                specifically for small and medium enterprises.
                            </p>
                            <div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
                                <div class="rounded-md shadow">
                                    <a href="https://blog.automation-for-smes.com" target="_blank"
                                        class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700 md:py-4 md:text-lg md:px-10">
                                        Automate Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </main>
                </div>
            </div>
            <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
                <img class="h-56 w-full object-cover sm:h-72 md:h-96 lg:w-full lg:h-full"
                    src="https://images.unsplash.com/photo-1518432031352-d6fc5c10da5a?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                    alt="Automation">
            </div>
        </div>

        <!-- Features -->
        <div class="py-12 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="lg:text-center">
                    <h2 class="text-base text-green-600 font-semibold tracking-wide uppercase">Features</h2>
                    <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                        Efficiency at scale
                    </p>
                </div>
                <div class="mt-10">
                    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">
                        <div class="p-6 bg-gray-50 rounded-lg">
                            <h3 class="text-lg font-medium text-gray-900">Workflow Builder</h3>
                            <p class="mt-2 text-base text-gray-500">Drag-and-drop interface to create workflows.</p>
                        </div>
                        <div class="p-6 bg-gray-50 rounded-lg">
                            <h3 class="text-lg font-medium text-gray-900">Integrations</h3>
                            <p class="mt-2 text-base text-gray-500">Connect with your favorite tools (Slack, Gmail,
                                etc.).</p>
                        </div>
                        <div class="p-6 bg-gray-50 rounded-lg">
                            <h3 class="text-lg font-medium text-gray-900">Analytics</h3>
                            <p class="mt-2 text-base text-gray-500">Track time saved and efficiency gains.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

</body>

</html>
