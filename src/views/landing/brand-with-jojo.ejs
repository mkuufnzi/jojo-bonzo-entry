<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brand With Jojo - Elevate Your Identity</title>
    <link rel="stylesheet" href="/assets/css/style.css" nonce="<%= nonce %>">
</head>
<body class="bg-white font-sans text-gray-900">

    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <div class="relative bg-pink-50 overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="relative z-10 pb-8 bg-pink-50 sm:pb-16 md:pb-20 lg:max-w-2xl lg:w-full lg:pb-28 xl:pb-32">
                <main class="mt-10 mx-auto max-w-7xl px-4 sm:mt-12 sm:px-6 md:mt-16 lg:mt-20 lg:px-8 xl:mt-28">
                    <div class="sm:text-center lg:text-left">
                        <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                            <span class="block xl:inline">Brand With Jojo</span>
                            <span class="block text-pink-600">Elevate your identity</span>
                        </h1>
                        <p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
                            Create stunning brand assets, visual identities, and marketing materials that resonate with your audience. Powered by AI and expert design principles.
                        </p>
                        <div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
                            <div class="rounded-md shadow">
                                <a href="https://brandwithjojo.com" target="_blank" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-pink-600 hover:bg-pink-700 md:py-4 md:text-lg md:px-10">
                                    Start Branding
                                </a>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </div>
        <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
            <img class="h-56 w-full object-cover sm:h-72 md:h-96 lg:w-full lg:h-full" src="https://images.unsplash.com/photo-1493612276216-ee3925520721?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80" alt="Branding">
        </div>
    </div>

    <!-- Features -->
    <div class="py-12 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="lg:text-center">
                <h2 class="text-base text-pink-600 font-semibold tracking-wide uppercase">Features</h2>
                <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                    Design made simple
                </p>
            </div>
            <div class="mt-10">
                <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">
                    <div class="p-6 bg-gray-50 rounded-lg">
                        <h3 class="text-lg font-medium text-gray-900">Logo Generation</h3>
                        <p class="mt-2 text-base text-gray-500">Create unique logos in seconds.</p>
                    </div>
                    <div class="p-6 bg-gray-50 rounded-lg">
                        <h3 class="text-lg font-medium text-gray-900">Brand Kits</h3>
                        <p class="mt-2 text-base text-gray-500">Consistent colors and fonts for your brand.</p>
                    </div>
                    <div class="p-6 bg-gray-50 rounded-lg">
                        <h3 class="text-lg font-medium text-gray-900">Social Media Assets</h3>
                        <p class="mt-2 text-base text-gray-500">Ready-to-post images for all platforms.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
