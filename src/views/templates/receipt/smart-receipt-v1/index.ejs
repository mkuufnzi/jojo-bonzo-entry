<% layout('layouts/document-master') %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<% block('head').append(`
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
`) %>

<%- include('../../../components/logic/smart-document-logic') %>

<!-- Template Interface -->
<div class="font-sans text-slate-800 antialiased">
    
    <div class="max-w-[800px] mx-auto px-8 py-12">
        
        <!-- Section: Header -->
        <div class="doc-section mb-8">
            <%- include('./components/header') %>
        </div>

        <!-- Section: Transaction Details -->
        <div class="doc-section mb-8">
            <%- include('./components/transaction_details') %>
        </div>

        <!-- Section: Line Items (Splittable) -->
        <div class="doc-section mb-8" data-split="true">
            <%- include('./components/line_items') %>
        </div>

        <!-- Section: Financial Summary -->
        <div class="doc-section mb-8">
            <%- include('./components/financial_summary') %>
        </div>

        <!-- Section: Loyalty Widgets -->
        <% if (branding.components?.loyalty_program?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('../../../components/smart-widgets/loyalty') %>
            </div>
        <% } %>

        <!-- Section: Discount Widgets -->
        <% if (branding.components?.discount_offer?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('../../../components/smart-widgets/discount') %>
            </div>
        <% } %>

        <!-- Section: Review Request -->
        <% if (branding.components?.review_request?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('../../../components/smart-widgets/review') %>
            </div>
        <% } %>

        <!-- Section: Referral Program -->
        <% if (branding.components?.referral_program?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('../../../components/smart-widgets/referral') %>
            </div>
        <% } %>

        <!-- Section: Support Links -->
        <% if (branding.components?.customer_support?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('../../../components/smart-widgets/support-links') %>
            </div>
        <% } %>

        <!-- Section: Footer -->
        <div class="doc-section mt-12">
            <%- include('./components/footer') %>
        </div>

    </div>
</div>
