<% layout('layouts/document-master') %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<% block('head').append(`
    <style>
        body { font-family: 'Outfit', sans-serif; }
    </style>
`) %>

<%- include('../../components/logic/smart-document-logic') %>

<!-- Template Interface -->
<div class="font-sans text-slate-800 antialiased">

    <!-- Section: Cover Page -->
    <div class="doc-section h-full">
        <%- include('./components/cover_page') %>
    </div>

    <!-- Container for Detailed Proposal Content -->
    <div class="max-w-4xl mx-auto px-16 py-12">
        
        <!-- Section: Executive Summary -->
        <div class="doc-section mb-12">
            <%- include('./components/executive_summary') %>
        </div>

        <!-- Section: Investment -->
        <div class="doc-section mb-12">
            <%- include('./components/investment') %>
        </div>

        <!-- Section: Product Support (Splittable) -->
        <% if (branding.components?.product_support?.enabled) { %>
            <div class="doc-section mb-12" data-split="true">
                <%- include('../../../components/smart-widgets/tutorials') %>
            </div>
        <% } %>

        <!-- Section: Signatures -->
        <div class="doc-section">
            <%- include('./components/signatures') %>
        </div>

    </div>
</div>
