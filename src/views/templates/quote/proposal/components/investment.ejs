<!-- Investment Outline -->
<h2 class="text-3xl font-bold mb-8 text-indigo-900 border-b border-indigo-100 pb-4">Investment Outline</h2>

<div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 mb-12">
    <% (branding.model?.items || []).forEach(item => { %>
    <div class="flex items-center justify-between py-4 border-b border-slate-200 last:border-0 last:pb-0 first:pt-0">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 shrink-0">
                <%- include('../../../../partials/common/smart-image', { 
                    src: item.img, 
                    alt: item.name, 
                    className: 'w-10 h-10 rounded border border-indigo-100 flex items-center justify-center bg-indigo-50/30',
                    size: 'sm',
                    fallback: '📦'
                }) %>
            </div>
            <div>
                <h4 class="font-bold text-lg text-slate-900"><%= item.name %></h4>
                <p class="text-sm text-slate-500"><%= item.category || 'Service' %> • Qty: <%= item.qty %></p>
            </div>
        </div>
        <div class="text-right">
            <span class="block font-bold text-lg text-slate-900">$<%= (item.price * item.qty).toFixed(2) %></span>
            <% if (item.qty > 1) { %>
                <span class="text-xs text-slate-400">$<%= item.price %> each</span>
            <% } %>
        </div>
    </div>
    <% }); %>
    
    <div class="mt-8 pt-8 border-t border-slate-200 flex justify-between items-center">
        <span class="text-xl font-bold text-slate-700">Estimated Total</span>
        <span class="text-4xl font-black text-indigo-600">$<%= branding.model.total.toFixed(2) %></span>
    </div>
</div>
