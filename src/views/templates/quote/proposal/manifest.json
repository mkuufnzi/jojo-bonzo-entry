        {
            "id": "product_recommendations",
            "name": "Optional Extras",
            "type": "toggle",
            "required": false,
            "defaultEnabled": true,
            "badge": "Upsell"
        },
        {
            "id": "marketing_banner",
            "name": "Marketing Message",
            "type": "toggle",
            "required": false,
            "defaultEnabled": false
        },
        {
            "id": "footer",
            "name": "Proposal Footer",
