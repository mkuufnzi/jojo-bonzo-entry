<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice #<%= branding.model.id %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lato', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Playfair Display', serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen py-10 px-4">

    <div class="max-w-4xl mx-auto bg-white shadow-lg p-12 min-h-[1000px] border-t-8 border-gray-800">
        
        <!-- Header -->
        <div class="flex justify-between items-start mb-16">
            <div>
                <% if (branding.themeData.logo) { %>
                    <div class="text-4xl mb-4"><%= branding.themeData.logo %></div>
                <% } %>
                <h1 class="text-3xl font-bold text-gray-900"><%= branding.themeData.name %></h1>
                <p class="text-sm text-gray-500 mt-1">Professional Services</p>
            </div>
            <div class="text-right">
                <h2 class="text-5xl font-bold text-gray-200 uppercase tracking-widest mb-4">Invoice</h2>
                <div class="space-y-1 text-sm text-gray-600">
                    <p><span class="font-bold w-24 inline-block text-gray-900">Invoice No:</span> #<%= branding.model.id %></p>
                    <p><span class="font-bold w-24 inline-block text-gray-900">Date:</span> <%= new Date().toLocaleDateString() %></p>
                    <p><span class="font-bold w-24 inline-block text-gray-900">Due Date:</span> <%= new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toLocaleDateString() %></p>
                </div>
            </div>
        </div>

        <!-- Addresses -->
        <div class="flex justify-between mb-16 border-b border-gray-200 pb-8">
            <div class="w-1/3">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">Bill To</h3>
                <p class="font-bold text-gray-900 text-lg">Sarah Mitchell</p>
                <p class="text-gray-600">sarah.mitchell@email.com</p>
                <p class="text-gray-600">123 Client Avenue</p>
                <p class="text-gray-600">New York, NY 10001</p>
            </div>
            <div class="w-1/3 text-right">
                <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3">From</h3>
                <p class="font-bold text-gray-900"><%= branding.themeData.name %></p>
                <p class="text-gray-600">456 Business Rd</p>
                <p class="text-gray-600">San Francisco, CA 94107</p>
            </div>
        </div>

        <!-- Line Items -->
        <div class="mb-12">
            <table class="w-full">
                <thead>
                    <tr class="border-b-2 border-gray-800">
                        <th class="text-left py-4 px-2 font-bold text-gray-900 w-1/2">Description</th>
                        <th class="text-center py-4 px-2 font-bold text-gray-900">Quantity</th>
                        <th class="text-right py-4 px-2 font-bold text-gray-900">Unit Price</th>
                        <th class="text-right py-4 px-2 font-bold text-gray-900">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <% branding.model.items.forEach((item, index) => { %>
                    <tr class="<%= index % 2 === 0 ? 'bg-gray-50' : 'bg-white' %> border-b border-gray-100">
                        <td class="py-4 px-2">
                            <span class="font-bold text-gray-800 block"><%= item.name %></span>
                            <span class="text-xs text-gray-500"><%= item.category %></span>
                        </td>
                        <td class="py-4 px-2 text-center text-gray-600"><%= item.qty %></td>
                        <td class="py-4 px-2 text-right text-gray-600">$<%= item.price.toFixed(2) %></td>
                        <td class="py-4 px-2 text-right font-bold text-gray-900">$<%= (item.price * item.qty).toFixed(2) %></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>

        <!-- Totals -->
        <div class="flex justify-end mb-16">
            <div class="w-1/2 lg:w-1/3 space-y-3">
                <div class="flex justify-between text-gray-600">
                    <span>Subtotal</span>
                    <span>$<%= branding.model.subtotal.toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-gray-600">
                    <span>Tax (8%)</span>
                    <span>$<%= branding.model.tax.toFixed(2) %></span>
                </div>
                <div class="flex justify-between text-2xl font-bold text-gray-900 pt-4 border-t-2 border-gray-800">
                    <span>Total Due</span>
                    <span>$<%= branding.model.total.toFixed(2) %></span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="text-center text-gray-500 text-sm border-t border-gray-200 pt-8">
            <p class="italic mb-2">"Great things in business are never done by one person."</p>
            <p class="font-bold text-gray-900"><%= branding.themeData.tagline %></p>
        </div>

    </div>

</body>
</html>
