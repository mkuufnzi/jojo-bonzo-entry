<% layout('layouts/document-master') %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<% block('head').append(`
    <style>
        body { font-family: 'Lato', sans-serif; }
        h1, h2, h3, h4, h5, h6 { font-family: 'Playfair Display', serif; }
        
        /* Classic Specific Section Padding */
        .classic-container {
            padding: 3rem; /* Re-adding the p-12 equivalent from the old wrapper */
        }
    </style>
`) %>

<%- include('../../../components/logic/smart-document-logic') %>

<!-- Template Interface -->
<div class="font-sans text-slate-800 antialiased classic-container">

    <!-- Section: Header -->
    <div class="doc-section mb-10 border-t-8 border-gray-800 pt-8">
        <%- include('./components/header') %>
    </div>

    <!-- Section: Addresses -->
    <div class="doc-section mb-10">
        <%- include('./components/addresses') %>
    </div>

    <!-- Section: Line Items (Splittable) -->
    <div class="doc-section mb-10" data-split="true">
        <%- include('./components/line_items') %>
    </div>

    <!-- Section: Recommendations (Splittable) -->
    <% if (branding.components?.product_recommendations?.enabled) { %>
        <div class="doc-section mb-10" data-split="true">
            <%- include('../../../components/smart-widgets/product-recommendations') %>
        </div>
    <% } %>

    <!-- Section: Totals -->
    <div class="doc-section mb-10">
        <%- include('./components/totals') %>
    </div>

    <!-- Section: Marketing Banner -->
    <% if (branding.components?.marketing_banner?.enabled) { %>
        <div class="doc-section mb-10">
            <%- include('../../../components/smart-widgets/banner') %>
        </div>
    <% } %>

    <!-- Section: Footer -->
    <div class="doc-section pt-10 mt-auto">
        <%- include('./components/footer') %>
    </div>

</div>
