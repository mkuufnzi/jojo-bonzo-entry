<!-- Header -->
<div class="flex justify-between items-start mb-16">
    <div>
        <div class="mb-4">
            <template x-if="theme.logoUrl">
                <img :src="theme.logoUrl" alt="Logo" class="h-12 w-auto object-contain">
            </template>
            <template x-if="!theme.logoUrl">
                <div class="text-4xl font-serif font-bold text-gray-800" x-text="theme.name"></div>
            </template>
        </div>
        <h1 class="text-3xl font-bold text-gray-900"><%= branding.themeData.name %></h1>
        <p class="text-sm text-gray-500 mt-1">Professional Services</p>
    </div>
    <div class="text-right">
        <h2 class="text-5xl font-bold text-gray-200 uppercase tracking-widest mb-4">Invoice</h2>
        <div class="space-y-1 text-sm text-gray-600">
            <p><span class="font-bold w-24 inline-block text-gray-900">Invoice No:</span> #<%= branding.model.id %></p>
            <p><span class="font-bold w-24 inline-block text-gray-900">Date:</span> <%= new Date().toLocaleDateString() %></p>
            <p><span class="font-bold w-24 inline-block text-gray-900">Due Date:</span> <%= new Date(Date.now() + 14 * 24 * 60 * 60 * 1000).toLocaleDateString() %></p>
        </div>
    </div>
</div>
