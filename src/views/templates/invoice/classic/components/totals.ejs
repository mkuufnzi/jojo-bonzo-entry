<!-- Totals -->
<div class="flex justify-end mb-16">
    <div class="w-1/2 lg:w-1/3 space-y-3">
        <div class="flex justify-between text-gray-600">
            <span>Subtotal</span>
            <span>$<%= branding.model.subtotal.toFixed(2) %></span>
        </div>
        <div class="flex justify-between text-gray-600">
            <span>Tax (8%)</span>
            <span>$<%= branding.model.tax.toFixed(2) %></span>
        </div>
        <div class="flex justify-between text-2xl font-bold text-gray-900 pt-4 border-t-2 border-gray-800">
            <span>Total Due</span>
            <span>$<%= branding.model.total.toFixed(2) %></span>
        </div>
    </div>
</div>
