<% layout('layouts/document-master') %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<%- include('../../../components/logic/smart-document-logic') %>

<!-- Template Interface -->
<div class="font-sans text-slate-800 antialiased">
    
    <!-- Page Overlay: Fixed background ignored by Paginator flow -->
    <div data-page-overlay class="fixed inset-0 pointer-events-none z-0" 
         :style="'background: ' + theme.pattern"></div>

    <!-- Section: Header (Full Width) -->
    <div class="doc-section relative z-10 w-full mb-8 shadow-sm">
        <%- include('./components/header') %>
    </div>

    <!-- Container for Constrained Content -->
    <div class="doc-section max-w-[780px] mx-auto px-8 pb-12">
        
        <!-- Section: Marketing Banner -->
        <% if (branding.components?.marketing_banner?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('../../../components/smart-widgets/banner') %>
            </div>
        <% } %>

        <!-- Section: Customer Info -->
        <div class="doc-section mb-6">
            <%- include('./components/customer_info') %>
        </div>

        <!-- Section: Line Items -->
        <div class="doc-section mb-8">
            <%- include('./components/line_items') %>
        </div>

        <!-- Section: Recommendations (Splittable) -->
        <% if (branding.components?.product_recommendations?.enabled) { %>
            <div class="doc-section mb-8" data-split="true">
                <%- include('../../../components/smart-widgets/product-recommendations') %>
            </div>
        <% } %>

        <!-- Section: Product Support (Splittable) -->
        <% if (branding.components?.product_support?.enabled) { %>
            <div class="doc-section mb-8" data-split="true">
                <%- include('../../../components/smart-widgets/tutorials') %>
            </div>
        <% } %>

        <!-- Section: Payment Details -->
        <% if (branding.components?.payment_details?.enabled) { %>
             <div class="doc-section mb-8">
                <%- include('../../../components/smart-widgets/payment-details') %>
             </div>
        <% } %>

        <!-- Section: Feedback/Support -->
        <% if (branding.components?.customer_support?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('../../../components/smart-widgets/support-card') %>
            </div>
        <% } %>

        <!-- Section: Footer -->
        <div class="doc-section mt-auto">
            <%- include('./components/footer') %>
        </div>
    </div>
</div>
