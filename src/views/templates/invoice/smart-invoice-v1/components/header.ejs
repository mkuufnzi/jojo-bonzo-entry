<!-- Header Banner -->
<div class="relative px-6 py-6 rounded-2xl overflow-hidden shadow-sm z-10" 
     :style="'background: ' + theme.gradient">
    <!-- Decorative Circles -->
    <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full bg-white/10"></div>
    <div class="absolute -bottom-5 left-16 w-24 h-24 rounded-full bg-white/5"></div>
    
    <div class="relative flex justify-between items-start text-white z-10">
        <div>
            <div class="flex items-center gap-3 mb-1.5">
                <!-- Logo with robust fallback -->
                <div class="flex-shrink-0">
                    <template x-if="theme.logoUrl">
                        <img :src="theme.logoUrl" alt="Logo" class="h-10 w-10 object-contain rounded-full bg-white p-1">
                    </template>
                    <template x-if="!theme.logoUrl">
                        <div class="flex items-center justify-center h-10 w-10 bg-white/20 rounded-full font-bold text-lg" 
                             x-text="(theme.name || 'B').charAt(0)"></div>
                    </template>
                </div>
                
                <div>
                    <div class="text-xl font-bold tracking-wide font-sans" x-text="theme.name"></div>
                    <div class="text-[10.5px] tracking-[0.15em] uppercase opacity-70 font-sans" x-text="theme.tagline"></div>
                </div>
            </div>
        </div>
        <div class="text-right">
            <div class="text-[10px] uppercase tracking-[0.15em] opacity-60 font-sans">Invoice</div>
            <%
                /**
                 * DATA SOURCE PRIORITY (Header Metadata):
                 * 1. branding.model.invoiceMeta – The normalized model (Priority #1)
                 * 2. invoiceData (raw)          – Legacy/Fallback raw payload
                 */
                const meta = branding.model?.invoiceMeta || {};
                const docNum = meta.docNumber || invoiceData?.DocNumber || invoiceData?.Id || '';
                const rawDate = meta.txnDate || invoiceData?.TxnDate || '';
                
                // Human-readable date formatting (e.g., "Feb 1, 2025")
                let displayDate = rawDate;
                try {
                    if (rawDate && rawDate.match && rawDate.match(/^\d{4}-\d{2}-\d{2}/)) {
                        displayDate = new Date(rawDate + 'T00:00:00').toLocaleDateString('en-US', { 
                            year: 'numeric', month: 'short', day: 'numeric' 
                        });
                    }
                } catch(e) { /* use raw if formatting fails */ }
            %>
            <div class="text-2xl font-bold font-sans">#INV-<%= docNum %></div>
            <div class="text-[10.5px] mt-0.5 opacity-60 font-sans"><%= displayDate %></div>
        </div>
    </div>
</div>

