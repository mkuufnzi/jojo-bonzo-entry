<!-- FOOTER -->
<%
    const theme = (branding.themeData || branding.theme) || {};
    const customerName = (branding.model?.customerName) || 'Valued Customer';
%>
<div class="mt-7 bg-white rounded-xl p-6 text-center shadow-sm font-sans">
    <!-- Logo fallback logic -->
    <div class="mb-2">
        <% if (theme.logoUrl) { %>
            <img src="<%= theme.logoUrl %>" alt="Logo" class="h-8 w-auto mx-auto object-contain">
        <% } else { %>
            <div class="w-10 h-10 bg-slate-100 rounded-full flex items-center justify-center mx-auto text-slate-400 font-bold text-lg">
                <%= (theme.name || 'B').charAt(0) %>
            </div>
        <% } %>
    </div>
    <div class="text-[13px] font-bold mt-1.5" style="<%= 'color: ' + (theme.text || '#1e293b') %>">
        Thank you for your order, <span><%= customerName %></span>!
    </div>
    <div class="text-[11px] text-gray-400 mt-1 max-w-xs mx-auto leading-relaxed">
        We appreciate your business at <strong style="<%= 'color: ' + (theme.primary || '#6366f1') %>"><%= theme.name || 'Our Store' %></strong>.
    </div>
    
    <div class="flex justify-center gap-2.5 mt-4 flex-wrap">
        <% if (branding?.model?.portal_url) { %>
            <a href="<%= branding.model.portal_url %>" 
               target="_blank"
               class="px-4 py-2 rounded-lg text-[11px] font-bold text-white border-0 decoration-none flex items-center gap-1.5"
               style="<%= 'background: ' + (theme.gradient || 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)') %>">
                <span>🌐</span> <span>View Interactive Version</span>
            </a>
        <% } %>
        <button class="px-4 py-2 rounded-lg text-[11px] font-bold bg-transparent border-2"
                style="<%= 'border-color: ' + (theme.accent || '#c4b5fd') + '; color: ' + (theme.primary || '#6366f1') %>">
            Share &amp; Earn
        </button>
    </div>
</div>

<div class="text-center mt-5 text-[9.5px] text-gray-400 font-sans">
     Smart Invoice Engine v2.1 · Personalized recommendations · Brand-themed delivery
</div>
