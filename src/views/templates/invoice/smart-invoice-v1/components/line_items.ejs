<!-- Line Items -->
<div class="mt-1">
    <table class="w-full border-collapse">
        <thead>
            <tr class="border-b-2" :style="'border-color: ' + theme.accent">
                <th class="py-2 text-left text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted"></th>
                <th class="py-2 text-left text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted">Product</th>
                <th class="py-2 text-left text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted">SKU</th>
                <th class="py-2 text-right text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted">Qty</th>
                <th class="py-2 text-right text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted">Unit</th>
                <th class="py-2 text-right text-[9.5px] font-bold uppercase tracking-widest opacity-60 font-sans" :style="'color: ' + theme.muted">Total</th>
            </tr>
        </thead>
        <tbody class="font-sans">
            <% (branding.model.items || []).forEach((item, index) => { %>
                <tr class="border-b border-gray-100">
                    <td class="py-2 w-9">
                        <%- include('../../../../partials/common/smart-image', { 
                            src: item.img, 
                            alt: item.name, 
                            className: 'w-9 h-9 rounded-lg flex items-center justify-center bg-gray-50',
                            size: 'sm',
                            fallback: '📦'
                        }) %>
                    </td>
                    <td class="py-2 pl-3">
                        <div class="text-[13px] font-bold" style="color: <%= branding.themeData.text || '#1e293b' %>"><%= item.name %></div>
                        <div class="text-[10px] text-gray-400"><%= item.category %></div>
                    </td>
                    <td class="py-2 text-[11px] text-gray-400"><%= item.sku %></td>
                    <td class="py-2 text-right text-[13px]" style="color: <%= branding.themeData.text || '#1e293b' %>"><%= item.qty %></td>
                    <td class="py-2 text-right text-[13px] text-gray-500">$<%= item.price.toFixed(2) %></td>
                    <td class="py-2 text-right text-[13px] font-bold" style="color: <%= branding.themeData.text || '#1e293b' %>">$<%= (item.price * item.qty).toFixed(2) %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<!-- Added Upsells (Part of Line Items Logic) -->
<div class="mt-4" x-show="addedItems.length > 0">
    <div class="rounded-lg p-3" :style="'background: ' + theme.light">
        <div class="text-[9.5px] font-bold uppercase tracking-widest mb-2 font-sans" :style="'color: ' + theme.secondary">Added to Order</div>
        <template x-for="id in addedItems" :key="id">
             <div class="flex justify-between items-center py-1.5 border-b border-black/5 last:border-0 font-sans">
                 <div class="text-xs font-medium text-black">
                     <span x-text="getRec(id) ? getRec(id).img : '?'"></span> <span x-text="getRec(id) ? getRec(id).name : 'Unknown Item'"></span>
                 </div>
                 <div class="flex items-center gap-3">
                     <span class="text-xs font-bold text-black" x-text="'$' + (getRec(id) ? getRec(id).price : 0).toFixed(2)"></span>
                     <button @click="toggleAdd(id)" class="text-red-500 hover:text-red-700 font-bold leading-none text-sm">&times;</button>
                 </div>
             </div>
        </template>
    </div>
</div>

