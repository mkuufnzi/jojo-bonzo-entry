<!-- Customer & Status/Shipping Row -->
<%# [FIX] ATOMIC TABLE LAYOUT - Guaranteed 3-column parallel alignment that cannot wrap or collapse %>
<div class="font-sans" 
     style="margin-top: 8px !important; margin-bottom: 8px !important; padding: 12px 0 !important; border-bottom: 1px solid #f1f5f9; width: 100% !important; display: block !important;">
    
    <table style="width: 100% !important; border-collapse: collapse !important; table-layout: fixed !important;" 
           data-no-split="true">
        <tr>
            <!-- Column 1: Bill To -->
            <td style="width: 33.33% !important; vertical-align: top !important; padding: 0 !important;">
                <div class="text-[10px] uppercase tracking-widest font-bold mb-1 opacity-60" :style="'color: ' + theme.muted">Bill To</div>
                <div class="text-[14px] font-bold text-slate-900" :style="'color: ' + theme.text"><%= invoiceData.customer?.name || invoiceData.CustomerRef?.name || 'Customer' %></div>
                <div class="text-[11px] text-gray-400 mt-1"><%= invoiceData.customer?.email || invoiceData.BillEmail?.Address || '' %></div>
                <div class="text-[11px] text-gray-400"><%= invoiceData.Id ? 'Order #' + invoiceData.Id : '' %></div>
            </td>

            <!-- Column 2: Shipping Address -->
            <td style="width: 33.33% !important; vertical-align: top !important; padding: 0 !important; padding-left: 30px !important;">
                <div class="text-[10px] uppercase tracking-widest font-bold mb-1 opacity-60" :style="'color: ' + theme.muted">Shipping Address</div>
                <div class="text-[13px] text-slate-600 leading-relaxed font-medium mt-1" 
                     style="line-height: 1.6 !important; color: #475569 !important;">
                    <% if (invoiceData.ShipAddr || invoiceData.BillAddr) { %>
                        <% const addr = invoiceData.ShipAddr || invoiceData.BillAddr; %>
                        <%= addr.Line1 || '' %><br>
                        <%= addr.City || '' %><% if (addr.City && (addr.CountrySubDivisionCode || addr.Region)) { %>, <% } %><%= addr.CountrySubDivisionCode || addr.Region || addr.state || '' %> <%= addr.PostalCode || addr.zip || '' %>
                    <% } else if (invoiceData.customer?.address) { %>
                        <%= invoiceData.customer.address.line1 || '' %><br>
                        <%= invoiceData.customer.address.city || '' %>, <%= invoiceData.customer.address.state || '' %> <%= invoiceData.customer.address.postal_code || '' %>
                    <% } else { %>
                        Address not provided
                    <% } %>
                </div>
            </td>

            <!-- Column 3: Status & Loyalty -->
            <td style="width: 33.33% !important; vertical-align: top !important; padding: 0 !important; text-align: right !important;">
                <div style="display: flex !important; flex-direction: column !important; align-items: flex-end !important; gap: 8px !important;">
                    <div style="text-align: right !important;">
                        <div class="text-[10px] uppercase tracking-widest font-bold mb-1 opacity-60" :style="'color: ' + theme.muted">Status</div>
                        <span class="px-3 py-1 rounded-full text-[11px] font-bold" 
                              style="display: inline-block !important; padding: 4px 12px !important; border-radius: 9999px !important; white-space: nowrap !important;"
                              :style="'background: ' + theme.accent + '; color: ' + theme.primary">Paid ✓</span>
                    </div>
                    <div style="text-align: right !important;">
                         <div class="text-[10px] uppercase tracking-widest font-bold mb-1 opacity-60" :style="'color: ' + theme.muted">Loyalty</div>
                         <span class="bg-amber-100 text-amber-600 px-3 py-1 rounded-full text-[11px] font-bold"
                               style="display: inline-block !important; padding: 4px 12px !important; border-radius: 9999px !important; background-color: #FEF3C7 !important; color: #D97706 !important; white-space: nowrap !important;">★ Gold</span>
                    </div>
                </div>
            </td>
        </tr>
    </table>
</div>
