<% layout('layouts/document-master') %>

<% block('head').append(`
    <!-- Fonts: Outfit & DM Sans -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    
    <style>
        /* Template Specific CSS */
        :root {
            --primary-color: ${branding.theme.primary || '#FFC800'};
            --secondary-color: ${branding.theme.secondary || '#2D2D2D'};
            --accent-color: ${branding.theme.accent || '#FF6B00'};
            --text-main: ${branding.theme.text || '#1A1A1A'};
            --bg-body: #F5F5F5;
            --bg-card: #FFFFFF;
            --success: #00C853;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
            line-height: 1.6;
            background: var(--bg-body);
        }

        h1, h2, h3, h4, .brand-font {
            font-family: 'Outfit', sans-serif;
        }
    </style>
`) %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<%- include('../../../components/logic/smart-document-logic') %>

<!-- Template Interface -->
<div class="font-sans text-slate-800 antialiased">
    
    <!-- Section: Header (Full Width) -->
    <% if (branding.components?.header?.enabled) { %>
        <div class="doc-section mb-8">
            <%- include('./components/header') %>
        </div>
    <% } %>

    <!-- Container for Constrained Content -->
    <div class="max-w-[850px] mx-auto px-8 pb-12">
        
        <!-- Section: Title & Customer Meta -->
        <% if (branding.components?.customer_info?.enabled) { %>
            <div class="doc-section mb-6">
                <%- include('./components/customer_info') %>
            </div>
        <% } %>

        <!-- Section: Smart Banner -->
        <% if (branding.components?.marketing_banner?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('./components/banner') %>
            </div>
        <% } %>

        <!-- Section: Line Items (Splittable) -->
        <% if (branding.components?.line_items?.enabled) { %>
            <div class="doc-section mb-8" data-split="true">
                <%- include('./components/line_items') %>
            </div>
        <% } %>

        <!-- Section: Totals -->
        <% if (branding.components?.totals?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('./components/totals') %>
            </div>
        <% } %>

        <!-- Section: Upsell Recommendations (Splittable) -->
        <% if (branding.components?.product_recommendations?.enabled) { %>
            <div class="doc-section mb-8" data-split="true">
                <%- include('../../../components/smart-widgets/product-recommendations') %>
            </div>
        <% } %>

        <!-- Section: Product Support (Splittable) -->
        <% if (branding.components?.product_support?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('../../../components/smart-widgets/tutorials') %>
            </div>
        <% } %>

        <!-- Section: Payment Details -->
        <% if (branding.components?.payment_details?.enabled) { %>
             <div class="doc-section mb-8">
                <%- include('./components/payment_info') %>
             </div>
        <% } %>

        <!-- Section: Customer Support Widget -->
        <% if (branding.components?.customer_support?.enabled) { %>
            <div class="doc-section mb-8">
                <%- include('../../../components/smart-widgets/support-card') %>
            </div>
        <% } %>

        <!-- Section: Footer -->
        <% if (branding.components?.footer?.enabled) { %>
            <div class="doc-section mt-auto">
                <%- include('./components/footer') %>
            </div>
        <% } %>
    </div>
</div>

