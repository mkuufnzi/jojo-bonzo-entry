<% layout('layouts/document-master') %>

<% block('head').append(`
    <!-- Fonts: Outfit & DM Sans -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    
    <style>
        /* Template Specific CSS */
        :root {
            --primary-color: <%= branding.theme.primary || '#FFC800' %>;
            --secondary-color: <%= branding.theme.secondary || '#2D2D2D' %>;
            --accent-color: <%= branding.theme.accent || '#FF6B00' %>;
            --text-main: <%= branding.theme.text || '#1A1A1A' %>;
            --bg-body: #F5F5F5;
            --bg-card: #FFFFFF;
            --success: #00C853;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--text-main);
            line-height: 1.6;
            background: var(--bg-body);
        }

        h1, h2, h3, h4, .brand-font {
            font-family: 'Outfit', sans-serif;
        }
    </style>
`) %>

<!-- Standard Document Configuration -->
<div id="doc-config" 
    data-page-size="A4" 
    data-orientation="portrait" 
    data-margin-top="50" 
    data-margin-bottom="50"
    class="hidden"></div>

<%- include('../../../components/logic/smart-document-logic') %>

<!-- Template Meta -->
<div class="font-sans text-slate-800 antialiased" style="font-family: 'DM Sans', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;">
    
    <% 
       /**
        * Widget Registry: Maps widget IDs to include paths
        */
       const WIDGET_REGISTRY = {
           'header': { path: './components/header', landmark: true, splittable: false },
           'spacer_1': { path: null, landmark: false, splittable: false },
           'spacer_2': { path: null, landmark: false, splittable: false },
           'customer_info': { path: './components/customer_info', landmark: false, splittable: false },
           'marketing_banner': { path: './components/banner', landmark: false, splittable: false },
           'line_items': { path: './components/line_items', landmark: false, splittable: true },
           'totals': { path: './components/totals', landmark: false, splittable: false },
           'product_recommendations': { path: '../../../components/smart-widgets/product-recommendations', landmark: false, splittable: false },
           'product_support': { path: '../../../components/smart-widgets/tutorials', landmark: false, splittable: false },
           'payment_details': { path: './components/payment_info', landmark: false, splittable: false },
           'customer_support': { path: '../../../components/smart-widgets/support-card', landmark: false, splittable: false },
           'footer': { path: './components/footer', landmark: true, splittable: false }
       };
       
       const layoutOrder = branding.layoutOrder || [];
       const widgetStates = branding.widgetStates || {};
       
       // Flattened structure for Paginator optimization
       // We skip the landing wrapper and render everything as direct descendants
    %>

    <!-- =============== RENDER LOOP (Deterministic) =============== -->
    <% 
        let i = 0;
        while(i < layoutOrder.length) {
            const widgetId = layoutOrder[i];
            const widget = WIDGET_REGISTRY[widgetId];
            const state = widgetStates[widgetId];
            const isEnabled = state?.enabled !== false;
            const isSpacer = widgetId.startsWith('spacer_');
            const splitAttr = widget?.splittable ? 'data-split="true"' : 'data-no-split="true"';
            
            // Constrain inner content width for non-landmark widgets
            const containerClass = widget?.landmark ? "w-full" : "max-w-[850px] mx-auto px-8";
    %>
        
        <% if (isEnabled) { %>
            <% if (isSpacer) { %>
                <div class="doc-section w-full block" 
                     data-widget-id="<%= widgetId %>" 
                     data-no-split="true"
                     style="display: block !important; height: <%= state?.value || 20 %>px !important; min-height: <%= state?.value || 20 %>px !important; margin: 0 !important;">
                </div>
            <% } else if (widget?.path) { %>
                <div class="doc-section <%= containerClass %> block" 
                     data-widget-id="<%= widgetId %>" 
                     <%- splitAttr %>
                     style="display: block !important; margin-bottom: 8px !important;">
                    <%- include(widget.path) %>
                </div>
            <% } %>
        <% } %>
        
        <% i++; %> 
    <% } %>
</div>

