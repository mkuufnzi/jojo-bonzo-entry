<style>
    .invoice-header {
        background: linear-gradient(135deg, var(--secondary-color) 0%, #000000 100%);
        padding: 0;
        position: relative;
        overflow: hidden;
    }
    .arrow-design {
        display: flex;
        align-items: center;
        padding: 16px 40px;
        position: relative;
    }
    .arrow-base {
        width: 60px; /* Compacted */
        height: 50px;
        background: var(--primary-color);
        clip-path: polygon(0 0, 75% 0, 100% 50%, 75% 100%, 0 100%);
    }
    .arrow {
        width: 35px; /* Compacted */
        height: 50px;
        background: var(--primary-color);
        clip-path: polygon(0 0, 60% 0, 100% 50%, 60% 100%, 0 100%, 40% 50%);
        margin-left: -5px;
        opacity: 0.9;
    }
    .logo-circle {
        background: var(--primary-color);
        color: var(--secondary-color);
        width: 40px; height: 40px; 
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-family: 'Outfit', sans-serif;
    }
</style>

<div class="invoice-header">
    <div class="arrow-design">
        <div class="flex items-center">
            <div class="arrow-base"></div>
            <div class="arrow"></div>
            <div class="arrow"></div>
        </div>
        <div class="ml-6 text-white">
            <div class="flex items-center gap-3 mb-1">
                <template x-if="theme.logoUrl">
                    <img :src="theme.logoUrl" alt="Logo" class="h-10 w-10 object-contain rounded-full bg-white p-1">
                </template>
                <template x-if="!theme.logoUrl">
                    <div class="logo-circle" x-text="(theme.name || 'B').charAt(0)"></div>
                </template>
                <div class="font-bold text-2xl tracking-tight brand-font" x-text="theme.name || 'Brand Name'"></div>
            </div>
            <div class="text-sm opacity-80 font-light" x-text="theme.tagline || 'Building the future of commerce.'"></div>
        </div>
    </div>
</div>
