             <span x-text="nurtureMsg.icon"></span>
        </div>
        <div class="flex-1 text-left">
            <h3 class="font-bold text-xl brand-font leading-tight" style="color: var(--secondary-color)" x-text="nurtureMsg.headline"></h3>
            <p class="text-sm text-gray-600 mt-1" x-text="nurtureMsg.body"></p>
        </div>
        <div class="shrink-0">
