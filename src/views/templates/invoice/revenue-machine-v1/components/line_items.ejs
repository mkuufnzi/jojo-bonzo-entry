<style>
    .items-section { padding: 12px 40px; background: white; }
    .items-table { width: 100%; border-collapse: separate; border-spacing: 0; }
    .items-table th {
        background: var(--secondary-color);
        color: white;
        padding: 8px 15px;
        text-align: left;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }
    .items-table th:first-child { border-top-left-radius: 8px; border-bottom-left-radius: 8px; }
    .items-table th:last-child { border-top-right-radius: 8px; border-bottom-right-radius: 8px; text-align: right; }
    
    .items-table td {
        padding: 8px 15px;
        border-bottom: 1px solid #E5E5E5;
        font-size: 14px;
    }
    .items-table tr:last-child td { border-bottom: none; }
    
    .item-tag {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 8px;
        background: #F3F4F6;
        color: #4B5563;
        border-radius: 12px;
        font-size: 10px;
        font-weight: 600;
        margin-top: 4px;
    }
    .item-tag.highlight {
        background: #FFF9E6;
        color: #B45309; /* Dark yellow/orange */
    }
</style>

<div class="items-section">
    <table class="items-table" data-split="true">
        <thead>
            <tr>
                <th style="width: 50%">Description</th>
                <th style="width: 15%">Price</th>
                <th style="width: 15%">Qty</th>
                <th style="text-align: right">Total</th>
            </tr>
        </thead>
        <tbody>
            <% (branding.model?.items || []).forEach((item, index) => { %>
                <tr>
                    <td class="flex items-center gap-3">
                        <div class="w-10 h-10 shrink-0">
                            <%- include('../../../../partials/common/smart-image', { 
                                src: item.img, 
                                alt: item.name, 
                                className: 'w-10 h-10 rounded flex items-center justify-center bg-gray-50',
                                size: 'sm',
                                fallback: '📦'
                            }) %>
                        </div>
                        <div>
                            <div class="font-bold text-gray-900"><%= item.name %></div>
                            <div class="text-xs text-gray-500"><%= item.description || item.category || '' %></div>
                            <div class="flex gap-2 mt-1">
                                <% if (item.price > 50) { %>
                                    <span class="item-tag highlight">
                                        <span>⭐</span> Loyalty Item
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    </td>
                    <td>$<%= item.price.toFixed(2) %></td>
                    <td><%= item.qty %></td>
                    <td class="text-right font-bold">$<%= (item.price * item.qty).toFixed(2) %></td>
                </tr>
            <% }); %>
            
            <% if (!branding.model?.items?.length) { %>
                <tr>
                   <td class="text-gray-400 italic" colspan="4">No items loaded.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>
