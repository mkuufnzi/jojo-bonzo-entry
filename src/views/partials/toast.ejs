<!-- Toast Notification Container -->
<div id="toast-container" class="fixed bottom-5 right-5 z-50 flex flex-col space-y-3 pointer-events-none">
    <!-- Toasts will be injected here -->
</div>

<!-- Toast Template (Hidden) -->
<template id="toast-template">
    <div class="toast transform translate-y-2 opacity-0 flex items-center w-full max-w-sm p-4 text-gray-500 bg-white rounded-lg shadow dark:text-gray-400 dark:bg-gray-800 pointer-events-auto border border-gray-100 dark:border-gray-700" role="alert">
        <div class="inline-flex items-center justify-center flex-shrink-0 w-8 h-8 rounded-lg">
            <svg class="w-5 h-5 toast-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                <!-- Icon path will be set dynamically -->
            </svg>
            <span class="sr-only">Icon</span>
        </div>
        <div class="ml-3 text-sm font-normal">
            <span class="font-semibold text-gray-900 dark:text-white toast-title block mb-0.5"></span>
            <div class="toast-message text-xs"></div>
        </div>
        <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-white text-gray-400 hover:text-gray-900 rounded-lg focus:ring-2 focus:ring-gray-300 p-1.5 hover:bg-gray-100 inline-flex items-center justify-center h-8 w-8 dark:text-gray-500 dark:hover:text-white dark:bg-gray-800 dark:hover:bg-gray-700" aria-label="Close" onclick="this.closest('.toast').remove()">
            <span class="sr-only">Close</span>
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
            </svg>
        </button>
    </div>
</template>

<script nonce="<%= nonce %>">
    /**
     * Show a Toast Notification
     * @param {string} title - Title of the toast
     * @param {string} message - Message body
     * @param {'success'|'error'|'warning'|'info'} type - Type of toast
     */
    window.showToast = function(title, message, type = 'info') {
        const container = document.getElementById('toast-container');
        const template = document.getElementById('toast-template');
        
        if (!container || !template) return;

        const clone = template.content.cloneNode(true);
        const toastEl = clone.querySelector('.toast');
        const iconContainer = clone.querySelector('.inline-flex');
        const iconSvg = clone.querySelector('.toast-icon');
        const titleEl = clone.querySelector('.toast-title');
        const messageEl = clone.querySelector('.toast-message');

        titleEl.textContent = title;
        messageEl.textContent = message;

        // Styles based on type
        const styles = {
            success: {
                bg: 'bg-green-100 dark:bg-green-800',
                text: 'text-green-500 dark:text-green-200',
                icon: 'M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 8.207-4 4a1 1 0 0 1-1.414 0l-2-2a1 1 0 0 1 1.414-1.414L9 10.586l3.293-3.293a1 1 0 0 1 1.414 1.414Z'
            },
            error: {
                bg: 'bg-red-100 dark:bg-red-800',
                text: 'text-red-500 dark:text-red-200',
                icon: 'M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5Zm3.707 11.793a1 1 0 1 1-1.414 1.414L10 11.414l-2.293 2.293a1 1 0 0 1-1.414-1.414L8.586 10 6.293 7.707a1 1 0 0 1 1.414-1.414L10 8.586l2.293-2.293a1 1 0 0 1 1.414 1.414L11.414 10l2.293 2.293Z'
            },
            warning: {
                bg: 'bg-orange-100 dark:bg-orange-700',
                text: 'text-orange-500 dark:text-orange-200',
                icon: 'M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM10 15a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm1-4a1 1 0 0 1-2 0V6a1 1 0 0 1 2 0v5Z'
            },
            info: {
                bg: 'bg-blue-100 dark:bg-blue-800',
                text: 'text-blue-500 dark:text-blue-200',
                icon: 'M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z'
            }
        };

        const style = styles[type] || styles.info;
        
        iconContainer.classList.add(...style.bg.split(' '));
        iconContainer.classList.add(...style.text.split(' '));
        iconSvg.setAttribute('d', style.icon);

        container.appendChild(toastEl);

        // Animate In
        requestAnimationFrame(() => {
            toastEl.classList.remove('translate-y-2', 'opacity-0');
        });

        // Auto Dismiss
        setTimeout(() => {
            toastEl.classList.add('translate-y-2', 'opacity-0'); // Animate Out
            setTimeout(() => {
                toastEl.remove();
            }, 300);
        }, 5000);
    };
</script>
