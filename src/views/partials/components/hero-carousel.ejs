<!-- Reusable Hero Carousel Component -->
<!-- Props: slides (Array of objects) 
     Each slide: {
       id: string,
       badge: { text: string, color: string, icon?: string },
       title: string, 
       titleHighlight: string,
       text: string,
       cta: { text: string, link: string },
       visuals: string[] (Array of image paths or 'code:...' strings)
     }
-->
<section class="relative overflow-hidden pt-16 pb-20 sm:pt-24 sm:pb-32 lg:pb-40 bg-white"
         x-data="{ 
             slideIndex: 0, 
             progress: 0,
             slides: <%= JSON.stringify(slides) %>,
             interval: null,
             init() {
                 this.start();
             },
             tick() {
                 this.progress++;
                 // 4 seconds (ticks 0, 1, 2, 3) per slide.
                 // Nested visuals update on 0, 1, 2. Hold on 3.
                 if (this.progress >= 4) {
                     this.nextSlide();
                 }
             },
             nextSlide() {
                 this.progress = 0;
                 this.slideIndex = (this.slideIndex + 1) % this.slides.length;
             },
             setSlide(index) {
                 this.progress = 0;
                 this.slideIndex = index;
             },
             start() {
                 if (this.interval) clearInterval(this.interval);
                 this.interval = setInterval(() => {
                     this.tick();
                 }, 2000); // 2 second heartbeat (8s total loop)
             },
             stop() {
                 clearInterval(this.interval);
                 this.interval = null;
             }
         }"
         @mouseenter="stop()"
         @mouseleave="start()">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="lg:grid lg:grid-cols-12 lg:gap-16 items-center">
            
            <!-- Content (Left) -->
            <template x-for="(slide, index) in slides" :key="index">
                <div class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left min-h-[400px] flex flex-col justify-center"
                     x-show="slideIndex === index"
                     x-transition:enter="transition ease-out duration-500" 
                     x-transition:enter-start="opacity-0 translate-y-4" 
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-transition:leave="transition ease-in duration-300 absolute top-0 left-0 w-full" 
                     x-transition:leave-start="opacity-100" 
                     x-transition:leave-end="opacity-0">
                     
                    <!-- Badge -->
                    <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold mb-6 w-fit"
                         :class="slide.badge.classes || 'bg-blue-50 text-brand-blue'">
                        <span x-text="slide.badge.text"></span>
                    </div>

                    <!-- Headline -->
                    <h1 class="text-4xl tracking-tight font-extrabold text-deep-ocean sm:text-5xl md:text-6xl font-heading leading-tight">
                        <span x-text="slide.title"></span> <span :class="slide.titleHighlightColor || 'text-brand-blue'" x-html="slide.titleHighlight"></span>
                    </h1>

                    <!-- Description -->
                    <p class="mt-4 text-lg text-slate-500 max-w-3xl sm:mt-5 md:text-xl lg:mx-0" x-html="slide.text"></p>

                    <!-- CTA -->
                    <div class="mt-8 flex flex-col sm:flex-row gap-4 sm:justify-center lg:justify-start">
                        <a :href="slide.cta.link" 
                           class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-bold rounded-lg text-white bg-brand-blue hover:bg-brand-indigo md:py-4 md:text-lg shadow-glow hover:shadow-card-hover transition-all transform hover:-translate-y-1">
                            <span x-text="slide.cta.text"></span>
                        </a>
                        
                        <!-- Secondary CTA (Learn More) -->
                        <template x-if="slide.secondaryCta">
                             <a :href="slide.secondaryCta.link" 
                                class="inline-flex items-center justify-center px-8 py-3 border border-slate-200 text-base font-bold rounded-lg text-slate-600 bg-white hover:bg-slate-50 hover:text-brand-blue md:py-4 md:text-lg shadow-sm hover:shadow-md transition-all">
                                <span x-text="slide.secondaryCta.text"></span>
                            </a>
                        </template>
                    </div>
                </div>
            </template>

            <!-- Visuals (Right) -->
            <div class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center justify-center h-[400px] lg:h-[500px]">
                
                <template x-for="(slide, index) in slides" :key="index">
                    <div x-show="slideIndex === index" 
                         class="w-full h-full relative" 
                         x-transition:enter="transition ease-out duration-500" 
                         x-transition:enter-start="opacity-0 scale-95" 
                         x-transition:enter-end="opacity-100 scale-100">
                         
                        <!-- Nested Carousel Container (Driven by Parent State) -->
                         <div class="relative w-full aspect-square max-h-[500px] flex items-center justify-center">
                             
                             <template x-for="(visual, vIndex) in slide.visuals" :key="vIndex">
                                 <!-- Show based on progress -->
                                 <div x-show="vIndex === Math.min(progress, slide.visuals.length - 1)"
                                      class="absolute inset-0 w-full h-full flex items-center justify-center"
                                      x-transition:enter="transition ease-out duration-500"
                                      x-transition:enter-start="opacity-0 translate-x-4"
                                      x-transition:enter-end="opacity-100 translate-x-0"
                                      x-transition:leave="transition ease-in duration-300 absolute top-0 left-0 w-full"
                                      x-transition:leave-start="opacity-100 translate-x-0"
                                      x-transition:leave-end="opacity-0 -translate-x-4">
                                     
                                     <!-- Image Handling -->
                                     <img :src="visual" alt="Visual" class="w-full h-full object-contain drop-shadow-2xl rounded-2xl">
                                 </div>
                             </template>

                             <!-- Nested Indicators -->
                             <div class="absolute bottom-4 left-0 w-full flex justify-center space-x-1 z-20">
                                 <template x-for="(visual, vIndex) in slide.visuals" :key="vIndex">
                                     <!-- Allow clicking visuals if desired, though usually auto-driven -->
                                     <button class="w-1.5 h-1.5 rounded-full transition-colors shadow-sm" 
                                             :class="vIndex === Math.min(progress, slide.visuals.length - 1) ? 'bg-brand-blue' : 'bg-slate-200'">
                                     </button>
                                 </template>
                             </div>
                         </div>
                    </div>
                </template>

            </div>
        </div>
        
        <!-- Main Carousel Indicators -->
        <div class="flex justify-center mt-8 space-x-2 relative z-20">
            <template x-for="(slide, index) in slides" :key="index">
                <button @click="setSlide(index)" class="w-3 h-3 rounded-full transition-colors" :class="slideIndex === index ? 'bg-brand-blue' : 'bg-slate-300'"></button>
            </template>
        </div>
    </div>
</section>
