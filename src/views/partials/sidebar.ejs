<!-- Sidebar Component - Production Grade -->
<!-- State managed via data attributes, not class toggling -->
<aside id="sidebar"
    class="bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 text-slate-600 dark:text-slate-400 group"
    data-collapsed="false"
    data-mobile-open="false"
    aria-label="Main navigation"
    role="navigation">

    <!-- Sidebar Styles: Extracted to /css/layouts/sidebar.css -->


<!-- Flash prevention script -->
<script nonce="<%= nonce %>">
(function() {
    var s = document.getElementById('sidebar');
    var isDesktop = window.innerWidth >= 1024;
    var wasCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
    if (isDesktop && wasCollapsed && s) {
        s.style.transition = 'none';
        s.dataset.collapsed = 'true';
        document.body.dataset.sidebarCollapsed = 'true';
            if (wasCollapsed) {
                requestAnimationFrame(function() {
                    s.style.transition = '';
                });
            }

            // Bind Onboarding Trigger
            var onboardingBtn = document.getElementById('triggerOnboarding');
            if (onboardingBtn) {
                onboardingBtn.addEventListener('click', function() {
                    window.location.reload();
                });
            }
    }
})();
</script>

    <!-- Logo / Header -->
    <div class="header-row flex items-center h-16 px-4 mb-4 justify-between">
        <div class="flex items-center space-x-3 overflow-hidden">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center flex-shrink-0 text-white shadow-sm shadow-blue-500/30">
                <span class="font-bold text-lg">F</span>
            </div>
            <span class="sidebar-text font-bold text-lg text-slate-900 dark:text-white tracking-tight whitespace-nowrap">Floovioo</span>
        </div>
        <!-- Mobile Close Button -->
        <button id="closeSidebar" 
                class="md:hidden text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors p-1"
                aria-label="Close navigation menu">
            <i data-lucide="x" class="w-5 h-5"></i>
        </button>
        <!-- Desktop Toggle Button -->
        <button id="toggleSidebar" 
                class="hidden lg:block text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors p-1 ml-auto"
                aria-label="Toggle sidebar"
                aria-expanded="true">
            <i data-lucide="chevrons-left" class="w-5 h-5 transition-transform duration-300" id="collapseIcon"></i>
        </button>
    </div>

    <!-- Onboarding Shortcut -->
    <% if (locals.showOnboardingModal) { %>
    <div class="px-3 pb-4">
        <button id="triggerOnboarding"
                class="flex items-center gap-3 w-full px-4 py-3 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800 rounded-xl hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-all group relative">
            <i data-lucide="sparkles" class="w-4 h-4 group-hover:rotate-12 transition-transform"></i>
            <span class="sidebar-text text-sm font-bold uppercase tracking-widest">Complete Setup</span>
            <!-- Tooltip -->
            <span class="sidebar-tooltip hidden">Complete Setup</span>
        </button>
    </div>
    <% } %>

    <!-- Navigation -->
    <div class="nav-container flex-1 px-3 space-y-1 overflow-y-auto">
        <!-- Main Nav Group -->
        <div class="space-y-1">
            <% 
            const navItems = [
                { label: 'Overview', href: '/dashboard', icon: 'layout-dashboard' },
                { label: 'Apps & Keys', href: '/apps', icon: 'key' },
                { label: 'Billing', href: '/billing', icon: 'credit-card' },
                { label: 'Subscription', href: '/subscription', icon: 'zap' }
            ]; 
            %>

            <% navItems.forEach(item => { %>
                <a href="<%= item.href %>"
                    class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 
                           <%= (typeof currentPath !== 'undefined' && currentPath === item.href) 
                               ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400' 
                               : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white' %> 
                           relative"
                    <% if (typeof currentPath !== 'undefined' && currentPath === item.href) { %>aria-current="page"<% } %>>
                    
                    <% if (typeof currentPath !== 'undefined' && currentPath === item.href) { %>
                        <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-blue-600 rounded-r-full sidebar-active-indicator"></div>
                    <% } %>

                    <!-- Icon Wrapper -->
                    <div class="w-5 h-5 flex-shrink-0 flex items-center justify-center">
                        <i data-lucide="<%= item.icon %>" class="w-5 h-5 transition-colors duration-200"></i>
                    </div>

                    <span class="sidebar-text ml-3 truncate"><%= item.label %></span>
                    
                    <% if (item.label === 'Billing' && typeof alerts !== 'undefined' && alerts.billing) { %>
                        <span class="ml-auto w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
                    <% } %>

                    <!-- Tooltip for collapsed state -->
                    <span class="sidebar-tooltip hidden"><%= item.label %></span>
                </a>
            <% }); %>
        </div>

        <!-- Services Group -->
        <div class="pt-6 pb-2">
            <p class="sidebar-text px-3 text-[0.625rem] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em]">Documents & Workflow</p>
            <div class="sidebar-divider hidden border-t border-slate-100 dark:border-slate-800 my-2"></div>
        </div>

        <div class="space-y-1">
            <% if (typeof availableServices !=='undefined' && availableServices.length> 0) { %>
                <% availableServices.forEach(service=> { %>
                    <a href="/services/<%= service.slug %>"
                        class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-200 <%= (typeof currentPath !== 'undefined' && currentPath === '/services/' + service.slug) ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white' %> relative"
                        <% if (typeof currentPath !== 'undefined' && currentPath === '/services/' + service.slug) { %>aria-current="page"<% } %>>
                        <% if (typeof currentPath !== 'undefined' && currentPath === '/services/' + service.slug) { %>
                            <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-blue-600 rounded-r-full sidebar-active-indicator"></div>
                        <% } %>
                        <div class="w-5 h-5 flex-shrink-0 flex items-center justify-center transition-all duration-200 group-hover:scale-110">
                            <%- include('service-icon', { service: service, type: 'sidebar' }) %>
                        </div>
                        <span class="sidebar-text ml-3 truncate flex-1">
                            <%= service.name %>
                        </span>
                        
                        <!-- Tooltip -->
                        <span class="sidebar-tooltip hidden"><%= service.name %></span>

                        <% if (service.isPro && (typeof user==='undefined' || !user.subscription || !user.subscription.plan || user.subscription.plan.name==='Free' )) { %>
                            <span class="sidebar-text ml-2 px-1 py-0.5 text-[0.5625rem] font-bold bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 border border-blue-200 dark:border-blue-800 rounded">PRO</span>
                        <% } %>
                    </a>
                <% }); %>
            <% } else { %>
                <div class="sidebar-text px-3 py-2 text-xs text-slate-500 italic">No workflows active</div>
            <% } %>
        </div>

        <% if (typeof user !== 'undefined' && user.isAdmin) { %>
            <!-- Admin Section -->
            <div class="pt-6 pb-2">
                <p class="sidebar-text px-3 text-[0.625rem] font-bold text-amber-500/80 uppercase tracking-[0.2em]">Administration</p>
                <div class="sidebar-divider hidden border-t border-slate-100 dark:border-slate-800 my-2"></div>
            </div>
            <div class="space-y-1">
                <a href="/admin" class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 hover:bg-amber-50 dark:hover:bg-amber-900/20 text-amber-600 dark:text-amber-500 hover:text-amber-700 relative">
                    <i data-lucide="shield-alert" class="w-5 h-5"></i>
                    <span class="sidebar-text ml-3 truncate">Admin Console</span>
                    <!-- Tooltip -->
                    <span class="sidebar-tooltip hidden">Admin Console</span>
                </a>
                <a href="/dashboard/transactional/legacy-templates" class="group flex items-center px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white relative">
                    <i data-lucide="archive" class="w-5 h-5"></i>
                    <span class="sidebar-text ml-3 truncate">Legacy Builder</span>
                    <!-- Tooltip -->
                    <span class="sidebar-tooltip hidden">Legacy Builder</span>
                </a>
            </div>
        <% } %>
    </div>

    <!-- Bottom Actions & Profile -->
    <div class="p-3 border-t border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/50 backdrop-blur-md">
        <!-- User Profile Widget -->
        <% if (typeof user !== 'undefined') { %>
            <div class="relative">
                <details class="w-full relative group shadow-none">
                    <summary class="list-none flex items-center p-1 rounded-lg cursor-pointer transition-all duration-200 hover:bg-slate-200 dark:hover:bg-slate-800 outline-none">
                        <div class="w-8 h-8 rounded bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-xs font-bold text-white flex-shrink-0 shadow-sm">
                            <%= user.name ? user.name.substring(0, 2).toUpperCase() : 'U' %>
                        </div>
                        <div class="sidebar-text ml-2.5 overflow-hidden text-left flex-1">
                            <p class="text-[0.6875rem] font-semibold text-slate-900 dark:text-white truncate"><%= user.name || 'User' %></p>
                            <p class="text-[0.625rem] text-slate-500 truncate"><%= user.email %></p>
                        </div>
                        <i data-lucide="chevron-up" class="sidebar-text w-3 h-3 ml-1 text-slate-400 transition-transform group-open:rotate-180"></i>
                    </summary>
                    
                    <!-- Popover Menu -->
                    <div class="absolute bottom-full left-0 mb-3 w-full bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl overflow-hidden min-w-[12.5rem] z-50 animate-in fade-in slide-in-from-bottom-2 duration-200">
                        <div class="px-4 py-3 bg-slate-50 dark:bg-slate-700/30 border-b border-slate-100 dark:border-slate-700">
                            <p class="text-sm text-slate-900 dark:text-white font-medium truncate"><%= user.name %></p>
                            <p class="text-[0.625rem] text-slate-500 truncate uppercase tracking-wider font-bold"><%= (user.subscription && user.subscription.plan) ? user.subscription.plan.name : 'FREE MEMBER' %></p>
                        </div>
                        <div class="p-1">
                            <a href="/user/profile" class="flex items-center space-x-2 px-3 py-2 text-xs text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 rounded-lg transition-colors">
                                <i data-lucide="user" class="w-4 h-4"></i>
                                <span>Profile Settings</span>
                            </a>
                            <a href="/subscription" class="flex items-center space-x-2 px-3 py-2 text-xs text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 rounded-lg transition-colors">
                                <i data-lucide="credit-card" class="w-4 h-4"></i>
                                <span>Subscription</span>
                            </a>
                            <div class="h-px bg-slate-100 dark:bg-slate-700 my-1 mx-2"></div>
                            <a href="/auth/logout" class="flex items-center space-x-2 px-3 py-2 text-xs text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors">
                                <i data-lucide="log-out" class="w-4 h-4"></i>
                                <span>Sign out</span>
                            </a>
                        </div>
                    </div>
                </details>
            </div>
        <% } %>
    </div>
</aside>

<!-- Mobile Overlay -->
<div id="sidebarOverlay"
    data-visible="false"
    aria-hidden="true"></div>
