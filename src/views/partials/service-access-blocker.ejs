<div class="flex items-start md:items-center justify-center p-6 pt-24 md:pt-6 w-full h-full min-h-[500px]">
    <div class="max-w-xl w-full bg-white rounded-[2rem] p-8 text-center relative overflow-hidden shadow-2xl border border-slate-100">
        <!-- Abstract Background -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-slate-100 rounded-full blur-[100px] opacity-50"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-indigo-50 rounded-full blur-[100px] opacity-50"></div>

        <!-- Locking Icon -->
        <div class="relative z-10 mx-auto w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center mb-6 ring-4 ring-slate-50/50">
            <i data-lucide="lock" class="w-10 h-10 text-slate-400"></i>
        </div>

        <h1 class="text-2xl font-black text-slate-800 uppercase tracking-tight mb-3">
            Service Access Restricted
        </h1>
        
        <p class="text-slate-500 font-medium mb-8 leading-relaxed px-4">
            <% if (locals.accessReason === 'subscription_required') { %>
                Your active subscription plan (<strong class="text-slate-700">Free Tier</strong>) does not include access to this tool.
            <% } else if (locals.accessReason === 'app_context_required') { %>
                This tool requires an active Application Context. Please create or select an App to proceed.
            <% } else if (locals.accessReason === 'service_disabled') { %>
                Access to <strong class="text-slate-700"><%= service ? service.name : 'this service' %></strong> is currently disabled for your selected App.
            <% } else { %>
                Access to this resource is restricted based on your current workspace settings.
            <% } %>
        </p>

        <div class="flex flex-col sm:flex-row gap-3 justify-center relative z-10">
            <a href="/apps" class="px-6 py-3 bg-blue-600 text-white rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-blue-700 transition-all shadow-lg hover:shadow-blue-500/20 active:scale-95 flex items-center justify-center gap-2">
                <i data-lucide="settings-2" class="w-4 h-4"></i>
                Manage Apps
            </a>
            <a href="/subscription" class="px-6 py-3 bg-white border border-slate-200 text-slate-600 rounded-xl font-bold uppercase tracking-widest text-xs hover:bg-slate-50 transition-all active:scale-95 flex items-center justify-center gap-2">
                <i data-lucide="credit-card" class="w-4 h-4"></i>
                Check Plan
            </a>
        </div>
    </div>
</div>
