<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 md:p-6">
        <div class="flex items-center justify-between mb-2">
            <h3 class="text-[0.625rem] md:text-xs font-medium text-gray-500 uppercase tracking-wider">Total Requests</h3>
            <% if (locals.stats && stats.isLimited) { %>
                <span class="px-2 py-0.5 text-[0.5625rem] md:text-[0.625rem] font-bold rounded-full bg-blue-50 text-blue-600 border border-blue-100 uppercase tracking-tight">
                    <%= stats.remainingQuota === -1 ? 'Unlimited' : stats.remainingQuota + ' Left' %>
                </span>
            <% } %>
        </div>
        <p class="text-xl md:text-2xl font-bold text-gray-900"><%= (locals.stats && stats.totalRequests) || 0 %></p>
        <p class="text-xs text-gray-500 mt-1">Last 30 days</p>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 md:p-6">
        <h3 class="text-[0.625rem] md:text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Success Rate</h3>
        <div class="flex items-baseline">
            <p class="text-xl md:text-2xl font-bold text-gray-900"><%= (locals.stats && stats.successRate) || 0 %>%</p>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2 overflow-hidden">
            <div id="usage-success-rate-bar" class="bg-green-500 h-1.5 rounded-full transition-all duration-500" data-percentage="<%= (locals.stats && stats.successRate) || 0 %>"></div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 md:p-6">
        <h3 class="text-[0.625rem] md:text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Avg Duration</h3>
        <p class="text-xl md:text-2xl font-bold text-gray-900"><%= (locals.stats && stats.avgDuration) || 0 %>ms</p>
        <p class="text-xs text-green-600 mt-1 flex items-center">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Server Time
        </p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 md:p-6">
        <h3 class="text-[0.625rem] md:text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Total Cost</h3>
        <p class="text-xl md:text-2xl font-bold text-gray-900">$<%= (locals.stats && stats.totalCost) || '0.00' %></p>
        <p class="text-xs text-gray-500 mt-1">Estimated usage</p>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-4">Daily Usage</h3>
    <div class="relative h-64 w-full">
        <canvas id="usageChart"></canvas>
    </div>
</div>
<script nonce="<%= nonce %>">
    document.addEventListener('DOMContentLoaded', () => {
        const bar = document.getElementById('usage-success-rate-bar');
        if (bar) {
            const pct = bar.dataset.percentage;
            bar.style.width = pct + '%';
        }
    });
</script>
