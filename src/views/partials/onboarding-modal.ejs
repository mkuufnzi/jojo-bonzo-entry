<% if (locals.showOnboardingModal) { %>
<!-- Onboarding Modal -->
<div id="onboardingModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fadeIn">
    <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-hidden animate-slideUp">
        <!-- Progress Bar -->
        <div class="h-1 bg-gray-100">
            <div id="progressBar" class="h-full bg-gradient-to-r from-blue-500 to-blue-600 transition-all duration-500" style="width: 25%"></div>
        </div>

        <!-- Modal Content -->
        <div class="p-8">
            <!-- Header -->
            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="user-plus" class="w-8 h-8 text-blue-600"></i>
                </div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Complete Your Profile</h2>
                <p class="text-sm text-gray-500">Help us personalize your experience</p>
            </div>

            <!-- Step Indicator -->
            <div class="flex items-center justify-center mb-8">
                <div class="flex items-center gap-2">
                    <div id="stepIndicator1" class="step-indicator active">1</div>
                    <div class="w-12 h-0.5 bg-gray-200"></div>
                    <div id="stepIndicator2" class="step-indicator">2</div>
                    <div class="w-12 h-0.5 bg-gray-200"></div>
                    <div id="stepIndicator3" class="step-indicator">3</div>
                    <div class="w-12 h-0.5 bg-gray-200"></div>
                    <div id="stepIndicator4" class="step-indicator">4</div>
                </div>
            </div>

            <!-- Steps Container -->
            <div id="stepsContainer" class="relative overflow-hidden min-h-[18.75rem]">
                <!-- Step 1: Basic Info -->
                <div id="step1" class="step-content active">
                    <h3 class="text-lg font-bold text-gray-900 mb-6">Tell us about yourself</h3>
                    <div class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">First Name *</label>
                                <input type="text" id="firstName" required class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" placeholder="John">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-2">Last Name *</label>
                                <input type="text" id="lastName" required class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" placeholder="Doe">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number <span class="text-gray-400">(Optional)</span></label>
                            <input type="tel" id="phoneNumber" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" placeholder="+1 (555) 123-4567">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Profession/Role <span class="text-gray-400">(Optional)</span></label>
                            <select id="profession" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                                <option value="">Select your role</option>
                                <option value="Developer">Developer</option>
                                <option value="Designer">Designer</option>
                                <option value="Business Owner">Business Owner</option>
                                <option value="Marketer">Marketer</option>
                                <option value="Consultant">Consultant</option>
                                <option value="Student">Student</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Profile Photo / Logo <span class="text-gray-400">(Optional)</span></label>
                            
                            <!-- Image Preview & Upload UI -->
                            <div class="flex items-center gap-4">
                                <div class="relative group cursor-pointer" onclick="document.getElementById('profileImage').click()">
                                    <div id="imagePreviewContainer" class="w-16 h-16 rounded-full bg-blue-50 border-2 border-dashed border-blue-200 flex items-center justify-center overflow-hidden transition-all hover:border-blue-400 hover:bg-blue-100">
                                        <i data-lucide="image-plus" class="w-6 h-6 text-blue-400" id="defaultIcon"></i>
                                        <img id="imagePreview" src="" alt="Preview" class="w-full h-full object-cover hidden">
                                    </div>
                                    <div class="absolute -bottom-1 -right-1 bg-white rounded-full p-1 shadow-md border border-gray-100 group-hover:scale-110 transition-transform">
                                        <i data-lucide="edit-2" class="w-3 h-3 text-gray-600"></i>
                                    </div>
                                </div>
                                <div class="flex-1">
                                    <p class="text-xs text-gray-500 mb-1">Upload a circular profile photo or company logo.</p>
                                    <p class="text-[10px] text-gray-400">JPG, PNG or GIF (Max 2MB)</p>
                                </div>
                                <input type="file" id="profileImage" accept="image/*" class="hidden" onchange="previewImage(this)">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Account Type -->
                <div id="step2" class="step-content">
                    <h3 class="text-lg font-bold text-gray-900 mb-6">How will you use Flozino?</h3>
                    <div class="space-y-4">
                        <label class="account-type-card cursor-pointer" for="accountTypeIndividual">
                            <input type="radio" id="accountTypeIndividual" name="accountType" value="INDIVIDUAL" checked class="hidden">
                            <div class="p-6 border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:bg-blue-50/50 transition-all account-type-option">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i data-lucide="user" class="w-6 h-6 text-blue-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-bold text-gray-900 mb-1">Individual</h4>
                                        <p class="text-sm text-gray-600">Personal projects and individual use</p>
                                    </div>
                                    <div class="radio-indicator"></div>
                                </div>
                            </div>
                        </label>
                        <label class="account-type-card cursor-pointer" for="accountTypeBusiness">
                            <input type="radio" id="accountTypeBusiness" name="accountType" value="BUSINESS" class="hidden">
                            <div class="p-6 border-2 border-gray-200 rounded-xl hover:border-blue-500 hover:bg-blue-50/50 transition-all account-type-option">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center flex-shrink-0">
                                        <i data-lucide="briefcase" class="w-6 h-6 text-purple-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-bold text-gray-900 mb-1">Business</h4>
                                        <p class="text-sm text-gray-600">Team collaboration and business operations</p>
                                    </div>
                                    <div class="radio-indicator"></div>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Step 3: Business Info (Conditional) -->
                <div id="step3" class="step-content">
                    <h3 class="text-lg font-bold text-gray-900 mb-6">Tell us about your business</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Business Name *</label>
                            <input type="text" id="businessName" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all" placeholder="Acme Corporation">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Business Sector *</label>
                            <select id="businessSector" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                                <option value="">Select sector</option>
                                <option value="Technology">Technology</option>
                                <option value="Healthcare">Healthcare</option>
                                <option value="Finance">Finance</option>
                                <option value="Education">Education</option>
                                <option value="Retail">Retail</option>
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="Consulting">Consulting</option>
                                <option value="Real Estate">Real Estate</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Business Address <span class="text-gray-400">(Optional)</span></label>
                            <textarea id="businessAddress" rows="2" class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all resize-none" placeholder="123 Main St, City, Country"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Step 4: Success -->
                <div id="step4" class="step-content text-center">
                    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="check-circle" class="w-10 h-10 text-green-600"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">All Set!</h3>
                    <p class="text-gray-600 mb-8">Your profile is complete. You're ready to explore Flozino.</p>
                    <button onclick="window.closeOnboardingModal()" class="px-8 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg font-medium hover:from-blue-700 hover:to-blue-800 transition-all shadow-lg hover:shadow-xl active:scale-95">
                        Get Started
                    </button>
                    <!-- Back button will be in the footer for Step 4? Or maybe explicit? 
                         User said "Back button on the last page". 
                         The standard back button is in the footer. 
                         I will modify logic to keep footer visible on Step 4 or add explicit button here. 
                         Actually, standard back button is cleaner. 
                    -->
                </div>
            </div>

            <!-- Error Message -->
            <div id="onboardingError" class="hidden mt-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                <p class="text-sm text-red-600 flex items-center gap-2">
                    <i data-lucide="alert-circle" class="w-4 h-4"></i>
                    <span id="onboardingErrorText"></span>
                </p>
            </div>

            <!-- Navigation Buttons -->
            <div class="flex items-center justify-between mt-8 pt-6 border-t border-gray-100" id="modalFooter">
                <!-- Back Button: Visible on Step 2, 3, AND 4 now -->
                <button id="backBtn" onclick="window.previousOnboardingStep()" class="px-6 py-2.5 text-gray-600 hover:text-gray-900 font-medium transition-all hidden">
                    <i data-lucide="arrow-left" class="w-4 h-4 inline mr-2"></i>
                    Back
                </button>
                <div class="flex-1"></div>
                <button id="skipBtn" onclick="window.skipOnboarding()" class="px-4 py-2.5 text-sm text-gray-500 hover:text-gray-700 transition-all mr-3 hidden">
                    Skip for now
                </button>
                <button id="nextBtn" onclick="window.nextOnboardingStep()" class="px-8 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-all shadow-md hover:shadow-lg active:scale-95">
                    <span id="nextBtnText">Continue</span>
                    <i data-lucide="arrow-right" class="w-4 h-4 inline ml-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const defaultIcon = document.getElementById('defaultIcon');
        const container = document.getElementById('imagePreviewContainer');
        
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                defaultIcon.classList.add('hidden');
                container.classList.remove('border-dashed');
                container.classList.add('border-solid');
            }
            
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
        </div>
    </div>
</div>

<!-- Styles Extracted to /css/components/onboarding-modal.css -->
<link rel="stylesheet" href="/css/components/onboarding-modal.css" nonce="<%= nonce %>">

<script nonce="<%= nonce %>">
    (function() {
        let currentStep = 1;
        const totalSteps = 4;

        window.nextOnboardingStep = async function() {
            // Validate current step
            if (currentStep === 1) {
                const firstName = document.getElementById('firstName').value.trim();
                const lastName = document.getElementById('lastName').value.trim();
                if (!firstName || firstName.length < 2) {
                    showError('First name must be at least 2 characters');
                    return;
                }
                if (!lastName || lastName.length < 2) {
                    showError('Last name must be at least 2 characters');
                    return;
                }
            } else if (currentStep === 2) {
                // Step 2 Validation (Implicitly handling logic here)
                const accountType = document.querySelector('input[name="accountType"]:checked').value;
                
                // If INDIVIDUAL, we are ready to submit
                if (accountType === 'INDIVIDUAL') {
                    await submitOnboarding();
                    return;
                }
                // If BUSINESS, proceed to Step 3
            } else if (currentStep === 3) {
                const businessName = document.getElementById('businessName').value.trim();
                const businessSector = document.getElementById('businessSector').value;
                if (!businessName) {
                    showError('Business name is required');
                    return;
                }
                if (!businessSector) {
                    showError('Please select a business sector');
                    return;
                }
                
                // Step 3 is the last step for Business
                await submitOnboarding();
                return;
            }

            // Navigation Logic (Only if not submitting)
            if (currentStep < totalSteps) {
                currentStep++;
                updateStepDisplay();
            }
        };

        window.previousOnboardingStep = function() {
            if (currentStep > 1) {
                const accountType = document.querySelector('input[name="accountType"]:checked').value;
                
                 if (currentStep === 4) {
                     if (accountType === 'INDIVIDUAL') {
                         currentStep = 2;
                     } else {
                         currentStep = 3;
                     }
                } else if (currentStep === 3) {
                     currentStep = 2;
                } else if (currentStep === 2) {
                     currentStep = 1;
                } else {
                    currentStep--;
                }
                
                updateStepDisplay();
            }
        };

        async function submitOnboarding() {
            try {
                // Create FormData for valid multipart/form-data submission
                const formData = new FormData();
                
                // Add fields
                formData.append('firstName', document.getElementById('firstName').value.trim());
                formData.append('lastName', document.getElementById('lastName').value.trim());
                
                const phoneNumber = document.getElementById('phoneNumber').value.trim();
                if (phoneNumber) formData.append('phoneNumber', phoneNumber);
                
                const profession = document.getElementById('profession').value;
                if (profession) formData.append('profession', profession);
                
                const accountType = document.querySelector('input[name="accountType"]:checked').value;
                formData.append('accountType', accountType);

                if (accountType === 'BUSINESS') {
                    formData.append('businessName', document.getElementById('businessName').value.trim());
                    formData.append('businessSector', document.getElementById('businessSector').value);
                    const businessAddress = document.getElementById('businessAddress').value.trim();
                    if (businessAddress) formData.append('businessAddress', businessAddress);
                }

                // Append Profile Image if selected
                const fileInput = document.getElementById('profileImage');
                if (fileInput && fileInput.files[0]) {
                    formData.append('profileImage', fileInput.files[0]);
                }

                const response = await fetch('/profile/onboarding', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    currentStep = 4;
                    updateStepDisplay();
                } else {
                    showError(result.error || 'Failed to save profile');
                }
            } catch (error) {
                console.error('[Onboarding] Submit error:', error);
                showError('An error occurred. Please try again.');
            }
        }

        function updateStepDisplay() {
            // Update step content
            document.querySelectorAll('.step-content').forEach((el, idx) => {
                if (idx + 1 === currentStep) {
                    el.classList.add('active');
                } else {
                    el.classList.remove('active');
                }
            });

            // Update step indicators
            for (let i = 1; i <= totalSteps; i++) {
                const indicator = document.getElementById('stepIndicator' + i);
                if (i < currentStep) {
                    indicator.classList.add('completed');
                    indicator.classList.remove('active');
                } else if (i === currentStep) {
                    indicator.classList.add('active');
                    indicator.classList.remove('completed');
                } else {
                    indicator.classList.remove('active', 'completed');
                }
            }

            // Update progress bar
            const progress = (currentStep / totalSteps) * 100;
            document.getElementById('progressBar').style.width = progress + '%';

            // Update buttons
            const backBtn = document.getElementById('backBtn');
            const nextBtn = document.getElementById('nextBtn');
            const skipBtn = document.getElementById('skipBtn');
            const nextBtnText = document.getElementById('nextBtnText');

            // 1. Back Button Visibility
            if (currentStep === 1) {
                backBtn.classList.add('hidden');
            } else {
                backBtn.classList.remove('hidden');
            }

            // 2. Next/Skip Buttons Visibility
            if (currentStep === 4) {
                // Success State: Hide Next/Skip. The "Get Started" button in content handles exit.
                nextBtn.classList.add('hidden');
                skipBtn.classList.add('hidden');
            } else {
                nextBtn.classList.remove('hidden');
                skipBtn.classList.add('hidden'); // FORCE ONBOARDING
            }

            // 3. Next Button Text
            // If strictly on Step 3, OR if on Step 2 AND Individual (which means next click submits)
            if (currentStep === 3 || (currentStep === 2 && document.querySelector('input[name="accountType"]:checked').value === 'INDIVIDUAL')) {
                nextBtnText.textContent = 'Complete';
            } else {
                nextBtnText.textContent = 'Continue';
            }

            hideError();
        }

        function showError(message) {
            document.getElementById('onboardingErrorText').textContent = message;
            document.getElementById('onboardingError').classList.remove('hidden');
        }

        function hideError() {
            document.getElementById('onboardingError').classList.add('hidden');
        }

        window.skipOnboarding = function() {
            if (confirm('You can complete your profile later from your account settings. Continue?')) {
                document.getElementById('onboardingModal').remove();
            }
        };

        window.closeOnboardingModal = function() {
            document.getElementById('onboardingModal').remove();
            location.reload(); // Refresh to update res.locals
        };
        
        // Preview Image Global Function (exposed to window for onchange)
        window.previewImage = function(input) {
            const preview = document.getElementById('imagePreview');
            const defaultIcon = document.getElementById('defaultIcon');
            const container = document.getElementById('imagePreviewContainer');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    defaultIcon.classList.add('hidden');
                    container.classList.remove('border-dashed');
                    container.classList.add('border-solid');
                }
                
                reader.readAsDataURL(input.files[0]);
            }
        };

        // Initialize Lucide icons after modal loads
        if (typeof lucide !== 'undefined') {
            setTimeout(() => lucide.createIcons(), 100);
        }
        
        // Initialize display
        updateStepDisplay();
    })();
</script>
<% } %>
