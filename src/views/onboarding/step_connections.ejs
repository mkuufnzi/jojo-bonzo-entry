<% layout('layouts/onboarding-layout') -%>

<form action="/onboarding/step/2" method="POST" class="space-y-6">
    
    <div>
        <h3 class="text-lg leading-6 font-medium text-gray-900">Connect Data Sources</h3>
        <p class="mt-1 text-sm text-gray-500">Select the platforms you use. You can connect them fully later in the dashboard.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <!-- QuickBooks -->
        <div class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-brand-blue">
            <div class="flex-shrink-0">
                <img class="h-10 w-10" src="https://companieslogo.com/img/orig/INTU-69092923.png?t=1720244492" alt="QuickBooks">
            </div>
            <div class="flex-1 min-w-0">
                <a href="#" class="focus:outline-none">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">QuickBooks Online</p>
                    <p class="text-sm text-gray-500 truncate">Accounting & Invoicing</p>
                </a>
            </div>
             <div class="h-5 flex items-center">
                 <input type="checkbox" name="connect_quickbooks" value="true" class="h-4 w-4 text-brand-blue border-gray-300 rounded focus:ring-brand-blue">
             </div>
        </div>

         <!-- Xero -->
        <div class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-brand-blue">
            <div class="flex-shrink-0">
                <img class="h-10 w-10" src="https://upload.wikimedia.org/wikipedia/en/thumb/9/9f/Xero_software_logo.svg/1200px-Xero_software_logo.svg.png" alt="Xero">
            </div>
            <div class="flex-1 min-w-0">
                <a href="#" class="focus:outline-none">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Xero</p>
                    <p class="text-sm text-gray-500 truncate">Cloud Accounting</p>
                </a>
            </div>
             <div class="h-5 flex items-center">
                 <input type="checkbox" name="connect_xero" value="true" class="h-4 w-4 text-brand-blue border-gray-300 rounded focus:ring-brand-blue">
             </div>
        </div>

        <!-- Stripe -->
        <div class="relative rounded-lg border border-gray-300 bg-white px-6 py-5 shadow-sm flex items-center space-x-3 hover:border-gray-400 focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-brand-blue">
             <div class="flex-shrink-0">
                <img class="h-10 w-10" src="https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg" alt="Stripe">
            </div>
            <div class="flex-1 min-w-0">
                 <a href="#" class="focus:outline-none">
                    <span class="absolute inset-0" aria-hidden="true"></span>
                    <p class="text-sm font-medium text-gray-900">Stripe</p>
                    <p class="text-sm text-gray-500 truncate">Payments & Billing</p>
                </a>
            </div>
            <div class="h-5 flex items-center">
                 <input type="checkbox" name="connect_stripe" value="true" class="h-4 w-4 text-brand-blue border-gray-300 rounded focus:ring-brand-blue">
             </div>
        </div>
    </div>

    <div class="pt-5 border-t border-gray-200">
        <div class="flex justify-between">
            <a href="/onboarding/step/1" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue">Back</a>
            <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-brand-blue hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue">
                Next: Branding
            </button>
        </div>
    </div>
</form>
