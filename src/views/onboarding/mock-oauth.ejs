<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connect <%= providerName %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-50 font-sans text-gray-900 flex items-center justify-center min-h-screen">

    <div class="bg-white rounded-xl shadow-lg max-w-md w-full p-8 text-center">
        
        <!-- Logos -->
        <div class="flex items-center justify-center space-x-6 mb-8">
            <div class="w-16 h-16 bg-blue-600 rounded-xl flex items-center justify-center text-white text-2xl font-bold shadow-md">
                F
            </div>
            <div class="text-gray-300 text-xl">⇄</div>
            <div class="w-16 h-16 bg-white border border-gray-100 rounded-xl flex items-center justify-center shadow-md p-2">
                <% if (logoUrl) { %>
                    <img src="<%= logoUrl %>" class="w-full h-full object-contain">
                <% } else { %>
                    <span class="text-xl font-bold text-gray-500"><%= providerName.substring(0,2) %></span>
                <% } %>
            </div>
        </div>

        <h1 class="text-2xl font-bold mb-2">Connect <%= providerName %></h1>
        <p class="text-gray-500 mb-8">
            <span class="font-semibold text-gray-900">Floovioo</span> would like to access your:
        </p>

        <!-- Permissions -->
        <div class="text-left bg-gray-50 p-4 rounded-lg mb-8 space-y-3">
            <div class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <div>
                    <span class="block font-medium text-sm">View Invoices & Customers</span>
                    <span class="block text-xs text-gray-500">Read-only access to invoice data</span>
                </div>
            </div>
            <div class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <div>
                    <span class="block font-medium text-sm">Company Profile</span>
                    <span class="block text-xs text-gray-500">View basic business details</span>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="space-y-3">
            <a href="<%= callbackUrl %>" class="block w-full py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">
                Authorize Access
            </a>
            <a href="/onboarding/wizard?step=2" class="block w-full py-3 text-gray-500 hover:text-gray-700 font-medium text-sm">
                Cancel
            </a>
        </div>
        
        <div class="mt-8 text-xs text-gray-400">
            This is a mock consent screen for development purposes.
        </div>

    </div>

</body>
</html>
