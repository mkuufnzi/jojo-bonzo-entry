<% layout('layouts/onboarding-layout') -%>

<form action="/onboarding/step/3" method="POST" class="space-y-6">
    
    <div>
        <h3 class="text-lg leading-6 font-medium text-gray-900">Brand Identity</h3>
        <p class="mt-1 text-sm text-gray-500">Define your primary look. You can create multiple profiles later.</p>
    </div>

    <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
        
        <!-- Colors -->
        <div class="sm:col-span-2">
            <label for="primaryColor" class="block text-sm font-medium text-gray-700">Primary Color</label>
            <div class="mt-1 flex items-center space-x-2">
                <input type="color" name="primaryColor" id="primaryColor" value="#2563EB" class="h-10 w-10 border border-gray-300 rounded overflow-hidden p-0">
                <input type="text" value="#2563EB" class="shadow-sm focus:ring-brand-blue focus:border-brand-blue block w-full sm:text-sm border-gray-300 rounded-md" onchange="document.getElementById('primaryColor').value = this.value">
            </div>
            <p class="mt-1 text-xs text-gray-500">Main brand buttons & highlights.</p>
        </div>

        <div class="sm:col-span-2">
            <label for="accentColor" class="block text-sm font-medium text-gray-700">Accent Color</label>
             <div class="mt-1 flex items-center space-x-2">
                <input type="color" name="accentColor" id="accentColor" value="#CA8A04" class="h-10 w-10 border border-gray-300 rounded overflow-hidden p-0">
                 <input type="text" value="#CA8A04" class="shadow-sm focus:ring-brand-blue focus:border-brand-blue block w-full sm:text-sm border-gray-300 rounded-md" onchange="document.getElementById('accentColor').value = this.value">
            </div>
             <p class="mt-1 text-xs text-gray-500">Call to actions or warnings.</p>
        </div>

         <div class="sm:col-span-6">
            <label class="block text-sm font-medium text-gray-700">Typography</label>
            <div class="mt-2 grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-4">
                 <div>
                    <label for="fontHeading" class="block text-xs font-medium text-gray-500">Heading Font</label>
                    <select id="fontHeading" name="fontHeading" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-brand-blue focus:border-brand-blue sm:text-sm rounded-md">
                        <option value="Inter">Inter (Clean, Modern)</option>
                        <option value="Roboto">Roboto (Technical)</option>
                        <option value="Merriweather">Merriweather (Serif, Classic)</option>
                    </select>
                </div>
                 <div>
                    <label for="fontBody" class="block text-xs font-medium text-gray-500">Body Font</label>
                     <select id="fontBody" name="fontBody" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-brand-blue focus:border-brand-blue sm:text-sm rounded-md">
                        <option value="Inter">Inter</option>
                        <option value="Roboto">Roboto</option>
                        <option value="Open Sans">Open Sans</option>
                    </select>
                </div>
            </div>
        </div>

    </div>

    <div class="pt-5 border-t border-gray-200">
        <div class="flex justify-between">
             <a href="/onboarding/step/2" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue">Back</a>
            <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                Finish Setup
            </button>
        </div>
    </div>
</form>
