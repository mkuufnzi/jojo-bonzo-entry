<!-- Component: Customer Support Widget (Card Style) -->
<div class="mt-8 pt-8 border-t border-gray-100" x-show="config.customerSupportResult !== false">
    <div class="bg-slate-50 rounded-xl p-5 border border-slate-100">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            
            <!-- Headline -->
            <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-white text-lg shadow-sm"
                     :style="'background: ' + theme.primary">
                    ?
                </div>
                <div>
                    <h4 class="font-bold text-sm text-slate-800">Need help with your order?</h4>
                    <p class="text-xs text-slate-500 mt-0.5">Our support team is available 24/7.</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-2 w-full sm:w-auto">
                <a href="#" class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm">
                    <span class="text-sm">📧</span> Email Us
                </a>
                <a href="#" class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors shadow-sm">
                    <span class="text-sm">💬</span> Live Chat
                </a>
            </div>

        </div>
    </div>
</div>
