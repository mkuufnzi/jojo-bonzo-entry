<!-- Review Request Widget -->
<div class="mx-8 mt-6 bg-gradient-to-r from-sky-50 to-blue-50 rounded-xl p-6 border border-sky-100">
    <div class="text-center">
        <div class="font-semibold text-sky-800 mb-2">How was your experience?</div>
        <!-- Alpine Rating if enabled, or just static links -->
        <div class="grid grid-cols-1 gap-3 font-sans">
        <template x-for="review in reviews" :key="review.id">
            <div class="bg-gray-50 rounded-lg p-3 border border-gray-100 flex justify-between items-center">
                <span class="text-xs font-medium text-gray-700" x-text="review.question"></span>
                <div class="flex gap-1">
                    <template x-if="review.type === 'rating'">
                        <div class="flex">
                            <template x-for="i in 5">
                                <span class="text-gray-300 text-sm cursor-pointer hover:text-yellow-400">★</span>
                            </template>
                        </div>
                    </template>
                    <template x-if="review.type === 'upload'">
                        <button class="bg-white border px-3 py-1 rounded text-[10px] font-bold uppercase tracking-wider">Upload</button>
                    </template>
                </div>
            </div>
        </template>
    </div>    <div class="text-sm text-sky-600">Your feedback helps us improve</div>
        <button class="mt-3 text-sky-700 hover:text-sky-800 text-sm font-semibold underline no-print">
            Write a detailed review →
        </button>
    </div>
</div>
