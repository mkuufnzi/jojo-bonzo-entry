<!-- MARKETING NURTURE BANNER -->
<!-- Expects: nurtureMsg (Alpine) or server-side data -->
<div class="mt-5 rounded-2xl p-5 cursor-pointer relative overflow-hidden shadow-lg transition-transform hover:scale-[1.01]"
     :style="'background: linear-gradient(135deg, #1E293B 0%, #334155 100%)'"
     @click="cycleNurture">
     <div class="absolute -top-5 -right-5 w-24 h-24 rounded-full bg-white/5"></div>
     
     <div class="relative flex items-start gap-3.5 z-10">
         <div class="text-2xl leading-none" x-text="nurtureMsg.icon"></div>
         <div class="flex-1">
             <div class="text-[13px] font-bold text-white mb-1 font-sans" x-text="nurtureMsg.headline"></div>
             <div class="text-[11px] text-white/60 leading-relaxed font-sans" x-text="nurtureMsg.body"></div>
         </div>
         <div class="text-[9px] text-white/30 uppercase tracking-widest mt-1">tap &rarr;</div>
     </div>
     
     <div class="flex gap-1.5 justify-center mt-3">
         <template x-for="(msg, idx) in nurtureMessages">
             <div class="h-1.5 rounded-full transition-all duration-300"
                  :style="{ width: idx === nurtureMsgIdx ? '18px' : '6px', background: idx === nurtureMsgIdx ? (theme.secondary || '#C9A227') : 'rgba(255,255,255,0.2)' }"></div>
         </template>
     </div>
</div>
