<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Breadcrumbs -->
    <div class="mb-6">
        <a href="/dashboard/workflows" class="text-slate-500 hover:text-slate-900 text-sm font-medium flex items-center gap-2 transition-colors">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>
            Back to Automations
        </a>
    </div>

    <!-- Header -->
    <div class="mb-10 flex items-center justify-between">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <span class="px-2 py-0.5 rounded text-[0.625rem] font-bold uppercase tracking-widest <%= workflow.isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                    <%= workflow.isActive ? 'Active' : 'Paused' %>
                </span>
                <span class="text-slate-400 text-sm font-mono">ID: <%= workflow.id %></span>
            </div>
            <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight"><%= workflow.name %></h1>
            <p class="text-slate-500 font-medium mt-1"><%= workflow.description || 'No description provided' %></p>
        </div>
        <div class="flex items-center gap-3">
            <form action="/dashboard/workflows/<%= workflow.id %>/test" method="POST">
                <button type="submit" class="bg-white border border-slate-200 text-slate-700 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center gap-2">
                    <i data-lucide="play" class="w-4 h-4 text-blue-500"></i>
                    Test Run
                </button>
            </form>
            <form action="/dashboard/workflows/<%= workflow.id %>/toggle" method="POST">
                <button type="submit" class="bg-slate-900 text-white px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg">
                    <%= workflow.isActive ? 'Pause Workflow' : 'Activate Workflow' %>
                </button>
            </form>
        </div>
    </div>

    <!-- Configuration Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <!-- Trigger -->
        <div class="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <i data-lucide="zap" class="w-24 h-24 text-amber-500"></i>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Trigger Configuration</h3>
            <div class="space-y-4 relative z-10">
                <div>
                    <span class="text-xs text-slate-500 font-bold uppercase">Type</span>
                    <p class="text-lg font-bold text-slate-900"><%= workflow.triggerType %></p>
                </div>
                <% if (workflow.triggerConfig) { %>
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                        <pre class="text-xs font-mono text-slate-600 overflow-x-auto"><%= JSON.stringify(workflow.triggerConfig, null, 2) %></pre>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Action -->
        <div class="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                <i data-lucide="activity" class="w-24 h-24 text-blue-500"></i>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Action Configuration</h3>
             <div class="space-y-4 relative z-10">
                <div>
                    <span class="text-xs text-slate-500 font-bold uppercase">Type</span>
                    <p class="text-lg font-bold text-slate-900"><%= workflow.actionConfig?.type || 'Unknown' %></p>
                </div>
                <% if (workflow.actionConfig) { %>
                    <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                        <pre class="text-xs font-mono text-slate-600 overflow-x-auto"><%= JSON.stringify(workflow.actionConfig, null, 2) %></pre>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Activity Log -->
    <div class="bg-white border border-slate-200 rounded-[2.5rem] shadow-sm overflow-hidden mb-10">
        <div class="p-6 border-b border-slate-100 bg-slate-50/30 flex items-center justify-between">
            <h3 class="text-xs font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                <i data-lucide="history" class="w-4 h-4 text-slate-400"></i>
                Recent Executions
            </h3>
            <span class="text-xs font-medium text-slate-500"><%= logs.length %> runs shown</span>
        </div>
        
        <% if (logs && logs.length > 0) { %>
            <div class="divide-y divide-slate-50">
                <% logs.forEach(log => { %>
                    <div class="p-4 hover:bg-slate-50/50 transition-colors flex items-center justify-between group">
                        <div class="flex items-center gap-4">
                            <div class="w-2 h-2 rounded-full <%= log.status === 'success' ? 'bg-emerald-500' : 'bg-red-500' %>"></div>
                            <div>
                                <p class="text-sm font-bold text-slate-900">
                                    <%= log.status === 'success' ? 'Success' : 'Failed' %>
                                </p>
                                <p class="text-xs text-slate-500 font-mono">
                                    <%= new Date(log.createdAt).toLocaleString() %>
                                </p>
                            </div>
                        </div>
                        
                        <div class="hidden md:block max-w-[200px]">
                            <p class="text-xs text-slate-400 font-mono truncate" title="<%= JSON.stringify(log.inputData) %>">
                                In: <%= JSON.stringify(log.inputData).substring(0, 30) %>...
                            </p>
                        </div>

                        <div class="flex items-center gap-4">
                             <span class="text-xs font-bold text-slate-500"><%= log.duration %>ms</span>
                             
                             <% if (log.outputData && log.outputData.artifacts && log.outputData.artifacts.pdfUrl) { %>
                                <a href="<%= log.outputData.artifacts.pdfUrl %>" target="_blank" class="px-3 py-1 bg-blue-50 text-blue-600 rounded-lg text-xs font-bold hover:bg-blue-100 transition-colors">
                                    View PDF
                                </a>
                             <% } %>

                             <button onclick="document.getElementById('log-<%= log.id %>').classList.toggle('hidden')" class="p-2 text-slate-300 hover:text-slate-600 transition-colors">
                                <i data-lucide="chevron-down" class="w-4 h-4"></i>
                             </button>
                        </div>
                    </div>
                    <!-- Details Drawer -->
                    <div id="log-<%= log.id %>" class="hidden bg-slate-50 p-6 border-b border-slate-100">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <h4 class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2">Input Payload</h4>
                                <pre class="text-xs font-mono text-slate-600 bg-white p-3 rounded-lg border border-slate-200 overflow-x-auto"><%= JSON.stringify(log.inputData, null, 2) %></pre>
                            </div>
                             <div>
                                <h4 class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2">Result</h4>
                                <pre class="text-xs font-mono text-slate-600 bg-white p-3 rounded-lg border border-slate-200 overflow-x-auto"><%= JSON.stringify(log.outputData, null, 2) %></pre>
                                <% if (log.error) { %>
                                    <div class="mt-2 text-xs text-red-600 font-bold bg-red-50 p-2 rounded">
                                        Error: <%= log.error %>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="p-12 text-center text-slate-400 text-sm">
                No executions yet. Run a test!
            </div>
        <% } %>
    </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
