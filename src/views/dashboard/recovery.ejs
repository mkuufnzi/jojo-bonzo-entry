<%- layout('layouts/dashboard-layout') %>

<div class="w-full max-w-[1920px] mx-auto px-2 sm:px-6 overflow-x-hidden" x-data="recoveryDashboard()">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
        <div>
            <h1 class="text-2xl sm:text-3xl font-heading font-black text-slate-900 tracking-tight flex items-center gap-3">
                <div class="p-2 bg-emerald-100 rounded-xl">
                    <i data-lucide="shield-check" class="w-6 h-6 text-emerald-600"></i>
                </div>
                Smart Recovery
            </h1>
            <p class="text-xs sm:text-sm text-slate-500 font-medium mt-1">Automated follow-ups for unpaid invoices. Recover revenue on autopilot.</p>
        </div>

        <button @click="triggerSync()" 
                :disabled="syncing"
                class="flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-emerald-500 transition-all shadow-lg active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
            <i data-lucide="refresh-cw" class="w-4 h-4" :class="{ 'animate-spin': syncing }"></i>
            <span x-text="syncing ? 'Syncing...' : 'Sync Now'"></span>
        </button>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 sm:gap-6 mb-10">
        <!-- Total Invoices (Connection Health) -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 group hover:shadow-md transition-all">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Total Invoices</span>
                <div class="p-2 bg-blue-50 rounded-lg">
                    <i data-lucide="database" class="w-4 h-4 text-blue-500"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-slate-900"><%= recovery.totalInvoices || 0 %></p>
            <p class="text-[10px] text-slate-400 mt-1 font-medium"><%= recovery.unpaidInvoices || 0 %> unpaid / open</p>
        </div>

        <!-- Total Overdue -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 group hover:shadow-md transition-all">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Overdue Invoices</span>
                <div class="p-2 bg-red-50 rounded-lg">
                    <i data-lucide="alert-triangle" class="w-4 h-4 text-red-500"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-slate-900"><%= recovery.totalOverdue %></p>
            <p class="text-[10px] text-slate-400 mt-1 font-medium">requiring follow-up</p>
        </div>

        <!-- Pending Reminders -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 group hover:shadow-md transition-all">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Pending Reminders</span>
                <div class="p-2 bg-amber-50 rounded-lg">
                    <i data-lucide="clock" class="w-4 h-4 text-amber-500"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-slate-900"><%= recovery.pendingReminders %></p>
            <p class="text-[10px] text-slate-400 mt-1 font-medium">queued for delivery</p>
        </div>

        <!-- Recovered Amount -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 group hover:shadow-md transition-all">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Recovered</span>
                <div class="p-2 bg-emerald-50 rounded-lg">
                    <i data-lucide="trending-up" class="w-4 h-4 text-emerald-500"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-emerald-600">$<%= (recovery.recoveredAmount || 0).toLocaleString() %></p>
            <p class="text-[10px] text-slate-400 mt-1 font-medium">total recovered</p>
        </div>

        <!-- Active Sequences -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 group hover:shadow-md transition-all">
            <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Active Sequences</span>
                <div class="p-2 bg-indigo-50 rounded-lg">
                    <i data-lucide="zap" class="w-4 h-4 text-indigo-500"></i>
                </div>
            </div>
            <p class="text-3xl font-black text-slate-900"><%= recovery.activeSequences %></p>
            <p class="text-[10px] text-slate-400 mt-1 font-medium">dunning workflows</p>
        </div>
    </div>

    <!-- Recovery Sequence Configuration -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Sequence Editor -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 sm:p-8">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="settings" class="w-4 h-4"></i>
                    Recovery Sequence
                </h3>
                <div class="flex items-center gap-4">
                    <a href="/dashboard/recovery/onboarding?step=1" class="text-xs font-bold text-slate-500 hover:text-slate-800 flex items-center gap-1 transition-colors">
                        <i data-lucide="help-circle" class="w-3 h-3"></i>
                        Relaunch Setup
                    </a>
                    <a href="/dashboard/recovery/settings" class="text-xs font-bold text-indigo-600 hover:text-indigo-700 flex items-center gap-1 transition-all">
                        Manage Workflows
                        <i data-lucide="arrow-right" class="w-3 h-3"></i>
                    </a>
                </div>
            </div>
            <p class="text-xs text-slate-500 mb-6">Define the follow-up schedule. Each step triggers an automated, branded reminder via your configured workflows.</p>

            <div class="space-y-4">
                <% if (recovery.sequence && recovery.sequence.steps && recovery.sequence.steps.length > 0) { %>
                    <% recovery.sequence.steps.forEach((step, index) => { %>
                        <div onclick="window.location.href='/dashboard/recovery/settings'" class="flex items-center gap-4 p-4 rounded-xl border relative group cursor-pointer transition-all
                            <%= index === 0 ? 'bg-emerald-50/50 border-emerald-100 hover:bg-emerald-50' : 
                                index === 1 ? 'bg-amber-50/50 border-amber-100 hover:bg-amber-50' : 
                                'bg-red-50/50 border-red-100 hover:bg-red-50' %>" role="button">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0
                                <%= index === 0 ? 'bg-emerald-100' : 
                                    index === 1 ? 'bg-amber-100' : 
                                    'bg-red-100' %>">
                                <span class="text-sm font-black <%= index === 0 ? 'text-emerald-600' : index === 1 ? 'text-amber-600' : 'text-red-600' %>"><%= index + 1 %></span>
                            </div>
                            <div class="flex-1">
                                <div class="flex justify-between items-center">
                                    <h4 class="text-sm font-bold text-slate-700">
                                        <%= step.templateId === 'reminder_gentle' ? 'Gentle Reminder' : 
                                            step.templateId === 'reminder_firm' ? 'Firm Follow-Up' : 
                                            step.templateId === 'reminder_final' ? 'Final Notice' : 'Reminder Step' %>
                                    </h4>
                                    <i data-lucide="edit-2" class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity <%= index === 0 ? 'text-emerald-400' : index === 1 ? 'text-amber-400' : 'text-red-400' %>"></i>
                                </div>
                                <p class="text-[10px] text-slate-400 font-medium">Day <%= step.day %> after due date • <%= step.action.toUpperCase() %></p>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-xs text-slate-400 italic py-4">No sequence steps defined.</p>
                <% } %>
            </div>

            <div class="mt-6 pt-4 border-t border-slate-100">
                <p class="text-[10px] text-slate-400 italic">
                    <i data-lucide="info" class="w-3 h-3 inline mr-1"></i>
                    Need to change the message or timing? <a href="/dashboard/recovery/settings" class="text-indigo-500 hover:text-indigo-600 font-bold">Edit the configuration</a>.
                </p>
            </div>
        </div>

        <!-- How It Works -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 sm:p-8">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                <i data-lucide="info" class="w-4 h-4"></i>
                How Smart Recovery Works
            </h3>

            <div class="space-y-6">
                <div class="flex gap-4">
                    <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                        <i data-lucide="search" class="w-4 h-4 text-indigo-600"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-700">1. Detect</h4>
                        <p class="text-xs text-slate-500">Floovioo scans your connected ERP for invoices past their due date (plus your <%= recovery.sequence?.settings?.gracePeriod || 0 %> day grace period).</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                        <i data-lucide="file-text" class="w-4 h-4 text-indigo-600"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-700">2. Brand & Personalize</h4>
                        <p class="text-xs text-slate-500">Reminders are rendered using your brand identity. You can customize the copy and tone in the <a href="/dashboard/workflows" class="text-blue-500 hover:underline">Workflows editor</a>.</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="w-8 h-8 bg-indigo-100 rounded-lg flex items-center justify-center shrink-0">
                        <i data-lucide="send" class="w-4 h-4 text-indigo-600"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-700">3. Deliver</h4>
                        <p class="text-xs text-slate-500">Reminders are automatically sent on a configurable schedule (Day 1, Day 7, Day 14) via the Floovioo branding pipeline.</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center shrink-0">
                        <i data-lucide="bar-chart-2" class="w-4 h-4 text-emerald-600"></i>
                    </div>
                    <div>
                        <h4 class="text-sm font-bold text-slate-700">4. Track</h4>
                        <p class="text-xs text-slate-500">When a payment webhook is received, Floovioo matches it to the recovery sequence and records the recovered amount.</p>
                    </div>
                </div>
            </div>

            <!-- Status Banner -->
            <div class="mt-8 p-4 bg-gradient-to-r from-emerald-50 to-indigo-50 rounded-xl border border-emerald-100">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-white rounded-lg shadow-sm">
                        <i data-lucide="shield-check" class="w-5 h-5 text-emerald-500"></i>
                    </div>
                    <div>
                        <h4 class="text-xs font-bold text-slate-700">Recovery Engine Status</h4>
                        <p class="text-[10px] text-slate-500"><%= recovery.activeSequences > 0 ? 'Active and monitoring your invoices.' : 'Inactive. Configure a sequence to begin.' %></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div x-show="toast" 
         x-transition
         class="fixed bottom-6 right-6 z-50 px-6 py-3 rounded-xl shadow-2xl text-sm font-bold flex items-center gap-2"
         :class="toastType === 'success' ? 'bg-emerald-600 text-white' : 'bg-red-600 text-white'">
        <i data-lucide="check-circle" class="w-4 h-4" x-show="toastType === 'success'"></i>
        <i data-lucide="alert-circle" class="w-4 h-4" x-show="toastType === 'error'"></i>
        <span x-text="toastMessage"></span>
    </div>
</div>

<script nonce="<%= nonce %>">
function recoveryDashboard() {
    return {
        syncing: false,
        toast: false,
        toastMessage: '',
        toastType: 'success',

        async triggerSync() {
            this.syncing = true;
            try {
                const res = await fetch('/dashboard/recovery/trigger', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await res.json();
                
                if (data.success) {
                    this.showToast('Sync triggered! Check back in a moment.', 'success');
                } else {
                    this.showToast(data.error || 'Sync failed', 'error');
                }
            } catch (e) {
                this.showToast('Network error. Please try again.', 'error');
            } finally {
                this.syncing = false;
            }
        },

        showToast(message, type = 'success') {
            this.toastMessage = message;
            this.toastType = type;
            this.toast = true;
            setTimeout(() => this.toast = false, 4000);
        }
    };
}

document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
