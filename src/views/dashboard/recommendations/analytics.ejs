<%- layout('layouts/dashboard-layout') %>

<!-- Content Area -->
<div class="max-w-7xl mx-auto space-y-12 pb-20" x-data="{ loading: false }">
    
    <!-- Header: Dynamic Stats -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 py-6">
        <div class="space-y-3">
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-[0.65rem] font-black uppercase tracking-[0.15em] text-indigo-600 mb-2">
                <i data-lucide="line-chart" class="w-3.5 h-3.5"></i>
                <span>Ecosystem Performance</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-black tracking-tight text-slate-900 dark:text-white leading-tight">Performance Analytics</h1>
            <p class="text-slate-500 dark:text-slate-400 font-medium max-w-2xl text-lg">Cross-platform conversion tracking and revenue lift attribution for your smart recommendation engine.</p>
        </div>
        
        <div class="flex items-center bg-white/60 dark:bg-slate-900/60 backdrop-blur-xl p-3 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-2xl overflow-hidden divide-x divide-slate-100 dark:divide-slate-800">
            <div class="px-8 py-2">
                <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest mb-1 text-center">Precise Conv.</p>
                <p class="text-3xl font-black text-indigo-600 tracking-tighter text-center"><%= metrics.conversionRate %></p>
            </div>
            <div class="px-8 py-2">
                <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest mb-1 text-center">Revenue Boost</p>
                <p class="text-3xl font-black text-emerald-600 tracking-tighter text-center"><%= metrics.revenueLift %></p>
            </div>
        </div>
    </div>

    <!-- Tier 1: Core Performance Visualizations -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Category Distribution (Glassmorphism) -->
        <div class="lg:col-span-2 bg-white/60 dark:bg-slate-900/60 backdrop-blur-2xl rounded-[3rem] border border-slate-200 dark:border-slate-800 p-10 shadow-2xl relative overflow-hidden group">
            <div class="flex items-center justify-between mb-12 relative z-10">
                <div class="space-y-1">
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white">Catalog Reach</h3>
                    <p class="text-sm text-slate-500 font-medium">Distribution of products and pricing tiers across your active categories.</p>
                </div>
                <div class="flex items-center space-x-3 px-4 py-2 bg-slate-50 dark:bg-slate-800 rounded-xl">
                    <span class="w-3 h-3 rounded-full bg-indigo-500 animate-pulse"></span>
                    <span class="text-[0.65rem] font-black text-slate-400 uppercase tracking-widest">Live Matrix</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
                <div class="h-72 relative animate-in fade-in duration-1000">
                    <canvas id="categoryChart"></canvas>
                </div>
                <div class="space-y-8">
                    <div class="flex items-center justify-between">
                        <p class="text-[0.65rem] font-black text-slate-400 uppercase tracking-widest">Value Distribution</p>
                        <span class="text-[0.6rem] font-bold text-slate-400">Total: <%= analytics.catalogSize %> units</span>
                    </div>
                    <div class="space-y-6">
                        <% if (analytics.priceRanges && analytics.priceRanges.length > 0) { %>
                            <% analytics.priceRanges.forEach((range, idx) => { %>
                                <div class="space-y-3 group/item">
                                    <div class="flex justify-between items-center text-[0.7rem] font-black">
                                        <span class="text-slate-500 group-hover/item:text-slate-700 dark:group-hover/item:text-slate-300 transition-colors"><%= range.label %></span>
                                        <span class="text-slate-900 dark:text-white"><%= range.value %> item<%= range.value === 1 ? '' : 's' %></span>
                                    </div>
                                    <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden p-0.5">
                                        <div class="h-full bg-gradient-to-r from-indigo-600 to-indigo-400 rounded-full shadow-sm transition-all duration-1000 ease-out" 
                                             style="width: <%= Math.max(5, (range.value / (analytics.catalogSize || 1) * 100)).toFixed(0) %>%; opacity: <%= (1 - (idx * 0.12)).toFixed(2) %>"></div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Atmospheric Glimmer -->
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none"></div>
            <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-emerald-500/10 rounded-full blur-[100px] pointer-events-none"></div>
        </div>

        <!-- Conversion Funnel Shell -->
        <div class="bg-slate-950 rounded-[3rem] border border-slate-800 p-10 text-white shadow-2xl relative overflow-hidden flex flex-col justify-between">
            <div class="relative z-10">
                <div class="w-16 h-16 rounded-[1.5rem] bg-indigo-600 flex items-center justify-center mb-10 shadow-2xl shadow-indigo-500/40">
                    <i data-lucide="zap" class="w-8 h-8 text-white"></i>
                </div>
                <h3 class="text-3xl font-black mb-4 tracking-tight leading-tight">Contextual Performance</h3>
                <p class="text-slate-400 font-medium text-sm leading-relaxed mb-12">Tracking every impression that successfully converts into a document line-item.</p>
                
                <div class="space-y-10">
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">Total Impressions</span>
                            <span class="text-2xl font-black text-white tracking-tighter"><%= metrics.impressions %></span>
                        </div>
                        <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden p-0.5">
                            <div class="h-full bg-white/20 w-full rounded-full"></div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <div class="flex justify-between items-end">
                            <span class="text-[0.65rem] font-black text-indigo-400 uppercase tracking-widest">Attributed Conv.</span>
                            <span class="text-2xl font-black text-indigo-400 tracking-tighter"><%= metrics.conversions %></span>
                        </div>
                        <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden p-0.5">
                            <div class="h-full bg-indigo-500 rounded-full shadow-[0_0_15px_rgba(99,102,241,0.5)]" style="width: <%= metrics.conversionRate %>"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="relative z-10 pt-10 mt-12 border-t border-white/5">
                <div class="flex items-center justify-between">
                    <span class="text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">Ecosystem Yield</span>
                    <span class="text-3xl font-black text-emerald-400 tracking-tighter"><%= metrics.revenueLift %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tier 2: Behavioral Intelligence -->
    <div class="space-y-8">
        <div class="flex items-end justify-between">
            <div class="space-y-1">
                <h3 class="text-2xl font-black text-slate-900 dark:text-white">Behavioral Segmentation</h3>
                <p class="text-sm text-slate-500 font-medium text-white/50">Dynamic clusters derived from Unified Data Hub RFM analysis.</p>
            </div>
            <a href="/dashboard/recommendations/segments" class="text-indigo-600 dark:text-indigo-400 font-black text-xs uppercase tracking-widest flex items-center group">
                Real-time Clusters
                <i data-lucide="arrow-right" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% customerClusters.forEach(cluster => { %>
                <a href="/dashboard/recommendations/segments/<%= cluster.clusterId %>" class="bg-white/40 dark:bg-slate-900/40 backdrop-blur-xl border border-slate-200 dark:border-slate-800 p-8 rounded-[2rem] group hover:border-<%= cluster.color %>-500 transition-all shadow-xl hover:shadow-<%= cluster.color %>-500/10">
                    <div class="flex items-center justify-between mb-8">
                        <div class="w-12 h-12 rounded-2xl bg-<%= cluster.color %>-500/10 flex items-center justify-center text-<%= cluster.color %>-500 group-hover:scale-110 transition-transform shadow-inner">
                            <i data-lucide="users" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[0.625rem] font-black uppercase text-slate-400 opacity-60">Deep Dive <i data-lucide="chevron-right" class="w-3 h-3 inline ml-1"></i></span>
                    </div>
                    <h4 class="text-lg font-black text-slate-800 dark:text-white uppercase tracking-tight mb-2"><%= cluster.name %></h4>
                    <p class="text-xs font-medium text-slate-500 mb-6 line-clamp-2 leading-relaxed"><%= cluster.description %></p>
                    <div class="flex items-end justify-between pt-6 border-t border-slate-100 dark:border-slate-800">
                        <div class="space-y-1">
                            <p class="text-[0.65rem] font-black text-slate-400 uppercase tracking-widest">Pop. Size</p>
                            <span class="text-xl font-black text-slate-900 dark:text-white leading-none"><%= cluster.size %></span>
                        </div>
                        <div class="text-right space-y-1">
                            <p class="text-[0.65rem] font-black text-slate-400 uppercase tracking-widest text-right">AOV</p>
                            <span class="text-xs font-black text-<%= cluster.color %>-500 uppercase tracking-widest"><%= cluster.avgOrderValue || '£0.00' %></span>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>

    <!-- Tier 3: Engagement Insights -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        
        <!-- Purchase Clusters Chart -->
        <div class="bg-white/60 dark:bg-slate-900/60 backdrop-blur-xl rounded-[3rem] border border-slate-200 dark:border-slate-800 p-10 shadow-xl overflow-hidden">
            <div class="flex items-center justify-between mb-12">
                <div class="space-y-1">
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tight">Cluster Distribution</h3>
                    <p class="text-sm text-slate-500 font-medium">Population density contrast across behavioral tiers.</p>
                </div>
                <div class="w-12 h-12 bg-slate-50 dark:bg-slate-800 rounded-2xl flex items-center justify-center text-slate-400 shadow-inner">
                    <i data-lucide="bar-chart-3" class="w-6 h-6"></i>
                </div>
            </div>
            <div class="h-80 w-full">
                <canvas id="clusterChart"></canvas>
            </div>
        </div>

        <!-- Affinity Rankings -->
        <div class="bg-white/60 dark:bg-slate-900/60 backdrop-blur-xl rounded-[3rem] border border-slate-200 dark:border-slate-800 shadow-xl flex flex-col overflow-hidden">
            <div class="px-10 py-8 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
                <div class="space-y-1">
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white uppercase tracking-tight">Affinity Rankings</h3>
                    <p class="text-sm text-slate-500 font-medium">Top high-confidence cross-sell pairs.</p>
                </div>
                <div class="bg-indigo-500/10 text-indigo-600 px-3 py-1 rounded-lg text-[0.6rem] font-black uppercase tracking-widest">Beta Engine</div>
            </div>
            <div class="flex-grow">
                <table class="w-full text-left">
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800/50 text-xs text-white/50">
                        <% if (affinities && affinities.length > 0) { %>
                            <% affinities.slice(0, 5).forEach((a, idx) => { %>
                                <tr class="hover:bg-indigo-50/30 dark:hover:bg-indigo-900/10 transition-colors group">
                                    <td class="px-10 py-6">
                                        <div class="flex items-center space-x-5">
                                            <div class="w-12 h-12 rounded-2xl bg-slate-50 dark:bg-slate-800 font-black text-slate-400 flex items-center justify-center text-lg shadow-inner group-hover:bg-indigo-500 group-hover:text-white transition-all">
                                                <%= idx + 1 %>
                                            </div>
                                            <div>
                                                <p class="block text-sm font-black text-slate-900 dark:text-white mb-1"><%= a.baseProduct %></p>
                                                <div class="flex items-center text-[0.65rem] text-slate-400 font-bold uppercase tracking-tight">
                                                    <i data-lucide="arrow-right-left" class="w-3 h-3 mr-1.5 text-indigo-500"></i>
                                                    Contextual logic for <span class="text-indigo-500 ml-1.5"><%= a.matchedSku || a.matchedProduct %></span>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-10 py-6 text-right">
                                        <div class="inline-flex flex-col items-end">
                                            <span class="px-3 py-1.5 bg-white dark:bg-slate-950 border border-slate-100 dark:border-slate-800 text-[0.6rem] font-black uppercase tracking-[0.1em] rounded-xl shadow-lg"><%= a.confidence %> CONFIDENCE</span>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="2" class="px-10 py-32 text-center text-white/50">
                                    <i data-lucide="layers-3" class="w-10 h-10 text-slate-200 mx-auto mb-4 opacity-50"></i>
                                    <p class="text-slate-400 font-medium text-sm italic">Synthesizing affinity map from transaction hub...</p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1" nonce="<%= nonce %>"></script>
<script nonce="<%= nonce %>">
    document.addEventListener('DOMContentLoaded', () => {
        const categoryData = <%- JSON.stringify(categoryDistribution || []) %>;
        const clusterData = <%- JSON.stringify(customerClusters || []) %>;

        const isDark = document.documentElement.classList.contains('dark');
        const textColor = isDark ? '#94a3b8' : '#64748b';
        const gridColor = isDark ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.04)';

        // 1. Category Doughnut
        const ctxCategory = document.getElementById('categoryChart');
        if (ctxCategory && categoryData.length > 0) {
            new Chart(ctxCategory, {
                type: 'doughnut',
                data: {
                    labels: categoryData.map(d => d.name),
                    datasets: [{
                        data: categoryData.map(d => d.value),
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.8)', // indigo
                            'rgba(168, 85, 247, 0.8)', // purple
                            'rgba(20, 184, 166, 0.8)', // teal
                            'rgba(245, 158, 11, 0.8)', // amber
                            'rgba(239, 68, 68, 0.8)',  // red
                            'rgba(59, 130, 246, 0.8)'  // blue
                        ],
                        borderWidth: 0,
                        hoverOffset: 25,
                        borderRadius: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom', 
                            labels: { 
                                usePointStyle: true, 
                                padding: 25,
                                font: { size: 10, weight: '900', family: 'Inter' },
                                color: textColor,
                                textTransform: 'uppercase'
                            } 
                        },
                        tooltip: {
                            backgroundColor: isDark ? '#0f172a' : '#ffffff',
                            padding: 15,
                            cornerRadius: 15,
                            titleFont: { size: 12, weight: 'black' },
                            bodyFont: { size: 11, weight: 'medium' },
                            borderColor: gridColor,
                            borderWidth: 1
                        }
                    },
                    cutout: '80%'
                }
            });
        }

        // 2. Customer Activity Clusters (Horizontal Bar)
        const ctxCluster = document.getElementById('clusterChart');
        if (ctxCluster && clusterData.length > 0) {
            new Chart(ctxCluster, {
                type: 'bar',
                data: {
                    labels: clusterData.map(d => d.name),
                    datasets: [{
                        label: 'Customers',
                        data: clusterData.map(d => d.size),
                        backgroundColor: function(context) {
                            const colors = {
                                'emerald': '#10b981',
                                'indigo': '#6366f1',
                                'rose': '#f43f5e'
                            };
                            const cluster = clusterData[context.dataIndex];
                            return colors[cluster.color] || '#6366f1';
                        },
                        borderRadius: 15,
                        borderSkipped: false,
                        maxBarThickness: 40
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: isDark ? '#0f172a' : '#ffffff',
                            padding: 15,
                            cornerRadius: 15,
                            borderColor: gridColor,
                            borderWidth: 1
                        }
                    },
                    scales: {
                        y: { 
                            grid: { display: false }, 
                            ticks: { 
                                color: textColor, 
                                font: { size: 11, weight: '900', family: 'Inter' },
                                padding: 15
                            } 
                        },
                        x: { 
                            beginAtZero: true, 
                            grid: { color: gridColor }, 
                            ticks: { color: textColor, font: { size: 10, weight: 'bold' }, padding: 10 } 
                        }
                    }
                }
            });
        }

        if (window.lucide) window.lucide.createIcons();
    });
</script>

<style>
    [x-cloak] { display: none !important; }
    canvas {
        filter: drop-shadow(0 15px 25px rgba(0,0,0,0.08));
    }
</style>

<%- include('../../partials/sidebar-script') %>
