<%- layout('layouts/dashboard-layout') %>

<!-- Content Area -->
<div class="max-w-7xl mx-auto space-y-12 pb-20">
    
    <!-- Hero Section -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 py-6 text-white">
        <div class="space-y-3">
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-[0.65rem] font-black uppercase tracking-[0.2em] text-amber-600 mb-2">
                <i data-lucide="users" class="w-3.5 h-3.5"></i>
                <span>Customer Intelligence</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-black tracking-tight text-slate-900 dark:text-white leading-tight">Customer Segments</h1>
            <p class="text-slate-500 dark:text-slate-400 font-medium max-w-2xl text-lg">Dynamic behavioral clusters derived from Unified Data Hub RFM analysis, updated in real-time as customers interact.</p>
        </div>
        
        <div class="flex items-center space-x-3">
            <button class="px-6 py-3 bg-slate-900 dark:bg-white text-white dark:text-slate-900 font-black rounded-xl hover:scale-105 transition-all text-xs uppercase tracking-widest shadow-xl flex items-center group">
                <i data-lucide="refresh-cw" class="w-4 h-4 mr-2 group-hover:rotate-180 transition-transform duration-500"></i>
                Recalculate Now
            </button>
        </div>
    </div>

    <!-- Segments Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% customerClusters.forEach(cluster => { %>
            <a href="/dashboard/recommendations/segments/<%= cluster.clusterId %>" class="bg-white/60 dark:bg-slate-900/60 backdrop-blur-2xl p-10 rounded-[3rem] border border-slate-200 dark:border-slate-800 flex flex-col group hover:border-<%= cluster.color %>-500/50 transition-all shadow-xl hover:shadow-<%= cluster.color %>-500/10">
                <div class="flex items-center justify-between mb-10">
                    <div class="w-16 h-16 rounded-[1.5rem] bg-<%= cluster.color %>-500/10 border border-<%= cluster.color %>-500/20 flex items-center justify-center text-<%= cluster.color %>-500 group-hover:scale-110 transition-transform shadow-inner">
                        <i data-lucide="<%= cluster.name.includes('VIP') ? 'crown' : (cluster.name.includes('Steady') ? 'activity' : 'user-plus') %>" class="w-8 h-8"></i>
                    </div>
                    <div class="text-right">
                        <p class="text-[0.6rem] font-black text-slate-400 uppercase tracking-widest mb-1">Density</p>
                        <span class="text-2xl font-black text-slate-900 dark:text-white leading-none tracking-tighter"><%= cluster.size %></span>
                    </div>
                </div>

                <div class="space-y-4 flex-grow">
                    <h3 class="text-2xl font-black text-slate-900 dark:text-white tracking-tight leading-none group-hover:text-<%= cluster.color %>-500 transition-colors uppercase italic"><%= cluster.name %></h3>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed italic"><%= cluster.description %></p>
                </div>

                <div class="mt-10 pt-10 border-t border-slate-100 dark:border-slate-800 space-y-6">
                    <div class="space-y-4">
                        <p class="text-[0.65rem] font-black text-slate-400 uppercase tracking-[0.2em] flex items-center">
                            <i data-lucide="target" class="w-3.5 h-3.5 mr-2"></i>
                            Strategic Directive
                        </p>
                        <p class="text-xs font-bold text-slate-600 dark:text-slate-300 bg-slate-50 dark:bg-slate-800/50 p-4 rounded-2xl border border-slate-100/50 dark:border-slate-800 opacity-80 italic">
                            "<%= cluster.strategy %>"
                        </p>
                    </div>

                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                             <span class="text-[0.6rem] font-black text-slate-400 tracking-widest uppercase">Target AOV</span>
                             <span class="text-xs font-black text-<%= cluster.color %>-500"><%= cluster.avgOrderValue %></span>
                        </div>
                        <span class="text-[0.65rem] font-black text-indigo-500 uppercase tracking-widest group-hover:translate-x-1 transition-transform">Explore Profile <i data-lucide="chevron-right" class="w-3 h-3 inline"></i></span>
                    </div>
                </div>
            </a>
        <% }) %>
    </div>

    <!-- Analysis Transparency / Metadata Section -->
    <div class="bg-slate-900 rounded-[3.5rem] p-12 text-white shadow-2xl relative overflow-hidden group">
        <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-8">
                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-blue-500/20 border border-blue-500/30 text-[0.65rem] font-black uppercase tracking-[0.2em] text-blue-400">
                    <i data-lucide="brain-circuit" class="w-3.5 h-3.5"></i>
                    <span>Intelligence Transparency</span>
                </div>
                <h3 class="text-4xl font-black tracking-tight leading-tight uppercase italic">Analysis Foundation</h3>
                <p class="text-slate-400 font-medium leading-relaxed text-lg italic">
                    Our clustering engine applies a hybrid RFM (Recency, Frequency, Monetary) model tailored for B2B transactional documents. This ensures recommendations are grounded in seasonal business cycles rather than just impulse purchase data.
                </p>
                <div class="grid grid-cols-2 gap-8 pt-4">
                    <div class="space-y-2">
                        <p class="text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">Last Computation</p>
                        <p class="text-sm font-black text-white italic">Synced 42 minutes ago</p>
                    </div>
                    <div class="space-y-2">
                        <p class="text-[0.65rem] font-black text-slate-500 uppercase tracking-widest">Model Confidence</p>
                        <p class="text-sm font-black text-emerald-400 italic">96.8% Reliable</p>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-md rounded-[2.5rem] p-8 border border-white/10 space-y-8">
                <h4 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em]">Contextual Constraints</h4>
                <div class="space-y-6 text-white/50">
                    <div class="flex items-start space-x-4">
                        <div class="w-8 h-8 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 shrink-0">
                            <i data-lucide="info" class="w-4 h-4"></i>
                        </div>
                        <div>
                            <p class="text-[0.65rem] font-black uppercase tracking-tight text-slate-300">Minimum Sample Size</p>
                            <p class="text-[0.6rem] font-medium leading-relaxed opacity-60">Segments require a minimum of 5 customers for high-confidence affinity mapping. Currently using fallback "Trending" logic where data is sparse.</p>
                        </div>
                    </div>
                    <div class="flex items-start space-x-4">
                        <div class="w-8 h-8 rounded-xl bg-amber-500/20 flex items-center justify-center text-amber-400 shrink-0 text-white">
                            <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                        </div>
                        <div>
                            <p class="text-[0.65rem] font-black uppercase tracking-tight text-slate-300">Transaction Threshold</p>
                            <p class="text-[0.6rem] font-medium leading-relaxed opacity-60">Revenue lift is calculated based on converted document line-items. Incomplete documents or drafts are excluded from ROI attribution.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Decoration -->
        <div class="absolute -top-32 -right-32 w-96 h-96 bg-indigo-500/20 rounded-full blur-[120px] group-hover:scale-125 transition-transform duration-1000 pointer-events-none"></div>
        <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-blue-500/10 rounded-full blur-[120px] pointer-events-none"></div>
    </div>
</div>

<%- include('../../partials/sidebar-script') %>
