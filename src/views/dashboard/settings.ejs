<%- layout('layouts/dashboard-layout') %>

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-10 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h2 class="text-3xl font-heading font-bold text-slate-900 tracking-tight">Notification Settings</h2>
            <p class="mt-2 text-slate-500">Manage how and when you want to be notified about system events.</p>
        </div>
        <button type="submit" form="settings-form" class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-3 rounded-xl text-sm font-bold shadow-lg hover:shadow-xl transition-all flex items-center gap-2 uppercase tracking-widest">
            <i data-lucide="save" class="w-4 h-4"></i>
            Save Preferences
        </button>
    </div>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="bg-emerald-50 border border-emerald-100 text-emerald-700 px-6 py-4 rounded-2xl relative mb-8 shadow-sm flex items-center gap-3 animate-in fade-in slide-in-from-top-4 duration-300" role="alert">
            <i data-lucide="check-circle" class="w-5 h-5"></i>
            <span class="font-bold text-sm uppercase tracking-wider">Settings saved successfully.</span>
        </div>
    <% } %>

    <form id="settings-form" action="/notifications/settings" method="POST" class="space-y-8">
        
        <!-- Channels Card -->
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Notification Channels</h3>
                <p class="mt-1 text-xs text-slate-500 font-medium">Global toggles for where you want to receive alerts.</p>
            </div>
            <div class="p-8 space-y-6">
                <div class="flex items-start">
                    <div class="flex items-center h-5">
                        <input id="emailEnabled" name="emailEnabled" type="checkbox" <%= config.emailEnabled ? 'checked' : '' %> class="h-4 w-4 text-slate-900 border-slate-300 rounded focus:ring-slate-900 cursor-pointer">
                    </div>
                    <div class="ml-3">
                        <label for="emailEnabled" class="text-sm font-bold text-slate-900">Email Notifications</label>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Receive critical alerts and updates via email (<b><%= user.email %></b>).</p>
                    </div>
                </div>
                <div class="flex items-start">
                    <div class="flex items-center h-5">
                        <input id="inAppEnabled" name="inAppEnabled" type="checkbox" <%= config.inAppEnabled ? 'checked' : '' %> class="h-4 w-4 text-slate-900 border-slate-300 rounded focus:ring-slate-900 cursor-pointer">
                    </div>
                    <div class="ml-3">
                        <label for="inAppEnabled" class="text-sm font-bold text-slate-900">In-App Notifications</label>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Show alerts in the top notification bell within the dashboard.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Categories Card -->
        <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 bg-slate-50/50">
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Event Configuration</h3>
                <p class="mt-1 text-xs text-slate-500 font-medium">Fine-tune which events trigger a notification.</p>
            </div>
            <div class="divide-y divide-slate-100">
                
                <!-- Tool Execution Success -->
                <div class="px-8 py-6 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div>
                        <p class="text-sm font-bold text-slate-900">Tool Execution Success</p>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Notify me when a tool finishes successfully.</p>
                    </div>
                    <div class="flex items-center">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="toolSuccess" <%= config.toolSuccess ? 'checked' : '' %> class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-900"></div>
                        </label>
                    </div>
                </div>

                <!-- Tool Execution Failure -->
                <div class="px-8 py-6 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div>
                        <p class="text-sm font-bold text-slate-900">Tool Execution Failed</p>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Notify me if a tool fails to execute.</p>
                    </div>
                    <div class="flex items-center">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="toolFailure" <%= config.toolFailure ? 'checked' : '' %> class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-900"></div>
                        </label>
                    </div>
                </div>

                <!-- Billing Alerts -->
                <div class="px-8 py-6 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div>
                        <p class="text-sm font-bold text-slate-900">Billing Alerts</p>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Notify me about limits, usage thresholds, and new invoices.</p>
                    </div>
                    <div class="flex items-center">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="billingAlert" <%= config.billingAlert ? 'checked' : '' %> class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-900"></div>
                        </label>
                    </div>
                </div>

                <!-- Payment Actions -->
                <div class="px-8 py-6 flex items-center justify-between hover:bg-slate-50/50 transition-colors">
                    <div>
                        <p class="text-sm font-bold text-slate-900">Payment Methods</p>
                        <p class="text-xs text-slate-500 font-medium mt-0.5">Notify when payment methods are added, removed, or updated.</p>
                    </div>
                    <div class="flex items-center">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="paymentAction" <%= config.paymentAction ? 'checked' : '' %> class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-slate-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-slate-900"></div>
                        </label>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>
