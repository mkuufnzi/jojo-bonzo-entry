<%- layout('layouts/dashboard-layout') %>

<!-- Dashboard Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <!-- Active Plan -->
    <div class="card p-5 border-l-4 border-blue-600">
        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Current Plan</p>
        <h3 class="text-lg font-bold text-slate-900 truncate">
            <%= (user.subscription && user.subscription.plan) ? user.subscription.plan.name : 'Free Member' %>
        </h3>
        <div class="mt-2 flex items-center gap-2">
            <span class="px-1.5 py-0.5 bg-blue-50 text-blue-600 text-[0.625rem] font-bold rounded border border-blue-100 uppercase tracking-widest">
                Enterprise Hub
            </span>
        </div>
    </div>

    <!-- Monthly Quota -->
    <div class="card p-5">
        <div class="flex justify-between items-start mb-2">
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Usage Limits</p>
                <h3 class="text-lg font-bold text-slate-900 tracking-tight">
                    <%= monthlyUsage %> <span class="text-slate-400 text-sm font-normal">/ <%= planLimit === -1 ? '∞' : planLimit %></span>
                </h3>
            </div>
            <div class="p-2 bg-slate-50 rounded-lg">
                <i data-lucide="bar-chart-3" class="w-4 h-4 text-slate-400"></i>
            </div>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-1.5 mt-2 overflow-hidden">
            <% const percentage = planLimit === -1 ? 0 : Math.min((monthlyUsage / planLimit) * 100, 100); %>
            <div class="bg-blue-600 h-1.5 rounded-full transition-all duration-1000" style="width: <%- percentage %>%;"></div>
        </div>
    </div>

    <!-- Lifetime Traffic -->
    <div class="card p-5">
        <div class="flex justify-between items-start mb-1">
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Success Rate</p>
                <h3 class="text-lg font-bold text-slate-900 tracking-tight">
                    <%= logsCount > 0 ? Math.round((successCount / logsCount) * 100) : 100 %>%
                </h3>
            </div>
            <div class="p-2 bg-green-50 rounded-lg">
                <i data-lucide="activity" class="w-4 h-4 text-green-600"></i>
            </div>
        </div>
        <p class="text-[0.625rem] font-bold text-green-600 uppercase tracking-widest">High Availability</p>
    </div>

    <!-- Total Requests -->
    <div class="card p-5">
        <div class="flex justify-between items-start mb-1">
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Requests</p>
                <h3 class="text-lg font-bold text-slate-900 tracking-tight"><%= logsCount %></h3>
            </div>
            <div class="p-2 bg-slate-50 rounded-lg">
                <i data-lucide="zap" class="w-4 h-4 text-blue-400"></i>
            </div>
        </div>
        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Lifetime Operations</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Graph -->
    <div class="lg:col-span-2 card p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-sm font-bold text-slate-900 uppercase tracking-widest flex items-center gap-2">
                <i data-lucide="line-chart" class="w-4 h-4 text-blue-600"></i>
                Usage Distribution
            </h2>
            <div class="flex gap-2">
                <span class="px-2 py-1 bg-slate-100 text-[0.625rem] font-bold text-slate-500 rounded uppercase tracking-widest">Last 30 Days</span>
            </div>
        </div>
        <div class="h-64 relative">
            <canvas id="hubUsageChart"></canvas>
        </div>
    </div>

    <!-- Service Status -->
    <div class="card p-6">
        <h2 class="text-sm font-bold text-slate-900 uppercase tracking-widest mb-6 flex items-center gap-2">
            <i data-lucide="shield-check" class="w-4 h-4 text-emerald-600"></i>
            Service Status
        </h2>
        <div class="space-y-5">
            <% if (typeof serviceStatuses !== 'undefined' && serviceStatuses.length > 0) { %>
                <% serviceStatuses.forEach(s => { %>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-<%= s.color %>-500 animate-pulse"></div>
                            <span class="text-sm font-bold text-slate-700 underline decoration-<%= s.color %>-500/30 decoration-2 underline-offset-4"><%= s.name %></span>
                        </div>
                        <span class="text-[0.625rem] font-bold text-<%= s.color === 'emerald' ? 'emerald' : (s.color === 'amber' ? 'amber' : 'rose') %>-600 uppercase tracking-widest"><%= s.status %></span>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="text-xs text-slate-400 font-medium italic">System status data unavailable.</div>
            <% } %>
            <div class="pt-4 mt-4 border-t border-slate-100">
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2">Systems Health</p>
                <div class="flex items-center gap-1.5">
                    <div class="flex-1 h-1 bg-emerald-500 rounded-full"></div>
                    <div class="flex-1 h-1 bg-emerald-500 rounded-full"></div>
                    <div class="flex-1 h-1 bg-emerald-500 rounded-full"></div>
                    <div class="flex-1 h-1 bg-emerald-500 rounded-full"></div>
                    <div class="flex-1 h-1 bg-emerald-500 rounded-full opacity-30"></div>
                </div>
                <div class="flex justify-between mt-1">
                    <span class="text-[0.5rem] font-bold text-slate-400">99.98% Uptime</span>
                    <span class="text-[0.5rem] font-bold text-slate-400">London/NYC</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Services Hub -->
<div class="mb-4 flex items-center justify-between">
    <h1 class="text-sm font-black text-slate-900 uppercase tracking-[0.2em]">Our Services</h1>
    <span class="h-px flex-1 bg-slate-100 mx-4"></span>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
    <% 
    const suites = [
        { id: 'transactional', name: 'Transactional', color: 'blue', icon: 'ReceiptText', desc: 'Invoices & Reports' },
        { id: 'recovery', name: 'Debt Collection', color: 'rose', icon: 'Coins', desc: 'Dunning & AR Sync' },
        { id: 'retention', name: 'Retention', color: 'teal', icon: 'HeartHandshake', desc: 'Onboarding & QBRs' },
        { id: 'sales', name: 'Sales', color: 'indigo', icon: 'BarChartHorizontal', desc: 'Pitch Decks & Leads' },
        { id: 'content', name: 'Content', color: 'purple', icon: 'Layers', desc: 'Infographics & SEO' }
    ];
    %>
    <% suites.forEach(suite => { %>
        <a href="/dashboard/<%= suite.id %>" class="group p-5 bg-white border border-slate-200 rounded-2xl hover:border-<%= suite.color %>-500 hover:shadow-xl transition-all relative overflow-hidden">
            <div class="absolute -right-4 -bottom-4 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity">
                <i data-lucide="<%= suite.icon %>" class="w-24 h-24 text-<%= suite.color %>-600"></i>
            </div>
            <div class="w-10 h-10 bg-<%= suite.color %>-50 text-<%= suite.color %>-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <i data-lucide="<%= suite.icon %>" class="w-5 h-5"></i>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-1 group-hover:text-<%= suite.color %>-600 transition-colors"><%= suite.name %></h3>
            <p class="text-[0.75rem] text-slate-500 font-medium leading-relaxed mb-4"><%= suite.desc %></p>
            <div class="flex items-center gap-1 text-<%= suite.color %>-600 font-bold text-[0.625rem] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all translate-x-[-10px] group-hover:translate-x-0">
                Manage Suite <i data-lucide="arrow-right" class="w-3 h-3"></i>
            </div>
        </a>
    <% }) %>
</div>

<!-- Chart Data Integration -->
<script id="hub-chart-data" type="application/json" nonce="<%= nonce %>">
    <%- JSON.stringify({
        usageByApp: usageByApp || {},
        apps: (user && user.apps) ? user.apps : []
    }) %>
</script>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    try {
        const dataEl = document.getElementById('hub-chart-data');
        if (!dataEl) return;
        const data = JSON.parse(dataEl.textContent);
        const ctx = document.getElementById('hubUsageChart')?.getContext('2d');
        if (!ctx) return;

        const labels = [];
        const today = new Date();
        for (let i = 29; i >= 0; i--) {
            const d = new Date();
            d.setDate(today.getDate() - i);
            labels.push(d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }));
        }

        const colors = ['#3b82f6', '#14b8a6', '#6366f1', '#a855f7'];
        const datasets = data.apps.map((app, idx) => {
            const appUsage = data.usageByApp[app.id] || {};
            const plotData = [];
            for (let i = 29; i >= 0; i--) {
                const d = new Date();
                d.setDate(today.getDate() - i);
                const ds = d.toISOString().split('T')[0];
                plotData.push(appUsage[ds] || 0);
            }
            const color = colors[idx % colors.length];
            return {
                label: app.name,
                data: plotData,
                borderColor: color,
                backgroundColor: color + '10',
                borderWidth: 2,
                tension: 0.4,
                pointRadius: 0,
                fill: true
            };
        });

        // Use global Chart.js
        if (typeof Chart !== 'undefined') {
            new Chart(ctx, {
                type: 'line',
                data: { labels, datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { position: 'bottom', labels: { boxWidth: 8, font: { size: 10, weight: 'bold' } } }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { font: { size: 9 } } },
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 7, font: { size: 9 } } }
                    }
                }
            });
        }
    } catch (e) {
        console.error('Hub chart error:', e);
    }
    
    // Lucide Icons
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
