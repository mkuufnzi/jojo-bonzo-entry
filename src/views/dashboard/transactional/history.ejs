<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto space-y-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 mb-1">
                <a href="/dashboard/transactional" class="text-sm text-slate-400 hover:text-blue-600 transition-colors font-medium">Transactional</a>
                <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-slate-300"></i>
                <span class="text-sm font-bold text-slate-900 dark:text-white">Branding History</span>
            </div>
            <h1 class="text-2xl font-heading font-black text-slate-900 dark:text-white tracking-tight">Branding History</h1>
            <p class="text-slate-500 text-sm font-medium mt-1">Every document your engine has processed — originals vs. smart-branded versions.</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="/dashboard/transactional" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 dark:hover:bg-slate-700 transition-all flex items-center">
                <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i>
                Dashboard
            </a>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
            <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Processed</p>
            <p class="text-2xl font-black text-slate-900 dark:text-white tracking-tight"><%= documents.length %></p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
            <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Completed</p>
            <p class="text-2xl font-black text-emerald-600 tracking-tight"><%= documents.filter(d => d.status === 'completed').length %></p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
            <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Processing</p>
            <p class="text-2xl font-black text-amber-500 tracking-tight"><%= documents.filter(d => d.status === 'processing').length %></p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm">
            <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Failed</p>
            <p class="text-2xl font-black text-red-500 tracking-tight"><%= documents.filter(d => d.status === 'failed').length %></p>
        </div>
    </div>

    <% if (documents && documents.length > 0) { %>
    <!-- Documents Table (Desktop) -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl shadow-sm overflow-hidden hidden md:block">
        <table class="w-full">
            <thead class="bg-slate-50/80 dark:bg-slate-800/50">
                <tr>
                    <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Status</th>
                    <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Resource</th>
                    <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Provider</th>
                    <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Event</th>
                    <th class="px-6 py-4 text-right text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Time</th>
                    <th class="px-6 py-4 text-right text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Date</th>
                    <th class="px-6 py-4 text-center text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em]">Action</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                <% documents.forEach(doc => { %>
                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors group">
                    <td class="px-6 py-4">
                        <% if (doc.status === 'completed') { %>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800 rounded-lg text-[0.6rem] font-black uppercase tracking-widest">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Done
                            </span>
                        <% } else if (doc.status === 'processing') { %>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-800 rounded-lg text-[0.6rem] font-black uppercase tracking-widest">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span> Active
                            </span>
                        <% } else { %>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 rounded-lg text-[0.6rem] font-black uppercase tracking-widest">
                                <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span> Failed
                            </span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm font-bold text-slate-900 dark:text-white"><%= doc.resourceId || '—' %></span>
                        <span class="block text-[0.6rem] text-slate-400 font-medium mt-0.5"><%= doc.resourceType || 'document' %></span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-[0.6rem] font-bold rounded text-slate-500 uppercase tracking-wider"><%= doc.provider || 'system' %></span>
                    </td>
                    <td class="px-6 py-4 text-xs font-medium text-slate-500 dark:text-slate-400 max-w-[160px] truncate"><%= doc.eventType || '—' %></td>
                    <td class="px-6 py-4 text-right font-mono text-xs font-bold text-blue-600"><%= doc.processingTimeMs ? doc.processingTimeMs + 'ms' : '—' %></td>
                    <td class="px-6 py-4 text-right text-xs text-slate-500 font-medium"><%= new Date(doc.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td class="px-6 py-4 text-center">
                        <a href="/dashboard/transactional/history/<%= doc.id %>" class="inline-flex items-center gap-1 text-blue-600 dark:text-blue-400 hover:text-blue-800 text-xs font-bold uppercase tracking-widest transition-colors group-hover:underline">
                            View <i data-lucide="arrow-right" class="w-3 h-3"></i>
                        </a>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>

    <!-- Documents Cards (Mobile) -->
    <div class="space-y-3 md:hidden">
        <% documents.forEach(doc => { %>
        <a href="/dashboard/transactional/history/<%= doc.id %>" class="block bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 shadow-sm hover:border-blue-400 dark:hover:border-blue-600 transition-all active:scale-[0.98]">
            <div class="flex items-center justify-between mb-3">
                <% if (doc.status === 'completed') { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-emerald-50 text-emerald-600 border border-emerald-200 rounded text-[0.55rem] font-black uppercase tracking-widest">
                        <span class="w-1 h-1 rounded-full bg-emerald-500"></span> Done
                    </span>
                <% } else if (doc.status === 'processing') { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-amber-50 text-amber-600 border border-amber-200 rounded text-[0.55rem] font-black uppercase tracking-widest">
                        <span class="w-1 h-1 rounded-full bg-amber-500 animate-pulse"></span> Active
                    </span>
                <% } else { %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-red-50 text-red-600 border border-red-200 rounded text-[0.55rem] font-black uppercase tracking-widest">
                        <span class="w-1 h-1 rounded-full bg-red-500"></span> Failed
                    </span>
                <% } %>
                <span class="text-[0.6rem] text-slate-400 font-medium"><%= new Date(doc.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %></span>
            </div>
            <h3 class="text-sm font-bold text-slate-900 dark:text-white truncate"><%= doc.resourceId || 'Document' %></h3>
            <div class="flex items-center gap-3 mt-2 text-[0.6rem] text-slate-400 font-medium">
                <span class="uppercase"><%= doc.provider || 'system' %></span>
                <span>•</span>
                <span><%= doc.resourceType || 'document' %></span>
                <% if (doc.processingTimeMs) { %>
                    <span>•</span>
                    <span class="text-blue-500 font-bold"><%= doc.processingTimeMs %>ms</span>
                <% } %>
            </div>
        </a>
        <% }); %>
    </div>

    <!-- Pagination -->
    <% if (pagination.total > 1) { %>
    <div class="flex items-center justify-between pt-4">
        <p class="text-xs text-slate-400 font-medium">Page <strong class="text-slate-900 dark:text-white"><%= pagination.current %></strong> of <strong class="text-slate-900 dark:text-white"><%= pagination.total %></strong></p>
        <div class="flex items-center gap-2">
            <% if (pagination.current > 1) { %>
                <a href="/dashboard/transactional/history?page=<%= pagination.current - 1 %>" class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl text-xs font-bold hover:bg-slate-50 dark:hover:bg-slate-700 transition-all flex items-center gap-1">
                    <i data-lucide="chevron-left" class="w-3 h-3"></i> Previous
                </a>
            <% } %>
            <% if (pagination.current < pagination.total) { %>
                <a href="/dashboard/transactional/history?page=<%= pagination.current + 1 %>" class="px-4 py-2 bg-slate-900 dark:bg-blue-600 text-white rounded-xl text-xs font-bold hover:bg-slate-800 dark:hover:bg-blue-700 transition-all flex items-center gap-1">
                    Next <i data-lucide="chevron-right" class="w-3 h-3"></i>
                </a>
            <% } %>
        </div>
    </div>
    <% } %>

    <% } else { %>
    <!-- Empty State -->
    <div class="bg-white dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-700 rounded-3xl p-16 text-center">
        <div class="w-16 h-16 mx-auto bg-slate-100 dark:bg-slate-800 rounded-2xl flex items-center justify-center mb-6">
            <i data-lucide="file-search" class="w-8 h-8 text-slate-300"></i>
        </div>
        <h2 class="text-lg font-black text-slate-900 dark:text-white mb-2">No Branded Documents Yet</h2>
        <p class="text-sm text-slate-500 max-w-md mx-auto mb-8">Your branding engine hasn't processed any documents yet. Connect an integration to start generating smart branded documents automatically.</p>
        <div class="flex items-center justify-center gap-3">
            <a href="/dashboard/integrations" class="px-6 py-3 bg-slate-900 dark:bg-blue-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:shadow-xl transition-all flex items-center gap-2">
                <i data-lucide="plug-2" class="w-4 h-4"></i>
                Connect Integration
            </a>
            <a href="/dashboard/transactional" class="px-6 py-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 dark:hover:bg-slate-700 transition-all">
                Back to Dashboard
            </a>
        </div>
    </div>
    <% } %>

</div>
