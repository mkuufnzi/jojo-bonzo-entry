<%- layout('layouts/dashboard-layout') %>

<div class="w-full max-w-[1920px] mx-auto px-2 sm:px-6 overflow-x-hidden">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs text-slate-400 font-medium mb-8">
        <a href="/dashboard/recovery/sessions" class="hover:text-slate-600 transition-colors">Recovery Sessions</a>
        <i data-lucide="chevron-right" class="w-3 h-3"></i>
        <% if (session) { %>
            <a href="/dashboard/recovery/customers/<%= session.customerId %>" class="hover:text-slate-600 transition-colors truncate max-w-[200px]"><%= session.customerName || 'Customer' %></a>
            <i data-lucide="chevron-right" class="w-3 h-3"></i>
        <% } %>
        <span class="text-slate-600">Dunning Event</span>
    </nav>

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
        <div>
            <h1 class="text-2xl sm:text-3xl font-heading font-black text-slate-900 tracking-tight flex items-center gap-3">
                <div class="p-2 rounded-xl <%= action.status === 'SENT' ? 'bg-emerald-100' : action.status === 'FAILED' ? 'bg-red-100' : action.status === 'DISPATCHED' ? 'bg-amber-100' : 'bg-slate-100' %>">
                    <i data-lucide="<%= action.status === 'SENT' ? 'check-circle-2' : action.status === 'FAILED' ? 'alert-circle' : action.status === 'DISPATCHED' ? 'arrow-up-right' : 'clock' %>" 
                       class="w-6 h-6 <%= action.status === 'SENT' ? 'text-emerald-600' : action.status === 'FAILED' ? 'text-red-600' : action.status === 'DISPATCHED' ? 'text-amber-600' : 'text-slate-600' %>"></i>
                </div>
                Dunning Event
            </h1>
            <p class="text-xs sm:text-sm text-slate-500 font-medium mt-1">
                Action <code class="text-[10px] bg-slate-100 px-1.5 py-0.5 rounded font-mono"><%= action.id.substring(0, 8) %>...</code>
                &nbsp;·&nbsp; <%= new Date(action.createdAt).toLocaleString() %>
            </p>
        </div>
        <!-- Status Badge -->
        <span class="px-4 py-2 rounded-full text-xs font-black uppercase tracking-widest border
            <%= action.status === 'SENT' ? 'bg-emerald-50 text-emerald-600 border-emerald-200' :
               action.status === 'FAILED' ? 'bg-red-50 text-red-600 border-red-200' :
               action.status === 'DISPATCHED' ? 'bg-amber-50 text-amber-600 border-amber-200' :
               action.status === 'QUEUED' ? 'bg-indigo-50 text-indigo-600 border-indigo-200' :
               'bg-slate-50 text-slate-500 border-slate-200' %>">
            <%= action.status %>
        </span>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <!-- Left: Event Details (2/3 width) -->
        <div class="xl:col-span-2 space-y-6">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- 🔑 Tracking IDs (for n8n verification) -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                    <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">🔑 Tracking IDs</h2>
                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Use these to verify n8n</span>
                </div>
                <div class="px-8 py-6 space-y-4">
                    <div>
                        <p class="text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-1">Action ID <span class="text-slate-400">(n8n must echo this back in callback)</span></p>
                        <code class="text-xs font-mono text-indigo-700 bg-indigo-50 px-3 py-2 rounded-xl block break-all border border-indigo-100 select-all cursor-pointer" title="Click to select"><%= action.id %></code>
                    </div>
                    <% if (session) { %>
                        <div>
                            <p class="text-[10px] font-black text-violet-500 uppercase tracking-widest mb-1">Session ID</p>
                            <code class="text-xs font-mono text-violet-700 bg-violet-50 px-3 py-2 rounded-xl block break-all border border-violet-100 select-all cursor-pointer" title="Click to select"><%= session.id %></code>
                        </div>
                    <% } %>
                    <div>
                        <p class="text-[10px] font-black text-cyan-500 uppercase tracking-widest mb-1">Business ID</p>
                        <code class="text-xs font-mono text-cyan-700 bg-cyan-50 px-3 py-2 rounded-xl block break-all border border-cyan-100 select-all cursor-pointer" title="Click to select"><%= action.businessId %></code>
                    </div>
                    <% if (session) { %>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Customer ID</p>
                                <code class="text-[10px] font-mono text-slate-600 bg-slate-50 px-2 py-1 rounded-lg block break-all select-all"><%= session.customerId %></code>
                            </div>
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Invoice ID (External)</p>
                                <code class="text-[10px] font-mono text-slate-600 bg-slate-50 px-2 py-1 rounded-lg block break-all select-all"><%= action.externalInvoiceId %></code>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Action Summary Card -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Action Details</h2>
                </div>
                <div class="px-8 py-6 grid grid-cols-2 md:grid-cols-3 gap-6">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Action Type</p>
                        <p class="text-sm font-bold text-slate-800"><%= action.actionType %></p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Invoice ID</p>
                        <p class="text-sm font-mono text-slate-800 truncate"><%= action.externalInvoiceId %></p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Sequence</p>
                        <p class="text-sm font-bold text-slate-800"><%= sequence ? sequence.name : '—' %></p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Created</p>
                        <p class="text-sm font-bold text-slate-800"><%= new Date(action.createdAt).toLocaleString() %></p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Sent At</p>
                        <p class="text-sm font-bold text-slate-800"><%= action.sentAt ? new Date(action.sentAt).toLocaleString() : '—' %></p>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Session Step</p>
                        <p class="text-sm font-bold text-slate-800"><%= session ? (session.currentStepIndex + 1) : '—' %> / <%= stepTotal || '?' %></p>
                    </div>
                </div>

                <% if (action.aiGeneratedCopy) { %>
                    <div class="px-8 pb-6">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">AI-Generated Copy</p>
                        <div class="bg-slate-50 rounded-2xl p-4 text-sm text-slate-700 font-medium leading-relaxed border border-slate-100">
                            <%= action.aiGeneratedCopy %>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Webhook Dispatch Info -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                    <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Outbound Webhook (→ n8n)</h2>
                    <% if (wasDispatched) { %>
                        <span class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[9px] font-black uppercase tracking-widest rounded-full border border-emerald-200">Dispatched</span>
                    <% } else { %>
                        <span class="px-2 py-0.5 bg-slate-100 text-slate-400 text-[9px] font-black uppercase tracking-widest rounded-full">Not Dispatched</span>
                    <% } %>
                </div>
                <div class="px-8 py-6 space-y-4">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Webhook URL</p>
                        <% if (webhookUrl) { %>
                            <code class="text-xs font-mono text-indigo-600 bg-indigo-50 px-3 py-2 rounded-xl block break-all border border-indigo-100"><%= webhookUrl %></code>
                        <% } else { %>
                            <p class="text-xs text-red-500 font-bold">⚠️ No webhook URL configured in DB service record</p>
                        <% } %>
                    </div>
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Callback URL (where n8n POSTs result back)</p>
                        <code class="text-xs font-mono text-emerald-700 bg-emerald-50 px-3 py-2 rounded-xl block break-all border border-emerald-100"><%= callbackUrl %></code>
                    </div>
                    <% if (action.metadata && action.metadata.dispatchedAt) { %>
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Dispatched At</p>
                            <p class="text-sm font-bold text-slate-800"><%= new Date(action.metadata.dispatchedAt).toLocaleString() %></p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- n8n Callback Response -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                    <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">n8n Callback Response (← n8n)</h2>
                    <% if (callbackReceived) { %>
                        <span class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[9px] font-black uppercase tracking-widest rounded-full border border-emerald-200">Received</span>
                    <% } else { %>
                        <span class="px-2 py-0.5 bg-amber-50 text-amber-500 text-[9px] font-black uppercase tracking-widest rounded-full border border-amber-200">Awaiting</span>
                    <% } %>
                </div>
                <div class="px-8 py-6">
                    <% if (callbackReceived) { %>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                            <div>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Delivery Status</p>
                                <span class="px-3 py-1 text-xs font-black uppercase tracking-widest rounded-full
                                    <%= callbackStatus === 'sent' || callbackStatus === 'delivered' || callbackStatus === 'success' ? 'bg-emerald-50 text-emerald-600' :
                                       callbackStatus === 'failed' || callbackStatus === 'bounced' ? 'bg-red-50 text-red-600' :
                                       'bg-slate-50 text-slate-500' %>">
                                    <%= callbackStatus %>
                                </span>
                            </div>
                            <% if (action.metadata && action.metadata.callbackReceivedAt) { %>
                                <div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Received At</p>
                                    <p class="text-sm font-bold text-slate-800"><%= new Date(action.metadata.callbackReceivedAt).toLocaleString() %></p>
                                </div>
                            <% } %>
                            <% if (deliveryMetadata) { %>
                                <% if (deliveryMetadata.provider) { %>
                                    <div>
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Provider</p>
                                        <p class="text-sm font-bold text-slate-800"><%= deliveryMetadata.provider %></p>
                                    </div>
                                <% } %>
                                <% if (deliveryMetadata.messageId) { %>
                                    <div class="col-span-2">
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Message ID</p>
                                        <code class="text-xs font-mono text-slate-600 bg-slate-50 px-2 py-1 rounded-lg block break-all"><%= deliveryMetadata.messageId %></code>
                                    </div>
                                <% } %>
                                <% if (deliveryMetadata.openedAt) { %>
                                    <div>
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Opened At</p>
                                        <p class="text-sm font-bold text-emerald-600"><%= new Date(deliveryMetadata.openedAt).toLocaleString() %></p>
                                    </div>
                                <% } %>
                                <% if (deliveryMetadata && deliveryMetadata.bounceReason) { %>
                                    <div class="col-span-3">
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Bounce Reason</p>
                                        <p class="text-sm font-bold text-red-500"><%= deliveryMetadata.bounceReason %></p>
                                    </div>
                                <% } %>
                            <% } %>

                            <!-- Render Extracted Dunning Action Content -->
                            <% if (action?.metadata?.dunningAction) { %>
                                <% const da = action.metadata.dunningAction; %>
                                <div class="col-span-full mt-4 space-y-6">
                                    <div class="flex items-center gap-4 border-b border-slate-100 pb-2">
                                        <div class="h-px bg-slate-200 flex-1"></div>
                                        <span class="text-[10px] uppercase tracking-[0.2em] font-black text-slate-400">Generated Content</span>
                                        <div class="h-px bg-slate-200 flex-1"></div>
                                    </div>

                                    <% if (da.tone_used) { %>
                                        <div>
                                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">AI Tone Used</p>
                                            <span class="px-3 py-1 bg-indigo-50 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-indigo-100"><%= da.tone_used %></span>
                                        </div>
                                    <% } %>

                                    <% if (da.email) { %>
                                        <div class="bg-slate-50 border border-slate-100 rounded-3xl p-6 sm:p-8 space-y-6">
                                            <div>
                                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Subject Line</p>
                                                <p class="text-sm sm:text-base font-bold text-slate-900 leading-relaxed"><%= da.email.subject || 'N/A' %></p>
                                            </div>
                                            
                                            <% if (da.email.preview_text) { %>
                                            <div>
                                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Preview Text / Preheader</p>
                                                <p class="text-xs font-semibold text-slate-500 italic"><%= da.email.preview_text %></p>
                                            </div>
                                            <% } %>

                                            <div>
                                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Composed Email Body</p>
                                                <div class="bg-white border border-slate-200 rounded-2xl p-6 font-mono text-xs sm:text-sm text-slate-700 leading-loose space-y-4 shadow-sm">
                                                    <% if (da.email.opening_greeting) { %><p><%= da.email.opening_greeting %></p><% } %>
                                                    <% if (da.email.context_reference) { %><p><%= da.email.context_reference %></p><% } %>
                                                    <% if (da.email.invoice_summary_section) { %><div class="pl-4 border-l-2 border-indigo-200 text-indigo-900 bg-indigo-50/50 p-3 rounded-r-xl"><pre class="font-mono text-[10px] sm:text-xs whitespace-pre-wrap"><%= da.email.invoice_summary_section %></pre></div><% } %>
                                                    <% if (da.email.consequence_statement) { %><p class="text-amber-800"><%= da.email.consequence_statement %></p><% } %>
                                                    <% if (da.email.call_to_action) { %><p class="font-bold text-slate-900"><%= da.email.call_to_action %></p><% } %>
                                                    <% if (da.email.closing_message) { %><p><%= da.email.closing_message %></p><% } %>
                                                    <% if (da.email.signature_block) { %><pre class="font-mono text-xs opacity-75 mt-4 pt-4 border-t border-slate-100 whitespace-pre-wrap"><%= da.email.signature_block %></pre><% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% } %>
                                    
                                    <% if (da.sms_variant && da.sms_variant.enabled) { %>
                                        <div class="bg-emerald-50 border border-emerald-100 rounded-3xl p-6 sm:p-8 mt-6">
                                            <div class="flex items-center gap-3 mb-3">
                                                <i data-lucide="smartphone" class="w-4 h-4 text-emerald-600"></i>
                                                <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">SMS Variant Generated</p>
                                            </div>
                                            <p class="text-sm font-semibold text-emerald-900 leading-relaxed font-mono"><%= da.sms_variant.message %></p>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>

                            <% if (action.metadata && action.metadata.n8nResponse) { %>
                                <div class="col-span-3">
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">n8n Full Response</p>
                                    <pre class="text-xs font-mono text-slate-600 bg-slate-50 p-4 rounded-2xl overflow-x-auto whitespace-pre-wrap break-all border border-slate-100"><%= JSON.stringify(action.metadata.n8nResponse, null, 2) %></pre>
                                </div>
                            <% } %>
                            <% if (action.metadata && action.metadata.callbackError) { %>
                                <div class="col-span-3">
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Error</p>
                                    <p class="text-sm font-bold text-red-500"><%= action.metadata.callbackError %></p>
                                </div>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-8">
                            <div class="w-12 h-12 bg-amber-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
                                <i data-lucide="clock" class="w-6 h-6 text-amber-400"></i>
                            </div>
                            <p class="text-sm font-bold text-slate-400">Waiting for n8n callback...</p>
                            <p class="text-xs text-slate-300 mt-1">n8n must POST to the callback URL with the correct Action ID (see above).</p>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- 📋 n8n Callback Contract (what n8n MUST send) -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden" x-data="{ open: false }">
                <button @click="open = !open" class="w-full px-8 py-5 border-b border-slate-100 bg-amber-50/50 flex items-center justify-between hover:bg-amber-100/50 transition-all">
                    <h2 class="text-xs font-black text-amber-600 uppercase tracking-[0.15em]">📋 n8n Callback Contract (What n8n Must Send)</h2>
                    <i data-lucide="chevron-down" class="w-4 h-4 text-amber-400 transition-transform" :class="open ? 'rotate-180' : ''"></i>
                </button>
                <div x-show="open" x-collapse>
                    <div class="px-8 py-6 space-y-4">
                        <p class="text-xs text-slate-500 font-medium">When n8n finishes processing the dunning email, it must POST this JSON to the callback URL:</p>
                        <pre class="text-xs font-mono bg-slate-900 text-emerald-300 p-5 rounded-2xl overflow-x-auto whitespace-pre-wrap border border-slate-700">POST <%= callbackUrl %>
Content-Type: application/json

{
  "actionIds": ["<%= action.id %>"],
  <% if (session) { %>"sessionIds": ["<%= session.id %>"],<% } %>
  "businessId": "<%= action.businessId %>",
  "status": "success",
  "metadata": {
    "n8nJobId": "{{ $execution.id }}",
    "dunningAction": { ... }
  }
}</pre>
                        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
                            <p class="text-[10px] font-black text-red-600 uppercase tracking-widest mb-1">⚠️ Common Mistake</p>
                            <p class="text-xs text-red-600 font-medium">
                                n8n must use <code class="bg-red-100 px-1 rounded">{{ $json.recovery.actionIds }}</code> 
                                from the incoming webhook — NOT the event type string. The event type "floovioo_transactional_batch_dispatch" 
                                is NOT a valid action ID and will return <code class="bg-red-100 px-1 rounded">outcome: "not_found"</code>.
                            </p>
                        </div>
                        <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4">
                            <p class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mb-1">✅ Correct n8n Expression</p>
                            <code class="text-xs font-mono text-emerald-700 block">"actionIds": {{ $json.recovery.actionIds }}</code>
                            <code class="text-xs font-mono text-emerald-700 block mt-1">"sessionIds": {{ $json.recovery.sessionIds }}</code>
                            <code class="text-xs font-mono text-emerald-700 block mt-1">"businessId": "{{ $json.recovery.businessId }}"</code>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- Raw Metadata (expandable) -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <% if (action.metadata && Object.keys(action.metadata).length > 0) { %>
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden" x-data="{ open: false }">
                    <button @click="open = !open" class="w-full px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between hover:bg-slate-100/50 transition-all">
                        <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Raw Metadata</h2>
                        <i data-lucide="chevron-down" class="w-4 h-4 text-slate-400 transition-transform" :class="open ? 'rotate-180' : ''"></i>
                    </button>
                    <div x-show="open" x-collapse>
                        <pre class="px-8 py-6 text-xs font-mono text-slate-600 bg-slate-50 overflow-x-auto whitespace-pre-wrap break-all"><%= JSON.stringify(action.metadata, null, 2) %></pre>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Right: Sidebar (1/3 width) -->
        <div class="space-y-6">

            <!-- Communication Log -->
            <% if (communicationLog) { %>
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
                        <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Communication Log</h2>
                    </div>
                    <div class="px-6 py-5 space-y-3 text-xs">
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Channel</span>
                            <span class="font-bold text-slate-700"><%= communicationLog.channel || '—' %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Recipient</span>
                            <span class="font-bold text-slate-700 truncate max-w-[150px]"><%= communicationLog.recipientEmail || '—' %></span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Status</span>
                            <span class="font-bold text-slate-700"><%= communicationLog.status || '—' %></span>
                        </div>
                    </div>
                </div>
            <% } %>

            <!-- Session Overview -->
            <% if (session) { %>
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                    <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
                        <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Parent Session</h2>
                    </div>
                    <div class="px-6 py-5 space-y-3 text-xs">
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Customer</span>
                            <a href="/dashboard/recovery/customers/<%= session.customerId %>" class="font-bold text-indigo-600 hover:text-indigo-800 transition-colors truncate max-w-[150px]">
                                <%= session.customerName || session.customerId %>
                            </a>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Status</span>
                            <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase tracking-widest
                                <%= session.status === 'ACTIVE' ? 'bg-indigo-50 text-indigo-500' :
                                   session.status === 'RECOVERED' ? 'bg-emerald-50 text-emerald-500' :
                                   session.status === 'PAUSED' ? 'bg-amber-50 text-amber-500' :
                                   'bg-slate-100 text-slate-400' %>">
                                <%= session.status %>
                            </span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-400 font-medium">Step</span>
                            <span class="font-bold text-slate-700"><%= session.currentStepIndex + 1 %> / <%= stepTotal %></span>
                        </div>
                        <% if (sequence) { %>
                            <div class="flex justify-between">
                                <span class="text-slate-400 font-medium">Sequence</span>
                                <span class="font-bold text-slate-700 truncate max-w-[150px]"><%= sequence.name %></span>
                            </div>
                        <% } %>

                        <!-- Other actions in this session -->
                        <% if (session.actions && session.actions.length > 1) { %>
                            <div class="pt-3 border-t border-slate-100">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Other Actions in Session</p>
                                <div class="space-y-1 max-h-[200px] overflow-y-auto">
                                    <% session.actions.forEach(a => { %>
                                        <a href="/dashboard/recovery/actions/<%= a.id %>" 
                                           class="flex items-center justify-between px-3 py-2 rounded-xl hover:bg-slate-50 transition-all <%= a.id === action.id ? 'bg-indigo-50 ring-1 ring-indigo-200' : '' %>">
                                            <div>
                                                <span class="text-[10px] font-bold text-slate-600"><%= a.actionType %></span>
                                                <span class="text-[9px] text-slate-400 ml-1"><%= a.id.substring(0, 8) %>...</span>
                                            </div>
                                            <span class="text-[9px] font-black uppercase tracking-widest
                                                <%= a.status === 'SENT' ? 'text-emerald-500' :
                                                   a.status === 'FAILED' ? 'text-red-500' :
                                                   'text-slate-400' %>">
                                                <%= a.status %>
                                            </span>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% } %>

            <!-- Quick Actions -->
            <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
                    <h2 class="text-xs font-black text-slate-500 uppercase tracking-[0.15em]">Quick Actions</h2>
                </div>
                <div class="px-6 py-5 space-y-3">
                    <a href="/dashboard/recovery/sessions" 
                       class="flex items-center gap-2 px-4 py-3 bg-slate-50 rounded-2xl text-xs font-bold text-slate-600 hover:bg-slate-100 transition-all border border-slate-100">
                        <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
                        Back to Sessions
                    </a>
                    <% if (session) { %>
                        <a href="/dashboard/recovery/customers/<%= session.customerId %>"
                           class="flex items-center gap-2 px-4 py-3 bg-indigo-50 rounded-2xl text-xs font-bold text-indigo-600 hover:bg-indigo-100 transition-all border border-indigo-100">
                            <i data-lucide="user" class="w-3.5 h-3.5"></i>
                            View Customer Profile
                        </a>
                    <% } %>
                    <!-- Retry Button (only if FAILED) -->
                    <% if (action.status === 'FAILED' || action.status === 'QUEUED') { %>
                        <button onclick="retryAction('<%= action.id %>')"
                                class="w-full flex items-center gap-2 px-4 py-3 bg-amber-50 rounded-2xl text-xs font-bold text-amber-600 hover:bg-amber-100 transition-all border border-amber-100">
                            <i data-lucide="refresh-cw" class="w-3.5 h-3.5"></i>
                            Retry Action
                        </button>
                    <% } %>
                    <!-- Copy Action ID -->
                    <button onclick="copyToClipboard('<%= action.id %>')"
                            class="w-full flex items-center gap-2 px-4 py-3 bg-slate-50 rounded-2xl text-xs font-bold text-slate-600 hover:bg-slate-100 transition-all border border-slate-100">
                        <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                        Copy Action ID
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
async function retryAction(actionId) {
    if (!confirm('Retry this dunning action? This will dispatch a new n8n webhook immediately.')) return;
    try {
        const res = await fetch(`/api/v1/recovery/actions/${actionId}/retry`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await res.json();
        if (data.success) {
            alert('✅ Action queued for retry! Refresh in 30 seconds.');
        } else {
            alert('❌ Retry failed: ' + (data.error || 'Unknown error'));
        }
    } catch (e) {
        alert('Network error: ' + e.message);
    }
}

function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
        alert('Copied to clipboard!');
    }).catch(() => {
        // Fallback
        const el = document.createElement('textarea');
        el.value = text;
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        alert('Copied to clipboard!');
    });
}

document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
