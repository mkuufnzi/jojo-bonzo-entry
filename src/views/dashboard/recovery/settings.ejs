<%- layout('layouts/dashboard-layout') %>

<div class="w-full max-w-4xl mx-auto py-8 px-4 sm:px-6" x-data="recoverySettings()">
    <!-- Breadcrumbs -->
    <nav class="flex mb-8" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
            <li class="inline-flex items-center">
                <a href="/dashboard/recovery" class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors">
                    <i data-lucide="shield-check" class="w-4 h-4 mr-2"></i>
                    Smart Recovery
                </a>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <i data-lucide="chevron-right" class="w-4 h-4 text-slate-400"></i>
                    <span class="ml-1 text-sm font-bold text-slate-900 md:ml-2">Advanced Settings</span>
                </div>
            </li>
        </ol>
    </nav>

    <div class="space-y-8">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-slate-200 pb-8">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                    <h1 class="text-3xl font-black text-slate-900 tracking-tight" x-text="form.name || 'Recovery Configuration'"></h1>
                    <template x-if="form.isDefault">
                        <span class="px-2 py-0.5 bg-indigo-100 text-indigo-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-indigo-200">Default</span>
                    </template>
                </div>
                <p class="text-slate-500 font-medium">Fine-tune how and when Floovioo follows up on your unpaid invoices.</p>
            </div>
            <div class="flex items-center gap-3">
                <button @click="saveSettings()" 
                        :disabled="saving"
                        class="px-6 py-2.5 bg-indigo-600 text-white rounded-xl text-sm font-bold hover:bg-indigo-700 transition-all shadow-lg active:scale-95 disabled:opacity-50">
                    <span x-text="saving ? 'Saving...' : 'Save Changes'"></span>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-8">
            <!-- Global Thresholds -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="settings-2" class="w-4 h-4"></i>
                    General Info & Strategy
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8 pb-8 border-b border-slate-100">
                    <!-- Name -->
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Campaign Name</label>
                        <input type="text" x-model="form.name" class="w-full p-3 rounded-xl border-slate-200 text-sm font-bold shadow-sm focus:ring-indigo-500">
                    </div>
                    <!-- Default Toggle (Simplified) -->
                    <div class="flex items-center gap-4 pt-9">
                         <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" x-model="form.isDefault" class="sr-only peer">
                            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                            <span class="ml-3 text-sm font-bold text-slate-700">Set as Default Campaign</span>
                        </label>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- Grace Period -->
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Grace Period (Days)</label>
                        <p class="text-xs text-slate-500 mb-4">How many days past the due date should we wait before sending the first reminder?</p>
                        <div class="flex items-center gap-4">
                            <button @click="form.settings.gracePeriod = Math.max(0, form.settings.gracePeriod - 1)" 
                                    class="w-10 h-10 rounded-lg border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition-colors">
                                <i data-lucide="minus" class="w-4 h-4 text-slate-600"></i>
                            </button>
                            <input type="number" 
                                   x-model="form.settings.gracePeriod" 
                                   class="w-20 text-center border-none text-2xl font-black text-indigo-600 focus:ring-0"
                                   readonly>
                            <button @click="form.settings.gracePeriod++" 
                                    class="w-10 h-10 rounded-lg border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition-colors">
                                <i data-lucide="plus" class="w-4 h-4 text-slate-600"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Brand Voice -->
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Default Brand Voice</label>
                        <p class="text-xs text-slate-500 mb-4">The overarching personality for your recovery communications.</p>
                        <div class="grid grid-cols-2 gap-3">
                            <button @click="form.settings.brandVoice = 'standard'"
                                    :class="form.settings.brandVoice === 'standard' ? 'border-indigo-600 bg-indigo-50 ring-2 ring-indigo-600' : 'border-slate-200 bg-white hover:border-slate-300'"
                                    class="p-4 rounded-xl border-2 text-left transition-all group">
                                <span class="block text-sm font-bold" :class="form.settings.brandVoice === 'standard' ? 'text-indigo-900' : 'text-slate-700'">Standard</span>
                                <span class="block text-[10px] text-slate-500 leading-tight mt-1">Professional, firm but polite. Best for SaaS & B2B.</span>
                            </button>
                            <button @click="form.settings.brandVoice = 'empathetic'"
                                    :class="form.settings.brandVoice === 'empathetic' ? 'border-emerald-600 bg-emerald-50 ring-2 ring-emerald-600' : 'border-slate-200 bg-white hover:border-slate-300'"
                                    class="p-4 rounded-xl border-2 text-left transition-all group">
                                <span class="block text-sm font-bold" :class="form.settings.brandVoice === 'empathetic' ? 'text-emerald-900' : 'text-slate-700'">Empathetic</span>
                                <span class="block text-[10px] text-slate-500 leading-tight mt-1">Soft, understanding, personal. Best for freelancers.</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Assignment Rules -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                    <i data-lucide="filter" class="w-4 h-4"></i>
                    Assignment Rules
                </h3>
                <p class="text-xs text-slate-500 mb-6 font-medium leading-relaxed">Define which invoices enter this campaign. Invoices matching these rules will bypass the default sequence.</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Minimum Invoice Amount ($)</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400 font-bold">$</div>
                            <input type="number" 
                                   x-model="form.rules.minAmount" 
                                   class="w-full pl-8 p-3 rounded-xl border-slate-200 text-sm font-bold shadow-sm focus:ring-indigo-500">
                        </div>
                        <p class="text-[10px] text-slate-400 mt-2">Only invoices above this amount will be tracked by this campaign.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Customer Tag / Segment</label>
                        <input type="text" 
                               x-model="form.rules.customerSegment" 
                               placeholder="e.g. VIP, Wholesale"
                               class="w-full p-3 rounded-xl border-slate-200 text-sm font-bold shadow-sm focus:ring-indigo-500">
                        <p class="text-[10px] text-slate-400 mt-2">Optional filter for specific customer types.</p>
                    </div>
                </div>
            </div>

            <!-- Sequence Steps -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="layers" class="w-4 h-4"></i>
                        Dunning Sequence Steps
                    </h3>
                    <button @click="addStep()" class="text-xs font-bold text-indigo-600 hover:text-indigo-800 flex items-center gap-1 transition-colors">
                        <i data-lucide="plus-circle" class="w-4 h-4"></i>
                        Add Reminder Step
                    </button>
                </div>

                <div class="space-y-4">
                    <template x-for="(step, index) in form.steps" :key="index">
                        <div class="p-6 rounded-2xl border border-slate-100 bg-slate-50/50 flex flex-col md:flex-row items-start md:items-center gap-6 relative group">
                            <!-- Step Number -->
                            <div class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-sm font-black text-slate-400 shadow-sm">
                                <span x-text="index + 1"></span>
                            </div>

                            <!-- Timing (Day X) -->
                            <div class="flex-1">
                                <label class="block text-[10px] uppercase font-black text-slate-400 tracking-tighter mb-1">Timing</label>
                                <div class="flex items-center gap-2">
                                    <span class="text-sm font-black text-slate-900">Day</span>
                                    <input type="number" 
                                           x-model="step.day" 
                                           class="w-16 p-2 rounded-lg border-slate-200 text-sm font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500">
                                </div>
                            </div>

                            <!-- Action -->
                            <div class="flex-1">
                                <label class="block text-[10px] uppercase font-black text-slate-400 tracking-tighter mb-1">Action Type</label>
                                <select x-model="step.action" 
                                        class="w-full p-2 rounded-lg border-slate-200 text-sm font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500">
                                    <option value="email">Send Email</option>
                                    <option value="sms">Send SMS</option>
                                    <option value="crm">CRM Integration / Logic</option>
                                </select>
                            </div>

                            <!-- Template / Copy Tone -->
                                <template x-if="step.action !== 'crm'">
                                    <div class="flex-[2]">
                                        <label class="block text-[10px] uppercase font-black text-slate-400 tracking-tighter mb-1">Message Tone / Template</label>
                                        <select x-model="step.templateId" 
                                                class="w-full p-2 rounded-lg border-slate-200 text-sm font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500 mb-2">
                                            <option value="reminder_gentle">Gentle Reminder (Friendly check-in)</option>
                                            <option value="reminder_firm">Firm Follow-up (Direct, expectation of payment)</option>
                                            <option value="reminder_final">Final Notice (Urgent, pre-legal/collection)</option>
                                        </select>
                                        
                                        <!-- Custom Copy Toggle -->
                                        <div x-data="{ editingCopy: !!step.customBody }">
                                            <button @click="editingCopy = !editingCopy" type="button" class="text-[10px] font-bold text-indigo-600 hover:text-indigo-800 flex items-center gap-1 mb-2">
                                                <i data-lucide="edit-3" class="w-3 h-3"></i>
                                                <span x-text="editingCopy ? 'Use Standard Template' : 'Customize Email Copy'"></span>
                                            </button>
                                            <textarea x-show="editingCopy" 
                                                      x-model="step.customBody"
                                                      placeholder="Hi {{customerName}}, just a quick reminder about invoice {{invoiceNumber}}..."
                                                      class="w-full p-3 rounded-xl border-slate-200 text-sm shadow-inner focus:ring-indigo-500 h-24 font-mono text-xs"></textarea>
                                        </div>
                                    </div>
                                </template>

                            <!-- CRM Description (if CRM selected) -->
                            <template x-if="step.action === 'crm'">
                                <div class="flex-[2]">
                                    <label class="block text-[10px] uppercase font-black text-slate-400 tracking-tighter mb-1">CRM Action Config</label>
                                    <div class="space-y-2">
                                        <input type="text" 
                                               x-model="step.metadata.actionName"
                                               placeholder="Action Name (e.g. 'Apply Discount')"
                                               class="w-full p-2 rounded-lg border-slate-200 text-xs font-bold shadow-sm focus:ring-indigo-500">
                                        <input type="text" 
                                               x-model="step.metadata.offerCode" 
                                               placeholder="Offer Code (Optional)"
                                               class="w-full p-2 rounded-lg border-slate-200 text-xs shadow-sm focus:ring-indigo-500">
                                    </div>
                                    <div class="mt-2 p-2 bg-indigo-50 rounded-lg text-[10px] font-medium text-indigo-700 flex items-center gap-2">
                                        <i data-lucide="zap" class="w-3 h-3 text-indigo-500"></i>
                                        Triggers 'crm:action' webhook.
                                    </div>
                                </div>
                            </template>


                            <!-- Remove -->
                            <button @click="removeStep(index)" 
                                    class="p-2 text-slate-300 hover:text-red-500 transition-colors">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </template>
                </div>

                <div class="mt-8 p-6 bg-blue-50/50 rounded-2xl border border-blue-100 flex items-start gap-4">
                    <div class="p-2 bg-blue-100 rounded-lg shrink-0">
                        <i data-lucide="info" class="w-4 h-4 text-blue-600"></i>
                    </div>
                    <div class="text-xs text-blue-800 leading-relaxed">
                        <strong class="block mb-1 font-bold">How these steps work</strong>
                        These steps are executed sequentially in order of the "Day" value. If an invoice is paid at any point, the sequence stops immediately.
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="flex justify-between items-center pt-8 border-t border-slate-200">
             <a href="/dashboard/recovery" class="text-sm font-bold text-slate-500 hover:text-slate-700 flex items-center gap-2">
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
                Back to Dashboard
             </a>
             <button @click="saveSettings()" 
                     :disabled="saving"
                     class="px-10 py-4 bg-indigo-600 text-white rounded-2xl font-black text-lg hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 active:scale-95 disabled:opacity-50">
                <span x-text="saving ? 'Saving...' : 'Save Configuration'"></span>
             </button>
        </div>
    </div>

    <!-- Toast -->
    <div x-show="toast" 
         x-transition
         class="fixed bottom-6 right-6 z-50 px-6 py-3 rounded-xl shadow-2xl text-sm font-bold flex items-center gap-2"
         :class="toastType === 'success' ? 'bg-emerald-600 text-white' : 'bg-red-600 text-white'"
         style="display: none;">
        <i data-lucide="check-circle" class="w-4 h-4" x-show="toastType === 'success'"></i>
        <i data-lucide="alert-circle" class="w-4 h-4" x-show="toastType === 'error'"></i>
        <span x-text="toastMessage"></span>
    </div>

    <!-- Data Injection (JSON to satisfy JS Linters) -->
    <%
        const isNew = typeof sequence.id === 'undefined' || !sequence.id;
        const recoveryData = {
            id: isNew ? null : sequence.id,
            name: isNew ? '' : sequence.name,
            steps: isNew ? [] : (sequence.steps || []),
            settings: sequence.settings || { gracePeriod: 3, brandVoice: 'standard' },
            rules: sequence.rules || {},
            isDefault: isNew ? false : !!sequence.isDefault
        };
    %>
    <script type="application/json" id="recovery-settings-data">
        <%- JSON.stringify(recoveryData) %>
    </script>
</div>

<script nonce="<%= nonce %>">
function recoverySettings() {
    // Initial data safely read from JSON script tag
    const dataDisplay = document.getElementById('recovery-settings-data');
    const initial = dataDisplay ? JSON.parse(dataDisplay.textContent) : {};
    // Ensure steps have a metadata object to prevent Alpine from crashing if it binds to it
    if (initial.steps && Array.isArray(initial.steps)) {
        initial.steps.forEach(step => {
            if (!step.metadata) step.metadata = { actionName: '', offerCode: '' };
        });
    }
    
    return {
        saving: false,
        toast: false,
        toastMessage: '',
        toastType: 'success',
        
        form: {
            id: initial.id,
            steps: initial.steps,
            settings: initial.settings,
            name: initial.name,
            isDefault: initial.isDefault,
            rules: initial.rules
        },

        addStep() {
            // Find max day to suggest next (increment by 7)
            const lastDay = this.form.steps.length > 0 
                ? Math.max(...this.form.steps.map(s => parseInt(s.day) || 0))
                : -3; // Start at Day 0 for first step
                
            this.form.steps.push({
                day: lastDay + 3,
                action: 'email',
                templateId: 'reminder_firm',
                metadata: { actionName: '', offerCode: '' }
            });
            
            // Re-render icons
            this.$nextTick(() => {
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        },

        removeStep(index) {
            this.form.steps.splice(index, 1);
        },

        async saveSettings() {
            this.saving = true;
            try {
                const res = await fetch('/dashboard/recovery/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.form)
                });

                const data = await res.json();
                if (data.success) {
                    this.showToast('Settings saved successfully!');
                    setTimeout(() => window.location.href = '/dashboard/recovery', 1500);
                } else {
                    throw new Error(data.error || 'Failed to save settings');
                }
            } catch (e) {
                this.showToast(e.message, 'error');
            } finally {
                this.saving = false;
            }
        },

        showToast(msg, type = 'success') {
            this.toastMessage = msg;
            this.toastType = type;
            this.toast = true;
            setTimeout(() => this.toast = false, 3000);
            this.$nextTick(() => {
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        }
    }
}
</script>
