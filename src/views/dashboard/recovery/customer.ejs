<%- layout('layouts/dashboard-layout') %>

<div class="w-full max-w-[1920px] mx-auto px-2 sm:px-6 overflow-x-hidden" x-data="customerRecovery()">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <a href="/dashboard/recovery/unpaid" class="text-xs font-bold text-slate-400 hover:text-indigo-600 transition-colors flex items-center gap-1">
                    <i data-lucide="arrow-left" class="w-3 h-3"></i>
                    Back to Unpaid Invoices
                </a>
            </div>
            <h1 class="text-2xl sm:text-3xl font-heading font-black text-slate-900 tracking-tight flex items-center gap-3">
                <%= customer.name %>
            </h1>
            <div class="flex items-center gap-4 mt-2 text-xs text-slate-500 font-medium">
                <% if (customer.email) { %>
                    <span class="flex items-center gap-1"><i data-lucide="mail" class="w-3 h-3"></i> <%= customer.email %></span>
                <% } %>
                <% if (customer.phone) { %>
                    <span class="flex items-center gap-1"><i data-lucide="phone" class="w-3 h-3"></i> <%= customer.phone %></span>
                <% } %>
                <% if (customer.company) { %>
                    <span class="flex items-center gap-1"><i data-lucide="building" class="w-3 h-3"></i> <%= customer.company %></span>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Total Balance</p>
            <p class="text-2xl font-black text-slate-900">$<%= Number(stats.totalBalance).toLocaleString() %></p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Unpaid Invoices</p>
            <p class="text-2xl font-black text-amber-600"><%= stats.unpaidCount %></p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Overdue</p>
            <p class="text-2xl font-black text-red-600"><%= stats.overdueCount %></p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm">
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Active Recovery</p>
            <p class="text-2xl font-black text-indigo-600"><%= stats.activeRecoveryCount %></p>
        </div>
    </div>

    <!-- Full Width Layout & Top Actions -->
    <div class="mb-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <!-- Tab Filter -->
        <div class="flex items-center gap-2">
            <button @click="activeFilter = 'all'" :class="activeFilter === 'all' ? 'bg-slate-900 text-white' : 'bg-white text-slate-500 hover:bg-slate-50'" class="px-4 py-2 rounded-xl text-xs font-bold transition-all border border-slate-200">
                All (<%= invoices.length %>)
            </button>
            <button @click="activeFilter = 'unpaid'" :class="activeFilter === 'unpaid' ? 'bg-amber-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-50'" class="px-4 py-2 rounded-xl text-xs font-bold transition-all border border-slate-200">
                Unpaid (<%= invoices.filter(i => i.balance > 0).length %>)
            </button>
            <button @click="activeFilter = 'overdue'" :class="activeFilter === 'overdue' ? 'bg-red-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-50'" class="px-4 py-2 rounded-xl text-xs font-bold transition-all border border-slate-200">
                Overdue (<%= invoices.filter(i => i.category === 'overdue' || i.category === 'recovery').length %>)
            </button>
            <button @click="activeFilter = 'recovery'" :class="activeFilter === 'recovery' ? 'bg-indigo-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-50'" class="px-4 py-2 rounded-xl text-xs font-bold transition-all border border-slate-200">
                In Recovery (<%= invoices.filter(i => i.category === 'recovery').length %>)
            </button>
            <button @click="activeFilter = 'paid'" :class="activeFilter === 'paid' ? 'bg-emerald-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-50'" class="px-4 py-2 rounded-xl text-xs font-bold transition-all border border-slate-200">
                Paid (<%= invoices.filter(i => i.balance === 0).length %>)
            </button>
        </div>

        <!-- Bulk Action: Assign Sequence & Start Recovery -->
        <div class="flex items-center gap-3">
            <select x-model="selectedSequence" class="px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-xs font-bold text-slate-700 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm w-48">
                <% sequences.forEach(seq => { %>
                    <option value="<%= seq.id %>" <%= seq.isDefault ? 'selected' : '' %>><%= seq.name %> <%= seq.isDefault ? '(Default)' : '' %></option>
                <% }); %>
            </select>

            <% const unpaidInvoices = invoices.filter(i => i.balance > 0 && i.category !== 'recovery'); %>
            <button @click="startRecovery()" 
                    :disabled="enrolling || <%= unpaidInvoices.length === 0 %>"
                    class="px-5 py-2.5 bg-indigo-600 text-white rounded-xl text-xs font-bold uppercase tracking-widest shadow-md hover:bg-indigo-500 hover:shadow-lg transition-all active:scale-[0.98] disabled:opacity-50 flex items-center justify-center gap-2">
                <i data-lucide="play" class="w-4 h-4"></i>
                <span x-text="enrolling ? 'Starting...' : 'Enroll <%= unpaidInvoices.length %> Invoices'"></span>
            </button>
        </div>
    </div>

    <!-- Main Table Container -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden mb-8">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="px-5 py-4 w-10"></th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Invoice</th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Date</th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400">Due</th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Total</th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Balance</th>
                        <th class="px-5 py-4 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% invoices.forEach(inv => { %>
                        <tr class="hover:bg-slate-50/50 transition-colors cursor-pointer group"
                            @click="expandedInvoice = expandedInvoice === '<%= inv.externalId %>' ? null : '<%= inv.externalId %>'"
                            x-show="activeFilter === 'all' 
                                || (activeFilter === 'unpaid' && '<%= inv.status %>' === 'unpaid') 
                                || (activeFilter === 'overdue' && ('<%= inv.category %>' === 'overdue' || '<%= inv.category %>' === 'recovery'))
                                || (activeFilter === 'recovery' && '<%= inv.category %>' === 'recovery')
                                || (activeFilter === 'paid' && '<%= inv.status %>' === 'paid')">
                            <td class="px-5 py-4 w-32 border-r border-slate-50 border-dashed">
                                <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg transition-colors border border-transparent"
                                     :class="expandedInvoice === '<%= inv.externalId %>' ? 'bg-indigo-50 text-indigo-600 border-indigo-100' : 'text-slate-400 group-hover:bg-slate-100 group-hover:text-slate-600 group-hover:border-slate-200'">
                                    <i data-lucide="chevron-down" class="w-4 h-4 transition-transform duration-200"
                                       :class="expandedInvoice === '<%= inv.externalId %>' ? 'rotate-180' : ''"></i>
                                    <span class="text-[10px] font-bold uppercase tracking-widest whitespace-nowrap" 
                                          x-text="expandedInvoice === '<%= inv.externalId %>' ? 'Close' : 'History'"></span>
                                </div>
                            </td>
                            <td class="px-5 py-4">
                                <span class="font-bold text-slate-700 text-sm">#<%= inv.externalId %></span>
                            </td>
                            <td class="px-5 py-4 text-xs text-slate-500 font-medium">
                                <%= inv.date.toLocaleDateString() %>
                            </td>
                            <td class="px-5 py-4 text-xs font-bold <%= inv.daysOverdue > 0 && inv.balance > 0 ? 'text-red-500' : 'text-slate-500' %>">
                                <%= inv.dueDate ? inv.dueDate.toLocaleDateString() : 'N/A' %>
                                <% if (inv.daysOverdue > 0 && inv.balance > 0) { %>
                                    <span class="block text-[10px] font-medium opacity-75"><%= inv.daysOverdue %>d overdue</span>
                                <% } %>
                            </td>
                            <td class="px-5 py-4 text-right">
                                <span class="font-bold text-slate-600 text-sm">$<%= Number(inv.total).toLocaleString() %></span>
                            </td>
                            <td class="px-5 py-4 text-right">
                                <span class="font-black text-sm <%= inv.balance > 0 ? 'text-slate-900' : 'text-emerald-500' %>">
                                    $<%= Number(inv.balance).toLocaleString() %>
                                </span>
                            </td>
                            <td class="px-5 py-4 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <% if (inv.category === 'recovery') { %>
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-indigo-50 text-indigo-600 border border-indigo-100">
                                            <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></div>
                                            Follow-up
                                        </span>
                                    <% } else if (inv.category === 'overdue') { %>
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-red-50 text-red-600 border border-red-100">
                                            <div class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></div>
                                            Overdue
                                        </span>
                                    <% } else if (inv.category === 'grace') { %>
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-50 text-amber-600 border border-amber-100">
                                            Grace Period
                                        </span>
                                    <% } else if (inv.category === 'open') { %>
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-slate-100 text-slate-500 border border-slate-200">
                                            Open
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide bg-emerald-50 text-emerald-600 border border-emerald-100">
                                            <i data-lucide="check" class="w-3 h-3"></i> Paid
                                        </span>
                                    <% } %>
                                    
                                    <% if (inv.daysOverdue > 0 && inv.balance > 0) { %>
                                        <button @click.stop="analyzeRisk('<%= inv.externalId %>')" class="p-1.5 rounded-lg bg-slate-50 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors border border-slate-200 hover:border-indigo-200" title="AI Risk Analysis">
                                            <i data-lucide="brain" class="w-3.5 h-3.5"></i>
                                        </button>
                                    <% } %>
                                </div>
                            </td>
                        </tr>

                        <tr x-show="expandedInvoice === '<%= inv.externalId %>'" x-collapse class="bg-indigo-50/20 shadow-inner border-y border-indigo-100/50 relative z-10">
                            <td colspan="7" class="px-8 py-8">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-10" @click.stop>
                                    
                                    <!-- Left Col: Session Details & Controls -->
                                    <% 
                                        const session = recoverySessions.find(s => s.externalInvoiceId === inv.externalId);
                                    %>
                                    <div>
                                        <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 flex items-center gap-2">
                                            <i data-lucide="shield-alert" class="w-3 h-3"></i> Recovery Session
                                        </h4>
                                        <% if (session) { %>
                                            <div class="bg-white p-4 rounded-xl border <%= session.status === 'ACTIVE' ? 'border-indigo-100 shadow-sm shadow-indigo-100/50' : session.status === 'PAUSED' ? 'border-amber-100' : 'border-slate-100' %>">
                                                <div class="flex items-center justify-between mb-3">
                                                    <span class="text-sm font-bold text-slate-800"><%= session.sequence.name %></span>
                                                    <span class="text-[9px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full
                                                        <% if (session.status === 'ACTIVE') { %>
                                                            bg-indigo-100 text-indigo-700
                                                        <% } else if (session.status === 'RECOVERED') { %>
                                                            bg-emerald-100 text-emerald-700
                                                        <% } else if (session.status === 'PAUSED') { %>
                                                            bg-amber-100 text-amber-700
                                                        <% } else { %>
                                                            bg-slate-100 text-slate-600
                                                        <% } %>
                                                    "><%= session.status %></span>
                                                </div>
                                                
                                                <div class="space-y-1 mb-4">
                                                    <p class="text-[11px] text-slate-500 font-medium">
                                                        <span class="text-slate-400 w-16 inline-block">Progress:</span> 
                                                        Step <%= session.currentStepIndex + 1 %> of <%= Array.isArray(session.sequence.steps) ? session.sequence.steps.length : '?' %>
                                                    </p>
                                                    <% if (session.nextActionAt && session.status === 'ACTIVE') { %>
                                                        <p class="text-[11px] text-slate-500 font-medium">
                                                            <span class="text-slate-400 w-16 inline-block">Next action:</span> 
                                                            <span class="font-bold text-indigo-600"><%= new Date(session.nextActionAt).toLocaleDateString() %></span>
                                                        </p>
                                                    <% } %>
                                                    <p class="text-[11px] text-slate-500 font-medium">
                                                        <span class="text-slate-400 w-16 inline-block">Started:</span> 
                                                        <%= new Date(session.createdAt).toLocaleDateString() %>
                                                    </p>
                                                </div>

                                                <% if (session.status === 'ACTIVE' || session.status === 'PAUSED') { %>
                                                    <div class="flex flex-wrap items-center gap-2 pt-3 border-t border-slate-100">
                                                        <% if (session.status === 'ACTIVE') { %>
                                                            <button @click="sessionAction('<%= session.id %>', 'pause')" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded-lg bg-amber-50 text-amber-600 hover:bg-amber-100 border border-amber-200/50 transition-all flex items-center gap-1.5"><i data-lucide="pause" class="w-3 h-3"></i> Pause</button>
                                                            <button @click="openEscalateModal('<%= session.id %>')" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded-lg bg-indigo-50 text-indigo-600 hover:bg-indigo-100 border border-indigo-200/50 transition-all flex items-center gap-1.5"><i data-lucide="arrow-up-circle" class="w-3 h-3"></i> Escalate</button>
                                                        <% } else if (session.status === 'PAUSED') { %>
                                                            <button @click="sessionAction('<%= session.id %>', 'resume')" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded-lg bg-emerald-50 text-emerald-600 hover:bg-emerald-100 border border-emerald-200/50 transition-all flex items-center gap-1.5"><i data-lucide="play" class="w-3 h-3"></i> Resume</button>
                                                        <% } %>
                                                        <button @click="openReassignModal('<%= session.id %>')" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded-lg bg-white text-slate-600 border border-slate-200 hover:bg-slate-50 transition-all flex items-center gap-1.5"><i data-lucide="git-branch" class="w-3 h-3"></i> Reassign</button>
                                                        
                                                        <div class="flex-1"></div>
                                                        <button @click="sessionAction('<%= session.id %>', 'terminate')" class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest rounded-lg bg-red-50 text-red-600 hover:bg-red-100 border border-red-200/50 transition-all ml-auto hover:text-white hover:bg-red-500 hover:border-red-600"><i data-lucide="x-octagon" class="w-3 h-3"></i> Terminate</button>
                                                    </div>
                                                <% } %>
                                            </div>
                                        <% } else { %>
                                            <div class="bg-white/50 border border-dashed border-slate-200 rounded-xl p-6 text-center">
                                                <i data-lucide="folder-check" class="w-6 h-6 text-slate-300 mx-auto mb-2"></i>
                                                <p class="text-xs text-slate-500 font-medium">No active recovery session.</p>
                                                <% if (inv.balance > 0) { %>
                                                    <p class="text-[10px] text-slate-400 mt-1">Use the tools above to enroll this invoice.</p>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    </div>

                                    <!-- Right Col: Action Timeline -->
                                    <% 
                                        const invoiceActions = actions.filter(a => a.externalInvoiceId === inv.externalId);
                                    %>
                                    <div>
                                        <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3 flex items-center gap-2">
                                            <i data-lucide="history" class="w-3 h-3"></i> Action Timeline
                                        </h4>
                                        <% if (invoiceActions.length === 0) { %>
                                            <div class="bg-white/50 border border-dashed border-slate-200 rounded-xl p-6 text-center h-[132px] flex flex-col justify-center items-center">
                                                <i data-lucide="inbox" class="w-5 h-5 text-slate-300 mb-2"></i>
                                                <p class="text-[11px] text-slate-400 font-medium">No follow-ups recorded yet.</p>
                                            </div>
                                        <% } else { %>
                                            <div class="bg-white rounded-xl border border-slate-100 p-4 max-h-[250px] overflow-y-auto custom-scrollbar relative">
                                                <!-- Vertical line -->
                                                <div class="absolute left-6 top-6 bottom-6 w-px bg-slate-100"></div>
                                                
                                                <div class="space-y-4">
                                                    <% invoiceActions.forEach(action => { %>
                                                        <div class="relative pl-8">
                                                            <div class="absolute left-0.5 top-1.5 w-3 h-3 rounded-full border-2 border-white shadow-sm <%= action.status === 'SENT' ? 'bg-emerald-500' : action.status === 'FAILED' ? 'bg-red-500' : action.status === 'DISPATCHED' ? 'bg-amber-500' : 'bg-slate-300' %>"></div>
                                                            <div class="flex items-start justify-between gap-4">
                                                                <div>
                                                                    <div class="flex items-center gap-2 mb-0.5">
                                                                        <span class="text-xs font-bold text-slate-800 capitalize"><%= action.actionType.replace(/_/g, ' ') %></span>
                                                                        
                                                                        <% if (action.status === 'SENT') { %>
                                                                            <span class="text-[9px] font-black text-emerald-600 uppercase tracking-widest bg-emerald-50 px-1.5 py-0.5 rounded">Sent</span>
                                                                        <% } else if (action.status === 'DISPATCHED') { %>
                                                                            <span class="text-[9px] font-black text-amber-600 uppercase tracking-widest bg-amber-50 px-1.5 py-0.5 rounded">Dispatched</span>
                                                                        <% } else if (action.status === 'FAILED') { %>
                                                                            <span class="text-[9px] font-black text-red-600 uppercase tracking-widest bg-red-50 px-1.5 py-0.5 rounded">Failed</span>
                                                                        <% } else { %>
                                                                            <span class="text-[9px] font-black text-slate-500 uppercase tracking-widest bg-slate-100 px-1.5 py-0.5 rounded"><%= action.status %></span>
                                                                        <% } %>
                                                                    </div>
                                                                    <p class="text-[10px] text-slate-400 font-medium">
                                                                        <%= new Date(action.sentAt || action.createdAt).toLocaleString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                                                    </p>
                                                                    <% if (action.aiGeneratedCopy) { %>
                                                                        <p class="text-[11px] text-slate-600 mt-2 italic bg-slate-50 p-2 rounded-lg border border-slate-100">"<%= action.aiGeneratedCopy.substring(0, 150) %><%= action.aiGeneratedCopy.length > 150 ? '...' : '' %>"</p>
                                                                    <% } %>
                                                                    <% if (action.metadata?.error) { %>
                                                                        <p class="text-[11px] text-red-600 mt-1 font-mono break-all"><%= action.metadata.error %></p>
                                                                    <% } %>
                                                                </div>
                                                                
                                                                <% if (action.status === 'FAILED') { %>
                                                                    <button @click="retryAction('<%= action.id %>')" :disabled="retrying === '<%= action.id %>'" class="shrink-0 px-2 py-1 text-[10px] font-bold uppercase tracking-wide rounded-lg border border-red-200 text-red-600 hover:bg-red-50 hover:border-red-300 transition-all flex items-center gap-1 disabled:opacity-50">
                                                                        <i x-show="retrying === '<%= action.id %>'" data-lucide="loader-2" class="w-3 h-3 animate-spin"></i>
                                                                        <i x-show="retrying !== '<%= action.id %>'" data-lucide="rotate-cw" class="w-3 h-3"></i>
                                                                        Retry
                                                                    </button>
                                                                <% } else { %>
                                                                    <a href="/dashboard/recovery/actions/<%= action.id %>" class="shrink-0 text-slate-400 hover:text-indigo-600 transition-colors p-1" title="View Details">
                                                                        <i data-lucide="external-link" class="w-4 h-4"></i>
                                                                    </a>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    <% }); %>
                                                </div>
                                            </div>
                                        <% } %>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modals -->
    <!-- Analyze Risk Modal -->
    <div x-show="analyzeModalOpen" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm" style="display: none;">
        <div @click.away="analyzeModalOpen = false" class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden border border-slate-100">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
                    <i data-lucide="brain" class="w-4 h-4 text-indigo-500"></i>
                    AI Risk Analysis
                </h3>
                <button @click="analyzeModalOpen = false" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6">
                <div x-show="analyzing" class="text-center py-8">
                    <i data-lucide="loader-2" class="w-8 h-8 text-indigo-500 animate-spin mx-auto mb-4"></i>
                    <p class="text-sm text-slate-500 font-medium">Analyzing invoice risk factors...</p>
                </div>
                <div x-show="!analyzing && riskData" class="space-y-6">
                    <div class="flex items-center justify-between p-4 rounded-2xl border" 
                         :class="{
                             'bg-red-50 border-red-100': riskData?.riskLevel === 'critical',
                             'bg-amber-50 border-amber-100': riskData?.riskLevel === 'high',
                             'bg-yellow-50 border-yellow-100': riskData?.riskLevel === 'medium',
                             'bg-emerald-50 border-emerald-100': riskData?.riskLevel === 'low'
                         }">
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-1">Risk Score</p>
                            <div class="flex items-baseline gap-2">
                                <span class="text-3xl font-black" 
                                      :class="{
                                          'text-red-700': riskData?.riskLevel === 'critical',
                                          'text-amber-700': riskData?.riskLevel === 'high',
                                          'text-yellow-700': riskData?.riskLevel === 'medium',
                                          'text-emerald-700': riskData?.riskLevel === 'low'
                                      }" x-text="riskData?.riskScore"></span>
                                <span class="text-xs font-bold text-slate-500">/ 100</span>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wide"
                                  :class="{
                                      'bg-red-100 text-red-700': riskData?.riskLevel === 'critical',
                                      'bg-amber-100 text-amber-700': riskData?.riskLevel === 'high',
                                      'bg-yellow-100 text-yellow-700': riskData?.riskLevel === 'medium',
                                      'bg-emerald-100 text-emerald-700': riskData?.riskLevel === 'low'
                                  }" x-text="riskData?.riskLevel"></span>
                        </div>
                    </div>
                    
                    <div>
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-3">Key Factors</p>
                        <ul class="space-y-2">
                            <template x-for="factor in riskData?.factors" :key="factor.name">
                                <li class="flex items-start gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100 transition-colors hover:bg-white hover:shadow-sm">
                                    <div class="mt-0.5"><i data-lucide="info" class="w-4 h-4 text-slate-400"></i></div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-0.5">
                                            <span class="text-xs font-bold text-slate-700" x-text="factor.name"></span>
                                            <span class="text-[10px] font-black text-slate-400 bg-white border border-slate-200 px-1.5 rounded shadow-sm" x-text="'+' + factor.impact + ' pts'"></span>
                                        </div>
                                        <p class="text-[10px] text-slate-500 font-medium" x-text="factor.description"></p>
                                    </div>
                                </li>
                            </template>
                        </ul>
                    </div>

                    <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4">
                        <p class="text-[10px] font-black uppercase tracking-widest text-indigo-400 mb-1">AI Recommendation</p>
                        <p class="text-sm font-bold text-indigo-900" x-text="riskData?.recommendedAction"></p>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex justify-end">
                <button @click="analyzeModalOpen = false" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-xs font-bold shadow-sm hover:bg-slate-50 transition-colors focus:ring-2 focus:ring-slate-200 outline-none">Close</button>
            </div>
        </div>
    </div>

    <!-- Reassign Modal -->
    <div x-show="reassignModalOpen" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm" style="display: none;">
        <div @click.away="reassignModalOpen = false" class="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden border border-slate-100">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <h3 class="text-sm font-black text-slate-800">Reassign Session</h3>
                <button @click="reassignModalOpen = false" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6">
                <p class="text-xs text-slate-500 mb-4">Select a new dunning sequence to move this recovery session to. The session step will reset to 1.</p>
                <div class="space-y-3">
                    <select x-model="reassignTargetSeq" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow">
                        <% sequences.forEach(seq => { %>
                            <option value="<%= seq.id %>"><%= seq.name %> <%= seq.isDefault ? '(Default)' : '' %></option>
                        <% }); %>
                    </select>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex justify-end gap-2">
                <button @click="reassignModalOpen = false" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-xs font-bold shadow-sm hover:bg-slate-50 transition-colors focus:ring-2 focus:ring-slate-200 outline-none">Cancel</button>
                <button @click="submitReassign()" :disabled="reassigning" class="px-4 py-2 bg-indigo-600 text-white rounded-xl text-xs font-bold shadow-sm hover:bg-indigo-500 disabled:opacity-50 transition-colors focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 outline-none flex items-center gap-2">
                    <i x-show="reassigning" data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i>
                    <span x-text="reassigning ? 'Moving...' : 'Confirm Move'"></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Escalate Modal -->
    <div x-show="escalateModalOpen" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-slate-900/50 backdrop-blur-sm" style="display: none;">
        <div @click.away="escalateModalOpen = false" class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden border border-slate-100">
            <div class="px-6 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <h3 class="text-sm font-black text-slate-800 flex items-center gap-2">
                    <i data-lucide="arrow-up-circle" class="w-4 h-4 text-indigo-500"></i>
                    Escalate Session
                </h3>
                <button @click="escalateModalOpen = false" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="p-6">
                <p class="text-xs text-slate-500 mb-6">Choose how you want to escalate this active recovery session.</p>
                
                <div class="space-y-4">
                    <label class="flex items-start gap-4 p-4 rounded-2xl border cursor-pointer transition-all" :class="escalationType === 'SKIP_STEP' ? 'bg-indigo-50/50 border-indigo-200 shadow-sm' : 'bg-white border-slate-200 hover:border-indigo-100'">
                        <input type="radio" value="SKIP_STEP" x-model="escalationType" class="mt-1 w-4 h-4 text-indigo-600 border-slate-300 focus:ring-indigo-500">
                        <div>
                            <span class="block text-sm font-bold text-slate-800">Skip to Next Step</span>
                            <span class="block text-xs text-slate-500 mt-1">Schedules the next step in the dunning sequence to fire immediately.</span>
                        </div>
                    </label>

                    <label class="flex items-start gap-4 p-4 rounded-2xl border cursor-pointer transition-all" :class="escalationType === 'EXTERNAL_COLLECTION' ? 'bg-amber-50/50 border-amber-200 shadow-sm' : 'bg-white border-slate-200 hover:border-amber-100'">
                        <input type="radio" value="EXTERNAL_COLLECTION" x-model="escalationType" class="mt-1 w-4 h-4 text-amber-600 border-slate-300 focus:ring-amber-500">
                        <div>
                            <span class="block text-sm font-bold text-slate-800">External Collections</span>
                            <span class="block text-xs text-slate-500 mt-1">Terminates automated recovery and assigns the invoice to an external collections agency.</span>
                        </div>
                    </label>

                    <label class="flex items-start gap-4 p-4 rounded-2xl border cursor-pointer transition-all" :class="escalationType === 'LEGAL_ACTION' ? 'bg-red-50/50 border-red-200 shadow-sm' : 'bg-white border-slate-200 hover:border-red-100'">
                        <input type="radio" value="LEGAL_ACTION" x-model="escalationType" class="mt-1 w-4 h-4 text-red-600 border-slate-300 focus:ring-red-500">
                        <div>
                            <span class="block text-sm font-bold text-slate-800">Legal Action</span>
                            <span class="block text-xs text-slate-500 mt-1">Terminates automated recovery and flags for immediate legal escalation.</span>
                        </div>
                    </label>
                </div>

                <div class="mt-6" x-show="escalationType !== 'SKIP_STEP'">
                    <label class="block text-xs font-bold text-slate-700 mb-2">Escalation Note (Required)</label>
                    <textarea x-model="escalationNote" rows="3" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow" placeholder="Add a reason or context for this manual escalation..."></textarea>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex justify-end gap-2">
                <button @click="escalateModalOpen = false" class="px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-xs font-bold shadow-sm hover:bg-slate-50 transition-colors focus:ring-2 focus:ring-slate-200 outline-none">Cancel</button>
                <button @click="submitEscalate()" :disabled="escalating || (escalationType !== 'SKIP_STEP' && !escalationNote.trim())" class="px-5 py-2 min-w-[120px] rounded-xl text-xs font-bold shadow-sm text-white transition-colors focus:ring-2 focus:ring-offset-2 outline-none flex items-center justify-center gap-2 disabled:opacity-50"
                        :class="{
                            'bg-indigo-600 hover:bg-indigo-500 focus:ring-indigo-500': escalationType === 'SKIP_STEP',
                            'bg-amber-600 hover:bg-amber-500 focus:ring-amber-500': escalationType === 'EXTERNAL_COLLECTION',
                            'bg-red-600 hover:bg-red-500 focus:ring-red-500': escalationType === 'LEGAL_ACTION'
                        }">
                    <i x-show="escalating" data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i>
                    <span x-text="escalating ? 'Escalating...' : 'Confirm Escalation'"></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div x-show="toast" x-transition
         class="fixed bottom-6 right-6 z-50 px-6 py-4 rounded-2xl shadow-2xl text-sm font-bold flex items-center gap-3 bg-slate-900 text-white border border-white/10"
         style="display: none;">
        <i data-lucide="check-circle" class="w-5 h-5" :class="toastType === 'success' ? 'text-emerald-400' : 'text-red-400'"></i>
        <span x-text="toastMessage"></span>
    </div>
</div>

<script nonce="<%= nonce %>">
function customerRecovery() {
    return {
        activeFilter: 'all',
        expandedInvoice: null,
        // Default to the designated default sequence, or the first one available
        selectedSequence: '<%= (sequences.find(s => s.isDefault) || sequences[0])?.id || "" %>',
        enrolling: false,
        toast: false,
        toastMessage: '',
        toastType: 'success',

        // Modal states
        analyzeModalOpen: false,
        analyzing: false,
        riskData: null,
        
        reassignModalOpen: false,
        reassigning: false,
        selectedSessionId: null,
        reassignTargetSeq: '<%= (sequences.find(s => s.isDefault) || sequences[0])?.id || "" %>',

        escalateModalOpen: false,
        escalating: false,
        escalationType: 'SKIP_STEP',
        escalationNote: '',
        
        retrying: null,

        init() {
            // Establish Server-Sent Events (SSE) connection for real-time updates
            const source = new EventSource('/dashboard/recovery/events');
            
            source.addEventListener('invoice_paid', (e) => {
                const data = JSON.parse(e.data);
                if (data && data.invoiceId) {
                    console.log(`[SSE] Real-time Payment Received for Invoice #${data.invoiceId}`);
                    this.showToast(`Payment received for invoice #${data.invoiceId}! Refreshing...`, 'success');
                    
                    // Soft reload after 2.5 seconds to show updated data
                    setTimeout(() => {
                        window.location.reload();
                    }, 2500);
                }
            });

            source.onerror = () => {
                console.warn('[SSE] Connection lost, attempting to reconnect...');
            };
        },
        
        async analyzeRisk(invoiceId) {
            this.analyzeModalOpen = true;
            this.analyzing = true;
            this.riskData = null;
            try {
                const res = await fetch(`/api/v1/recovery/invoices/${invoiceId}/analyze`, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    this.riskData = data.data;
                    this.$nextTick(() => {
                        if (typeof lucide !== 'undefined') lucide.createIcons();
                    });
                } else {
                    this.showToast(data.error || 'Failed to analyze risk', 'error');
                    this.analyzeModalOpen = false;
                }
            } catch(e) {
                this.showToast('Network error', 'error');
                this.analyzeModalOpen = false;
            } finally {
                this.analyzing = false;
            }
        },
        
        openReassignModal(sessionId) {
            this.selectedSessionId = sessionId;
            this.reassignModalOpen = true;
        },
        
        async submitReassign() {
            if(!this.selectedSessionId || !this.reassignTargetSeq) return;
            this.reassigning = true;
            
            try {
                const res = await fetch(`/api/v1/recovery/sessions/${this.selectedSessionId}/reassign`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ sequenceId: this.reassignTargetSeq })
                });
                const data = await res.json();
                if(data.success) {
                    this.showToast('Session reassigned successfully', 'success');
                    this.reassignModalOpen = false;
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    this.showToast(data.error || 'Failed to reassign session', 'error');
                }
            } catch(e) {
                this.showToast('Network error', 'error');
            } finally {
                this.reassigning = false;
            }
        },

        openEscalateModal(sessionId) {
            this.selectedSessionId = sessionId;
            this.escalationType = 'SKIP_STEP';
            this.escalationNote = '';
            this.escalateModalOpen = true;
            this.$nextTick(() => {
                if (typeof lucide !== 'undefined') lucide.createIcons();
            });
        },
        
        async submitEscalate() {
            if(!this.selectedSessionId) return;
            this.escalating = true;
            
            try {
                const res = await fetch(`/api/v1/recovery/sessions/${this.selectedSessionId}/escalate`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: this.escalationType, note: this.escalationNote })
                });
                const data = await res.json();
                if(data.success) {
                    this.showToast('Session escalated successfully', 'success');
                    this.escalateModalOpen = false;
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    this.showToast(data.error || 'Failed to escalate session', 'error');
                }
            } catch(e) {
                this.showToast('Network error', 'error');
            } finally {
                this.escalating = false;
            }
        },

        async retryAction(actionId) {
            this.retrying = actionId;
            try {
                const res = await fetch(`/api/v1/recovery/actions/${actionId}/retry`, { method: 'POST' });
                const data = await res.json();
                if(data.success) {
                    this.showToast('Action retry triggered', 'success');
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    this.showToast(data.error || 'Failed to retry action', 'error');
                }
            } catch(e) {
                this.showToast('Network error', 'error');
            } finally {
                this.retrying = null;
            }
        },

        async startRecovery() {
            this.enrolling = true;
            try {
                const res = await fetch('/dashboard/recovery/customers/enroll', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        // Send sequence override from dropdown
                        sequenceId: this.selectedSequence,
                        customers: [{
                            customerId: '<%= customer.id %>',
                            customerName: '<%= customer.name %>',
                            // Send enriched invoice data for smart matching
                            invoices: <%- JSON.stringify(invoices.filter(i => i.balance > 0 && i.category !== 'recovery').map(i => ({
                                invoiceId: i.externalId,
                                balance: i.balance,
                                dueDate: i.dueDate
                            }))) %>
                        }]
                    })
                });
                const data = await res.json();
                if (data.success) {
                    this.showToast('Recovery started!', 'success');
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    this.showToast(data.error || 'Failed', 'error');
                }
            } catch (e) {
                this.showToast('Network error', 'error');
            } finally {
                this.enrolling = false;
            }
        },

        showToast(msg, type) {
            this.toastMessage = msg;
            this.toastType = type;
            this.toast = true;
            setTimeout(() => this.toast = false, 5000);
        },

        async sessionAction(sessionId, action) {
            const actionMap = {
                pause: { method: 'POST', endpoint: `/api/v1/recovery/sessions/${sessionId}/pause`, label: 'Paused' },
                resume: { method: 'POST', endpoint: `/api/v1/recovery/sessions/${sessionId}/resume`, label: 'Resumed' },
                terminate: { method: 'POST', endpoint: `/api/v1/recovery/sessions/${sessionId}/terminate`, label: 'Terminated' }
            };
            const config = actionMap[action];
            if (!config) return;

            if (action === 'terminate' && !confirm('Are you sure you want to terminate this recovery session?')) return;

            try {
                const res = await fetch(config.endpoint, {
                    method: config.method,
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await res.json();
                if (data.success) {
                    this.showToast(`Session ${config.label}`, 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    this.showToast(data.error || `Failed to ${action}`, 'error');
                }
            } catch (e) {
                this.showToast('Network error', 'error');
            }
        }
    };
}

document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
