<%- layout('layouts/dashboard-layout') %>

<div class="w-full max-w-[1920px] mx-auto px-2 sm:px-6 overflow-x-hidden" x-data="recoveryActivity()">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-10 gap-4">
        <div>
            <h1 class="text-2xl sm:text-3xl font-heading font-black text-slate-900 tracking-tight flex items-center gap-3">
                <div class="p-2 bg-indigo-100 rounded-xl">
                    <i data-lucide="history" class="w-6 h-6 text-indigo-600"></i>
                </div>
                Recovery Activity
            </h1>
            <p class="text-xs sm:text-sm text-slate-500 font-medium mt-1">Detailed view of overdue invoices and recovery actions.</p>
        </div>

        <div class="flex items-center gap-3">
             <a href="/dashboard/recovery" class="flex items-center gap-2 px-5 py-2.5 bg-white border border-slate-200 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-600 hover:bg-slate-50 transition-all shadow-sm active:scale-95">
                <i data-lucide="arrow-left" class="w-4 h-4 text-slate-400"></i>
                Back
            </a>
            <a href="/api/v1/recovery/export?type=<%= activeTab === 'logs' ? 'actions' : 'sessions' %>"
               class="flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-500 transition-all shadow-lg active:scale-95">
                <i data-lucide="download" class="w-4 h-4"></i>
                Export CSV
            </a>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="flex items-center gap-8 border-b border-slate-200 mb-8 overflow-x-auto no-scrollbar">
        <a href="/dashboard/recovery" class="pb-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all whitespace-nowrap">Overview</a>
        <a href="/dashboard/recovery/sequences" class="pb-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all whitespace-nowrap">Campaigns</a>
        <a href="/dashboard/recovery/sessions" class="pb-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all whitespace-nowrap">Active Sessions</a>
        <a href="/dashboard/recovery/activity" class="pb-4 text-sm font-bold border-b-2 border-indigo-600 text-indigo-600 whitespace-nowrap">History</a>
        <a href="/dashboard/recovery/clusters" class="pb-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all whitespace-nowrap">Clusters</a>
        <a href="/dashboard/recovery/webhooks" class="pb-4 text-sm font-bold border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all whitespace-nowrap">Event Log</a>
    </div>

    <!-- Main Content -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        
        <!-- Tabs -->
        <div class="border-b border-gray-100 px-6">
            <nav class="-mb-px flex space-x-8" aria-label="Tabs">
                <a href="/dashboard/recovery/activity?tab=invoices" class="<%= activeTab === 'invoices' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                    Invoices in Recovery
                </a>
                <a href="/dashboard/recovery/activity?tab=logs" class="<%= activeTab === 'logs' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' %> whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm">
                    Workflow Logs
                </a>
            </nav>
        </div>

        <!-- Filters (Placeholder) -->
        <div class="p-4 border-b border-gray-100 bg-gray-50 flex gap-4">
            <input type="text" placeholder="Search invoices..." class="input input-sm border-gray-300 rounded-md w-64">
            <select class="select select-sm border-gray-300 rounded-md">
                <option>All Statuses</option>
                <option>Active Recovery</option>
                <option>Escalated</option>
                <option>Paid</option>
            </select>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <% if (activeTab === 'invoices') { %>
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Invoice / Customer</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Action</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Next Steps</th>
                            <th scope="col" class="relative px-6 py-3">
                                <span class="sr-only">Actions</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200" x-data="{ expandedGroup: null }">
                        <% if (invoices.length === 0) { %>
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-check-circle text-4xl text-green-400 mb-3"></i>
                                    <p>No overdue invoices found in recovery.</p>
                                </td>
                            </tr>
                        <% } else { %>
                            <% invoices.forEach((group, index) => { %>
                                <!-- CUSTOMER HEADER ROW -->
                                <tr class="bg-slate-50 cursor-pointer hover:bg-slate-100 transition-colors" x-on:click="expandedGroup = expandedGroup === <%= index %> ? null : <%= index %>">
                                    <td colspan="6" class="px-6 py-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-4">
                                                <div class="w-10 h-10 rounded-xl bg-indigo-100 text-indigo-700 flex items-center justify-center font-bold text-lg shadow-inner">
                                                    <%= group.customerName.charAt(0).toUpperCase() %>
                                                </div>
                                                <div>
                                                    <h3 class="text-sm font-bold text-slate-900"><%= group.customerName %></h3>
                                                    <p class="text-xs text-slate-500 font-medium"><%= group.invoices.length %> Invoices in Recovery</p>
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-6">
                                                <div class="text-right">
                                                    <p class="text-[10px] text-slate-400 uppercase tracking-widest font-black">Total Owed</p>
                                                    <p class="text-sm font-black text-rose-600"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(group.totalAmount) %></p>
                                                </div>
                                                <i data-lucide="chevron-down" class="w-5 h-5 text-slate-400 transform transition-transform" :class="expandedGroup === <%= index %> ? 'rotate-180' : ''"></i>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                
                                <!-- INVOICES FOR THIS CUSTOMER -->
                                <% group.invoices.forEach(inv => { %>
                                    <tr x-show="expandedGroup === <%= index %>" x-cloak class="bg-white hover:bg-slate-50 transition-colors border-l-2 border-indigo-500">
                                        <td class="px-6 py-4 whitespace-nowrap pl-16">
                                            <div class="flex items-center">
                                                <div class="flex-shrink-0 flex items-center justify-center text-slate-400">
                                                    <i class="fas fa-file-invoice w-4 h-4"></i>
                                                </div>
                                                <div class="ml-3">
                                                    <div class="text-sm font-bold text-slate-700">Invoice <%= inv.id %></div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm text-slate-900 font-bold">
                                                <%= new Intl.NumberFormat('en-US', { style: 'currency', currency: inv.currency || 'USD' }).format(inv.amount) %>
                                            </div>
                                            <div class="text-[10px] font-medium text-slate-400 mt-0.5">Due: <%= new Date(inv.dueDate).toLocaleDateString() %></div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="px-2.5 py-1 inline-flex text-[10px] uppercase tracking-wider font-bold rounded-md bg-rose-50 text-rose-600 border border-rose-100">
                                                <%= inv.daysOverdue %> Days Overdue
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                                            <% if (inv.lastAction) { %>
                                                <div class="flex flex-col">
                                                    <span class="font-bold text-slate-700 text-xs uppercase tracking-wide"><%= inv.lastAction.type.replace(/_/g, ' ') %></span>
                                                    <div class="flex items-center gap-2 mt-1">
                                                        <span class="text-[10px] text-slate-400 font-medium"><%= new Date(inv.lastAction.date).toLocaleDateString() %></span>
                                                        <% if (inv.lastAction.status === 'success' || inv.lastAction.status === 'sent') { %>
                                                            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-sm bg-emerald-50 text-emerald-600">
                                                        <% } else if (inv.lastAction.status === 'dispatched') { %>
                                                            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-sm bg-amber-50 text-amber-600">
                                                        <% } else { %>
                                                            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded-sm bg-rose-50 text-rose-600">
                                                        <% } %>
                                                            <%= inv.lastAction.status %>
                                                        </span>
                                                    </div>
                                                    <% if (inv.lastAction.status && inv.lastAction.status.toUpperCase() === 'FAILED') { %>
                                                        <button @click="retryAction('<%= inv.lastAction.id %>')" :disabled="retrying === '<%= inv.lastAction.id %>'" class="mt-2 w-fit px-2 py-1 text-[9px] font-black uppercase tracking-wider rounded border border-rose-200 text-rose-600 hover:bg-rose-50 hover:border-rose-300 transition-all flex items-center gap-1 disabled:opacity-50 outline-none">
                                                            <i x-show="retrying === '<%= inv.lastAction.id %>'" data-lucide="loader-2" class="w-2.5 h-2.5 animate-spin"></i>
                                                            <i x-show="retrying !== '<%= inv.lastAction.id %>'" data-lucide="rotate-cw" class="w-2.5 h-2.5"></i>
                                                            Retry Failed
                                                        </button>
                                                    <% } %>
                                                </div>
                                            <% } else { %>
                                                <span class="text-slate-400 italic text-xs font-medium">Awaiting first action...</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                                            <% if (inv.status === 'overdue') { %>
                                                <span class="text-[10px] font-black tracking-widest uppercase text-indigo-500 flex items-center gap-1.5">
                                                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></div> Active
                                                </span>
                                            <% } else { %>
                                                <span class="text-[10px] font-bold tracking-widest uppercase text-slate-400">Standby</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                            <a href="/dashboard/recovery/customers/<%= group.customerId %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all shadow-sm group" title="View Details">
                                                <i class="fas fa-arrow-right text-xs group-hover:translate-x-0.5 transition-transform"></i>
                                            </a>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            <% } else { %>
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action Type</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Target</th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Executed At</th>
                            <th scope="col" class="relative px-6 py-3">
                                <span class="sr-only">Details</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <% if (logs.length === 0) { %>
                            <tr>
                                <td colspan="5" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fas fa-history text-4xl text-gray-300 mb-3"></i>
                                    <p>No workflow logs found for recovery.</p>
                                </td>
                            </tr>
                        <% } else { %>
                            <% logs.forEach(log => { %>
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 capitalize">
                                        <%= log.actionType %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                            <%= log.status === 'sent' || log.status === 'success' || log.status === 'dispatched' ? 'bg-green-100 text-green-800' : 
                                               log.status === 'failed' ? 'bg-red-100 text-red-800' : 
                                               'bg-yellow-100 text-yellow-800' %>">
                                            <%= log.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        <%= log.session ? 'Inv #' + log.session.externalInvoiceId : 'N/A' %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                        <%= new Date(log.createdAt).toLocaleString() %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                        <% if (log.session) { %>
                                        <a href="/dashboard/recovery/sessions/<%= log.session.id %>" class="text-indigo-600 hover:text-indigo-900" title="View Session">
                                            <i class="fas fa-search-plus"></i>
                                        </a>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            <% } %>
        </div>
        
    </div>

    <!-- Toast UI -->
    <div x-show="toast" 
         x-transition
         class="fixed bottom-6 right-6 z-50 px-6 py-4 rounded-2xl shadow-2xl text-sm font-bold flex items-center gap-3 bg-slate-900 text-white border border-white/10"
         style="display: none;">
        <i data-lucide="check-circle" class="w-5 h-5" :class="toastType === 'success' ? 'text-emerald-400' : 'text-red-400'"></i>
        <span x-text="toastMessage"></span>
    </div>
</div>

<script nonce="<%= nonce %>">
function recoveryActivity() {
    return {
        retrying: null,
        toast: false,
        toastMessage: '',
        toastType: 'success',

        showToast(msg, type = 'success') {
            this.toastMessage = msg;
            this.toastType = type;
            this.toast = true;
            setTimeout(() => this.toast = false, 5000);
        },

        async retryAction(actionId) {
            this.retrying = actionId;
            try {
                const res = await fetch(`/api/v1/recovery/actions/${actionId}/retry`, {
                    method: 'POST'
                });
                const data = await res.json();
                if (data.success) {
                    this.showToast('Action retried successfully', 'success');
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    this.showToast(data.error || 'Failed to retry action', 'error');
                }
            } catch (err) {
                this.showToast('Network error, please try again', 'error');
            } finally {
                this.retrying = null;
            }
        }
    }
}
</script>
