<%- layout('layouts/dashboard-layout') %>

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
        <h2 class="text-3xl font-heading font-bold text-slate-900 tracking-tight">Account Settings</h2>
        <p class="mt-2 text-slate-500">Manage your profile information, business details, and security preferences.</p>
    </div>

    <% if (typeof success !=='undefined' && success) { %>
        <div class="bg-emerald-50 border border-emerald-100 text-emerald-700 px-6 py-4 rounded-2xl relative mb-8 shadow-sm flex items-center gap-3 animate-in fade-in slide-in-from-top-4 duration-300" role="alert">
            <i data-lucide="check-circle" class="w-5 h-5"></i>
            <span class="font-bold text-sm uppercase tracking-wider"><%= success %></span>
        </div>
    <% } %>

    <% if (typeof error !=='undefined' && error) { %>
        <div class="bg-rose-50 border border-rose-100 text-rose-700 px-6 py-4 rounded-2xl relative mb-8 shadow-sm flex items-center gap-3 animate-in fade-in slide-in-from-top-4 duration-300" role="alert">
            <i data-lucide="alert-circle" class="w-5 h-5"></i>
            <span class="font-bold text-sm uppercase tracking-wider"><%= error %></span>
        </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
        <!-- Left Column: Personal Info & Business Info -->
        <div class="lg:col-span-2 space-y-8">
            <form action="/user/profile" method="POST" enctype="multipart/form-data" class="space-y-8">
                
                <!-- Personal Information -->
                <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-8 py-6 border-b border-slate-100 flex items-center gap-4 bg-slate-50/50">
                        <div class="w-10 h-10 bg-blue-100 text-brand-blue rounded-xl flex items-center justify-center">
                            <i data-lucide="user" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Personal Information</h3>
                    </div>
                    <div class="p-8">
                        <!-- Profile Image Upload -->
                        <div class="flex items-center gap-6 mb-8">
                            <div class="relative group">
                                <% if (user.avatar) { %>
                                    <img src="<%= user.avatar %>" alt="Profile" class="w-20 h-20 rounded-2xl object-cover shadow-sm ring-4 ring-slate-50">
                                <% } else { %>
                                    <div class="w-20 h-20 bg-blue-50 rounded-2xl flex items-center justify-center ring-4 ring-slate-50 text-brand-blue">
                                        <i data-lucide="user" class="w-8 h-8"></i>
                                    </div>
                                <% } %>
                                <div class="absolute -bottom-2 -right-2 bg-white rounded-full p-2 shadow-md border border-slate-100 cursor-pointer hover:bg-slate-50 transition-colors">
                                    <i data-lucide="camera" class="w-4 h-4 text-slate-400"></i>
                                </div>
                            </div>
                            <div class="flex-1">
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2">Profile Photo</label>
                                <input type="file" name="profileImage" accept="image/*" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:uppercase file:tracking-widest file:bg-blue-50 file:text-brand-blue hover:file:bg-blue-100 transition-all cursor-pointer">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="firstName">First Name</label>
                                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:font-normal"
                                    id="firstName" type="text" name="firstName" value="<%= (locals.userProfile && locals.userProfile.firstName) || '' %>" placeholder="Enter first name">
                            </div>
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="lastName">Last Name</label>
                                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:font-normal"
                                    id="lastName" type="text" name="lastName" value="<%= (locals.userProfile && locals.userProfile.lastName) || '' %>" placeholder="Enter last name">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="email">Email Address</label>
                                <input class="w-full bg-slate-100 border border-slate-200 rounded-xl py-3 px-4 text-slate-500 text-sm font-bold cursor-not-allowed"
                                    id="email" type="email" value="<%= user.email %>" readonly disabled title="Email cannot be changed">
                            </div>
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="phoneNumber">Phone Number</label>
                                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:font-normal"
                                    id="phoneNumber" type="tel" name="phoneNumber" value="<%= (locals.userProfile && locals.userProfile.phoneNumber) || '' %>" placeholder="+1 (555) 000-0000">
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="profession">Profession / Role</label>
                                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:font-normal"
                                    id="profession" type="text" name="profession" value="<%= (locals.userProfile && locals.userProfile.profession) || '' %>" placeholder="e.g. Senior Developer">
                            </div>
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="accountType">Account Type</label>
                                <select id="accountType" name="accountType" onchange="toggleBusinessSection()" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all cursor-pointer">
                                    <option value="INDIVIDUAL" <%= (!locals.userProfile || locals.userProfile.accountType === 'INDIVIDUAL') ? 'selected' : '' %>>Individual</option>
                                    <option value="BUSINESS" <%= (locals.userProfile && locals.userProfile.accountType === 'BUSINESS') ? 'selected' : '' %>>Business</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Business Information (Conditioned by Logic) -->
                <div id="businessSection" class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden <%= (locals.userProfile && locals.userProfile.accountType === 'BUSINESS') ? '' : 'hidden' %>">
                    <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center">
                                <i data-lucide="briefcase" class="w-5 h-5"></i>
                            </div>
                            <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Business Details</h3>
                        </div>
                        <span class="px-3 py-1 bg-purple-100 text-purple-700 text-[0.625rem] font-bold rounded-lg border border-purple-200 uppercase tracking-widest">Business Account</span>
                    </div>
                    <div class="p-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="businessName">Company Name</label>
                                <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all placeholder:font-normal"
                                    id="businessName" type="text" name="businessName" value="<%= (locals.userProfile && locals.userProfile.businessName) || '' %>" placeholder="Enter company name">
                            </div>
                            <div>
                                <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="businessSector">Industry Sector</label>
                                <select id="businessSector" name="businessSector" class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all cursor-pointer">
                                    <option value="">Select industry</option>
                                    <option value="Technology" <%= (locals.userProfile && locals.userProfile.businessSector === 'Technology') ? 'selected' : '' %>>Technology</option>
                                    <option value="Healthcare" <%= (locals.userProfile && locals.userProfile.businessSector === 'Healthcare') ? 'selected' : '' %>>Healthcare</option>
                                    <option value="Finance" <%= (locals.userProfile && locals.userProfile.businessSector === 'Finance') ? 'selected' : '' %>>Finance</option>
                                    <option value="Education" <%= (locals.userProfile && locals.userProfile.businessSector === 'Education') ? 'selected' : '' %>>Education</option>
                                    <option value="Consulting" <%= (locals.userProfile && locals.userProfile.businessSector === 'Consulting') ? 'selected' : '' %>>Consulting</option>
                                    <option value="Other" <%= (locals.userProfile && locals.userProfile.businessSector === 'Other') ? 'selected' : '' %>>Other</option>
                                </select>
                            </div>
                        </div>

                        <div class="mt-6">
                            <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="businessAddress">Company Address</label>
                            <textarea class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue focus:ring-4 focus:ring-blue-500/10 outline-none transition-all resize-none placeholder:font-normal"
                                id="businessAddress" name="businessAddress" rows="2" placeholder="Street, City, Country"><%= (locals.userProfile && locals.userProfile.businessAddress) || '' %></textarea>
                        </div>
                    </div>
                </div>
                
                <!-- Main Save Button -->
                <div class="flex justify-end pt-4">
                        <button class="bg-slate-900 hover:bg-slate-800 text-white text-sm font-bold py-3 px-8 rounded-xl transition-all shadow-lg hover:shadow-xl active:scale-95 uppercase tracking-widest"
                        type="submit">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Right Column: Security & Stats -->
        <div class="space-y-8">
            <!-- Quick Stats Widget -->
            <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-3xl p-8 text-white shadow-xl overflow-hidden relative group">
                <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:scale-110 transition-transform duration-500">
                    <i data-lucide="shield-check" class="w-24 h-24"></i>
                </div>
                <h4 class="text-[0.625rem] font-bold uppercase tracking-widest opacity-60 mb-2">Account Status</h4>
                <p class="text-2xl font-black mb-6 flex items-center gap-2">
                    <%= (user.subscription && user.subscription.plan) ? user.subscription.plan.name : 'Free Tier' %>
                    <i data-lucide="crown" class="w-5 h-5 text-amber-400"></i>
                </p>
                <div class="space-y-4 relative z-10">
                    <div class="flex items-center justify-between text-xs font-bold py-2 border-b border-white/10">
                        <span class="opacity-60">Member Since</span>
                        <span><%= new Date(user.createdAt).toLocaleDateString() %></span>
                    </div>
                    <div class="flex items-center justify-between text-xs font-bold py-2">
                        <span class="opacity-60">Verification</span>
                        <span class="px-2 py-1 rounded-lg bg-green-500/20 text-green-300 border border-green-500/30 text-[0.625rem] font-bold uppercase tracking-wider">Verified</span>
                    </div>
                </div>
                <a href="/dashboard/subscription" class="mt-8 block text-center py-3 bg-white/10 hover:bg-white/20 border border-white/20 rounded-xl text-[0.625rem] font-bold uppercase tracking-widest transition-all">View Subscription</a>
            </div>

            <!-- Security: Two-Factor Auth & Password -->
            <div class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-8 py-6 border-b border-slate-100 flex items-center gap-4 bg-slate-50/50">
                    <div class="w-10 h-10 bg-rose-100 text-rose-600 rounded-xl flex items-center justify-center">
                        <i data-lucide="lock" class="w-5 h-5"></i>
                    </div>
                    <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest">Security</h3>
                </div>
                <div class="p-8 space-y-8">
                    
                    <!-- Two-Factor Authentication -->
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <h4 class="text-sm font-bold text-slate-900">Two-Factor Auth</h4>
                                <p class="text-xs text-slate-500 mt-1 font-medium">Add extra security layer.</p>
                            </div>
                            <form action="/user/2fa/toggle" method="POST">
                                <button type="submit" 
                                    class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-brand-blue focus:ring-offset-2 <%= user.isTwoFactorEnabled ? 'bg-brand-blue' : 'bg-slate-200' %>" 
                                    role="switch" 
                                    aria-checked="<%= user.isTwoFactorEnabled %>">
                                    <span aria-hidden="true" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out <%= user.isTwoFactorEnabled ? 'translate-x-5' : 'translate-x-0' %>"></span>
                                </button>
                            </form>
                        </div>
                        <% if (user.isTwoFactorEnabled) { %>
                            <div class="bg-blue-50 text-blue-700 text-xs px-4 py-3 rounded-xl border border-blue-100 flex items-center gap-2 font-bold">
                                <i data-lucide="check-circle" class="w-4 h-4"></i>
                                2FA Enabled via Email
                            </div>
                        <% } else { %>
                            <div class="bg-slate-50 text-slate-500 text-xs px-4 py-3 rounded-xl border border-slate-200 flex items-center gap-2 font-bold">
                                <i data-lucide="shield-off" class="w-4 h-4"></i>
                                2FA Disabled
                            </div>
                        <% } %>
                    </div>

                    <hr class="border-slate-100">

                    <!-- Change Password Form -->
                    <form action="/user/password" method="POST" class="space-y-5">
                        <div>
                            <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="currentPassword">Current Password</label>
                            <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue outline-none transition-all placeholder:font-normal"
                                id="currentPassword" type="password" name="currentPassword" required placeholder="••••••••">
                        </div>
                        <div>
                            <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="newPassword">New Password</label>
                            <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue outline-none transition-all placeholder:font-normal"
                                id="newPassword" type="password" name="newPassword" required placeholder="••••••••">
                        </div>
                        <div>
                            <label class="block text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-2" for="confirmPassword">Confirm Password</label>
                            <input class="w-full bg-slate-50 border border-slate-200 rounded-xl py-3 px-4 text-slate-700 text-sm font-bold focus:bg-white focus:border-brand-blue outline-none transition-all placeholder:font-normal"
                                id="confirmPassword" type="password" name="confirmPassword" required placeholder="••••••••">
                        </div>
                        <button class="w-full bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 hover:text-slate-900 text-xs font-bold py-3 rounded-xl transition-all uppercase tracking-widest"
                            type="submit">
                            Update Security
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
    function toggleBusinessSection() {
        const type = document.getElementById('accountType').value;
        const section = document.getElementById('businessSection');
        if (type === 'BUSINESS') {
            section.classList.remove('hidden');
            section.classList.add('animate-in', 'fade-in', 'slide-in-from-top-4');
        } else {
            section.classList.add('hidden');
        }
    }
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>
