<%- layout('layouts/dashboard-layout') %>
<% console.log(`[EJS DEBUG INDEX] Available keys: ${Object.keys(locals).join(', ')}`); %>
<% console.log(`[EJS DEBUG INDEX] Stats: ${JSON.stringify(locals.stats)}`); %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[0.625rem] font-bold rounded-lg border border-emerald-100 uppercase tracking-widest">Core Data</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Unified Data Hub</h1>
            </div>
            <p class="text-slate-500 font-medium">Your centralized enterprise data engine, aggregated and normalized from all connected source integrations.</p>
        </div>
        
        <div class="flex items-center gap-3">
              <a href="/dashboard/integrations" class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center shadow-sm hover:shadow active:scale-95">
                 <i data-lucide="settings" class="w-4 h-4 mr-2"></i>
                 Manage Connections
             </a>
        </div>
    </div>

    <!-- Connected Integrations -->
    <% if (locals.integrations && locals.integrations.length > 0) { %>
        <div class="mb-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% locals.integrations.forEach(int => { %>
                <div class="bg-white border border-slate-200 rounded-[2rem] p-6 shadow-sm flex flex-col justify-between group hover:border-emerald-200 transition-all duration-300">
                    <div class="flex items-start justify-between mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center">
                                <i data-lucide="database" class="w-6 h-6 text-slate-400 group-hover:text-emerald-500 transition-colors"></i>
                            </div>
                            <div>
                                <h3 class="font-black text-slate-900 capitalize"><%= int.provider %></h3>
                                <p class="text-[0.625rem] text-slate-500 font-bold uppercase tracking-widest flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 rounded-full <%= int.status === 'connected' ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]' : 'bg-slate-300' %>"></span>
                                    <%= int.status %>
                                </p>
                            </div>
                        </div>
                        <button onclick="triggerSync('<%= int.id %>', this)" 
                                class="w-10 h-10 rounded-xl bg-slate-50 border border-slate-100 flex items-center justify-center hover:bg-emerald-50 hover:border-emerald-200 transition-all group/btn" 
                                title="Sync Now">
                            <i data-lucide="refresh-cw" class="w-4 h-4 text-slate-400 group-hover/btn:text-emerald-500 transition-colors sync-icon"></i>
                        </button>
                    </div>

                    <div class="pt-4 border-t border-slate-50 flex items-center justify-between text-[0.625rem] font-bold uppercase tracking-widest text-slate-400">
                        <span>Last Synced</span>
                        <span class="text-slate-900 group-hover:text-emerald-600 transition-colors">
                            <%= int.updatedAt ? new Date(int.updatedAt).toLocaleDateString() + ' ' + new Date(int.updatedAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : 'Never' %>
                        </span>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-slate-900 rounded-3xl p-6 shadow-xl text-white relative overflow-hidden group">
            <div class="absolute -right-4 -bottom-4 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl group-hover:bg-emerald-500/20 transition-all duration-700"></div>
            <div class="relative z-10">
                <p class="text-[0.625rem] font-bold text-emerald-400 uppercase tracking-widest mb-1">Total Revenue</p>
                <h3 id="stat-total-revenue" class="text-4xl font-black text-white tracking-tight">$<%= (locals.stats?.totalRevenue || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></h3>
                <div class="mt-4 flex items-center gap-2">
                    <span class="px-2 py-0.5 bg-emerald-500/20 text-emerald-400 text-[0.625rem] font-bold rounded-lg border border-emerald-500/30 uppercase tracking-wider">Aggregated</span>
                </div>
            </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm flex items-center justify-between group hover:border-slate-300 transition-all">
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Outstanding Balance</p>
                <h3 class="text-3xl font-black text-slate-900 tracking-tight text-red-600" id="stat-outstanding-balance">$<%= (locals.stats?.outstandingBalance || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></h3>
                <p class="mt-1 text-[0.625rem] text-slate-400 font-bold uppercase tracking-wider">Awaiting Collection</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-red-50 text-red-500 flex items-center justify-center border border-red-100">
                <i data-lucide="alert-circle" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm flex items-center justify-between group hover:border-slate-300 transition-all">
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Collected</p>
                <h3 class="text-3xl font-black text-slate-900 tracking-tight text-emerald-600" id="stat-total-paid">$<%= (locals.stats?.totalPaid || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></h3>
                <p class="mt-1 text-[0.625rem] text-slate-400 font-bold uppercase tracking-wider">Realized Revenue</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-500 flex items-center justify-center border border-emerald-100">
                <i data-lucide="check-circle" class="w-6 h-6"></i>
            </div>
        </div>
    </div>

    <!-- Secondary Stats -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-12">
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 flex items-center gap-4">
             <div class="w-10 h-10 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center">
                <i data-lucide="users" class="w-5 h-5"></i>
            </div>
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Customers</p>
                <p class="text-lg font-black text-slate-900" id="stat-customers"><%= (locals.stats?.totalCustomers || 0) %></p>
            </div>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 flex items-center gap-4">
             <div class="w-10 h-10 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center">
                <i data-lucide="file-text" class="w-5 h-5"></i>
            </div>
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Invoices</p>
                <p class="text-lg font-black text-slate-900" id="stat-invoices"><%= (locals.stats?.totalInvoices || 0) %></p>
            </div>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 flex items-center gap-4">
             <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center">
                <i data-lucide="shopping-cart" class="w-5 h-5"></i>
            </div>
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Orders</p>
                <p class="text-lg font-black text-slate-900" id="stat-orders"><%= (locals.stats?.totalOrders || 0) %></p>
            </div>
        </div>
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 flex items-center gap-4">
             <div class="w-10 h-10 rounded-lg bg-slate-200 text-slate-600 flex items-center justify-center">
                <i data-lucide="database" class="w-5 h-5"></i>
            </div>
            <div>
                <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Sources</p>
                <p class="text-lg font-black text-slate-900"><%= (locals.salesBySource?.length || 0) %></p>
            </div>
        </div>
    </div>

    <!-- Analytics Engine Charts -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-12">
        <!-- Revenue Trend 30D -->
        <div class="xl:col-span-2 bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm group hover:border-emerald-200 transition-all duration-500">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="trending-up" class="w-4 h-4 text-emerald-500"></i>
                    Revenue Trend (30 Days)
                </h3>
                <span class="px-2 py-1 bg-emerald-50 text-[0.625rem] font-bold text-emerald-600 rounded uppercase tracking-widest border border-emerald-100">Analytics Engine</span>
            </div>
            <div class="h-[300px] w-full relative">
                <canvas id="unifiedTrendChart"></canvas>
            </div>
        </div>

        <!-- Revenue By Source -->
        <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm group flex flex-col hover:border-slate-300 transition-all duration-500">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2 mb-6">
                <i data-lucide="pie-chart" class="w-4 h-4 text-emerald-500"></i>
                Revenue by Source
            </h3>
            <div class="flex-1 flex items-center justify-center relative min-h-[200px]">
                <canvas id="unifiedSourceChart"></canvas>
            </div>
            
            <!-- Top Customers Minilist embedded in right col -->
            <div class="mt-8 pt-6 border-t border-slate-100">
                <h4 class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-4">Top Customers</h4>
                <div class="space-y-3">
                    <% if (locals.topCustomers && locals.topCustomers.length > 0) { %>
                        <% locals.topCustomers.slice(0, 3).forEach(c => { %>
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-3 w-3/4">
                                    <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-[0.625rem] font-black text-slate-400">
                                        <%= c.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <span class="text-xs font-bold text-slate-900 truncate"><%= c.name %></span>
                                </div>
                                <span class="text-xs font-black text-emerald-600">$<%= (c.totalRevenue || 0).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></span>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-[0.625rem] font-medium text-slate-400 italic">No customer data yet.</div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Transactions (Invoices) -->
    <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                <i data-lucide="clock" class="w-4 h-4 text-emerald-500"></i>
                Recent Invoices
            </h3>
            <a href="/dashboard/unified/transactions" class="text-xs font-bold text-emerald-600 hover:text-emerald-700">View All</a>
        </div>
        
        <% if (locals.recentTransactions && locals.recentTransactions.length > 0) { %>
            <div class="w-full relative overflow-x-auto text-left">
                <table class="w-full text-sm text-left">
                    <thead class="text-[0.625rem] uppercase tracking-widest text-slate-400 bg-slate-50 border-y border-slate-100">
                        <tr>
                            <th scope="col" class="px-6 py-3 font-bold rounded-l-xl">Invoice #</th>
                            <th scope="col" class="px-6 py-3 font-bold">Customer</th>
                            <th scope="col" class="px-6 py-3 font-bold">Source</th>
                            <th scope="col" class="px-6 py-3 font-bold">Date</th>
                            <th scope="col" class="px-6 py-3 font-bold">Amount</th>
                            <th scope="col" class="px-6 py-3 font-bold rounded-r-xl">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% locals.recentTransactions.forEach(t => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-4 font-mono text-xs font-bold text-slate-700"><%= t.invoiceNumber || t.externalId %></td>
                                <td class="px-6 py-4">
                                    <div class="font-bold text-slate-900"><%= t.customer ? t.customer.name : 'Unknown' %></div>
                                </td>
                                <td class="px-6 py-4 text-xs font-medium text-slate-500 uppercase tracking-wider">
                                    <%= t.source %>
                                </td>
                                <td class="px-6 py-4 text-xs font-medium text-slate-500">
                                    <%= t.issuedDate ? new Date(t.issuedDate).toLocaleDateString() : 'N/A' %>
                                </td>
                                <td class="px-6 py-4 font-bold text-slate-900">
                                    $<%= parseFloat(t.amount || 0).toFixed(2) %>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-2.5 py-1 text-[0.625rem] font-bold rounded-md uppercase tracking-wider 
                                        <%= t.status === 'PAID' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : (t.status === 'OVERDUE' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-blue-50 text-blue-700 border border-blue-200') %>">
                                        <%= t.status || 'UNKNOWN' %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-12 bg-slate-50 rounded-2xl border border-dashed border-slate-300">
                <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-slate-200 flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="receipt" class="w-8 h-8 text-slate-400"></i>
                </div>
                <h3 class="text-sm font-bold text-slate-900 mb-1">No transactions found</h3>
                <p class="text-xs text-slate-500">Connect a data source to see unified transactions here.</p>
            </div>
        <% } %>
    </div>
</div>

<script id="unified-analytics-data" type="application/json" nonce="<%= nonce %>">
    <%- JSON.stringify({
        trend: locals.analytics?.revenueTrend || locals.analyticsTrend || [],
        sources: locals.salesBySource || []
    }) %>
</script>

<script nonce="<%= nonce %>">
async function triggerSync(integrationId, btn) {
    const icon = btn.querySelector('.sync-icon');
    
    // UI state: loading
    btn.disabled = true;
    icon.classList.add('animate-spin', 'text-emerald-500');
    
    try {
        const response = await fetch(`/dashboard/unified/sync/${integrationId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await response.json();
        
        if (data.success) {
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            throw new Error(data.error || 'Sync failed');
        }
    } catch (err) {
        alert('Sync failed: ' + err.message);
        btn.disabled = false;
        icon.classList.remove('animate-spin', 'text-emerald-500');
    }
}

function initUnifiedCharts() {
    try {
        const dataEl = document.getElementById('unified-analytics-data');
        if (!dataEl || typeof Chart === 'undefined') return;
        const data = JSON.parse(dataEl.textContent);

        // 1. Trend Chart
        const trendCtx = document.getElementById('unifiedTrendChart')?.getContext('2d');
        if (trendCtx) {
            let labels = [];
            let revenues = [];

            if (data.trend.length > 0) {
                labels = data.trend.map(t => {
                    const d = new Date(t.date);
                    return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
                });
                revenues = data.trend.map(t => t.revenue);
            } else {
                // Generate empty 30-day timeline
                const today = new Date();
                for (let i = 29; i >= 0; i--) {
                    const d = new Date(today);
                    d.setDate(d.getDate() - i);
                    labels.push(d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }));
                    revenues.push(0);
                }
            }

            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: 'Revenue',
                        data: revenues,
                        borderColor: '#10b981', // Emerald 500
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        borderWidth: 3,
                        tension: 0.4,
                        pointRadius: 0,
                        pointHoverRadius: 6,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            callbacks: {
                                label: (ctx) => '$' + ctx.raw.toLocaleString()
                            }
                        }
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            grid: { color: '#f1f5f9' }, 
                            ticks: { 
                                font: { size: 10, family: 'Inter, sans-serif' },
                                callback: (val) => '$' + val.toLocaleString()
                            } 
                        },
                        x: { 
                            grid: { display: false }, 
                            ticks: { maxTicksLimit: 7, font: { size: 10, family: 'Inter, sans-serif' } } 
                        }
                    }
                }
            });
        }

        // 2. Source Doughnut Chart
        const sourceCtx = document.getElementById('unifiedSourceChart')?.getContext('2d');
        if (sourceCtx) {
            let labels = ['No Sync Data'];
            let revenues = [0.01]; // Small value just to render a grey empty circle
            let bgColors = ['#f1f5f9'];

            if (data.sources.length > 0) {
                labels = data.sources.map(s => s.source.toUpperCase());
                revenues = data.sources.map(s => s.revenue);
                bgColors = ['#10b981', '#3b82f6', '#f59e0b', '#8b5cf6'];
            }

            new Chart(sourceCtx, {
                type: 'doughnut',
                data: {
                    labels,
                    datasets: [{
                        data: revenues,
                        backgroundColor: bgColors,
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                padding: 20,
                                font: { size: 10, family: 'Inter, sans-serif', weight: 'bold' }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: (ctx) => ` ${ctx.label}: $${ctx.raw.toLocaleString()}`
                            }
                        }
                    }
                }
            });
        }
    } catch (err) {
        console.error('Failed to init Unified charts:', err);
    }
}

async function hydrateUnifiedDashboardStats() {
    try {
        const res = await fetch('/api/v1/unified-data/stats');
        if (!res.ok) throw new Error('Failed to fetch stats');
        const payload = await res.json();
        
        // Defensive parsing: Handle flat object or nested {data: {stats: ...}}
        const stats = payload.data?.stats || payload.stats || payload;
        
        if (stats) {
            const formatMoney = (val) => '$' + (val || 0).toLocaleString(undefined, {minimumFractionDigits: 2});
            const formatNumber = (val) => (val || 0).toLocaleString();

            const elRev = document.getElementById('stat-total-revenue');
            if (elRev) elRev.innerText = formatMoney(stats.totalRevenue);
            
            const elBal = document.getElementById('stat-outstanding-balance');
            if (elBal) elBal.innerText = formatMoney(stats.outstandingBalance);
            
            const elPaid = document.getElementById('stat-total-paid');
            if (elPaid) elPaid.innerText = formatMoney(stats.totalPaid);

            const elCust = document.getElementById('stat-customers');
            if (elCust) elCust.innerText = formatNumber(stats.totalCustomers);

            const elInv = document.getElementById('stat-invoices');
            if (elInv) elInv.innerText = formatNumber(stats.totalInvoices);

            const elOrd = document.getElementById('stat-orders');
            if (elOrd) elOrd.innerText = formatNumber(stats.totalOrders);
        }
    } catch (err) {
        console.error('Failed to hydrate realtime stats:', err);
    }
}

document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
    initUnifiedCharts();
    hydrateUnifiedDashboardStats();
});
</script>

