<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-8 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[0.625rem] font-bold rounded-lg border border-blue-100 uppercase tracking-widest">Assets</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Unified Inventory</h1>
            </div>
            <p class="text-slate-500 font-medium">Real-time product availability and stock levels across all your enterprise storage locations and storefronts.</p>
        </div>
        
        <div class="flex items-center gap-3">
             <div class="relative group">
                <button class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center shadow-sm">
                    <i data-lucide="filter" class="w-4 h-4 mr-2"></i>
                    <%= locals.sourceFilter ? sourceFilter : 'Filter Source' %>
                </button>
                <div class="absolute right-0 mt-2 w-48 bg-white border border-slate-100 rounded-2xl shadow-xl p-2 hidden group-hover:block z-50">
                    <a href="/dashboard/unified/inventory" class="block px-4 py-2 text-xs font-bold <%= !locals.sourceFilter ? 'bg-slate-50 text-slate-900' : 'text-slate-600 hover:bg-slate-50' %> rounded-lg">All Sources</a>
                    <% if (locals.connectedIntegrations) { %>
                        <% connectedIntegrations.forEach(int => { %>
                            <a href="/dashboard/unified/inventory?source=<%= int.provider %>" class="block px-4 py-2 text-xs font-bold <%= locals.sourceFilter === int.provider ? 'bg-slate-50 text-slate-900' : 'text-slate-600 hover:bg-slate-50' %> rounded-lg uppercase tracking-widest text-[10px]"><%= int.provider %></a>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <% /* Diagnostic logs removed */ %>
    <% const displayProducts = locals.unifiedProducts || locals.products || []; %>
    <div class="bg-white border border-slate-200 rounded-[2.5rem] overflow-hidden shadow-sm">
        <% if (displayProducts.length > 0) { %>
            <div class="w-full relative overflow-x-auto text-left">
                <table class="w-full text-sm text-left">
                    <thead class="text-[0.625rem] uppercase tracking-widest text-slate-400 bg-slate-50 border-y border-slate-100">
                        <tr>
                            <th scope="col" class="px-6 py-4 font-bold rounded-l-xl">Product Name</th>
                            <th scope="col" class="px-6 py-4 font-bold">SKU</th>
                            <th scope="col" class="px-6 py-4 font-bold">Source</th>
                            <th scope="col" class="px-6 py-4 font-bold text-center">Stock Level</th>
                            <th scope="col" class="px-6 py-4 font-bold text-right rounded-r-xl">Price</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% displayProducts.forEach(p => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-6 py-5">
                                    <div class="font-bold text-slate-900 flex items-center gap-2">
                                        <%= p.name %>
                                        <% if (p.category) { %>
                                            <span class="px-1.5 py-0.5 bg-slate-50 text-slate-400 text-[8px] font-bold uppercase rounded border border-slate-100"><%= p.category %></span>
                                        <% } %>
                                    </div>
                                    <div class="text-[0.625rem] text-slate-400 font-medium truncate max-w-xs"><%= p.description || 'No description provided' %></div>
                                </td>
                                <td class="px-6 py-5">
                                    <div class="font-mono text-xs font-black text-slate-700 bg-slate-50 px-2 py-0.5 rounded border border-slate-100 inline-block"><%= p.sku || 'N/A' %></div>
                                </td>
                                <td class="px-6 py-5">
                                    <span class="px-2 py-1 bg-slate-100 text-slate-600 text-[0.625rem] font-black rounded-lg uppercase tracking-widest border border-slate-200">
                                        <%= p.source %>
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-center">
                                    <div class="flex flex-col items-center">
                                        <span class="text-sm font-black <%= p.quantity < 5 ? 'text-red-500' : 'text-slate-900' %>"><%= p.quantity %></span>
                                        <% if (p.quantity < 5) { %>
                                            <span class="text-[0.625rem] font-bold text-red-400 uppercase tracking-tighter">Low Stock</span>
                                        <% } %>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-right font-black text-slate-900">
                                    $<%= parseFloat(p.price || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="text-center py-20">
                <div class="w-16 h-16 bg-slate-50 rounded-2xl border border-slate-100 flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="package" class="w-8 h-8 text-slate-300"></i>
                </div>
                <h3 class="text-lg font-black text-slate-900 mb-2">Inventory empty</h3>
                <p class="text-slate-500 max-w-xs mx-auto text-sm font-medium">No products or inventory items have been synchronized for this business context.</p>
                <div class="mt-8 flex flex-col items-center gap-4">
                    <button onclick="triggerSync()" id="syncBtn" class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black text-sm hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 group">
                        <i data-lucide="refresh-cw" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500"></i>
                        SYNC NOW
                    </button>
                    
                    <a href="/dashboard/integrations" class="text-[10px] font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest transition-colors">
                        Manage Data Sources
                    </a>
                </div>

                <script nonce="<%= nonce %>">
                    async function triggerSync() {
                        const btn = document.getElementById('syncBtn');
                        const originalHtml = btn.innerHTML;
                        
                        try {
                            btn.disabled = true;
                            btn.classList.add('opacity-50', 'cursor-not-allowed');
                            btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> SYNCING...';
                            if (typeof lucide !== 'undefined') lucide.createIcons();
                            
                            const response = await fetch('/dashboard/unified/sync-all', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({})
                            });
                            
                            const result = await response.json();
                            
                            if (result.success) {
                                window.location.reload();
                            } else {
                                alert('Sync failed: ' + (result.error || 'Unknown error'));
                                btn.disabled = false;
                                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                                btn.innerHTML = originalHtml;
                                if (typeof lucide !== 'undefined') lucide.createIcons();
                            }
                        } catch (err) {
                            console.error('Sync Error:', err);
                            alert('An error occurred during sync');
                            btn.disabled = false;
                            btn.classList.remove('opacity-50', 'cursor-not-allowed');
                            btn.innerHTML = originalHtml;
                            if (typeof lucide !== 'undefined') lucide.createIcons();
                        }
                    }
                </script>
            </div>
        <% } %>
    </div>
</div>

<script nonce="<%= nonce %>">
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>
