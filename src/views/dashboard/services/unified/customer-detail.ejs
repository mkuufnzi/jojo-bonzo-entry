<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Back Navigation -->
    <div class="mb-6">
        <a href="/dashboard/unified/customers" class="inline-flex items-center text-[0.625rem] font-bold text-slate-400 hover:text-slate-900 uppercase tracking-widest transition-colors group">
            <i data-lucide="arrow-left" class="w-3.5 h-3.5 mr-2 group-hover:-translate-x-1 transition-transform"></i>
            Back to Customers
        </a>
    </div>

    <!-- Customer Profile Header -->
    <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm mb-8 relative overflow-hidden group">
        <div class="absolute -right-8 -top-8 w-48 h-48 bg-blue-50/50 rounded-full blur-3xl group-hover:bg-blue-100/50 transition-all duration-700"></div>
        
        <div class="relative z-10 flex flex-col lg:flex-row justify-between lg:items-end gap-6">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-16 h-16 rounded-2xl bg-blue-600 text-white flex items-center justify-center text-2xl font-black shadow-lg shadow-blue-200">
                        <%= customer.name.charAt(0) %>
                    </div>
                    <div>
                        <div class="flex items-center gap-2 mb-1">
                             <div class="flex flex-col">
                                <span class="text-[0.5rem] font-bold text-blue-500 uppercase tracking-[0.2em] mb-1">CRM Profile</span>
                                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight"><%= customer.name %></h1>
                             </div>
                             <span class="px-2 py-0.5 bg-slate-100 text-slate-600 text-[0.5rem] font-bold rounded border border-slate-200 uppercase tracking-widest self-end mb-1"><%= customer.source %></span>
                        </div>
                        <p class="text-xs font-mono text-slate-400 uppercase tracking-widest">ID: <%= customer.externalId %></p>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-8">
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Email Address</p>
                        <p class="text-xs font-bold text-slate-900"><%= customer.email || '--' %></p>
                    </div>
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Phone Number</p>
                        <p class="text-xs font-bold text-slate-900"><%= customer.phone || '--' %></p>
                    </div>
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Orders</p>
                        <p class="text-xs font-black text-slate-900"><%= customer.orders.length %></p>
                    </div>
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Total Revenue</p>
                        <% const totalRev = customer.invoices.reduce((sum, inv) => sum + parseFloat(inv.amount), 0); %>
                        <p class="text-xs font-black text-emerald-600 hover:text-emerald-700 cursor-default">$<%= totalRev.toLocaleString(undefined, {minimumFractionDigits: 2}) %></p>
                    </div>
                </div>
            </div>
            
            <div class="flex gap-3">
                 <button class="bg-slate-900 text-white px-5 py-2.5 rounded-xl text-[0.625rem] font-bold uppercase tracking-widest hover:bg-slate-800 transition-all shadow-md">
                    <i data-lucide="plus" class="w-3.5 h-3.5 mr-2 inline-block"></i>
                    New Invoice
                </button>
            </div>
        </div>
    </div>

    <!-- Activity Timeline -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <!-- Main Activity Feed -->
        <div class="lg:col-span-2">
            <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm h-full">
                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-8 flex items-center gap-2">
                    <i data-lucide="activity" class="w-4 h-4 text-emerald-500"></i>
                    Unified Activity Timeline
                </h3>

                <% 
                    // Combine all transactions into one timeline
                    const timeline = [
                        ...customer.invoices.map(i => ({ ...i, type: 'INVOICE', date: i.issuedDate })),
                        ...customer.orders.map(o => ({ ...o, type: 'ORDER', date: o.orderDate })),
                        ...customer.payments.map(p => ({ ...p, type: 'PAYMENT', date: p.paymentDate })),
                        ...customer.estimates.map(e => ({ ...e, type: 'ESTIMATE', date: e.estimateDate }))
                    ].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
                %>

                <% if (timeline.length > 0) { %>
                    <div class="space-y-6">
                        <% timeline.forEach((item, idx) => { %>
                            <div class="relative pl-8 pb-6 <%= idx === timeline.length - 1 ? '' : 'border-l border-slate-100' %>">
                                <div class="absolute left-[-9px] top-0 w-[18px] h-[18px] rounded-full border-4 border-white shadow-sm flex items-center justify-center
                                    <%= item.type === 'INVOICE' ? 'bg-purple-500' : (item.type === 'ORDER' ? 'bg-amber-500' : (item.type === 'PAYMENT' ? 'bg-emerald-500' : 'bg-blue-500')) %>">
                                </div>
                                <div class="flex flex-col md:flex-row justify-between gap-4">
                                    <div>
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="text-[0.625rem] font-black tracking-widest uppercase
                                                <%= item.type === 'INVOICE' ? 'text-purple-600' : (item.type === 'ORDER' ? 'text-amber-600' : (item.type === 'PAYMENT' ? 'text-emerald-600' : 'text-blue-600')) %>">
                                                <%= item.type %>
                                            </span>
                                            <span class="text-[0.625rem] text-slate-400 font-bold uppercase tracking-wider"><%= new Date(item.date).toLocaleDateString() %></span>
                                        </div>
                                        <h4 class="text-sm font-black text-slate-900 tracking-tight">
                                            <%= item.invoiceNumber || item.orderNum || item.paymentNum || item.estimateNum || 'Transaction' %>
                                        </h4>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-black text-slate-900">$<%= parseFloat(item.amount).toLocaleString(undefined, {minimumFractionDigits: 2}) %></p>
                                        <span class="text-[0.5rem] font-bold uppercase px-2 py-0.5 rounded border 
                                            <%= item.status === 'PAID' ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : 'bg-slate-50 text-slate-600 border-slate-200' %>">
                                            <%= item.status || 'PROCESSED' %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="text-center py-20 bg-slate-50 rounded-3xl border border-dashed border-slate-200">
                        <i data-lucide="layers" class="w-8 h-8 text-slate-300 mx-auto mb-3"></i>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">No activity found for this customer</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Sidebar Details -->
        <div class="space-y-8">
            <!-- Balances -->
            <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm">
                <h3 class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-6">Financial Summary</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Amount Owed</p>
                        <% const outstanding = customer.invoices.reduce((sum, inv) => sum + parseFloat(inv.balance || 0), 0); %>
                        <h4 class="text-2xl font-black text-red-600">$<%= outstanding.toLocaleString(undefined, {minimumFractionDigits: 2}) %></h4>
                    </div>
                    <div class="w-full h-px bg-slate-100"></div>
                    <div>
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Last Payment</p>
                        <% if (customer.payments.length > 0) { %>
                             <h4 class="text-sm font-black text-slate-900">$<%= parseFloat(customer.payments[0].amount).toLocaleString() %></h4>
                             <p class="text-[0.625rem] text-slate-400 font-bold uppercase tracking-wider"><%= new Date(customer.payments[0].paymentDate).toLocaleDateString() %></p>
                        <% } else { %>
                             <p class="text-xs font-bold text-slate-400 italic">No payments recorded</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Source Info -->
            <div class="bg-slate-900 rounded-[2.5rem] p-8 shadow-xl text-white">
                <h3 class="text-[0.625rem] font-black text-emerald-400 uppercase tracking-widest mb-6">Integration Meta</h3>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                         <div class="w-8 h-8 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center text-emerald-400">
                             <i data-lucide="database" class="w-4 h-4"></i>
                         </div>
                         <div>
                             <p class="text-[10px] text-slate-400 font-bold uppercase">Source ERP</p>
                             <p class="text-xs font-black capitalize"><%= customer.source %></p>
                         </div>
                    </div>
                    <div class="flex items-center gap-3">
                         <div class="w-8 h-8 rounded-lg bg-slate-800 border border-slate-700 flex items-center justify-center text-emerald-400">
                             <i data-lucide="tag" class="w-4 h-4"></i>
                         </div>
                         <div>
                             <p class="text-[10px] text-slate-400 font-bold uppercase">Customer ID</p>
                             <p class="text-[10px] font-mono text-emerald-400"><%= customer.externalId %></p>
                         </div>
                    </div>
                </div>
                <button class="w-full mt-8 py-3 bg-slate-800 border border-slate-700 rounded-xl text-[0.625rem] font-bold uppercase tracking-widest hover:bg-slate-700 transition-all">
                    View Raw Data
                </button>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
