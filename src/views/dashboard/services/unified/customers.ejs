<%- layout('layouts/dashboard-layout') %>
<% /* Diagnostic logs removed */ %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[0.625rem] font-bold rounded-lg border border-blue-100 uppercase tracking-widest">CRM & Relations</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Unified Customers</h1>
            </div>
            <p class="text-slate-500 font-medium">Holistic relationship management with cross-platform customer profiles and behavioral clustering.</p>
        </div>
        
        <div class="flex items-center gap-3">
             <!-- Source Filter -->
             <div class="flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5 mr-2">
                 <i data-lucide="filter" class="w-3.5 h-3.5 text-slate-400"></i>
                 <select onchange="window.location.href='/dashboard/unified/customers?source=' + this.value" class="bg-transparent border-none text-[0.625rem] font-bold text-slate-600 uppercase tracking-widest focus:ring-0 outline-none cursor-pointer">
                     <option value="">All Sources</option>
                     <% if (locals.connectedIntegrations) { %>
                        <% connectedIntegrations.forEach(int => { %>
                            <option value="<%= int.provider %>" <%= (locals.sourceFilter === int.provider) ? 'selected' : '' %>><%= int.provider %></option>
                        <% }) %>
                     <% } %>
                 </select>
             </div>
             <div class="relative w-64">
                <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400"></i>
                <input type="text" placeholder="Search customers..." class="w-full pl-10 pr-4 py-2 border border-slate-200 rounded-xl text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all shadow-sm">
             </div>
        </div>
    </div>

    <!-- Customers List -->
    <div class="bg-white border border-slate-200 rounded-[2.5rem] shadow-sm overflow-hidden">
        <% const customerList = locals.customers || customers || [] %>
        <% if (customerList.length > 0) { %>
            <div class="w-full relative overflow-x-auto text-left">
                <table class="w-full text-sm text-left">
                    <thead class="text-[0.625rem] uppercase tracking-widest text-slate-400 bg-slate-50 border-b border-slate-100">
                        <tr>
                            <th scope="col" class="px-6 py-4 font-bold">Customer Name</th>
                            <th scope="col" class="px-6 py-4 font-bold">Contact</th>
                            <th scope="col" class="px-6 py-4 font-bold text-center">Source</th>
                            <th scope="col" class="px-6 py-4 font-bold text-center">Activity</th>
                            <th scope="col" class="px-6 py-4 font-bold text-right rounded-r-xl">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <% customerList.forEach(c => { %>
                            <tr class="hover:bg-slate-50/50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="font-bold text-slate-900 group-hover:text-blue-600 transition-colors uppercase tracking-tight text-xs"><%= c.name %></div>
                                    <div class="text-[0.5rem] font-mono text-slate-400 mt-1 uppercase">ID: <%= c.externalId %></div>
                                </td>
                                <td class="px-6 py-4">
                                    <div class="text-[10px] font-bold text-slate-600 truncate max-w-[150px]"><%= c.email || 'No email' %></div>
                                    <div class="text-[10px] text-slate-400 font-medium"><%= c.phone || '--' %></div>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[0.625rem] font-bold bg-slate-100 text-slate-600 uppercase border border-slate-200">
                                        <%= c.source %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <div class="flex flex-col items-center">
                                            <span class="text-[0.625rem] font-black text-slate-900"><%= c._count?.invoices || 0 %></span>
                                            <span class="text-[0.5rem] text-slate-400 uppercase font-bold">Inv</span>
                                        </div>
                                        <div class="w-[1px] h-4 bg-slate-200"></div>
                                        <div class="flex flex-col items-center">
                                            <span class="text-[0.625rem] font-black text-slate-900"><%= c._count?.orders || 0 %></span>
                                            <span class="text-[0.5rem] text-slate-400 uppercase font-bold">Ord</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a href="/dashboard/unified/customers/<%= c.id %>" class="inline-flex items-center px-3 py-1 bg-white border border-slate-200 text-slate-900 hover:bg-slate-900 hover:text-white hover:border-slate-900 transition-all rounded-lg font-bold text-[0.625rem] uppercase tracking-widest">
                                        View Detail
                                        <i data-lucide="chevron-right" class="w-3 h-3 ml-1.5 opacity-50"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination Mock -->
            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between text-xs font-bold text-slate-500 uppercase tracking-wider">
                <span>Showing 1 to <%= customerList.length %> of <%= customerList.length %></span>
                <div class="flex gap-2">
                    <button class="px-3 py-1 rounded border border-slate-200 disabled:opacity-50" disabled>PREV</button>
                    <button class="px-3 py-1 rounded bg-slate-900 text-white border border-slate-900">1</button>
                    <button class="px-3 py-1 rounded border border-slate-200 hover:bg-slate-50">NEXT</button>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-20 bg-slate-50">
                <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-slate-200 flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="users" class="w-8 h-8 text-slate-400"></i>
                </div>
                <h3 class="text-sm font-bold text-slate-900 mb-1">No customers found</h3>
                <p class="text-xs text-slate-500 mb-6">Connect a data source to sync customers into the Unified Hub.</p>
                
                <div class="flex flex-col items-center gap-4">
                    <button onclick="triggerSync()" id="syncBtn" class="inline-flex items-center gap-2 px-8 py-4 bg-indigo-600 text-white rounded-2xl font-black text-sm hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 group">
                        <i data-lucide="refresh-cw" class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500"></i>
                        SYNC NOW
                    </button>
                    
                    <a href="/dashboard/integrations" class="text-[10px] font-bold text-slate-400 hover:text-slate-600 uppercase tracking-widest transition-colors">
                        Manage Data Sources
                    </a>
                </div>

                <script nonce="<%= nonce %>">
                    async function triggerSync() {
                        const btn = document.getElementById('syncBtn');
                        const originalHtml = btn.innerHTML;
                        
                        try {
                            btn.disabled = true;
                            btn.classList.add('opacity-50', 'cursor-not-allowed');
                            btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> SYNCING...';
                            if (typeof lucide !== 'undefined') lucide.createIcons();
                            
                            const response = await fetch('/dashboard/unified/sync-all', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({})
                            });
                            
                            const result = await response.json();
                            
                            if (result.success) {
                                window.location.reload();
                            } else {
                                alert('Sync failed: ' + (result.error || 'Unknown error'));
                                btn.disabled = false;
                                btn.classList.remove('opacity-50', 'cursor-not-allowed');
                                btn.innerHTML = originalHtml;
                                if (typeof lucide !== 'undefined') lucide.createIcons();
                            }
                        } catch (err) {
                            console.error('Sync Error:', err);
                            alert('An error occurred during sync');
                            btn.disabled = false;
                            btn.classList.remove('opacity-50', 'cursor-not-allowed');
                            btn.innerHTML = originalHtml;
                            if (typeof lucide !== 'undefined') lucide.createIcons();
                        }
                    }
                </script>
            </div>
        <% } %>
    </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
