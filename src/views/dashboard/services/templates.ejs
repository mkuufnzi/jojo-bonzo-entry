<style nonce="<%= nonce %>">
    @keyframes scan {
        0%, 100% { top: 0%; opacity: 0; }
        15% { opacity: 1; }
        85% { opacity: 1; }
        100% { top: 100%; opacity: 0; }
    }
</style>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();

    // Logic for File Upload
    const heroUpload = document.getElementById('heroUpload');
    const overlay = document.getElementById('extractionOverlay');
    const loadText = document.getElementById('loadingText');

    if(heroUpload) {
        heroUpload.addEventListener('change', async (e) => {
             const file = e.target.files[0];
             if(!file) return;

             // 1. Show Overlay
             overlay.classList.remove('opacity-0', 'pointer-events-none');
             
             // 2. Prepare Form Data
             const formData = new FormData();
             formData.append('file', file);

             try {
                // 3. Send Request
                const response = await fetch('/dashboard/brand/extract', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    const result = await response.json();
                    
                    // 4. Success Animation
                    loadText.textContent = "Extraction complete! Redirecting...";
                    
                    // Short delay to show the success message
                    setTimeout(() => {
                        window.location.href = '/dashboard/brand?success=Extraction+Complete';
                    }, 800);
                    
                } else {
                    const err = await response.json();
                    throw new Error(err.error || 'Upload failed');
                }

             } catch (error) {
                 // Error Handling
                 alert('Extraction Failed: ' + error.message);
                 overlay.classList.add('opacity-0', 'pointer-events-none');
             }
        });
    }
});
</script>
