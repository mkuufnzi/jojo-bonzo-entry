<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[0.625rem] font-bold rounded-lg border border-blue-100 uppercase tracking-widest">Pillar I</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Transactional Branding</h1>
            </div>
            <p class="text-slate-500 font-medium">Turn invoices from cost centers to revenue machines with high-end branded templates and smart features.</p>
        </div>
        
        <div class="flex items-center gap-3">
            <button class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center">
                <i data-lucide="settings" class="w-4 h-4 mr-2"></i>
                Service Settings
            </button>
            <a href="/dashboard/brand" class="bg-slate-900 text-white px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:shadow-xl transition-all shadow-lg flex items-center">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                New Blueprint
            </a>
        </div>
    </div>

    <!-- Dynamic Onboarding & Stats Grid -->
    <div class="mb-12">
        
    <!-- Dynamic Onboarding & Stats Grid -->
    <div class="mb-12">
        
        <!-- Onboarding Hero (Show if not ready or skipped) -->
        <% const isOnboardingComplete = business && business.onboardingStatus === 'COMPLETED'; %>
        <% if (!isReady && business) { %>
            <div class="bg-gradient-to-r from-slate-900 via-blue-900 to-indigo-950 rounded-3xl p-8 mb-8 relative overflow-hidden shadow-2xl group border border-blue-500/30">
                <div class="absolute right-0 top-0 h-full w-1/2 bg-[url('/assets/pattern-white.svg')] opacity-5"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8">
                    <div class="max-w-2xl">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="px-2 py-0.5 bg-blue-500/20 text-blue-400 text-[0.625rem] font-bold rounded-lg border border-blue-500/20 uppercase tracking-widest backdrop-blur-sm">
                                <%= isIntegrationSkipped ? 'Engine Offline' : 'Setup Required' %>
                            </span>
                        </div>
                        
                        <% if (isIntegrationSkipped) { %>
                            <h2 class="text-4xl font-heading font-black mb-4 tracking-tight text-white italic">The Revenue Machine is Idle.</h2>
                            <p class="text-slate-300 font-medium text-lg mb-6 max-w-lg">
                                We're ready to transform your documents, but we have no data to process. Connect your ERP to start the engine.
                            </p>
                            <div class="flex items-center gap-4">
                                <a href="/onboarding/wizard?step=2" class="bg-blue-600 text-white px-8 py-3.5 rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg flex items-center group">
                                    <i data-lucide="plug-2" class="w-4 h-4 mr-2 group-hover:rotate-12 transition-transform"></i>
                                    Connect ERP Data &rarr;
                                </a>
                                <a href="/onboarding/wizard?step=4" class="text-slate-400 hover:text-white text-sm font-bold uppercase tracking-widest transition-colors">
                                    Review Config
                                </a>
                            </div>
                        <% } else { %>
                            <h2 class="text-4xl font-heading font-black mb-4 tracking-tight text-white">Complete your Business Profile</h2>
                            <p class="text-slate-300 font-medium text-lg mb-6 max-w-lg">
                                Unlock the full power of the Transactional Engine by completing your brand standards and settings.
                            </p>
                            <a href="/onboarding/wizard?step=<%= business.currentOnboardingStep || 1 %>" 
                               class="bg-white text-slate-900 px-8 py-3.5 rounded-xl font-bold hover:bg-slate-100 transition-all shadow-lg inline-flex items-center">
                                Continue Setup &rarr;
                            </a>
                        <% } %>
                    </div>

                    <!-- Visual Progress Indicator -->
                    <div class="hidden md:block w-48 h-48 relative">
                        <svg class="w-full h-full transform -rotate-90">
                            <circle cx="96" cy="96" r="88" stroke="currentColor" stroke-width="8" fill="transparent" class="text-slate-800" />
                            <circle cx="96" cy="96" r="88" stroke="currentColor" stroke-width="8" fill="transparent" class="text-blue-500"
                                stroke-dasharray="553"
                                stroke-dashoffset="<%= 553 - (553 * (business.currentOnboardingStep || 1) / 4) %>" />
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-white">
                            <span class="text-3xl font-black"><%= Math.round(((business.currentOnboardingStep || 1) / 4) * 100) %>%</span>
                            <span class="text-[0.625rem] font-bold uppercase text-slate-500">Ready</span>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Analytics Widgets -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <!-- Revenue Card -->
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm relative overflow-hidden group hover:border-blue-500 transition-all">
                <% if (isIntegrationSkipped) { %>
                    <div class="absolute inset-0 z-20 backdrop-blur-[2px] bg-white/40 flex flex-col items-center justify-center p-4 text-center">
                        <p class="text-[0.625rem] font-bold text-slate-500 uppercase tracking-widest mb-2">Needs Integration</p>
                        <a href="/onboarding/wizard?step=2" class="text-blue-600 font-bold text-xs hover:underline flex items-center gap-1">
                            Connect <i data-lucide="external-link" class="w-3 h-3"></i>
                        </a>
                    </div>
                <% } %>
                <div class="absolute -right-4 -top-4 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity">
                    <i data-lucide="dollar-sign" class="w-24 h-24 text-green-600"></i>
                </div>
                <div class="flex items-center justify-between mb-4">
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Total Revenue</p>
                    <span class="p-1.5 bg-green-50 rounded-lg">
                         <i data-lucide="trending-up" class="w-3 h-3 text-green-600"></i>
                    </span>
                </div>
                <h3 class="text-3xl font-black text-slate-900 mb-1 tracking-tight">
                    <%= typeof totalRevenue !== 'undefined' ? '$' + totalRevenue.toLocaleString() : '$0.00' %>
                </h3>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    Lifetime Volume
                </p>
            </div>

            <!-- Invoices Processed -->
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm relative overflow-hidden group hover:border-blue-500 transition-all">
                 <% if (isIntegrationSkipped) { %>
                    <div class="absolute inset-0 z-20 backdrop-blur-[2px] bg-white/40 flex flex-col items-center justify-center p-4 text-center border-2 border-dashed border-slate-100 rounded-3xl m-1">
                        <i data-lucide="lock" class="w-4 h-4 text-slate-300 mb-2"></i>
                        <span class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Locked</span>
                    </div>
                <% } %>
                <div class="absolute -right-4 -top-4 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity">
                    <i data-lucide="file-text" class="w-24 h-24 text-blue-600"></i>
                </div>
                <div class="flex items-center justify-between mb-4">
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Documents</p>
                </div>
                <h3 class="text-3xl font-black text-slate-900 mb-1 tracking-tight">
                    <%= typeof processedCount !== 'undefined' ? processedCount : 0 %>
                </h3>
                <p class="text-xs font-bold text-blue-600 uppercase tracking-widest">Processed</p>
            </div>

            <!-- Sync Status -->
            <a href="/dashboard/connections" class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm relative overflow-hidden group hover:border-blue-500 transition-all">
                <div class="absolute -right-4 -top-4 opacity-[0.03] group-hover:opacity-[0.08] transition-opacity">
                    <i data-lucide="refresh-cw" class="w-24 h-24 text-indigo-600"></i>
                </div>
                <div class="flex items-center justify-between mb-4">
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Sync Health</p>
                    <% const isSynced = business && business.integrations && business.integrations.length > 0; %>
                    <span class="w-2 h-2 rounded-full <%= isSynced ? 'bg-green-500' : (isIntegrationSkipped ? 'bg-orange-500 animate-pulse' : 'bg-slate-300') %>"></span>
                </div>
                <h3 class="text-2xl font-black text-slate-900 mb-1 tracking-tight">
                    <%= isSynced ? 'Active' : (isIntegrationSkipped ? 'Skipped' : 'Unconfigured') %>
                </h3>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                    <%= business.integrations && business.integrations.length > 0 
                        ? (business.integrations.length > 1 ? business.integrations.length + ' Connected Sources' : 'Provider: ' + (business.integrations[0]?.provider || 'None'))
                        : 'No Data Source' %>
                </p>
            </a>

            <!-- n8n Status (Dynamic) -->
            <% const isConnected = typeof connectivity !== 'undefined' && connectivity && connectivity.connected; %>
            <div id="n8nStatusCard" class="<%= isConnected ? 'bg-slate-900' : 'bg-red-900/10 border-red-500/20' %> border border-slate-800 rounded-3xl p-8 shadow-sm relative overflow-hidden group transition-all">
                <div class="absolute -right-4 -top-4 opacity-[0.1] group-hover:opacity-[0.2] transition-opacity">
                    <i data-lucide="zap" class="w-24 h-24 <%= isConnected ? 'text-yellow-400' : 'text-red-400' %>"></i>
                </div>
                <div class="flex items-center justify-between mb-4">
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">n8n Engine</p>
                    <span id="n8nIndicator" class="w-2 h-2 rounded-full <%= isConnected ? 'bg-green-500' : 'bg-red-500 animate-pulse' %>"></span>
                </div>
                <h3 id="n8nStatusText" class="text-2xl font-black text-white mb-1 tracking-tight">
                    <%= isConnected ? 'Connected' : 'Offline' %>
                </h3>
                <p id="n8nStatusSub" class="text-xs font-bold text-slate-500 uppercase tracking-widest">
                    <%= isConnected ? 'Active Gateway' : 'Ping Failed' %>
                </p>
            </div>
        </div>
    </div>

    <!-- Main Content Grid Reconstructed -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12 items-start">
        
        <!-- Left/Main Column (2/3 Width) -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Revenue Recovery (Recovery Machine - High Impact) -->
            <% if (isReady && overdueInvoices && overdueInvoices.length > 0) { %>
            <div class="bg-white border-2 border-rose-100 rounded-3xl p-8 shadow-sm relative overflow-hidden group">
                <div class="absolute right-0 top-0 h-full w-1/3 bg-gradient-to-l from-rose-50 to-transparent opacity-50"></div>
                <div class="relative z-10">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h2 class="text-2xl font-black text-slate-900 flex items-center gap-3 italic uppercase tracking-tight">
                                <i data-lucide="shield-alert" class="w-7 h-7 text-rose-500"></i>
                                Revenue Recovery
                            </h2>
                            <p class="text-slate-500 mt-1 font-medium text-sm"><%= overdueInvoices.length %> leaks detected in your revenue cycle.</p>
                        </div>
                        <div class="px-4 py-2 bg-rose-500 text-white rounded-xl text-[10px] font-black uppercase tracking-[0.2em] animate-pulse">
                            Action Required
                        </div>
                    </div>

                    <div class="space-y-3">
                        <% overdueInvoices.forEach(inv => { %>
                        <div class="p-4 bg-white border border-slate-100 rounded-2xl flex items-center justify-between hover:border-rose-300 hover:shadow-md transition-all group/item">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-rose-50 flex items-center justify-center group-hover/item:bg-rose-100 transition-colors">
                                    <i data-lucide="file-warning" class="w-5 h-5 text-rose-500"></i>
                                </div>
                                <div>
                                    <h4 class="text-slate-900 font-bold text-sm"><%= inv.normalized.contactName %></h3>
                                    <div class="flex items-center gap-2 text-[10px] text-slate-400 font-bold uppercase tracking-wider">
                                        <span><%= inv.externalId %></span>
                                        <span>•</span>
                                        <span class="text-rose-400">Overdue <%= Math.floor((Date.now() - new Date(inv.normalized.date).getTime()) / (1000 * 60 * 60 * 24)) %> Days</span>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-6">
                                <div class="text-right">
                                    <span class="block text-lg font-black text-rose-600 tracking-tight">$<%= inv.normalized.amount.toLocaleString() %></span>
                                </div>
                                <button 
                                    onclick="triggerFollowup('<%= inv.id %>')"
                                    class="px-4 py-2 bg-slate-900 hover:bg-rose-600 text-white text-[10px] font-black uppercase tracking-widest rounded-xl transition-all active:scale-95 shadow-lg group-hover/item:shadow-rose-500/20"
                                >
                                    Follow-up
                                </button>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
            </div>
            <% } %>

            <!-- Branding History (The Engine in Action) -->
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h2 class="text-xl font-black text-slate-900 flex items-center gap-2 tracking-tight uppercase">
                            <i data-lucide="zap" class="w-6 h-6 text-blue-500"></i>
                            Branding History
                        </h2>
                        <p class="text-slate-500 mt-1 text-xs font-medium tracking-tight">Real-time throughput of your Transactional Branding engine.</p>
                    </div>
                    <% if (isReady && brandingHistory && brandingHistory.length > 0) { %>
                        <span class="flex items-center gap-2 text-[10px] font-black text-green-600 uppercase tracking-widest bg-green-50 px-3 py-1.5 rounded-lg border border-green-100">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                            Live
                        </span>
                    <% } %>
                </div>

                <% if (isReady && brandingHistory && brandingHistory.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% brandingHistory.slice(0, 8).forEach(doc => { %>
                    <div class="p-4 bg-slate-50/50 border border-slate-100 rounded-2xl flex items-center justify-between hover:border-blue-300 transition-all group/item">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center group-hover/item:bg-blue-100 transition-colors">
                                <i data-lucide="file-check" class="w-3.5 h-3.5 text-blue-500"></i>
                            </div>
                            <div class="max-w-[140px]">
                                <span class="block text-slate-900 font-bold text-[11px] truncate leading-tight"><%= doc.normalized.contactName %></span>
                                <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest"><%= doc.externalId %></span>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="block text-slate-900 font-black text-sm tracking-tight">$<%= doc.normalized.amount.toLocaleString() %></span>
                            <span class="text-[9px] text-blue-500 font-black uppercase tracking-tighter">Branded</span>
                        </div>
                    </div>
                    <% }) %>
                </div>
                <% } else { %>
                <div class="flex flex-col items-center justify-center py-12 text-center border-2 border-dashed border-slate-100 rounded-3xl">
                    <div class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mb-3">
                        <i data-lucide="database-zap" class="w-6 h-6 text-slate-300"></i>
                    </div>
                    <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest max-w-[200px]">Waiting for signal...</p>
                </div>
                <% } %>
            </div>

            <!-- Recent Conversions (Technical Log) -->
            <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
                <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/30">
                    <h3 class="text-xs font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="terminal" class="w-4 h-4 text-slate-400"></i>
                        Conversion logs
                    </h3>
                    <a href="#" class="text-[0.625rem] font-bold text-blue-600 uppercase tracking-widest hover:underline">Full Archive</a>
                </div>
                <div class="overflow-hidden">
                    <table class="w-full divide-y divide-slate-100">
                        <thead class="bg-slate-50/50">
                            <tr>
                                <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.1em]">Timestamp</th>
                                <th class="px-6 py-4 text-left text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.1em]">Action</th>
                                <th class="px-6 py-4 text-center text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.1em]">Status</th>
                                <th class="px-6 py-4 text-right text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.1em]">Latency</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <% if (recentLogs && recentLogs.length > 0) { %>
                                <% recentLogs.slice(0, 5).forEach(log => { %>
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-6 py-4 text-xs font-medium text-slate-500"><%= new Date(log.createdAt).toLocaleTimeString() %></td>
                                        <td class="px-6 py-4 text-xs font-bold text-slate-900 uppercase tracking-tight"><%= log.action || 'GENERATE' %></td>
                                        <td class="px-6 py-4 text-center">
                                            <span class="px-2 py-0.5 <%= log.status === 'success' ? 'bg-green-50 text-green-600 border-green-200' : 'bg-red-50 text-red-600 border-red-200' %> rounded-lg border text-[0.625rem] font-black uppercase tracking-widest">
                                                <%= log.status === 'success' ? 'OK 200' : 'ERR 500' %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-right font-mono text-[0.6875rem] font-bold text-blue-600"><%= log.duration ? log.duration + 'ms' : '---' %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" class="px-6 py-12 text-center text-slate-400 font-bold uppercase text-[0.625rem] tracking-widest italic">Silent Engine</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Sidebar / Right Column (1/3 Width) -->
        <div class="lg:col-span-1 space-y-8">
            
            <!-- Active Blueprints -->
            <div class="bg-white border border-slate-200 rounded-3xl p-8 shadow-sm">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.2em]">Active Blueprints</h3>
                    <div class="flex gap-1">
                        <div class="w-1 h-1 rounded-full bg-blue-500"></div>
                        <div class="w-1 h-1 rounded-full bg-slate-200"></div>
                        <div class="w-1 h-1 rounded-full bg-slate-200"></div>
                    </div>
                </div>

                <!-- Integration State / Resume CTA -->
                <% if (isIntegrationSkipped) { %>
                <div class="bg-amber-50 rounded-2xl p-6 border border-amber-100 mb-6">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="p-2 bg-amber-100 rounded-lg text-amber-600">
                            <i data-lucide="alert-circle" class="w-5 h-5"></i>
                        </div>
                        <h4 class="text-xs font-black text-amber-900 uppercase tracking-widest">Sync Pipe Paused</h4>
                    </div>
                    <p class="text-amber-800/70 text-[10px] font-medium leading-relaxed mb-4">You have active blueprints but the data pipe is closed. Reconnect to resume branding.</p>
                    <a href="/onboarding/wizard?step=2" class="w-full inline-block text-center bg-amber-600 text-white py-2.5 rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-amber-700 transition-colors shadow-lg shadow-amber-600/20">
                        Reconnect ERP
                    </a>
                </div>
                <% } %>

                <div class="space-y-4">
                    <% if (isIntegrationSkipped || !activeBlueprints || activeBlueprints.length === 0) { %>
                        <div class="py-12 flex flex-col items-center text-center opacity-40">
                            <div class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                                <i data-lucide="layout-template" class="w-6 h-6 text-slate-300"></i>
                            </div>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">0 Blueprints Found</span>
                        </div>
                    <% } else { %>
                        <% activeBlueprints.forEach(t => { %>
                            <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 hover:border-blue-400 transition-all cursor-pointer group">
                                <div class="flex items-center justify-between mb-2">
                                    <h4 class="text-xs font-black text-slate-900 group-hover:text-blue-600 transition-colors uppercase tracking-tight"><%= t.name %></h4>
                                    <i data-lucide="chevron-right" class="w-3 h-3 text-slate-300"></i>
                                </div>
                                <div class="flex items-center gap-2">
                                    <div class="h-1 flex-1 bg-slate-200 rounded-full overflow-hidden">
                                        <div class="h-full bg-blue-500" style="width: 100%"></div>
                                    </div>
                                    <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Active</span>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
                
                <button class="w-full mt-6 py-3 rounded-2xl border-2 border-dashed border-slate-100 text-slate-400 text-[10px] font-black uppercase tracking-widest hover:border-blue-400 hover:text-blue-600 transition-all">
                    Design Vault &rarr;
                </button>
            </div>

            <!-- Recovery Insights (Revenue Machine narrative) -->
            <div class="bg-slate-900 rounded-3xl p-8 text-white relative overflow-hidden group shadow-2xl shadow-blue-900/40">
                <div class="absolute -right-8 -bottom-8 opacity-20 group-hover:scale-110 transition-transform">
                    <i data-lucide="bar-chart-3" class="w-48 h-48 text-blue-400"></i>
                </div>
                <div class="relative z-10">
                    <div class="w-12 h-12 bg-white/10 backdrop-blur-md rounded-xl flex items-center justify-center mb-6">
                        <i data-lucide="zap" class="w-6 h-6 text-yellow-400"></i>
                    </div>
                    <h3 class="text-lg font-black italic uppercase tracking-tighter mb-2">Revenue Recovery Optimizer</h3>
                    <p class="text-slate-400 text-xs font-medium mb-6 leading-relaxed">
                        Our AI models identify recovery triggers that match your brand's unique signature. 
                        <strong class="text-white">Active protection enabled.</strong>
                    </p>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-3 bg-white/5 rounded-xl border border-white/10">
                            <span class="block text-[8px] font-black text-slate-500 uppercase tracking-widest mb-1">Success</span>
                            <span class="text-xl font-black text-white italic"><%= stats && stats.successRate ? Math.round(stats.successRate) : '0' %>%</span>
                        </div>
                        <div class="p-3 bg-white/5 rounded-xl border border-white/10">
                            <span class="block text-[8px] font-black text-slate-500 uppercase tracking-widest mb-1">Impact</span>
                            <span class="text-xl font-black text-emerald-400 italic">High</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Support Card -->
            <div class="bg-blue-50 border border-blue-100 rounded-3xl p-6 text-center">
                <h3 class="text-xs font-black text-blue-900 uppercase tracking-[0.1em] mb-2">Enterprise Lab</h3>
                <p class="text-blue-800/60 text-[10px] font-bold mb-4">Request bespoke document schemas from our engineering squad.</p>
                <button class="w-full bg-white text-blue-600 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest border border-blue-200 hover:shadow-lg transition-all">
                    Open Lab Ticket
                </button>
            </div>
        </div>
    </div>
</div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
    
    // --- End Playground Logic ---

    // --- End Playground Logic ---

    // n8n Ping Check
    const checkN8nStatus = async () => {
        const card = document.getElementById('n8nStatusCard');
        if (!card) return; // Guard
        
        const statusText = document.getElementById('n8nStatusText');
        const sub = document.getElementById('n8nStatusSub');
        const led = document.getElementById('n8nIndicator');

        console.log('🔄 [Floovioo] Pinging n8n Engine...');

        try {
            const start = performance.now();
            const res = await fetch('/services/transactional-branding/ping', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({})
            });
            const data = await res.json();
            const latency = Math.round(performance.now() - start);

            if (res.ok && data.success && data.connected) {
                console.log(`✅ [Floovioo] n8n Connected in ${latency}ms`, data);
                
                statusText.textContent = 'Connected';
                sub.textContent = `Latency: ${latency}ms`;
                statusText.classList.add('text-green-400');
                statusText.classList.remove('text-white');
                
                led.classList.remove('bg-slate-600', 'animate-pulse');
                led.classList.add('bg-green-500', 'shadow-[0_0_10px_rgba(34,197,94,0.5)]');
                
            } else {
                console.warn('⚠️ [Floovioo] n8n Connected logic mismatch', data);
                throw new Error('Connection logic failed');
            }
        } catch (err) {
            console.error('❌ [Floovioo] n8n Connection Failed', err);
            
            statusText.textContent = 'Disconnected';
            sub.textContent = 'Backoff Retry';
            statusText.classList.add('text-red-500');
            statusText.classList.remove('text-white');

            led.classList.remove('bg-slate-600', 'animate-pulse');
            led.classList.add('bg-red-500');
        }
    };

    // Run check immediately
    checkN8nStatus();
});
</script>
