<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-indigo-50 text-indigo-600 text-[0.625rem] font-bold rounded-lg border border-indigo-100 uppercase tracking-widest">Pillar III</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Sales Enablement</h1>
            </div>
            <p class="text-slate-500 font-medium">Close deals faster with automated proposals, pitch decks, and custom contract generation.</p>
        </div>
        
        <div class="flex items-center gap-3">
            <button class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center">
                <i data-lucide="trending-up" class="w-4 h-4 mr-2 text-indigo-500"></i>
                Revenue Analytics
            </button>
            <button class="bg-indigo-600 text-white px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:shadow-xl transition-all shadow-lg flex items-center">
                <i data-lucide="sparkles" class="w-4 h-4 mr-2 text-indigo-200"></i>
                AI Pitch Designer
            </button>
        </div>
    </div>

    <!-- Revenue Pipeline Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-12">
        <div class="lg:col-span-3 bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm overflow-hidden relative">
            <div class="absolute -right-8 -top-8 opacity-[0.03]">
                <i data-lucide="bar-chart-3" class="w-64 h-64 text-indigo-600"></i>
            </div>
            
            <div class="flex items-center justify-between mb-8 relative z-10">
                <div>
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="target" class="w-4 h-4 text-indigo-500"></i>
                        Deal Velocity
                    </h3>
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-1">Metric: Mean Time to Close (MTTC)</p>
                </div>
                <div class="bg-indigo-50 px-4 py-2 rounded-2xl border border-indigo-100">
                    <span class="text-[0.625rem] font-bold text-indigo-600 uppercase tracking-widest">Status: Accelerated</span>
                </div>
            </div>

            <!-- Funnel Visualization Mockup -->
            <div class="space-y-4 relative z-10">
                <div class="flex items-center gap-4">
                    <div class="w-32 text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Discovery</div>
                    <div class="flex-1 bg-slate-50 rounded-full h-8 overflow-hidden relative">
                        <div class="bg-indigo-100 h-full w-[100%] transition-all"></div>
                        <span class="absolute right-4 top-1.5 text-xs font-black text-indigo-600">$4.5M</span>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-32 text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Proposal Sent</div>
                    <div class="flex-1 bg-slate-50 rounded-full h-8 overflow-hidden relative pl-[10%]">
                        <div class="bg-indigo-300 h-full w-[70%] transition-all rounded-l-full"></div>
                        <span class="absolute right-4 top-1.5 text-xs font-black text-indigo-700">$1.2M</span>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-32 text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Negotiation</div>
                    <div class="flex-1 bg-slate-50 rounded-full h-8 overflow-hidden relative pl-[25%]">
                        <div class="bg-indigo-500 h-full w-[40%] transition-all rounded-l-full"></div>
                        <span class="absolute right-4 top-1.5 text-xs font-black text-indigo-900">$450K</span>
                    </div>
                </div>
                 <div class="flex items-center gap-4">
                    <div class="w-32 text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Closing</div>
                    <div class="flex-1 bg-slate-50 rounded-full h-8 overflow-hidden relative pl-[40%]">
                        <div class="bg-indigo-700 h-full w-[20%] transition-all rounded-l-full shadow-inner shadow-black/20"></div>
                        <span class="absolute right-4 top-1.5 text-xs font-black text-white">$120K</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Activity -->
        <div class="space-y-6">
            <div class="bg-indigo-600 rounded-3xl p-6 text-white shadow-xl">
                <p class="text-[0.625rem] font-bold text-indigo-200 uppercase tracking-widest mb-4">Win Rate</p>
                <h4 class="text-4xl font-black mb-1">64.2%</h4>
                <p class="text-[0.625rem] text-indigo-100 font-medium opacity-70">+4.5% vs Industry Avg</p>
            </div>
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
                <h4 class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-4">Real-Time Alerts</h4>
                <div class="space-y-4">
                     <div class="flex items-start gap-3">
                        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-1.5"></div>
                        <div>
                            <p class="text-xs font-bold text-slate-700">Acme Corp viewed proposal</p>
                            <p class="text-[0.625rem] text-slate-400 uppercase font-medium">Just now • 3rd view</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 mt-1.5"></div>
                        <div>
                            <p class="text-xs font-bold text-slate-700">Contract Ready: Beta Inc</p>
                            <p class="text-[0.625rem] text-slate-400 uppercase font-medium">2 hours ago</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Proposal Vault & Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <div class="lg:col-span-2 bg-white border border-slate-200 rounded-[2.5rem] shadow-sm overflow-hidden">
             <div class="p-6 border-b border-slate-100 bg-slate-50/30 flex justify-between items-center">
                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                    <i data-lucide="folder" class="w-4 h-4 text-slate-400"></i>
                    Proposal Vault
                </h3>
                <div class="flex gap-2">
                    <span class="px-2 py-1 bg-white border border-slate-200 rounded text-[0.625rem] font-bold text-slate-500 uppercase tracking-widest cursor-pointer hover:bg-slate-50 transition-colors">Drafts</span>
                    <span class="px-2 py-1 bg-indigo-600 rounded text-[0.625rem] font-bold text-white uppercase tracking-widest cursor-pointer transition-colors shadow-sm shadow-indigo-200">Active</span>
                </div>
             </div>
             <div class="divide-y divide-slate-50">
                <% [
                    { company: 'Acme Global', amount: '$45,000', status: 'Sent', time: 'Today', icon: 'send' },
                    { company: 'Nexus Systems', amount: '$12,500', status: 'Signed', time: 'Yesterday', icon: 'file-check' },
                    { company: 'Starlight Retail', amount: '$8,900', status: 'Sent', time: 'Jan 21', icon: 'send' },
                    { company: 'Hyperion Tech', amount: '$120,000', status: 'Negotiating', time: 'Jan 20', icon: 'message-square' }
                ].forEach(deal => { %>
                    <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition-colors group">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-indigo-50 group-hover:text-indigo-600 transition-all">
                                <i data-lucide="<%= deal.icon %>" class="w-4 h-4"></i>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-slate-800"><%= deal.company %></h4>
                                <p class="text-[0.625rem] text-slate-400 uppercase font-medium tracking-widest"><%= deal.time %></p>
                            </div>
                        </div>
                        <div class="flex items-center gap-6">
                            <div class="text-right">
                                <p class="text-[0.6875rem] font-black text-slate-900 tracking-tight"><%= deal.amount %></p>
                                <span class="text-[0.5rem] font-bold text-slate-400 uppercase tracking-widest"><%= deal.status %></span>
                            </div>
                            <button class="p-2 text-slate-300 hover:text-indigo-600 transition-colors">
                                <i data-lucide="more-horizontal" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                <% }) %>
             </div>
        </div>

        <div class="bg-indigo-900 rounded-[2.5rem] p-8 text-white shadow-2xl relative overflow-hidden flex flex-col justify-between">
            <div class="absolute -right-12 -top-12 opacity-10">
                <i data-lucide="zap" class="w-48 h-48 text-white"></i>
            </div>
            <div class="relative z-10">
                <h3 class="text-2xl font-black tracking-tight mb-4">Enterprise Proposal Generator</h3>
                <p class="text-indigo-200 text-sm font-medium leading-relaxed opacity-80 mb-8">Securely sync with Salesforce or HubSpot to auto-populate high-fidelity PDF proposals in milliseconds.</p>
                <div class="space-y-3">
                    <button class="w-full bg-white text-indigo-900 py-3 rounded-2xl font-bold text-xs uppercase tracking-widest hover:bg-amber-50 transition-all flex items-center justify-center">
                        <i data-lucide="database" class="w-4 h-4 mr-2"></i>
                        Connect CRM
                    </button>
                    <button class="w-full bg-indigo-800 text-white border border-indigo-700 py-3 rounded-2xl font-bold text-xs uppercase tracking-widest hover:bg-indigo-700 transition-all">
                        Documentation
                    </button>
                </div>
            </div>
            <div class="relative z-10 pt-8 border-t border-indigo-800 mt-8">
                 <p class="text-[0.625rem] font-bold text-indigo-400 uppercase tracking-widest mb-2 italic">Architecture Status</p>
                 <div class="flex items-center gap-2">
                     <div class="flex-1 h-0.5 bg-indigo-700 rounded-full">
                         <div class="bg-amber-400 w-[80%] h-full rounded-full"></div>
                     </div>
                     <span class="text-[0.5rem] font-bold">ALPHA_v0.2</span>
                 </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
