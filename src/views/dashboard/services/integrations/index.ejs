<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-blue-50 text-blue-600 text-[0.625rem] font-bold rounded-lg border border-blue-100 uppercase tracking-widest">Enterprise Hub</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Integrations & Sync</h1>
            </div>
            <p class="text-slate-500 font-medium">Control your global data pipeline, monitor sync health, and manage third-party connections.</p>
        </div>
        
        <div class="flex items-center gap-3">
             <a href="/dashboard/integrations/connections" class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-[0.625rem] font-black uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center shadow-sm hover:shadow active:scale-95">
                <i data-lucide="plug-2" class="w-4 h-4 mr-2 text-blue-500"></i>
                Manage Connections
            </a>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12">
        <div class="bg-white border border-slate-200 rounded-[2rem] p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center border border-blue-100">
                    <i data-lucide="link" class="w-5 h-5 text-blue-600"></i>
                </div>
            </div>
            <p class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-1">Active Links</p>
            <h4 class="text-2xl font-black text-slate-900"><%= locals.activeConnections?.length || 0 %></h4>
        </div>

        <div class="bg-white border border-slate-200 rounded-[2rem] p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center border border-emerald-100">
                    <i data-lucide="activity" class="w-5 h-5 text-emerald-600"></i>
                </div>
                <span class="text-[0.625rem] font-bold text-emerald-600 uppercase">99.9% Uptime</span>
            </div>
            <p class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-1">API Health</p>
            <h4 class="text-2xl font-black text-slate-900">Optimal</h4>
        </div>

        <div class="bg-white border border-slate-200 rounded-[2rem] p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center border border-purple-100">
                    <i data-lucide="database" class="w-5 h-5 text-purple-600"></i>
                </div>
            </div>
            <p class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-1">Total Synced</p>
            <h4 class="text-2xl font-black text-slate-900"><%= locals.totalSyncedRecords || '0' %></h4>
        </div>

        <div class="bg-white border border-slate-200 rounded-[2rem] p-6 shadow-sm">
            <div class="flex items-center justify-between mb-4">
                <div class="w-10 h-10 rounded-xl bg-slate-900 flex items-center justify-center border border-slate-800">
                    <i data-lucide="workflow" class="w-5 h-5 text-white"></i>
                </div>
            </div>
            <p class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-1">Automation Engines</p>
            <h4 class="text-2xl font-black text-slate-900">2 Active</h4>
        </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Sync Logs -->
        <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-lg font-black text-slate-900 tracking-tight flex items-center gap-3">
                    <i data-lucide="history" class="w-5 h-5 text-blue-500"></i>
                    Recent Synced Activity
                </h3>
            </div>

            <div class="space-y-6">
                <% if (locals.syncJobs && locals.syncJobs.length > 0) { %>
                    <% locals.syncJobs.forEach(job => { %>
                        <div class="flex items-start gap-4 pb-6 border-b border-slate-50 last:border-0 last:pb-0">
                            <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="refresh-cw" class="w-4 h-4 text-slate-400"></i>
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center justify-between mb-1">
                                    <h5 class="text-xs font-bold text-slate-900 uppercase tracking-widest"><%= job.entityType %> Sync</h5>
                                    <span class="text-[0.625rem] text-slate-400 font-bold"><%= new Date(job.startedAt).toLocaleDateString() %></span>
                                </div>
                                <p class="text-[0.625rem] font-medium text-slate-500">
                                    <%= job.status === 'COMPLETED' ? `Successfully updated ${job.recordsSynced} records.` : `Error: ${job.errorMessage || 'Failed connection'}` %>
                                </p>
                            </div>
                            <div class="flex items-center gap-1">
                                <span class="w-1.5 h-1.5 rounded-full <%= job.status === 'COMPLETED' ? 'bg-emerald-500' : 'bg-red-500' %>"></span>
                                <span class="text-[0.5rem] font-black uppercase tracking-tighter text-slate-400"><%= job.status %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="py-12 text-center">
                        <i data-lucide="clock" class="w-12 h-12 text-slate-200 mx-auto mb-4"></i>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">No recent jobs found</p>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Infrastructure Status -->
        <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white relative overflow-hidden">
            <div class="absolute -right-12 -top-12 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>
            
            <div class="relative z-10">
                <h3 class="text-xl font-black mb-8 flex items-center gap-3">
                    <i data-lucide="server" class="w-6 h-6 text-blue-400"></i>
                    Infrastructure Status
                </h3>

                <div class="space-y-8">
                    <div class="p-6 bg-white/5 border border-white/10 rounded-3xl">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Database Replica</span>
                            <span class="px-2 py-0.5 bg-emerald-500/10 text-emerald-400 text-[0.625rem] font-black rounded-lg border border-emerald-500/20">OPERATIONAL</span>
                        </div>
                        <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                            <div class="w-full h-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                        </div>
                    </div>

                    <div class="p-6 bg-white/5 border border-white/10 rounded-3xl">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">n8n Engine</span>
                            <span class="px-2 py-0.5 bg-blue-500/10 text-blue-400 text-[0.625rem] font-black rounded-lg border border-blue-500/20">CONNECTED</span>
                        </div>
                        <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                            <div class="w-[85%] h-full bg-blue-400"></div>
                        </div>
                        <p class="mt-3 text-[0.5rem] font-bold text-blue-400/60 uppercase tracking-widest">Latency: 1828ms</p>
                    </div>

                    <div class="p-6 bg-white/5 border border-white/10 rounded-3xl">
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Webhooks Tunnel</span>
                            <span class="px-2 py-0.5 bg-purple-500/10 text-purple-400 text-[0.625rem] font-black rounded-lg border border-purple-500/20">SECURED</span>
                        </div>
                    </div>
                </div>
        <!-- Active Connections -->
        <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-lg font-black text-slate-900 tracking-tight flex items-center gap-3">
                    <i data-lucide="plug-2" class="w-5 h-5 text-emerald-500"></i>
                    Connected Channels
                </h3>
                <a href="/dashboard/integrations/connections" class="text-[0.625rem] font-bold text-blue-600 uppercase tracking-widest hover:underline">Manage &rarr;</a>
            </div>

            <% if (locals.activeConnections && locals.activeConnections.length > 0) { %>
                <div class="grid grid-cols-1 gap-4">
                    <% locals.activeConnections.forEach(conn => { %>
                        <div class="border border-slate-100 rounded-2xl p-5 flex items-center justify-between group hover:border-blue-200 transition-colors">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center p-2">
                                    <img src="/assets/logos/<%= conn.provider %>.svg" alt="<%= conn.provider %>" class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all" onerror="this.src='https://cdn.worldvectorlogo.com/logos/<%= conn.provider %>.svg'">
                                </div>
                                <div>
                                    <h5 class="text-sm font-black text-slate-900 capitalize"><%= conn.provider %></h5>
                                    <p class="text-[0.625rem] font-bold text-emerald-600 uppercase tracking-tight">Active & Synced</p>
                                </div>
                            </div>
                            <div class="bg-slate-50 hover:bg-slate-900 hover:text-white text-slate-600 p-2 rounded-lg transition-all">
                                <i data-lucide="external-link" class="w-4 h-4"></i>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="py-12 text-center bg-slate-50/50 rounded-3xl border border-dashed border-slate-200">
                    <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center mx-auto mb-4 shadow-sm border border-slate-100">
                        <i data-lucide="plug-2" class="w-8 h-8 text-slate-300"></i>
                    </div>
                    <h5 class="text-sm font-black text-slate-900 mb-1">No Active Channels</h5>
                    <p class="text-xs text-slate-500 mb-6 font-medium">Connect your ERP to start syncing data.</p>
                    <a href="/dashboard/integrations/connections" class="inline-flex items-center px-6 py-2.5 bg-blue-600 text-white text-[0.625rem] font-black uppercase tracking-widest rounded-xl hover:bg-blue-700 transition-all shadow-sm">
                        Connect Now &rarr;
                    </a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
