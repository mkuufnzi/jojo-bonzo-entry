<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-12 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <span class="px-2 py-0.5 bg-teal-50 text-teal-600 text-[0.625rem] font-bold rounded-lg border border-teal-100 uppercase tracking-widest">Pillar II</span>
                <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Customer Retention</h1>
            </div>
            <p class="text-slate-500 font-medium">Maximize LTV with automated QBRs, onboarding guides, and churn prevention.</p>
        </div>
        
        <div class="flex items-center gap-3">
             <button class="bg-white border border-slate-200 text-slate-600 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-50 transition-all flex items-center">
                <i data-lucide="activity" class="w-4 h-4 mr-2 text-teal-500"></i>
                Alert Protocols
            </button>
            <button class="bg-slate-900 text-white px-6 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest hover:shadow-xl transition-all shadow-lg flex items-center">
                <i data-lucide="shield-check" class="w-4 h-4 mr-2 text-teal-400"></i>
                Secure Account
            </button>
        </div>
    </div>

    <!-- Executive Health Dashboard -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-12">
        <div class="lg:col-span-3 bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm relative overflow-hidden">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                        <i data-lucide="heart" class="w-4 h-4 text-teal-500"></i>
                        Ecosystem Vitality
                    </h3>
                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-1">Cohort: Enterprise Alpha (January 2026)</p>
                </div>
                <div class="flex gap-4">
                    <div class="text-right">
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">Health Score</p>
                        <p class="text-2xl font-black text-teal-600">92%</p>
                    </div>
                    <div class="text-right">
                        <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-1">At-Risk Accounts</p>
                        <p class="text-2xl font-black text-red-500">03</p>
                    </div>
                </div>
            </div>

            <!-- Health Distribution Chart Mockup (Simple CSS) -->
            <div class="flex items-end justify-between h-48 gap-4 px-4">
                <% [85, 92, 78, 95, 88, 91, 94].forEach((val, i) => { %>
                    <div class="flex-1 bg-slate-50 flex flex-col justify-end rounded-xl overflow-hidden group cursor-help" title="Segment <%= i+1 %>: <%= val %>% Health">
                        <div class="bg-teal-500/20 group-hover:bg-teal-500/40 transition-all" style="height: <%= val %>%">
                             <div class="bg-teal-500 w-full h-1 rounded-t-full"></div>
                        </div>
                    </div>
                <% }) %>
            </div>
            <div class="flex justify-between mt-6 px-4">
                <span class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Retention Phase</span>
                <span class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">Growth Phase</span>
            </div>
        </div>

        <!-- Sidebar Stats -->
        <div class="space-y-6">
            <div class="bg-slate-900 rounded-3xl p-6 text-white shadow-xl">
                <p class="text-[0.625rem] font-bold text-teal-400 uppercase tracking-widest mb-4">Retention Revenue</p>
                <h4 class="text-3xl font-black mb-1">$1.2M</h4>
                <p class="text-[0.625rem] text-slate-400 font-medium opacity-70">Secured via churn prevention</p>
                <div class="mt-6 pt-6 border-t border-slate-800">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-[0.625rem] font-bold text-slate-500">Success Rate</span>
                        <span class="text-[0.625rem] font-bold text-teal-400">99.4%</span>
                    </div>
                    <div class="w-full bg-slate-800 rounded-full h-1">
                        <div class="bg-teal-500 h-1 rounded-full" style="width: 99.4%"></div>
                    </div>
                </div>
            </div>
            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
                <h4 class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mb-4">Top Churn Triggers</h4>
                <ul class="space-y-4">
                    <li class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-700">Login Inactivity</span>
                        <span class="text-[0.625rem] font-bold text-red-500">HIGH</span>
                    </li>
                    <li class="flex items-center justify-between">
                         <span class="text-xs font-bold text-slate-700">Quota Burnout</span>
                        <span class="text-[0.625rem] font-bold text-amber-500">MID</span>
                    </li>
                    <li class="flex items-center justify-between">
                         <span class="text-xs font-bold text-slate-700">Ticket Escalation</span>
                        <span class="text-[0.625rem] font-bold text-slate-400">LOW</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Active Projects & Automated Documents -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <!-- Automation Timeline -->
        <div class="bg-white border border-slate-200 rounded-[2.5rem] p-8 shadow-sm">
            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest mb-8 flex items-center gap-2">
                <i data-lucide="clock" class="w-4 h-4 text-blue-500"></i>
                Retention Workflow Timeline
            </h3>
            <div class="space-y-8 relative before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-slate-100">
                <div class="relative pl-10">
                    <div class="absolute left-0 top-1.5 w-6 h-6 bg-blue-50 border-2 border-blue-500 rounded-full flex items-center justify-center">
                         <i data-lucide="check" class="w-3 h-3 text-blue-600"></i>
                    </div>
                    <h4 class="text-sm font-bold text-slate-900">Day 1: Onboarding Protocol</h4>
                    <p class="text-xs text-slate-500 mt-1">Automated welcome guide and integration mapping generated.</p>
                </div>
                <div class="relative pl-10">
                    <div class="absolute left-0 top-1.5 w-6 h-6 bg-emerald-50 border-2 border-emerald-500 rounded-full flex items-center justify-center">
                         <i data-lucide="play" class="w-3 h-3 text-emerald-600 ml-0.5"></i>
                    </div>
                    <h4 class="text-sm font-bold text-slate-900">Day 30: First Value Hook</h4>
                    <p class="text-xs text-slate-500 mt-1">Detailed usage report showcasing ROI and performance signals.</p>
                </div>
                <div class="relative pl-10 opacity-50">
                    <div class="absolute left-0 top-1.5 w-6 h-6 bg-slate-50 border-2 border-slate-300 rounded-full flex items-center justify-center">
                         <div class="w-2 h-2 bg-slate-300 rounded-full"></div>
                    </div>
                    <h4 class="text-sm font-bold text-slate-700 font-mono">Day 90: QBR Strategy Blueprint</h4>
                    <p class="text-xs text-slate-400 mt-1 italic">Pending system status analysis (ETA: Feb 12).</p>
                </div>
            </div>
        </div>

        <!-- Retention Toolset -->
        <div class="grid grid-cols-2 gap-4">
             <% const tools = [
                { name: 'ROI Reports', icon: 'trending-up', color: 'blue', desc: 'Auto-calculate customer gain' },
                { name: 'Usage Audits', icon: 'search', color: 'teal', desc: 'Identify dormant features' },
                { name: 'Migration Docs', icon: 'shuffle', color: 'indigo', desc: 'Smooth stack transitions' },
                { name: 'Churn Alerts', icon: 'bell', color: 'red', desc: 'Real-time risk monitoring' }
            ]; %>
            <% tools.forEach(tool => { %>
                <div class="p-6 bg-white border border-slate-100 rounded-3xl hover:border-<%= tool.color %>-500 transition-all shadow-sm group">
                    <div class="w-10 h-10 bg-<%= tool.color %>-50 text-<%= tool.color %>-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                        <i data-lucide="<%= tool.icon %>" class="w-5 h-5"></i>
                    </div>
                    <h4 class="text-sm font-bold text-slate-900 mb-1"><%= tool.name %></h4>
                    <p class="text-[0.625rem] text-slate-400 font-medium leading-relaxed"><%= tool.desc %></p>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
