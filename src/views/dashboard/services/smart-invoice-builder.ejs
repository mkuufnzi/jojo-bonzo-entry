<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../partials/head') %>
    <style>
        [x-cloak] { display: none !important; }
        /* Font Imports */
        @import url('https://fonts.googleapis.com/css2?family=Georgia:wght@400;700&family=Inter:wght@400;600;700&display=swap');
    </style>
</head>
<body class="bg-gray-50 text-slate-800" x-data="invoiceBuilder()">

    <%- include('../../partials/sidebar') %>

    <main class="ml-64 p-8">
        
        <!-- HEADER: Builder Controls -->
        <div class="flex justify-between items-center mb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Template Builder</h1>
                <p class="text-sm text-gray-500">Configure your Smart Invoice Logic & Branding</p>
            </div>
            <div class="flex gap-3">
                <button @click="saveConfig()" class="bg-indigo-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-indigo-700 transition">
                    Save Configuration
                </button>
            </div>
        </div>

        <!-- ─── BUILDER UI ─── -->
        <div class="relative min-h-screen bg-gray-100 rounded-xl overflow-hidden border border-gray-200">
            
            <!-- Background Pattern Binding -->
            <div class="absolute inset-0 pointer-events-none z-0" 
                 :style="'background: ' + themes[currentTheme].pattern"></div>

            <!-- THEME SWITCHER BAR -->
            <div class="relative z-10 flex gap-4 p-4 bg-white border-b border-gray-200 items-center flex-wrap">
                <span class="text-xs font-semibold text-gray-500 tracking-widest uppercase mr-2">Brand Theme</span>
                
                <template x-for="(t, key) in themes" :key="key">
                    <button 
                        @click="currentTheme = key"
                        class="px-4 py-1.5 rounded-full border-2 text-xs font-bold flex items-center gap-2 transition-all"
                        :class="currentTheme === key ? 'border-current bg-opacity-10' : 'border-gray-200 bg-white text-gray-500'"
                        :style="currentTheme === key ? `color: ${t.primary}; background-color: ${t.light}; border-color: ${t.primary}` : ''"
                    >
                        <span x-text="t.logo"></span>
                        <span x-text="t.name"></span>
                    </button>
                </template>

                <div class="ml-auto flex items-center gap-3">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" x-model="config.upsellEnabled" class="rounded text-indigo-600 focus:ring-indigo-500">
                        <span class="text-xs font-medium text-gray-600">Upsell Engine</span>
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" x-model="config.contentEnabled" class="rounded text-indigo-600 focus:ring-indigo-500">
                        <span class="text-xs font-medium text-gray-600">Content Module</span>
                    </label>
                </div>
            </div>

            <!-- INVOICING PREVIEW AREA -->
            <div class="relative z-1 max-w-3xl mx-auto py-12 px-4">
                
                <!-- CARD -->
                <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                    
                    <!-- HEADER BANNER -->
                    <div class="p-8 relative overflow-hidden" :style="'background: ' + themes[currentTheme].gradient">
                        <!-- Decorative Circles -->
                        <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full bg-white bg-opacity-10"></div>
                        <div class="absolute -bottom-5 left-16 w-24 h-24 rounded-full bg-white bg-opacity-5"></div>

                        <div class="flex justify-between items-start relative z-10 text-white">
                            <div class="flex items-center gap-3">
                                <span class="text-3xl" x-text="themes[currentTheme].logo"></span>
                                <div>
                                    <div class="text-xl font-bold tracking-wide" x-text="themes[currentTheme].name"></div>
                                    <div class="text-[10px] tracking-[0.15em] uppercase opacity-70" x-text="themes[currentTheme].tagline"></div>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-[10px] uppercase tracking-widest opacity-60">Invoice</div>
                                <div class="text-2xl font-bold">#INV-2025-0847</div>
                                <div class="text-[11px] mt-1 opacity-60">Feb 1, 2025</div>
                            </div>
                        </div>
                    </div>

                    <!-- CUSTOMER INFO -->
                    <div class="flex justify-between p-8 border-b border-gray-100 bg-white">
                        <div>
                            <div class="text-[10px] font-bold uppercase tracking-widest mb-1" :style="'color: ' + themes[currentTheme].muted">Bill To</div>
                            <div class="font-bold text-sm" :style="'color: ' + themes[currentTheme].text">Sarah Mitchell</div>
                            <div class="text-xs text-gray-500">sarah.mitchell@email.com</div>
                            <div class="text-xs text-gray-500">Member since 2023 · 14 orders</div>
                        </div>
                        <div class="flex gap-6 text-right">
                            <div>
                                <div class="text-[10px] font-bold uppercase tracking-widest mb-1" :style="'color: ' + themes[currentTheme].muted">Status</div>
                                <span class="px-2 py-0.5 rounded-full text-[11px] font-bold" 
                                      :style="'background: ' + themes[currentTheme].accent + '; color: ' + themes[currentTheme].primary">Paid ✓</span>
                            </div>
                            <div>
                                <div class="text-[10px] font-bold uppercase tracking-widest mb-1" :style="'color: ' + themes[currentTheme].muted">Loyalty</div>
                                <span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-amber-100 text-amber-600">★ Gold</span>
                            </div>
                        </div>
                    </div>

                    <!-- ITEMS TABLE -->
                    <div class="px-8 pb-8">
                        <table class="w-full">
                            <thead>
                                <tr class="border-b-2" :style="'border-color: ' + themes[currentTheme].accent">
                                    <th class="py-3 text-left text-[10px] uppercase tracking-widest font-bold" :style="'color: ' + themes[currentTheme].muted">Product</th>
                                    <th class="py-3 text-right text-[10px] uppercase tracking-widest font-bold" :style="'color: ' + themes[currentTheme].muted">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="item in items" :key="item.id">
                                    <tr class="border-b border-gray-50">
                                        <td class="py-3 flex items-center gap-3">
                                            <div class="w-9 h-9 rounded bg-gray-50 flex items-center justify-center text-lg" x-text="item.img"></div>
                                            <div>
                                                <div class="text-sm font-semibold" :style="'color: ' + themes[currentTheme].text" x-text="item.name"></div>
                                                <div class="text-[10px] text-gray-400" x-text="item.category"></div>
                                            </div>
                                        </td>
                                        <td class="py-3 text-right font-medium text-sm" :style="'color: ' + themes[currentTheme].text" x-text="'$' + (item.price * item.qty).toFixed(2)"></td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>

                         <!-- UPSELL ADDED ITEMS -->
                         <div x-show="addedItems.length > 0" class="mt-4 p-3 rounded-lg" :style="'background: ' + themes[currentTheme].light">
                             <div class="text-[9px] font-bold uppercase tracking-widest mb-2" :style="'color: ' + themes[currentTheme].secondary">⚡ Added to Order</div>
                             <template x-for="id in addedItems" :key="id">
                                 <div class="flex justify-between items-center py-1 border-b border-black/5 last:border-0">
                                     <div class="flex items-center gap-2">
                                         <span x-text="getRec(id).img"></span>
                                         <span class="text-xs font-medium" :style="'color: ' + themes[currentTheme].text" x-text="getRec(id).name"></span>
                                     </div>
                                     <div class="flex items-center gap-3">
                                         <span class="text-xs font-bold" :style="'color: ' + themes[currentTheme].primary" x-text="'$' + getRec(id).price"></span>
                                         <button @click="toggleAdd(id)" class="text-red-500 hover:text-red-700 font-bold text-xs">×</button>
                                     </div>
                                 </div>
                             </template>
                         </div>

                        <!-- TOTALS -->
                        <div class="mt-6 flex justify-end">
                            <div class="w-48">
                                <div class="flex justify-between text-xs py-1 text-gray-500">
                                    <span>Subtotal</span>
                                    <span x-text="'$' + subtotal.toFixed(2)"></span>
                                </div>
                                <div class="flex justify-between text-xs py-1 text-gray-500 border-t border-gray-100 mt-2 pt-2">
                                    <span class="text-sm font-bold" :style="'color: ' + themes[currentTheme].text">Total</span>
                                    <span class="text-sm font-bold" :style="'color: ' + themes[currentTheme].primary" x-text="'$' + total.toFixed(2)"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ─── NURTURE BANNER (Marketing) ─── -->
                <div x-show="config.contentEnabled" class="mt-6 rounded-xl p-5 cursor-pointer relative overflow-hidden shadow-lg transition-transform hover:scale-[1.01]"
                     @click="cycleNurture()"
                     style="background: linear-gradient(135deg, #1E293B 0%, #334155 100%);">
                    
                     <div class="flex items-start gap-4 relative z-10 text-white">
                         <div class="text-2xl leading-none" x-text="nurtureMessages[nurtureIdx].icon"></div>
                         <div class="flex-1">
                             <div class="font-bold text-sm mb-1" x-text="nurtureMessages[nurtureIdx].headline"></div>
                             <div class="text-xs opacity-60 leading-relaxed" x-text="nurtureMessages[nurtureIdx].body"></div>
                         </div>
                         <div class="text-[9px] opacity-30 mt-1">tap →</div>
                     </div>
                     
                     <!-- Pagination Dots -->
                     <div class="flex justify-center gap-1.5 mt-4">
                         <template x-for="(msg, i) in nurtureMessages" :key="i">
                             <div class="h-1.5 rounded-full transition-all duration-300"
                                  :style="i === nurtureIdx ? `width: 18px; background: ${themes[currentTheme].secondary}` : 'width: 6px; background: rgba(255,255,255,0.2)'"></div>
                         </template>
                     </div>
                </div>

                <!-- ─── UPSELL ENGINE (Recommendations) ─── -->
                <div x-show="config.upsellEnabled" class="mt-8 transition-all duration-500">
                    <div class="flex justify-between items-center mb-3">
                        <div>
                            <div class="text-sm font-bold" :style="'color: ' + themes[currentTheme].text">🎯 Recommended for You</div>
                            <div class="text-[10px] text-gray-400">Personalized based on your order history</div>
                        </div>
                        <span class="text-[9px] font-bold px-2 py-1 rounded bg-green-50 text-green-700">AI-Powered</span>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <template x-for="rec in recommendations" :key="rec.id">
                            <div class="bg-white rounded-xl p-4 shadow-sm relative border-2 transition-all cursor-pointer hover:shadow-md"
                                 :style="addedItems.includes(rec.id) ? `border-color: ${themes[currentTheme].primary}` : 'border-color: transparent'">
                                
                                <!-- Match Dial -->
                                <div class="absolute top-2 right-2 w-8 h-8 flex items-center justify-center rounded-full border-2 text-[9px] font-bold"
                                     :style="`border-color: ${themes[currentTheme].light}; color: ${themes[currentTheme].primary}`">
                                    <span x-text="rec.match + '%'"></span>
                                </div>

                                <div class="flex items-center gap-3 mb-2">
                                    <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl" :style="'background: ' + themes[currentTheme].light" x-text="rec.img"></div>
                                    <div class="pr-6">
                                        <div class="text-xs font-bold leading-tight" :style="'color: ' + themes[currentTheme].text" x-text="rec.name"></div>
                                        <div class="text-[10px] font-bold mt-1" :style="'color: ' + themes[currentTheme].primary" x-text="'$' + rec.price"></div>
                                    </div>
                                </div>

                                <div class="text-[9px] text-gray-500 bg-gray-50 rounded px-2 py-1 mb-3 leading-snug">
                                    💡 <span x-text="rec.reason"></span>
                                </div>

                                <button @click="toggleAdd(rec.id)" 
                                        class="w-full py-2 rounded-lg text-[10px] font-bold uppercase tracking-wider transition-all"
                                        :style="addedItems.includes(rec.id) ? `background: ${themes[currentTheme].accent}; color: ${themes[currentTheme].primary}` : `background: ${themes[currentTheme].gradient}; color: white`">
                                    <span x-text="addedItems.includes(rec.id) ? '✓ Added' : '+ Add to Order'"></span>
                                </button>
                            </div>
                        </template>
                    </div>
                </div>

                <!-- ─── FOOTER ─── -->
                <div class="mt-8 text-center opacity-50 text-[10px]">
                    Smart Invoice Engine v2.1 · Floovioo Transactional
                </div>

            </div>
        </div>
    </main>

    <script>
        function invoiceBuilder() {
            return {
                currentTheme: 'bloom',
                config: {
                    upsellEnabled: true,
                    contentEnabled: true
                },
                nurtureIdx: 0,
                addedItems: [],
                
                // MOCK DATA
                themes: {
                    bloom: {
                        name: "Bloom Organics",
                        primary: "#2D6A4F", secondary: "#40916C", accent: "#B7E4C7", light: "#F0FAF4", text: "#1B4332", muted: "#52796F",
                        gradient: "linear-gradient(135deg, #2D6A4F 0%, #40916C 100%)",
                        logo: "🌿", tagline: "Pure. Natural. Nourishing.",
                        pattern: "radial-gradient(circle at 20% 50%, rgba(45,106,79,0.06) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(64,145,108,0.04) 0%, transparent 50%)",
                    },
                    luxe: {
                        name: "MAISON ÉLITE",
                        primary: "#1A1A2E", secondary: "#C9A227", accent: "#F5E6C8", light: "#FAFAF8", text: "#1A1A2E", muted: "#6B6B7B",
                        gradient: "linear-gradient(135deg, #1A1A2E 0%, #16213E 100%)",
                        logo: "◆", tagline: "Luxury redefined.",
                        pattern: "repeating-linear-gradient(45deg, transparent, transparent 40px, rgba(201,162,39,0.03) 40px, rgba(201,162,39,0.03) 80px)",
                    },
                    spark: {
                        name: "SparkTech",
                        primary: "#6366F1", secondary: "#8B5CF6", accent: "#C4B5FD", light: "#F5F3FF", text: "#312E81", muted: "#7C3AED",
                        gradient: "linear-gradient(135deg, #6366F1 0%, #8B5CF6 100%)",
                        logo: "⚡", tagline: "Power your workflow.",
                        pattern: "radial-gradient(circle at 90% 80%, rgba(99,102,241,0.08) 0%, transparent 40%), radial-gradient(circle at 10% 10%, rgba(139,92,246,0.05) 0%, transparent 50%)",
                    }
                },
                items: [
                    { id: 1, name: "Organic Matcha Powder", category: "Beverages", qty: 2, price: 34.99, img: "🍵" },
                    { id: 2, name: "Cold Pressed Coconut Oil", category: "Oils", qty: 1, price: 28.50, img: "🥥" },
                    { id: 3, name: "Almond Butter (Unsalted)", category: "Spreads", qty: 3, price: 12.99, img: "🥜" }
                ],
                recommendations: [
                    { id: 101, name: "Ceremonial Grade Matcha Kit", price: 54.99, img: "🎌", reason: "Pairs with Matcha Powder", match: 94 },
                    { id: 102, name: "MCT Oil Drops", price: 22.99, img: "💧", reason: "Coconut Oil buyers love this", match: 88 },
                    { id: 103, name: "Organic Honey (Raw)", price: 18.99, img: "🍯", reason: "Enhances Almond Butter", match: 81 },
                    { id: 104, name: "Bamboo Reusable Cups", price: 16.99, img: "🎋", reason: "Complete your ritual", match: 76 }
                ],
                nurtureMessages: [
                    { icon: "🔥", headline: "Your ritual awaits.", body: "87% of matcha lovers upgrade to ceremonial grade within 30 days." },
                    { icon: "💡", headline: "Smart combo detected.", body: "This bundle saves you 18% and ships free today." },
                    { icon: "⭐", headline: "Join 12,400 happy customers.", body: "\"The MCT drops transformed my morning routine.\" — Sarah K." }
                ],

                // COMPUTED (simulated via getters for simplicity or explicit update)
                get subtotal() {
                     return this.items.reduce((s, i) => s + i.price * i.qty, 0);
                },
                get addedTotal() {
                    return this.addedItems.reduce((s, id) => {
                        const p = this.recommendations.find(r => r.id === id);
                        return s + (p ? p.price : 0);
                    }, 0);
                },
                get total() {
                    return (this.subtotal + this.addedTotal) * 1.08;
                },

                // METHODS
                getRec(id) {
                    return this.recommendations.find(r => r.id === id);
                },
                toggleAdd(id) {
                    if (this.addedItems.includes(id)) {
                        this.addedItems = this.addedItems.filter(x => x !== id);
                    } else {
                        this.addedItems.push(id);
                    }
                },
                cycleNurture() {
                    this.nurtureIdx = (this.nurtureIdx + 1) % this.nurtureMessages.length;
                },
                async saveConfig() {
                    try {
                        const payload = {
                            theme: this.currentTheme,
                            upsellConfig: { active: this.config.upsellEnabled },
                            contentConfig: { active: this.config.contentEnabled }
                        };
                        const res = await fetch('/dashboard/brand/config', {
                            method: 'POST',
                            headers: {'Content-Type': 'application/json'},
                            body: JSON.stringify(payload)
                        });
                        if (res.ok) alert('Configuration Saved!');
                    } catch (e) {
                        alert('Error saving configuration');
                    }
                }
            }
        }
    </script>
</body>
</html>
