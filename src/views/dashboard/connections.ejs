<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-10 flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Connections</h1>
            <p class="text-slate-500 font-medium">Manage your linked accounting and CRM data sources.</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-full border border-blue-100">
                <%= activeConnections.length %> Active Connection<%= activeConnections.length !== 1 ? 's' : '' %>
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Connected List -->
        <div class="lg:col-span-2 space-y-6">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
                <i data-lucide="check-circle" class="w-4 h-4"></i>
                Connected Platforms
            </h3>

            <% if (activeConnections.length > 0) { %>
                <div class="grid grid-cols-1 gap-4">
                    <% activeConnections.forEach(conn => { %>
                        <% const def = definitions.find(d => d.slug === conn.provider || d.slug === (conn.provider + '-online')); %>
                        <div class="bg-white border <%= conn.status === 'connected' ? 'border-slate-200' : 'border-red-200 bg-red-50/10' %> rounded-3xl p-6 shadow-sm hover:border-blue-400 transition-all flex items-center justify-between group">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center border border-slate-100 group-hover:bg-white transition-colors">
                                    <% if (def && def.logoUrl) { %>
                                        <img src="<%= def.logoUrl %>" class="w-8 h-8 object-contain" alt="">
                                    <% } else { %>
                                        <span class="text-xl font-bold text-slate-300"><%= conn.provider[0].toUpperCase() %></span>
                                    <% } %>
                                </div>
                                <div>
                                    <h4 class="font-bold text-slate-900 capitalize"><%= conn.provider %> Integration</h4>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="w-1.5 h-1.5 rounded-full <%= conn.status === 'connected' ? 'bg-green-500' : 'bg-red-500' %>"></span>
                                        <span class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">
                                            <%= conn.status === 'connected' ? 'Connected & Synced' : 'Action Required' %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                <a href="/dashboard/connections/<%= conn.provider %>" class="px-4 py-2 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 hover:bg-slate-50 transition-all">
                                    Configure
                                </a>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="bg-slate-50 border border-dashed border-slate-200 rounded-3xl p-12 text-center">
                    <i data-lucide="link-2" class="w-12 h-12 text-slate-300 mx-auto mb-4"></i>
                    <p class="text-slate-400 font-bold uppercase text-[0.625rem] tracking-widest">No active connections found</p>
                    <p class="text-slate-500 text-sm mt-2 max-w-xs mx-auto font-medium">Connect your accounting software to start automating your brand identity.</p>
                </div>
            <% } %>

            <!-- Available List -->
            <div class="pt-8">
                <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2 mb-6">
                    <i data-lucide="plus-circle" class="w-4 h-4"></i>
                    Available Integrations
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <% definitions.filter(d => !activeConnections.some(c => c.provider === d.slug || (d.slug === 'zoho-crm' && c.provider === 'zoho'))).forEach(item => { %>
                        <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm hover:shadow-md transition-all flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-xl bg-slate-50 flex items-center justify-center border border-slate-100">
                                    <img src="<%= item.logoUrl %>" class="w-6 h-6 object-contain" alt="">
                                </div>
                                <div>
                                    <h4 class="text-sm font-bold text-slate-900"><%= item.name %></h4>
                                    <p class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-0.5"><%= item.category %></p>
                                </div>
                            </div>
                            <a href="/onboarding/api/integrations/<%= item.slug %>/connect" class="p-2 text-slate-400 hover:text-blue-600 transition-colors">
                                <i data-lucide="plus" class="w-5 h-5"></i>
                            </a>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Sidebar / Rules -->
        <div class="space-y-8">
            <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-[2rem] p-8 text-white shadow-xl relative overflow-hidden">
                <i data-lucide="shield-check" class="absolute -right-4 -bottom-4 w-32 h-32 opacity-10"></i>
                <h3 class="text-lg font-black tracking-tight mb-4 flex items-center gap-2">
                    <i data-lucide="info" class="w-5 h-5 text-blue-400"></i>
                    Trust & Safety
                </h3>
                <p class="text-slate-400 text-sm font-medium leading-relaxed mb-6">
                    We use bank-level encryption for all Oauth tokens. Your document data is never stored permanently on our servers unless caching is enabled for performance.
                </p>
                <div class="space-y-3">
                    <div class="flex items-center gap-3">
                        <i data-lucide="key" class="w-4 h-4 text-emerald-400"></i>
                        <span class="text-[0.625rem] font-bold uppercase tracking-widest text-slate-300">OAuth 2.0 Encrypted</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <i data-lucide="clock" class="w-4 h-4 text-emerald-400"></i>
                        <span class="text-[0.625rem] font-bold uppercase tracking-widest text-slate-300">Automatic Token Rotation</span>
                    </div>
                </div>
            </div>

            <div class="bg-white border border-slate-200 rounded-3xl p-6 shadow-sm">
                <h3 class="text-[0.625rem] font-black text-slate-400 uppercase tracking-widest mb-4">Sync Configuration</h3>
                <p class="text-xs text-slate-500 font-medium leading-relaxed">
                    By default, we fetch <strong>Invoices</strong> and <strong>Contacts</strong> every 15 minutes. To adjust these rules, click "Configure" on your active connection.
                </p>
            </div>
        </div>
    </div>
</div>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    if (typeof lucide !== 'undefined') lucide.createIcons();
});
</script>
