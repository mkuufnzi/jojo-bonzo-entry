<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Brand Standards</h1>
            <p class="text-slate-500 font-medium">Define your visual identity for all generated documents.</p>
        </div>
        <% if (locals.success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="check-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.success %>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="alert-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.error %>
            </div>
        <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- Editor Column -->
        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 p-8">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                <i data-lucide="sliders" class="w-4 h-4"></i>
                Configuration
            </h3>
            
            <form id="brandForm" class="space-y-10">
                
                 <!-- Active Template -->
                 <div>
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-lg font-black text-slate-900 flex items-center gap-2">
                            <i data-lucide="layout-template" class="w-5 h-5 text-indigo-500"></i>
                            Active Template
                        </h2>
                    </div>

                    <!-- Template ID Hidden Input -->
                    <input type="hidden" name="activeTemplateId" id="invoiceTemplateId" value="<%= manifest.id %>">

                     <div class="grid grid-cols-1">
                        <div class="border-2 border-indigo-500 bg-indigo-50/20 rounded-xl p-4 flex items-center gap-4 cursor-default relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/5 to-transparent pointer-events-none"></div>
                            <div class="h-16 w-16 bg-white rounded-lg border border-slate-200 shadow-sm flex items-center justify-center shrink-0">
                                <i data-lucide="sparkles" class="w-8 h-8 text-indigo-500"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900"><%= manifest.name %></h4>
                                <p class="text-xs text-slate-500 font-medium mt-1"><%= manifest.description %></p>
                            </div>
                            <div class="ml-auto">
                                <% if (profile.activeTemplateId === manifest.id) { %>
                                    <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-widest flex items-center gap-1">
                                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                                        Active
                                    </span>
                                <% } else { %>
                                    <span class="bg-slate-100 text-slate-500 px-3 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-widest flex items-center gap-1">
                                        Inactive
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>



                <!-- Template Features Widget -->
                <div>
                    <h2 class="text-lg font-black text-slate-900 mb-4 flex items-center gap-2">
                        <i data-lucide="sliders-horizontal" class="w-5 h-5 text-indigo-500"></i>
                         Template Features
                    </h2>
                    
                    <div class="bg-indigo-50/50 rounded-2xl p-6 border border-indigo-100 space-y-4">
                        <% if (typeof features !== 'undefined' && features && features.length > 0) { %>
                            <% features.forEach(feature => { %>
                                <% 
                                    const isRequired = feature.required;
                                    // Determine if enabled: check profile config first, then default
                                    const isEnabled = profile.components?.[feature.id]?.enabled ?? feature.defaultEnabled ?? true;
                                %>
                                <div class="flex items-center justify-between p-3 bg-white rounded-xl border border-indigo-50 shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <div class="p-2 bg-indigo-50 rounded-lg text-indigo-500">
                                            <% if (feature.id.includes('header')) { %> <i data-lucide="layout-template" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('footer')) { %> <i data-lucide="panel-bottom" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('recommendations')) { %> <i data-lucide="shopping-bag" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('support')) { %> <i data-lucide="life-buoy" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('banner')) { %> <i data-lucide="megaphone" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('line_items')) { %> <i data-lucide="list" class="w-4 h-4"></i> <% } %>
                                            <% if (feature.id.includes('customer_info')) { %> <i data-lucide="user" class="w-4 h-4"></i> <% } %>
                                        </div>
                                        <div>
                                            <h4 class="text-sm font-bold text-slate-700 flex items-center gap-2">
                                                <%= feature.name %>
                                                <% if (feature.badge) { %>
                                                    <span class="bg-indigo-100 text-indigo-600 text-[10px] px-1.5 py-0.5 rounded uppercase tracking-wider font-bold"><%= feature.badge %></span>
                                                <% } %>
                                            </h4>
                                            <p class="text-[10px] text-slate-400 font-medium uppercase tracking-wide"><%= feature.description %></p>
                                        </div>
                                    </div>
                                    
                                    <% if (isRequired) { %>
                                        <div class="flex items-center gap-1.5 px-3 py-1 bg-slate-100 rounded-lg">
                                            <i data-lucide="lock" class="w-3 h-3 text-slate-400"></i>
                                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Required</span>
                                        </div>
                                        <input type="hidden" name="components[<%= feature.id %>][enabled]" value="true">
                                    <% } else { %>
                                        <% if (feature.type === 'toggle') { %>
                                            <div class="flex items-center">
                                                <label class="relative inline-flex items-center cursor-pointer">
                                                    <input type="checkbox" name="components[<%= feature.id %>][enabled]" value="true" 
                                                           class="sr-only peer component-toggle" 
                                                           data-id="<%= feature.id %>"
                                                           <%= isEnabled ? 'checked' : '' %>>
                                                    <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-indigo-500"></div>
                                                </label>
                                            </div>
                                        <% } %>
                                    <% } %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-sm text-red-500">Error loading template manifest.</p>
                        <% } %>
                    </div>
                </div>

                <!-- End of Configuration Widgets -->

                <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-4">
                    <button type="button" id="refreshBtn" onclick="refreshPreview()" class="px-6 py-2.5 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 uppercase tracking-widest hover:bg-slate-50 transition-all">
                        Refresh Preview
                    </button>
                    <!-- IMPORTANT: preventDefault in onsubmit is crucial to avoid double submission -->
                    <button type="button" onclick="saveAndRefresh()" class="px-8 py-2.5 bg-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-800 hover:shadow-lg transition-all shadow-md">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Preview Column -->
        <div class="sticky top-10">
            <div class="bg-slate-900 rounded-[2rem] shadow-2xl overflow-hidden border border-slate-800">
                <div class="bg-slate-800/50 px-6 py-4 flex justify-between items-center border-b border-slate-700">
                    <div class="flex items-center gap-2">
                         <div class="flex gap-1.5">
                             <div class="w-3 h-3 rounded-full bg-red-500"></div>
                             <div class="w-3 h-3 rounded-full bg-amber-500"></div>
                             <div class="w-3 h-3 rounded-full bg-green-500"></div>
                         </div>
                         <span class="ml-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Document Preview</span>
                    </div>
                    <select id="previewTypeSelect" class="bg-slate-800 text-slate-300 text-xs font-bold uppercase border border-slate-600 rounded px-2 py-1 outline-none focus:border-blue-500">
                        <option value="invoice" <%= manifest.type === 'INVOICE' ? 'selected' : '' %>>Invoice</option>
                        <option value="receipt" <%= manifest.type === 'RECEIPT' ? 'selected' : '' %>>Receipt</option>
                        <option value="quote" <%= manifest.type === 'QUOTE' ? 'selected' : '' %>>Quote</option>
                        <option value="credit_memo" <%= manifest.type === 'CREDIT_MEMO' ? 'selected' : '' %>>Credit Memo</option>
                    </select>
                </div>
                
                <!-- Scaled Iframe Wrapper -->
                <!-- We want the container to fill the column width, and height to match A4 aspect ratio relative to that width -->
                <div id="previewContainer" class="relative w-full bg-gray-100 overflow-hidden" style="aspect-ratio: 210/297;">
                    <!-- Iframe is fixed at A4 Resolution (794px x 1123px at 96 DPI) -->
                    <!-- We use JS to scale it down to fit the container -->
                    <!-- Removed allow-same-origin to prevent iframe from navigating parent (framebusting) -->
                    <iframe id="previewFrame" 
                            src="/dashboard/brand/preview?templateId=<%= manifest.id %>&type=<%= manifest.type %>" 
                            class="absolute top-0 left-0 origin-top-left border-none shadow-lg"
                            style="width: 794px; height: 1123px; transform: scale(0.4);" 
                            sandbox="allow-scripts allow-forms"></iframe>
                </div>
            </div>
            <p class="text-center text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-4">
                A4 Printable View • Scaled to Fit
            </p>
        </div>
    </div>
    <!-- Code Editor Modal -->
    <div id="editorModal" class="hidden fixed inset-0 z-[60] overflow-hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="absolute inset-0 bg-slate-900 bg-opacity-90 transition-opacity backdrop-blur-sm" id="editorModalBackdrop"></div>
        
        <div class="fixed inset-4 bg-slate-900 rounded-xl shadow-2xl overflow-hidden flex flex-col border border-slate-700">
            <!-- Header -->
            <div class="bg-slate-800 px-6 py-4 flex items-center justify-between border-b border-slate-700">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-blue-500/10 rounded-lg">
                        <i data-lucide="code-2" class="h-5 w-5 text-blue-400"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-slate-100">Template Source Editor</h3>
                        <p class="text-xs text-slate-400" id="editorTemplateName">Editing: Custom Template</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs text-amber-500 bg-amber-500/10 px-3 py-1.5 rounded-full border border-amber-500/20 flex items-center gap-1.5">
                        <i data-lucide="alert-triangle" class="h-3 w-3"></i>
                        Advanced Mode
                    </span>
                    <button type="button" id="closeEditorBtn" class="p-2 text-slate-400 hover:text-white rounded-lg hover:bg-slate-700 transition-colors">
                        <i data-lucide="x" class="h-5 w-5"></i>
                    </button>
                </div>
            </div>

            <!-- Editor Body -->
            <div class="flex-1 bg-[#1e1e1e] relative">
                <div id="monaco-container" class="absolute inset-0"></div>
            </div>

            <!-- Footer -->
            <div class="bg-slate-800 px-6 py-4 border-t border-slate-700 flex justify-between items-center">
                <div class="flex items-center gap-4 text-xs text-slate-400">
                     <div class="flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                        EJS / HTML5
                     </div>
                     <div>Ln <span id="cursorLine">1</span>, Col <span id="cursorCol">1</span></div>
                </div>
                <div class="flex items-center gap-3">
                    <button type="button" class="px-4 py-2 text-sm font-medium text-slate-300 hover:text-white transition-colors" onclick="document.getElementById('editorModal').classList.add('hidden')">
                        Discard Changes
                    </button>
                    <button type="button" id="saveCodeBtn" class="flex items-center gap-2 px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium shadow-lg shadow-blue-500/20 transition-all">
                        <i data-lucide="save" class="h-4 w-4"></i>
                        Save Template
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Load Monaco Editor via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    // Icons
    if (typeof lucide !== 'undefined') lucide.createIcons();

    const form = document.getElementById('brandForm');
    if(form) {
        form.addEventListener('submit', (e) => {
            e.preventDefault();
            console.log('Form submission intercepted');
        });
    }
    const previewFrame = document.getElementById('previewFrame');
    const saveBtn = document.querySelector('button[type="submit"]'); // Define globally for this scope

    // ... existing vars ...
    
    // Monaco Init
    let editor = null;
    require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' }});

    const initEditor = (initialValue) => {
        if(editor) return editor.setValue(initialValue);
        
        require(['vs/editor/editor.main'], function() {
            editor = monaco.editor.create(document.getElementById('monaco-container'), {
                value: initialValue,
                language: 'html', // html handles embedded css/js well enough for EJS
                theme: 'vs-dark',
                automaticLayout: true,
                minimap: { enabled: true },
                fontSize: 14,
                fontFamily: "'JetBrains Mono', 'Fira Code', Consolas, monospace",
                lineHeight: 1.5,
                padding: { top: 20 }
            });

            // Update status bar
            editor.onDidChangeCursorPosition((e) => {
                document.getElementById('cursorLine').textContent = e.position.lineNumber;
                document.getElementById('cursorCol').textContent = e.position.column;
            });
        });
    }

    // Edit Button Logic (Delegation)
    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.edit-code-btn');
        if(!btn) return;
        
        e.stopPropagation(); // Prevent card selection
        e.preventDefault();

        const templateId = btn.getAttribute('data-id');
        const isCustom = templateId.startsWith('custom:');
        
        // Show Modal
        const modal = document.getElementById('editorModal');
        modal.classList.remove('hidden');
        document.getElementById('editorTemplateName').textContent = `ID: ${templateId}`;
        document.getElementById('saveCodeBtn').setAttribute('data-id', templateId);

        // Fetch Source
        // For custom, we can fetch from an endpoint. For standard... we might just show "Read Only" or fetch the standard render?
        // Let's implement an endpoint: GET /api/branding/template/:id/source
        try {
            const res = await fetch(`/api/branding/template/${templateId}/source`);
            const data = await res.json();
            
            if(data.source) {
                 initEditor(data.source);
            } else {
                 initEditor('<!-- Could not load source -->');
            }
        } catch(err) {
            console.error(err);
            initEditor('<!-- Error loading source -->');
        }
    });

    // Close Logic
    const closeEditor = () => document.getElementById('editorModal').classList.add('hidden');
    document.getElementById('closeEditorBtn').addEventListener('click', closeEditor);
    document.getElementById('editorModalBackdrop').addEventListener('click', closeEditor);

    // Save Logic
    document.getElementById('saveCodeBtn').addEventListener('click', async () => {
        if(!editor) return;
        const code = editor.getValue();
        const templateId = document.getElementById('saveCodeBtn').getAttribute('data-id');
        const btn = document.getElementById('saveCodeBtn');

        btn.disabled = true;
        btn.innerHTML = '<i class="animate-spin" data-lucide="loader-2"></i> Saving...';
        if(typeof lucide !== 'undefined') lucide.createIcons();

        try {
            const res = await fetch(`/api/branding/template/${templateId}/source`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ htmlContent: code })
            });
            const data = await res.json();
            
            if(data.success) {
                // Refresh Preview
                const previewFrame = document.getElementById('previewFrame');
                if(previewFrame) previewFrame.src = previewFrame.src; // Reload iframe
                closeEditor();
                // Show toast?
            } else {
                alert('Save failed: ' + data.error);
            }
        } catch(e) {
            alert('Error saving template');
        } finally {
             btn.disabled = false;
             btn.innerHTML = '<i data-lucide="save"></i> Save Template';
             if(typeof lucide !== 'undefined') lucide.createIcons();
        }
    });

    // ... existing JS ... (AI Modal, etc)

    // Template Card Selection
    const cards = document.querySelectorAll('.template-card');
    const templateInput = document.getElementById('invoiceTemplateId');

    cards.forEach(card => {
        card.addEventListener('click', () => {
            // Remove selection from all
            cards.forEach(c => c.classList.remove('ring-2', 'ring-blue-500', 'bg-blue-50'));
            
            // Add to clicked
            card.classList.add('ring-2', 'ring-blue-500', 'bg-blue-50');
            
            // Update Hidden Input
            const id = card.getAttribute('data-id');
            if(templateInput) templateInput.value = id;

            // Trigger Save & Preview
            triggerAutoSave();
        });
    });

    // Component Toggles Auto-Save
    document.querySelectorAll('.component-toggle').forEach(toggle => {
        toggle.addEventListener('change', triggerAutoSave);
    });

    // Inputs Auto-Save
    // NO-OP: All inputs currently removed in favor of toggle-only configuration.
    // Re-enable here if we add text inputs to the generic widget.
    /*
    ['someInput'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', triggerAutoSave);
    });
    */


    // ============================================================
    // LIVE PREVIEW LOGIC
    // ============================================================
    let debounceTimer;
    
    function triggerAutoSave() {
        // Visual indicator
        if(saveBtn) saveBtn.textContent = 'Saving...';
        
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            saveAndRefresh();
        }, 800); // 800ms debounce
    }

    async function saveAndRefresh() {
        if(!form) return;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Construct Payload
        // We'll trust the form data structure for components: components[id][enabled]
        // But for nested JSON logic in backend, it's safer to struct it here if needed.
        // The backend BrandingController.updateSettings likely just takes req.body.
        
        // Let's gather the components manually to be sure
        const components = {};
        document.querySelectorAll('.component-toggle').forEach(toggle => {
             const id = toggle.getAttribute('data-id');
             components[id] = { enabled: toggle.checked };
        });

        const payload = {
            // "Template Ecosystem" Mode: We only send the feature configuration.
            // The visual identity (colors/fonts) is deprecated/moved to Theme settings (not here).
            // The manifesto drives what "components" (or features) are active.
            
            activeTemplateId: document.getElementById('invoiceTemplateId').value, // CRITICAL: Tell backend WHICH template
            components, // { [featureId]: { enabled: true/false } }
            
            // Legacy/Fallback for any direct profile props if needed, but for now we are clean.
        };

        try {
            const response = await fetch('/dashboard/brand/settings?format=json', { // Explicitly request JSON to prevent redirect logic
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                if(saveBtn) saveBtn.textContent = 'Saved';
                setTimeout(() => { if(saveBtn) saveBtn.textContent = 'Save Changes'; }, 2000);
                refreshPreview();
            } else {
                console.error('Save failed');
                if(saveBtn) saveBtn.textContent = 'Error';
            }
        } catch (e) {
            console.error('Auto-save error', e);
        }
    }

    function refreshPreview() {
        if (previewFrame) {
            // Reload iframe with selected type & template ID
            const type = document.getElementById('previewTypeSelect').value || 'invoice';
            const templateId = document.getElementById('invoiceTemplateId').value;
            
            const currentSrc = new URL(previewFrame.src, window.location.origin); // Ensure base URL
            currentSrc.searchParams.set('t', Date.now()); // bust cache
            currentSrc.searchParams.set('type', type);
            if(templateId) currentSrc.searchParams.set('templateId', templateId);
            
            previewFrame.src = currentSrc.toString();
        }
    }

    // AI Generation / n8n Webhook Logic
    const generateBtn = document.getElementById('openAiModalBtn');
    if (generateBtn) {
        generateBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            
            // UI State
            const originalText = generateBtn.innerHTML;
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<i class="animate-spin" data-lucide="loader-2"></i> Generatin...';
            if(typeof lucide !== 'undefined') lucide.createIcons();

            try {
                // 1. Gather Context
                const payload = {
                    type: document.getElementById('previewTypeSelect').value || 'invoice',
                    data: {
                        // Pass current form values as specific overrides if needed,
                        // otherwise backend uses saved profile.
                        // We'll pass the "draft" values so user sees immediate results.
                        colors: {
                            primary: document.getElementById('primaryColorText').value,
                            secondary: document.getElementById('secondaryColorText').value
                        },
                        font: document.getElementById('fontSelect').value
                    }
                };

                // 2. Call Service
                // maps to ServicesController.handleDynamicAction -> DesignEngine.executeAction
                const response = await fetch('/services/transactional-core/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success && result.type === 'html') {
                    // 3. Render Result
                    const previewFrame = document.getElementById('previewFrame');
                    if (previewFrame) {
                        // Use srcdoc for immediate HTML rendering
                        previewFrame.removeAttribute('src'); // Clear URL source to prioritize srcdoc
                        previewFrame.srcdoc = result.content;
                        
                        // Show Success Toast/Label
                        // "Your Ugly Invoice" Label as requested
                        const label = document.createElement('div');
                        label.className = 'absolute top-4 left-1/2 transform -translate-x-1/2 bg-yellow-400 text-black font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg z-50 animate-bounce';
                        label.innerHTML = '✨ Your Ugly Invoice (n8n) ✨';
                        label.id = 'uglyLabel';
                        
                        // Remove old label if exists
                        const oldLabel = document.getElementById('uglyLabel');
                        if(oldLabel) oldLabel.remove();
                        
                        previewFrame.parentElement.appendChild(label);
                        setTimeout(() => label.remove(), 5000);
                    }
                } else {
                    alert('Generation completed but returned unexpected format: ' + JSON.stringify(result));
                }

            } catch (error) {
                console.error('Generation Error:', error);
                alert('Failed to generate document. Please try again.');
            } finally {
                generateBtn.disabled = false;
                generateBtn.innerHTML = originalText;
                if(typeof lucide !== 'undefined') lucide.createIcons();
            }
        });
    }

    // Type Selector Listener
    const typeSelect = document.getElementById('previewTypeSelect');
    if(typeSelect) {
        typeSelect.addEventListener('change', refreshPreview);
    }

    // --- SCALED PREVIEW LOGIC ---
    function updatePreviewScale() {
        const container = document.getElementById('previewContainer');
        const iframe = document.getElementById('previewFrame');
        if (!container || !iframe) return;

        const containerWidth = container.offsetWidth;
        const targetWidth = 794; // A4 Width in Pixels (96 DPI)
        const scale = containerWidth / targetWidth;

        iframe.style.transform = `scale(${scale})`;
        // Also update height to match aspect ratio if needed, but we rely on fixed 1448px height being scaled down
    }

    // Run on load and resize
    updatePreviewScale();
    window.addEventListener('resize', updatePreviewScale);
    
    // --- URL PERSISTENCE ---
    // Ensure if user refreshes, they stay on this template
    const currentTemplateId = document.getElementById('invoiceTemplateId').value;
    if (currentTemplateId) {
        const url = new URL(window.location);
        url.searchParams.set('templateId', currentTemplateId);
        window.history.replaceState({}, '', url);
    }

});
</script>
