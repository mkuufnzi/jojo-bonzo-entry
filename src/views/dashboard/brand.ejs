<%- layout('layouts/dashboard-layout') %>

<div class="max-w-[1920px] mx-auto px-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Brand Standards</h1>
            <p class="text-slate-500 font-medium">Define your visual identity for all generated documents.</p>
        </div>
        <% if (locals.success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="check-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.success %>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="alert-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.error %>
            </div>
        <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- Editor Column -->
        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 p-8">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                <i data-lucide="sliders" class="w-4 h-4"></i>
                Configuration
            </h3>
            
            <form id="brandForm" class="space-y-10" onsubmit="return false;">
                
                 <!-- Active Template -->
                 <div>
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-lg font-black text-slate-900 flex items-center gap-2">
                            <i data-lucide="layout-template" class="w-5 h-5 text-indigo-500"></i>
                            Active Template
                        </h2>
                    </div>

                    <!-- Template ID Hidden Input -->
                    <input type="hidden" name="activeTemplateId" id="invoiceTemplateId" value="<%= manifest.id %>">

                     <div class="grid grid-cols-1">
                        <div class="border-2 border-indigo-500 bg-indigo-50/20 rounded-xl p-4 flex items-center gap-4 cursor-default relative overflow-hidden">
                            <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/5 to-transparent pointer-events-none"></div>
                            <div class="h-16 w-16 bg-white rounded-lg border border-slate-200 shadow-sm flex items-center justify-center shrink-0">
                                <i data-lucide="sparkles" class="w-8 h-8 text-indigo-500"></i>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900"><%= manifest.name %></h4>
                                <p class="text-xs text-slate-500 font-medium mt-1"><%= manifest.description %></p>
                            </div>
                            <div class="ml-auto">
                                <% if (profile.activeTemplateId === manifest.id) { %>
                                    <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-widest flex items-center gap-1">
                                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                                        Active
                                    </span>
                                <% } else { %>
                                    <span class="bg-slate-100 text-slate-500 px-3 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-widest flex items-center gap-1">
                                        Inactive
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Template Features Widget -->
                <div>
                    <h2 class="text-lg font-black text-slate-900 mb-4 flex items-center gap-2">
                        <i data-lucide="sliders-horizontal" class="w-5 h-5 text-indigo-500"></i>
                         Template Features
                    </h2>
                    
                     <input type="hidden" name="layoutOrder" id="layoutOrderInput" value="">
                    
                    <div id="sortableWidgetList" class="bg-indigo-50/50 rounded-2xl p-6 border border-indigo-100 space-y-4">
                        <% if (typeof features !== 'undefined' && features && features.length > 0) { %>
                            <% 
                                const savedOrder = profile.components?.layoutOrder || [];
                                const sortedFeatures = [...features].sort((a, b) => {
                                    const indexA = savedOrder.indexOf(a.id);
                                    const indexB = savedOrder.indexOf(b.id);
                                    if(indexA !== -1 && indexB !== -1) return indexA - indexB;
                                    if(indexA !== -1) return -1;
                                    if(indexB !== -1) return 1;
                                    return 0;
                                });
                            %>

                            <% sortedFeatures.forEach(feature => { %>
                                <% 
                                    const isRequired = feature.required;
                                    const compConfig = profile.components?.[feature.id] || {};
                                    const isEnabled = compConfig.enabled ?? feature.defaultEnabled ?? true;
                                    const val = compConfig.value ?? feature.defaultValue ?? '';
                                %>
                                <div class="widget-item <%= feature.id.includes('spacer') ? 'p-2' : 'p-4' %> <%= (feature.id === 'header' || feature.id === 'footer') ? 'locked-widget opacity-80' : '' %> bg-white rounded-xl border border-indigo-50 shadow-sm mb-3 group transition-all hover:shadow-md hover:border-indigo-200" 
                                     data-id="<%= feature.id %>"
                                     data-type="<%= feature.type %>">
                                    <div class="flex items-center justify-between mb-3">
                                        <div class="flex items-center gap-3">
                                            <% if (feature.id !== 'header' && feature.id !== 'footer') { %>
                                                <div class="drag-handle cursor-grab active:cursor-grabbing p-1.5 text-slate-300 hover:text-slate-500 rounded hover:bg-slate-100">
                                                    <i data-lucide="grip-vertical" class="w-4 h-4"></i>
                                                </div>
                                            <% } else { %>
                                                <div class="p-1.5 text-slate-200">
                                                    <i data-lucide="lock" class="w-4 h-4"></i>
                                                </div>
                                            <% } %>

                                            <div class="p-2 bg-indigo-50 rounded-lg text-indigo-500">
                                                <% if (feature.id.includes('header')) { %> <i data-lucide="layout-template" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('footer')) { %> <i data-lucide="panel-bottom" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('recommendations')) { %> <i data-lucide="shopping-bag" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('support')) { %> <i data-lucide="life-buoy" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('banner')) { %> <i data-lucide="megaphone" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('line_items')) { %> <i data-lucide="list" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('customer_info')) { %> <i data-lucide="user" class="w-4 h-4"></i> <% } %>
                                                <% if (feature.id.includes('spacer')) { %> <i data-lucide="unfold-vertical" class="w-4 h-4"></i> <% } %>
                                                <% if (!['header', 'footer', 'recommendations', 'support', 'banner', 'line_items', 'customer_info', 'spacer'].some(k => feature.id.includes(k))) { %>
                                                     <i data-lucide="box" class="w-4 h-4"></i>
                                                <% } %>
                                            </div>
                                            <div>
                                                <h4 class="text-sm font-bold text-slate-700 flex items-center gap-2">
                                                    <%= feature.name %>
                                                    <% if (feature.badge) { %>
                                                        <span class="bg-indigo-100 text-indigo-600 text-[10px] px-1.5 py-0.5 rounded uppercase tracking-wider font-bold"><%= feature.badge %></span>
                                                    <% } %>
                                                </h4>
                                                <p class="text-[10px] text-slate-400 font-medium uppercase tracking-wide"><%= feature.description %></p>
                                            </div>
                                        </div>
                                        
                                        <% if (isRequired) { %>
                                            <div class="flex items-center gap-1.5 px-3 py-1 bg-slate-100 rounded-lg">
                                                <i data-lucide="lock" class="w-3 h-3 text-slate-400"></i>
                                                <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Required</span>
                                            </div>
                                            <input type="hidden" name="components[<%= feature.id %>][enabled]" value="true" class="component-enabled-hidden">
                                        <% } else { %>
                                            <div class="flex items-center gap-2">
                                                <% if (feature.id.includes('spacer')) { %>
                                                    <button type="button" 
                                                            onclick="this.closest('.widget-item').remove(); window.triggerAutoSave();"
                                                            class="text-slate-300 hover:text-red-500 transition-colors p-1"
                                                            title="Remove Spacer">
                                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                    </button>
                                                <% } %>
                                                <label class="relative inline-flex items-center cursor-pointer">
                                                    <input type="checkbox" name="components[<%= feature.id %>][enabled]" value="true" 
                                                           class="sr-only peer component-toggle" 
                                                           data-id="<%= feature.id %>"
                                                           <%= isEnabled ? 'checked' : '' %>>
                                                    <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-indigo-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-indigo-500"></div>
                                                </label>
                                            </div>
                                        <% } %>
                                    </div>

                                    <% if (feature.type === 'input') { %>
                                        <div class="pl-14 pr-4 pb-2">
                                            <div class="flex items-center gap-4">
                                                <input type="range" 
                                                       min="0" max="200" step="5"
                                                       value="<%= val %>"
                                                       class="flex-1 h-1.5 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-indigo-500 component-value-range"
                                                       oninput="this.nextElementSibling.value = this.value; window.triggerAutoSave()">
                                                <input type="number" 
                                                       name="components[<%= feature.id %>][value]" 
                                                       value="<%= val %>"
                                                       class="w-16 px-2 py-1 bg-slate-50 border border-slate-200 rounded text-xs font-bold text-indigo-600 component-value-input"
                                                       oninput="this.previousElementSibling.value = this.value; window.triggerAutoSave()">
                                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">px</span>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-sm text-red-500">Error loading template manifest.</p>
                        <% } %>
                    </div>

                    <div class="mt-4 flex justify-center">
                         <button type="button" onclick="window.addSpacer()" class="flex items-center gap-2 px-4 py-2 border-2 border-dashed border-indigo-200 rounded-xl text-xs font-bold text-indigo-400 uppercase tracking-widest hover:border-indigo-400 hover:text-indigo-600 transition-all group">
                            <i data-lucide="plus-circle" class="w-4 h-4 group-hover:scale-110 transition-transform"></i>
                            Insert New Spacer
                         </button>
                    </div>
                </div>

                <!-- Sortable Library -->
                <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js" nonce="<%= nonce %>"></script>

                <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-4">
                    <button type="button" id="refreshBtn" onclick="window.refreshPreview()" class="px-6 py-2.5 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 uppercase tracking-widest hover:bg-slate-50 transition-all">
                        Refresh Preview
                    </button>
                    <button type="submit" class="px-8 py-2.5 bg-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-800 hover:shadow-lg transition-all shadow-md">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Preview Column -->
        <div class="sticky top-10">
            <div class="bg-slate-900 rounded-[2rem] shadow-2xl overflow-hidden border border-slate-800">
                <div class="bg-slate-800/50 px-6 py-4 flex justify-between items-center border-b border-slate-700">
                    <div class="flex items-center gap-6">
                         <div class="flex gap-1.5">
                             <div class="w-3 h-3 rounded-full bg-red-500"></div>
                             <div class="w-3 h-3 rounded-full bg-amber-500"></div>
                             <div class="w-3 h-3 rounded-full bg-green-500"></div>
                         </div>
                         
                         <!-- Zoom Controls -->
                         <div class="flex items-center bg-slate-900 rounded-lg p-1 border border-slate-700">
                             <button type="button" onclick="window.zoomIn()" class="p-1.5 text-slate-400 hover:text-white transition-colors" title="Zoom In">
                                 <i data-lucide="zoom-in" class="w-4 h-4"></i>
                             </button>
                             <button type="button" onclick="window.resetZoom()" class="px-2 text-[10px] font-bold text-slate-500 hover:text-white transition-colors border-x border-slate-700" id="zoomPercent">
                                 100%
                             </button>
                             <button type="button" onclick="window.zoomOut()" class="p-1.5 text-slate-400 hover:text-white transition-colors" title="Zoom Out">
                                 <i data-lucide="zoom-out" class="w-4 h-4"></i>
                             </button>
                         </div>
                    </div>

                    <div class="flex items-center gap-3">
                        <select id="previewTypeSelect" class="bg-slate-800 text-slate-300 text-xs font-bold uppercase border border-slate-600 rounded px-2 py-1 outline-none focus:border-blue-500" onchange="window.refreshPreview()">
                            <option value="invoice" <%= manifest.type === 'INVOICE' ? 'selected' : '' %>>Invoice</option>
                            <option value="receipt" <%= manifest.type === 'RECEIPT' ? 'selected' : '' %>>Receipt</option>
                            <option value="quote" <%= manifest.type === 'QUOTE' ? 'selected' : '' %>>Quote</option>
                            <option value="credit_memo" <%= manifest.type === 'CREDIT_MEMO' ? 'selected' : '' %>>Credit Memo</option>
                        </select>

                        <button type="button" 
                                id="downloadPdfBtn"
                                data-app-id="<%= appId %>"
                                data-api-key="<%= apiKey %>"
                                onclick="window.downloadPdf()" 
                                class="flex items-center gap-2 px-4 py-1.5 bg-indigo-600 text-white rounded-lg text-[11px] font-bold uppercase tracking-wider hover:bg-indigo-500 transition-all shadow-lg active:scale-95">
                            <i data-lucide="download" class="w-3.5 h-3.5"></i>
                            PDF
                        </button>
                    </div>
                </div>
                
                <div id="previewContainer" class="relative w-full bg-gray-50 overflow-auto h-[800px]">
                    <iframe id="previewFrame" 
                            name="previewFrame"
                            src="/dashboard/brand/preview?templateId=<%= manifest.id %>&type=<%= manifest.type %>" 
                            class="absolute top-0 left-0 origin-top-left border-none shadow-lg"
                            style="width: 100%; height: 100%;" 
                            sandbox="allow-scripts allow-forms allow-same-origin"></iframe>
                </div>
            </div>
            
             <form id="previewHiddenForm" action="/dashboard/brand/preview" method="POST" target="previewFrame" class="hidden">
                 <input type="hidden" name="templateId" id="previewFormTemplateId">
                 <input type="hidden" name="type" id="previewFormType">
                 <input type="hidden" name="components" id="previewFormComponents">
                 <input type="hidden" name="brandColors" id="previewFormColors">
                 <input type="hidden" name="tagline" id="previewFormTagline">
                 <input type="hidden" name="companyName" id="previewFormCompanyName">
                 <input type="hidden" name="layoutOrder" id="previewFormLayoutOrder">
            </form>
            <p class="text-center text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-4">
                Desktop View • Scaled to Fit
            </p>
        </div>
    </div>
</div>

<!-- Load Monaco Editor via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>

<script nonce="<%= nonce %>">
window.BrandEditor = {
    currentZoom: 1.0,
    debounceTimer: null,
    previewDebounce: null,
    sortableInstance: null,

    init() {
        console.log('🏁 [BrandEditor] Initializing...');
        if (typeof lucide !== 'undefined') lucide.createIcons();
        
        const previewFrame = document.getElementById('previewFrame');
        if (previewFrame) {
            previewFrame.addEventListener('load', () => this.updatePreviewScale());
            window.addEventListener('resize', () => this.updatePreviewScale());
            this.updatePreviewScale();
        }

        const widgetList = document.getElementById('sortableWidgetList');
        if (widgetList && typeof Sortable !== 'undefined') {
            console.log('✅ [BrandEditor] Sortable found, initializing...');
            this.sortableInstance = new Sortable(widgetList, {
                animation: 150,
                handle: '.drag-handle',
                ghostClass: 'bg-indigo-50',
                filter: '.locked-widget',
                onEnd: () => {
                    console.log('🖱️ [BrandEditor] Drag end detected');
                    this.updateLayoutOrderInput();
                    this.triggerAutoSave();
                }
            });
            this.updateLayoutOrderInput();
        } else {
            console.warn('⚠️ [BrandEditor] Sortable NOT initialized. List:', !!widgetList, 'Sortable:', typeof Sortable);
        }

        document.querySelectorAll('.component-toggle').forEach(t => t.addEventListener('change', () => this.triggerAutoSave()));
        
        const brandForm = document.getElementById('brandForm');
        if (brandForm) {
            brandForm.addEventListener('submit', (e) => {
                e.preventDefault();
                this.saveToDatabase();
            });
        }
    },

    triggerAutoSave() {
        const btn = document.querySelector('button[type="submit"]');
        if(btn) btn.innerHTML = '<i class="animate-spin w-3 h-3 border-2 border-slate-400 border-t-transparent rounded-full mr-2"></i>Syncing...';
        
        clearTimeout(this.previewDebounce);
        this.previewDebounce = setTimeout(() => this.updateLivePreview(), 400);

        clearTimeout(this.debounceTimer);
        this.debounceTimer = setTimeout(() => this.saveToDatabase(), 2000);
    },

    updatePreviewScale() {
        const container = document.getElementById('previewContainer');
        const iframe = document.getElementById('previewFrame');
        if (!container || !iframe) return;
        const bw = 1024;
        const scale = Math.min(1, container.offsetWidth / bw) * this.currentZoom;
        iframe.style.width = bw + 'px';
        iframe.style.height = '2500px';
        iframe.style.transform = `scale(${scale})`;
        iframe.style.transformOrigin = 'top left';
        iframe.style.left = Math.max(0, (container.offsetWidth - (bw * scale)) / 2) + 'px';
        const z = document.getElementById('zoomPercent');
        if(z) z.innerText = Math.round(this.currentZoom * 100) + '%';
    },

    zoomIn() { if(this.currentZoom < 2) { this.currentZoom += 0.1; this.updatePreviewScale(); } },
    zoomOut() { if(this.currentZoom > 0.5) { this.currentZoom -= 0.1; this.updatePreviewScale(); } },
    resetZoom() { this.currentZoom = 1.0; this.updatePreviewScale(); },

    updateLayoutOrderInput() {
        const order = Array.from(document.querySelectorAll('.widget-item')).map(el => el.getAttribute('data-id'));
        const input = document.getElementById('layoutOrderInput');
        if (input) input.value = JSON.stringify(order);
    },

    addSpacer() {
        const list = document.getElementById('sortableWidgetList');
        if(!list) return;
        const id = `spacer_${Date.now()}`;
        const html = `
            <div class="widget-item p-2 bg-white rounded-xl border border-indigo-50 shadow-sm mb-3 group transition-all hover:shadow-md h-[80px]" data-id="${id}" data-type="spacer">
                <div class="flex items-center justify-between mb-2">
                    <div class="flex items-center gap-3">
                        <div class="drag-handle cursor-grab p-1 text-slate-300 hover:text-slate-500 rounded hover:bg-slate-100"><i data-lucide="grip-vertical" class="w-4 h-4"></i></div>
                        <h4 class="text-xs font-bold text-slate-700">Spacer</h4>
                    </div>
                    <button type="button" onclick="this.closest('.widget-item').remove(); window.triggerAutoSave();" class="text-slate-300 hover:text-red-500 p-1"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
                    <input type="checkbox" class="component-toggle sr-only" checked>
                </div>
                <div class="flex items-center justify-between gap-4 px-2">
                    <span class="text-[10px] font-bold text-slate-500 uppercase">Height (px)</span>
                    <input type="number" value="20" class="component-value-input w-16 px-1.5 py-1 text-right bg-white border border-slate-200 rounded text-xs" oninput="window.triggerAutoSave()">
                </div>
            </div>`;
        const footer = list.querySelector('[data-id="footer"]');
        const div = document.createElement('div');
        div.innerHTML = html.trim();
        const el = div.firstChild;
        if(footer) list.insertBefore(el, footer); else list.appendChild(el);
        if(typeof lucide !== 'undefined') lucide.createIcons();
        this.updateLayoutOrderInput();
        this.triggerAutoSave();
    },

    updateLivePreview() {
        const hiddenForm = document.getElementById('previewHiddenForm');
        if(!hiddenForm) return;
        const comps = {};
        const order = [];
        document.querySelectorAll('.widget-item').forEach(item => {
            const id = item.getAttribute('data-id');
            const type = item.getAttribute('data-type');
            const toggle = item.querySelector('.component-toggle');
            const enabled = toggle ? toggle.checked : true;
            comps[id] = { enabled };
            if (type === 'input' || type === 'spacer') {
                comps[id].value = parseInt(item.querySelector('.component-value-input')?.value || 20);
            }
            order.push(id);
        });

        document.getElementById('previewFormTemplateId').value = document.getElementById('invoiceTemplateId').value;
        document.getElementById('previewFormType').value = document.getElementById('previewTypeSelect').value;
        document.getElementById('previewFormComponents').value = JSON.stringify(comps);
        document.getElementById('previewFormLayoutOrder').value = JSON.stringify(order);
        hiddenForm.submit();
    },

    async saveToDatabase() {
        const comps = {};
        const order = [];
        document.querySelectorAll('.widget-item').forEach(item => {
            const id = item.getAttribute('data-id');
            const toggle = item.querySelector('.component-toggle');
            comps[id] = { enabled: toggle ? toggle.checked : true };
            if(item.getAttribute('data-type') === 'spacer') {
                comps[id].value = parseInt(item.querySelector('.component-value-input')?.value || 20);
            }
            order.push(id);
        });

        const payload = {
            activeTemplateId: document.getElementById('invoiceTemplateId').value,
            components: comps,
            layoutOrder: order
        };

        try {
            const res = await fetch('/dashboard/brand/settings?format=json', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify(payload)
            });
            if (res.ok) {
                const btn = document.querySelector('button[type="submit"]');
                if(btn) { btn.textContent = 'Saved'; setTimeout(() => btn.textContent = 'Save Changes', 2000); }
            }
        } catch (e) { console.error('Save error', e); }
    }
};

window.triggerAutoSave = () => window.BrandEditor.triggerAutoSave();
window.zoomIn = () => window.BrandEditor.zoomIn();
window.zoomOut = () => window.BrandEditor.zoomOut();
window.resetZoom = () => window.BrandEditor.resetZoom();
window.addSpacer = () => window.BrandEditor.addSpacer();
window.refreshPreview = () => window.BrandEditor.updateLivePreview();
window.downloadPdf = () => alert('PDF export context restricted in preview refactor.');

document.addEventListener('DOMContentLoaded', () => window.BrandEditor.init());
</script>
