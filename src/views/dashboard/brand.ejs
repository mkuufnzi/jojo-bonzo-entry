<%- layout('layouts/dashboard-layout') %>

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-center mb-10">
        <div>
            <h1 class="text-3xl font-heading font-black text-slate-900 tracking-tight">Brand Standards</h1>
            <p class="text-slate-500 font-medium">Define your visual identity for all generated documents.</p>
        </div>
        <% if (locals.success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="check-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.success %>
            </div>
        <% } %>
        <% if (locals.error) { %>
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-2 rounded-xl text-sm font-bold flex items-center shadow-sm">
                <i data-lucide="alert-circle" class="w-4 h-4 mr-2"></i>
                <%= locals.error %>
            </div>
        <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
        <!-- Editor Column -->
        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-200 p-8">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center gap-2">
                <i data-lucide="sliders" class="w-4 h-4"></i>
                Configuration
            </h3>
            
            <form action="/dashboard/brand/update" method="POST" id="brandForm" class="space-y-8">
                
                 <!-- Template Selection (New) -->
                 <div>
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-lg font-black text-slate-900 flex items-center gap-2">
                            <i data-lucide="layout-template" class="w-5 h-5 text-purple-500"></i>
                            Template Design
                        </h2>
                        <button type="button" id="openAiModalBtn" class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 text-white px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wide hover:shadow-lg transition-all flex items-center gap-2">
                            <i data-lucide="sparkles" class="w-3 h-3"></i>
                            Generate New
                        </button>
                    </div>

                    <!-- Template ID Hidden Input -->
                    <!-- We store the selected template ID here (either 'rec_minimal' or 'custom:UUID') -->
                    <!-- Note: For MVP we might need to add this field to the DB schema or reuse 'templates' JSON storage logic -->
                    <!-- Let's assume we repurposed the 'templates' JSON to store { invoice: 'custom:uuid' } -->
                    <input type="hidden" name="templates[invoice]" id="invoiceTemplateId" value="<%= (profile.templates && profile.templates.invoice) || 'invoice_standard' %>">

                     <div class="grid grid-cols-2 gap-4">
                        <div class="border-2 border-slate-200 rounded-xl p-4 cursor-pointer hover:border-blue-500 transition-all text-center template-card" data-id="invoice_standard">
                            <div class="bg-slate-100 rounded-lg h-24 mb-3 flex items-center justify-center">
                                <span class="text-slate-400 font-bold text-xs">Standard</span>
                            </div>
                            <span class="text-xs font-bold text-slate-700">Classic Clean</span>
                        </div>
                        
                        <!-- Dynamic Custom Templates would be listed here -->
                        <% if (locals.userTemplates && locals.userTemplates.length > 0) { %>
                            <% locals.userTemplates.forEach(t => { %>
                                <div class="border-2 border-purple-200 bg-purple-50/30 rounded-xl p-4 cursor-pointer hover:border-purple-500 transition-all text-center template-card relative" data-id="custom:<%= t.id %>">
                                    <div class="absolute top-2 right-2 flex gap-1">
                                        <button type="button" class="p-1 bg-white/90 rounded hover:bg-blue-50 text-blue-600 edit-code-btn" data-id="custom:<%= t.id %>" title="Edit Source Code">
                                            <i data-lucide="code-2" class="h-4 w-4"></i>
                                        </button>
                                        <div class="bg-purple-100 text-purple-700 text-[0.6rem] font-bold px-2 py-1 rounded flex items-center">
                                            <i data-lucide="sparkles" class="w-3 h-3 mr-1"></i> AI
                                        </div>
                                    </div>
                                    <div class="bg-white/50 rounded-lg h-24 mb-3 flex items-center justify-center overflow-hidden border border-purple-100">
                                         <span class="text-purple-400 font-bold text-[10px]"><%= t.name %></span>
                                    </div>
                                    <span class="text-xs font-bold text-slate-700 truncate block"><%= t.name %></span>
                                </div>
                            <% }); %>
                        <% } %>
                    </div>
                </div>

                <!-- Visual Identity -->
                <div>
                    <h2 class="text-lg font-black text-slate-900 mb-4 flex items-center gap-2">
                        <i data-lucide="palette" class="w-5 h-5 text-blue-500"></i>
                        Visual Identity
                    </h2>
                    
                    <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100 space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Primary Color</label>
                                <div class="flex items-center gap-3">
                                    <div class="relative w-10 h-10 rounded-xl overflow-hidden shadow-sm border border-slate-200">
                                        <input type="color" name="brandColors[primary]" 
                                            id="primaryColorPicker"
                                            value="<%= profile.brandColors?.primary || '#3b82f6' %>"
                                            class="absolute -top-2 -left-2 w-16 h-16 p-0 border-0 cursor-pointer">
                                    </div>
                                    <input type="text" id="primaryColorText" value="<%= profile.brandColors?.primary || '#3b82f6' %>" 
                                        class="w-full bg-white px-3 py-2 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Accent Color</label>
                                <div class="flex items-center gap-3">
                                    <div class="relative w-10 h-10 rounded-xl overflow-hidden shadow-sm border border-slate-200">
                                        <input type="color" name="brandColors[secondary]" 
                                            id="secondaryColorPicker"
                                            value="<%= profile.brandColors?.secondary || '#10b981' %>"
                                            class="absolute -top-2 -left-2 w-16 h-16 p-0 border-0 cursor-pointer">
                                    </div>
                                    <input type="text" id="secondaryColorText" value="<%= profile.brandColors?.secondary || '#10b981' %>" 
                                        class="w-full bg-white px-3 py-2 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all">
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Typography</label>
                            <div class="relative">
                                <i data-lucide="type" class="absolute left-3 top-2.5 w-4 h-4 text-slate-400"></i>
                                <select name="fontSettings[heading]" id="fontSelect"
                                        class="w-full bg-white pl-10 pr-4 py-2 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 appearance-none">
                                    <option value="Inter" <%= profile.fontSettings?.heading === 'Inter' ? 'selected' : '' %>>Inter (Modern Sans)</option>
                                    <option value="Times New Roman" <%= profile.fontSettings?.heading === 'Times New Roman' ? 'selected' : '' %>>Times New Roman (Classic Serif)</option>
                                    <option value="Courier New" <%= profile.fontSettings?.heading === 'Courier New' ? 'selected' : '' %>>Courier New (Technical)</option>
                                    <option value="Arial" <%= profile.fontSettings?.heading === 'Arial' ? 'selected' : '' %>>Arial (Universal)</option>
                                </select>
                            </div>
                        </div>

                        <div>
                             <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Logo URL</label>
                             <div class="relative">
                                 <i data-lucide="image" class="absolute left-3 top-2.5 w-4 h-4 text-slate-400"></i>
                                 <input type="url" name="logoUrl" value="<%= profile.logoUrl || '' %>"
                                        placeholder="https://example.com/logo.png"
                                        class="w-full bg-white pl-10 pr-4 py-2 rounded-xl border border-slate-200 text-sm font-bold text-slate-700 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 placeholder:font-normal">
                             </div>
                             <p class="text-[0.625rem] font-bold text-slate-400 mt-2 uppercase tracking-wide">Hosted image links only for now</p>
                        </div>
                    </div>
                </div>

                <!-- Functional Branding -->
                <div>
                     <h2 class="text-lg font-black text-slate-900 mb-4 flex items-center gap-2">
                        <i data-lucide="server-cog" class="w-5 h-5 text-indigo-500"></i>
                        Metadata & Ops
                     </h2>
                     
                     <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100 space-y-6">
                         <!-- Upsell -->
                         <div class="flex flex-col gap-4">
                             <div class="flex items-center justify-between">
                                 <label class="font-bold text-sm text-slate-700">Upsell Module</label>
                                 <div class="flex items-center">
                                     <input type="checkbox" name="upsellConfig[enabled]" id="upsellToggle" value="true"
                                            <%= profile.upsellConfig?.enabled ? 'checked' : '' %>
                                            class="w-5 h-5 text-blue-600 rounded focus:ring-blue-500 border-slate-300">
                                     <span class="ml-2 text-xs font-bold text-slate-500 uppercase tracking-widest">Active</span>
                                 </div>
                             </div>
                             <div id="upsellFields" class="<%= profile.upsellConfig?.enabled ? '' : 'hidden' %> bg-white p-4 rounded-xl border border-slate-200">
                                 <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">Coupon Code</label>
                                 <input type="text" name="upsellConfig[coupon]" id="couponInput" value="<%= profile.upsellConfig?.coupon || '' %>"
                                        class="w-full px-3 py-2 rounded-lg border border-slate-200 text-sm font-bold text-slate-700 focus:border-blue-500 outline-none">
                             </div>
                         </div>

                         <!-- Support -->
                         <div>
                            <label class="block font-bold text-sm text-slate-700 mb-2">Support Contact Email</label>
                            <div class="relative">
                                <i data-lucide="mail" class="absolute left-3 top-2.5 w-4 h-4 text-slate-400"></i>
                                <input type="email" name="supportConfig[email]" placeholder="support@yourcompany.com"
                                       id="supportEmailInput"
                                       value="<%= profile.supportConfig?.email || '' %>"
                                       class="w-full pl-10 pr-4 py-2 rounded-xl border border-slate-200 text-sm text-slate-700 font-bold focus:border-blue-500 outline-none">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-4">
                    <button type="button" id="refreshBtn" class="px-6 py-2.5 border border-slate-200 rounded-xl text-xs font-bold text-slate-600 uppercase tracking-widest hover:bg-slate-50 transition-all">
                        Refresh Preview
                    </button>
                    <button type="submit" class="px-8 py-2.5 bg-slate-900 text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-slate-800 hover:shadow-lg transition-all shadow-md">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- Preview Column -->
        <div class="sticky top-10">
            <div class="bg-slate-900 rounded-[2rem] shadow-2xl overflow-hidden border border-slate-800">
                <div class="bg-slate-800/50 px-6 py-4 flex justify-between items-center border-b border-slate-700">
                    <div class="flex items-center gap-2">
                         <div class="flex gap-1.5">
                             <div class="w-3 h-3 rounded-full bg-red-500"></div>
                             <div class="w-3 h-3 rounded-full bg-amber-500"></div>
                             <div class="w-3 h-3 rounded-full bg-green-500"></div>
                         </div>
                         <span class="ml-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Live Preview</span>
                    </div>
                    <select id="previewTypeSelect" class="bg-slate-800 text-slate-300 text-xs font-bold uppercase border border-slate-600 rounded px-2 py-1 outline-none focus:border-blue-500">
                        <option value="invoice">Invoice</option>
                        <option value="receipt">Receipt</option>
                        <option value="estimate">Estimate</option>
                    </select>
                </div>
                <!-- Iframe Wrapper for Aspect Ratio -->
                <div class="relative w-full aspect-[1/1.4] bg-white">
                    <iframe id="previewFrame" src="/dashboard/brand/preview" class="absolute inset-0 w-full h-full" sandbox="allow-same-origin allow-scripts allow-forms"></iframe>
                </div>
            </div>
            <p class="text-center text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest mt-4">
                Changes may require a save to reflect in preview
            </p>
        </div>
    </div>
    <!-- Code Editor Modal -->
    <div id="editorModal" class="hidden fixed inset-0 z-[60] overflow-hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="absolute inset-0 bg-slate-900 bg-opacity-90 transition-opacity backdrop-blur-sm" id="editorModalBackdrop"></div>
        
        <div class="fixed inset-4 bg-slate-900 rounded-xl shadow-2xl overflow-hidden flex flex-col border border-slate-700">
            <!-- Header -->
            <div class="bg-slate-800 px-6 py-4 flex items-center justify-between border-b border-slate-700">
                <div class="flex items-center gap-3">
                    <div class="p-2 bg-blue-500/10 rounded-lg">
                        <i data-lucide="code-2" class="h-5 w-5 text-blue-400"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-slate-100">Template Source Editor</h3>
                        <p class="text-xs text-slate-400" id="editorTemplateName">Editing: Custom Template</p>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <span class="text-xs text-amber-500 bg-amber-500/10 px-3 py-1.5 rounded-full border border-amber-500/20 flex items-center gap-1.5">
                        <i data-lucide="alert-triangle" class="h-3 w-3"></i>
                        Advanced Mode
                    </span>
                    <button type="button" id="closeEditorBtn" class="p-2 text-slate-400 hover:text-white rounded-lg hover:bg-slate-700 transition-colors">
                        <i data-lucide="x" class="h-5 w-5"></i>
                    </button>
                </div>
            </div>

            <!-- Editor Body -->
            <div class="flex-1 bg-[#1e1e1e] relative">
                <div id="monaco-container" class="absolute inset-0"></div>
            </div>

            <!-- Footer -->
            <div class="bg-slate-800 px-6 py-4 border-t border-slate-700 flex justify-between items-center">
                <div class="flex items-center gap-4 text-xs text-slate-400">
                     <div class="flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                        EJS / HTML5
                     </div>
                     <div>Ln <span id="cursorLine">1</span>, Col <span id="cursorCol">1</span></div>
                </div>
                <div class="flex items-center gap-3">
                    <button type="button" class="px-4 py-2 text-sm font-medium text-slate-300 hover:text-white transition-colors" onclick="document.getElementById('editorModal').classList.add('hidden')">
                        Discard Changes
                    </button>
                    <button type="button" id="saveCodeBtn" class="flex items-center gap-2 px-5 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-lg text-sm font-medium shadow-lg shadow-blue-500/20 transition-all">
                        <i data-lucide="save" class="h-4 w-4"></i>
                        Save Template
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Load Monaco Editor via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>

<script nonce="<%= nonce %>">
document.addEventListener('DOMContentLoaded', () => {
    // Icons
    if (typeof lucide !== 'undefined') lucide.createIcons();

    const form = document.getElementById('brandForm');
    const previewFrame = document.getElementById('previewFrame');
    const saveBtn = document.querySelector('button[type="submit"]'); // Define globally for this scope

    // ... existing vars ...
    
    // Monaco Init
    let editor = null;
    require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs' }});

    const initEditor = (initialValue) => {
        if(editor) return editor.setValue(initialValue);
        
        require(['vs/editor/editor.main'], function() {
            editor = monaco.editor.create(document.getElementById('monaco-container'), {
                value: initialValue,
                language: 'html', // html handles embedded css/js well enough for EJS
                theme: 'vs-dark',
                automaticLayout: true,
                minimap: { enabled: true },
                fontSize: 14,
                fontFamily: "'JetBrains Mono', 'Fira Code', Consolas, monospace",
                lineHeight: 1.5,
                padding: { top: 20 }
            });

            // Update status bar
            editor.onDidChangeCursorPosition((e) => {
                document.getElementById('cursorLine').textContent = e.position.lineNumber;
                document.getElementById('cursorCol').textContent = e.position.column;
            });
        });
    }

    // Edit Button Logic (Delegation)
    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.edit-code-btn');
        if(!btn) return;
        
        e.stopPropagation(); // Prevent card selection
        e.preventDefault();

        const templateId = btn.getAttribute('data-id');
        const isCustom = templateId.startsWith('custom:');
        
        // Show Modal
        const modal = document.getElementById('editorModal');
        modal.classList.remove('hidden');
        document.getElementById('editorTemplateName').textContent = `ID: ${templateId}`;
        document.getElementById('saveCodeBtn').setAttribute('data-id', templateId);

        // Fetch Source
        // For custom, we can fetch from an endpoint. For standard... we might just show "Read Only" or fetch the standard render?
        // Let's implement an endpoint: GET /api/branding/template/:id/source
        try {
            const res = await fetch(`/api/branding/template/${templateId}/source`);
            const data = await res.json();
            
            if(data.source) {
                 initEditor(data.source);
            } else {
                 initEditor('<!-- Could not load source -->');
            }
        } catch(err) {
            console.error(err);
            initEditor('<!-- Error loading source -->');
        }
    });

    // Close Logic
    const closeEditor = () => document.getElementById('editorModal').classList.add('hidden');
    document.getElementById('closeEditorBtn').addEventListener('click', closeEditor);
    document.getElementById('editorModalBackdrop').addEventListener('click', closeEditor);

    // Save Logic
    document.getElementById('saveCodeBtn').addEventListener('click', async () => {
        if(!editor) return;
        const code = editor.getValue();
        const templateId = document.getElementById('saveCodeBtn').getAttribute('data-id');
        const btn = document.getElementById('saveCodeBtn');

        btn.disabled = true;
        btn.innerHTML = '<i class="animate-spin" data-lucide="loader-2"></i> Saving...';
        if(typeof lucide !== 'undefined') lucide.createIcons();

        try {
            const res = await fetch(`/api/branding/template/${templateId}/source`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ htmlContent: code })
            });
            const data = await res.json();
            
            if(data.success) {
                // Refresh Preview
                const previewFrame = document.getElementById('previewFrame');
                if(previewFrame) previewFrame.src = previewFrame.src; // Reload iframe
                closeEditor();
                // Show toast?
            } else {
                alert('Save failed: ' + data.error);
            }
        } catch(e) {
            alert('Error saving template');
        } finally {
             btn.disabled = false;
             btn.innerHTML = '<i data-lucide="save"></i> Save Template';
             if(typeof lucide !== 'undefined') lucide.createIcons();
        }
    });

    // ... existing JS ... (AI Modal, etc)

    // Template Card Selection
    const cards = document.querySelectorAll('.template-card');
    const templateInput = document.getElementById('invoiceTemplateId');

    cards.forEach(card => {
        card.addEventListener('click', () => {
            // Remove selection from all
            cards.forEach(c => c.classList.remove('ring-2', 'ring-blue-500', 'bg-blue-50'));
            
            // Add to clicked
            card.classList.add('ring-2', 'ring-blue-500', 'bg-blue-50');
            
            // Update Hidden Input
            const id = card.getAttribute('data-id');
            if(templateInput) templateInput.value = id;

            // Trigger Save & Preview
            triggerAutoSave();
        });
    });

    // Toggle Upsell
    const upsellToggle = document.getElementById('upsellToggle');
    const upsellFields = document.getElementById('upsellFields');
    
    if (upsellToggle && upsellFields) {
        upsellToggle.addEventListener('change', (e) => {
            if (e.target.checked) {
                upsellFields.classList.remove('hidden');
            } else {
                upsellFields.classList.add('hidden');
            }
            triggerAutoSave();
        });
    }

    // Color Pickers Sync
    const setupColorSync = (pickerId, textId) => {
        const picker = document.getElementById(pickerId);
        const text = document.getElementById(textId);
        if (picker && text) {
            picker.addEventListener('input', (e) => {
                text.value = e.target.value;
                triggerAutoSave();
            });
            text.addEventListener('input', (e) => {
                picker.value = e.target.value;
                triggerAutoSave();
            });
        }
    };

    setupColorSync('primaryColorPicker', 'primaryColorText');
    setupColorSync('secondaryColorPicker', 'secondaryColorText');

    // Font Helper
    const fontSelect = document.getElementById('fontSelect');
    if (fontSelect) {
        fontSelect.addEventListener('change', triggerAutoSave);
    }

    // Refresh Button logic (manual refresh)
    const refreshBtn = document.getElementById('refreshBtn');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', () => {
            refreshPreview();
        });
    }

    // Inputs Auto-Save
    ['couponInput', 'supportEmailInput'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.addEventListener('input', triggerAutoSave);
    });
    
    // Logo URL Auto-Save
    const logoInput = document.querySelector('input[name="logoUrl"]');
    if(logoInput) logoInput.addEventListener('input', triggerAutoSave);


    // ============================================================
    // LIVE PREVIEW LOGIC
    // ============================================================
    let debounceTimer;
    
    function triggerAutoSave() {
        // Visual indicator
        if(saveBtn) saveBtn.textContent = 'Saving...';
        
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            saveAndRefresh();
        }, 800); // 800ms debounce
    }

    async function saveAndRefresh() {
        if(!form) return;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        // Handle nested or special fields if necessary, but backend expects body.
        // Actually, JSON body is cleaner for the Controller logic we wrote.
        // We need to construct the JSON object correctly matching the nested structure.
        
        // Construct detailed JSON payload manually to match Service expectations
        const payload = {
            brandColors: {
                primary: document.getElementById('primaryColorText').value,
                secondary: document.getElementById('secondaryColorText').value
            },
            fontSettings: {
                heading: document.getElementById('fontSelect').value
            },
            logoUrl: document.querySelector('input[name="logoUrl"]').value,
            upsellConfig: {
                enabled: document.getElementById('upsellToggle').checked,
                coupon: document.getElementById('couponInput').value
            },
            supportConfig: {
                email: document.getElementById('supportEmailInput').value
            }
        };

        try {
            const response = await fetch('/dashboard/brand/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                if(saveBtn) saveBtn.textContent = 'Saved';
                setTimeout(() => { if(saveBtn) saveBtn.textContent = 'Save Changes'; }, 2000);
                refreshPreview();
            } else {
                console.error('Save failed');
                if(saveBtn) saveBtn.textContent = 'Error';
            }
        } catch (e) {
            console.error('Auto-save error', e);
        }
    }

    function refreshPreview() {
        if (previewFrame) {
            // Reload iframe with selected type
            const type = document.getElementById('previewTypeSelect').value || 'invoice';
            const currentSrc = new URL(previewFrame.src, window.location.origin); // Ensure base URL
            currentSrc.searchParams.set('t', Date.now()); // bust cache
            currentSrc.searchParams.set('type', type);
            previewFrame.src = currentSrc.toString();
        }
    }

    // AI Generation / n8n Webhook Logic
    const generateBtn = document.getElementById('openAiModalBtn');
    if (generateBtn) {
        generateBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            
            // UI State
            const originalText = generateBtn.innerHTML;
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<i class="animate-spin" data-lucide="loader-2"></i> Generatin...';
            if(typeof lucide !== 'undefined') lucide.createIcons();

            try {
                // 1. Gather Context
                const payload = {
                    type: document.getElementById('previewTypeSelect').value || 'invoice',
                    data: {
                        // Pass current form values as specific overrides if needed,
                        // otherwise backend uses saved profile.
                        // We'll pass the "draft" values so user sees immediate results.
                        colors: {
                            primary: document.getElementById('primaryColorText').value,
                            secondary: document.getElementById('secondaryColorText').value
                        },
                        font: document.getElementById('fontSelect').value
                    }
                };

                // 2. Call Service
                // maps to ServicesController.handleDynamicAction -> DesignEngine.executeAction
                const response = await fetch('/services/transactional-core/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();

                if (result.success && result.type === 'html') {
                    // 3. Render Result
                    const previewFrame = document.getElementById('previewFrame');
                    if (previewFrame) {
                        // Use srcdoc for immediate HTML rendering
                        previewFrame.removeAttribute('src'); // Clear URL source to prioritize srcdoc
                        previewFrame.srcdoc = result.content;
                        
                        // Show Success Toast/Label
                        // "Your Ugly Invoice" Label as requested
                        const label = document.createElement('div');
                        label.className = 'absolute top-4 left-1/2 transform -translate-x-1/2 bg-yellow-400 text-black font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg z-50 animate-bounce';
                        label.innerHTML = '✨ Your Ugly Invoice (n8n) ✨';
                        label.id = 'uglyLabel';
                        
                        // Remove old label if exists
                        const oldLabel = document.getElementById('uglyLabel');
                        if(oldLabel) oldLabel.remove();
                        
                        previewFrame.parentElement.appendChild(label);
                        setTimeout(() => label.remove(), 5000);
                    }
                } else {
                    alert('Generation completed but returned unexpected format: ' + JSON.stringify(result));
                }

            } catch (error) {
                console.error('Generation Error:', error);
                alert('Failed to generate document. Please try again.');
            } finally {
                generateBtn.disabled = false;
                generateBtn.innerHTML = originalText;
                if(typeof lucide !== 'undefined') lucide.createIcons();
            }
        });
    }

    // Type Selector Listener
    const typeSelect = document.getElementById('previewTypeSelect');
    if(typeSelect) {
        typeSelect.addEventListener('change', refreshPreview);
    }
});
</script>
