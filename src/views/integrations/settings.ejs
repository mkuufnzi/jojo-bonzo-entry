<%- layout('layouts/dashboard-layout') %>

<div class="px-6 py-8">
    
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <div class="flex items-center space-x-4">
            <div class="w-16 h-16 bg-white border rounded-xl flex items-center justify-center shadow-sm">
                <% if (integrationDefinition.logoUrl) { %>
                    <img src="<%= integrationDefinition.logoUrl %>" class="w-10 h-10 object-contain">
                <% } else { %>
                    <span class="text-xl font-bold text-gray-400"><%= provider.substring(0,2).toUpperCase() %></span>
                <% } %>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-gray-900"><%= integrationDefinition.name %> Integration</h1>
                <div class="flex items-center mt-1">
                    <span class="w-2.5 h-2.5 bg-green-500 rounded-full mr-2"></span>
                    <span class="text-sm text-green-700 font-medium">Connected</span>
                    <span class="mx-2 text-gray-300">•</span>
                    <span class="text-sm text-gray-500">Last Synced: Never</span>
                </div>
            </div>
        </div>
        <div class="flex space-x-3">
            <a href="/onboarding/api/integrations/<%= provider %>/connect" class="bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors inline-block">
                Re-connect
            </a>
            <form method="POST" action="/dashboard/connections/<%= provider %>/disconnect" 
                  onsubmit="return confirm('Are you sure you want to disconnect <%= integrationDefinition.name %>? This action cannot be undone.');" class="inline">
                <button type="submit" class="bg-red-50 border border-red-200 text-red-600 hover:bg-red-100 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                    Disconnect
                </button>
            </form>
        </div>
    </div>

    <!-- Layout -->
    <div class="grid grid-cols-12 gap-8" x-data="{ 
        activeTab: 'settings', 
        loading: false,
        previewData: null,
        lastSynced: null,
        fetchPreview(force = false) {
            const entity = document.getElementById('previewEntity').value;
            this.loading = true;
            this.previewData = null;
            
            const url = `/dashboard/connections/<%= provider %>/preview?entity=${entity}${force ? '&refresh=true' : ''}`;
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    this.previewData = data;
                    this.loading = false;
                    if (data && data.length > 0) {
                        this.lastSynced = new Date(data[0].syncedAt || Date.now()).toLocaleTimeString();
                    }
                })
                .catch(err => {
                    this.previewData = { error: err.message };
                    this.loading = false;
                });
        },
        getHeaders() {
            const entity = document.getElementById('previewEntity')?.value || 'invoices';
            const configs = {
                'invoices': { ref: 'Inv #', name: 'Customer', val: 'Total' },
                'items': { ref: 'SKU / Code', name: 'Item Name', val: 'Rate' },
                'contacts': { ref: 'ID', name: 'Contact Name', val: 'Type' },
                'customers': { ref: 'ID', name: 'Customer Name', val: 'Phone' },
                'salesorders': { ref: 'SO #', name: 'Customer', val: 'Total' },
                'purchaseorders': { ref: 'PO #', name: 'Vendor', val: 'Total' },
                'bills': { ref: 'Bill #', name: 'Vendor', val: 'Total' },
                'payments': { ref: 'Payment #', name: 'Customer', val: 'Amount' }
            };
            return configs[entity] || { ref: 'Reference', name: 'Identity', val: 'Value' };
        }
    }">
        
        <!-- Sidebar Navigation -->
        <div class="col-span-3">
            <nav class="space-y-1">
                <button @click="activeTab = 'settings'" 
                        :class="{'bg-blue-50 text-blue-700 border-blue-200': activeTab === 'settings', 'hover:bg-gray-50 text-gray-600 border-transparent': activeTab !== 'settings'}"
                        class="w-full flex items-center px-4 py-3 text-sm font-medium rounded-lg border transition-colors mb-2">
                    <svg class="w-5 h-5 mr-3" :class="activeTab === 'settings' ? 'text-blue-500' : 'text-gray-400'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Sync Settings
                </button>

                <button @click="activeTab = 'preview'" 
                        :class="{'bg-purple-50 text-purple-700 border-purple-200': activeTab === 'preview', 'hover:bg-gray-50 text-gray-600 border-transparent': activeTab !== 'preview'}"
                        class="w-full flex items-center px-4 py-3 text-sm font-medium rounded-lg border transition-colors">
                    <svg class="w-5 h-5 mr-3" :class="activeTab === 'preview' ? 'text-purple-500' : 'text-gray-400'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                    Data Preview
                </button>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="col-span-9">
            
            <!-- Tab: Settings -->
            <div x-show="activeTab === 'settings'" class="bg-white border rounded-xl shadow-sm p-6">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Allowed Data Objects</h2>
                <p class="text-sm text-gray-500 mb-6">Select which data tables you want <%= integrationDefinition.name %> to sync with Floovioo.</p>

                <form action="/dashboard/connections/<%= provider %>/config" method="POST">
                    <input type="hidden" name="_csrf" value="<%= nonce %>"> <!-- Using nonce as placeholder if needed, or implement CSRF properly -->
                    
                    <div class="space-y-4 mb-8">
                        
                        <!-- Global Config (QuickBooks Specific) -->
                        <% if (provider === 'quickbooks') { %>
                        <div class="p-5 border border-indigo-100 rounded-xl bg-indigo-50/50 mb-6">
                            <div class="flex items-start">
                                <div class="flex-shrink-0">
                                    <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </div>
                                <div class="ml-3 w-full">
                                    <h3 class="text-sm font-bold text-indigo-900">Webhook Configuration</h3>
                                    <div class="mt-2 text-sm text-indigo-700">
                                        <p class="mb-2">Enter the Verifier Token from your Intuit Developer Portal to enable secure event reception.</p>
                                    </div>
                                    <div class="mt-2">
                                        <label for="verifierToken" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Verifier Token</label>
                                        <input type="text" name="verifierToken" id="verifierToken"
                                            value="<%= (typeof serviceConfig !== 'undefined' && serviceConfig.verifierToken) ? serviceConfig.verifierToken : '' %>"
                                            class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2"
                                            placeholder="e.g. 45f7432c-...">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% } %>
                        
                        <!-- Toggle: Invoices -->
                        <div class="flex items-center justify-between p-4 border rounded-lg hover:bg-gray-50">
                            <div class="flex items-center">
                                <span class="bg-blue-100 text-blue-600 p-2 rounded-lg mr-4">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                </span>
                                <div>
                                    <h3 class="font-medium text-gray-900">Invoices</h3>
                                    <p class="text-xs text-gray-500">Sync sales invoices and status.</p>
                                </div>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" name="tables[]" value="invoices" class="sr-only peer" 
                                    <%= (settings.tables && settings.tables.includes('invoices')) ? 'checked' : '' %>>
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                            </label>
                        </div>


                        <!-- Toggle: Items -->
                        <div class="flex items-center justify-between p-4 border rounded-lg hover:bg-gray-50">
                             <div class="flex items-center">
                                 <span class="bg-pink-100 text-pink-600 p-2 rounded-lg mr-4">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
                                 </span>
                                 <div>
                                     <h3 class="font-medium text-gray-900">Items / Inventory</h3>
                                     <p class="text-xs text-gray-500">Sync products and services.</p>
                                 </div>
                             </div>
                             <label class="relative inline-flex items-center cursor-pointer">
                                 <input type="checkbox" name="tables[]" value="items" class="sr-only peer"
                                     <%= (settings.tables && settings.tables.includes('items')) ? 'checked' : '' %>>
                                 <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-600"></div>
                             </label>
                        </div>
                        
                        <!-- Toggle: Customers -->
                        <div class="flex items-center justify-between p-4 border rounded-lg hover:bg-gray-50">
                             <div class="flex items-center">
                                 <span class="bg-green-100 text-green-600 p-2 rounded-lg mr-4">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                                 </span>
                                 <div>
                                     <h3 class="font-medium text-gray-900">Customers / Contacts</h3>
                                     <p class="text-xs text-gray-500">Sync client details and addresses.</p>
                                 </div>
                             </div>
                             <label class="relative inline-flex items-center cursor-pointer">
                                 <input type="checkbox" name="tables[]" value="customers" class="sr-only peer"
                                     <%= (settings.tables && settings.tables.includes('customers')) ? 'checked' : '' %>>
                                 <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-green-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600"></div>
                             </label>
                        </div>

                        <!-- Toggle: Estimates -->
                        <div class="flex items-center justify-between p-4 border rounded-lg hover:bg-gray-50">
                             <div class="flex items-center">
                                 <span class="bg-amber-100 text-amber-600 p-2 rounded-lg mr-4">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                 </span>
                                 <div>
                                     <h3 class="font-medium text-gray-900">Estimates / Quotes</h3>
                                     <p class="text-xs text-gray-500">Sync estimates for proposal branding.</p>
                                 </div>
                             </div>
                             <label class="relative inline-flex items-center cursor-pointer">
                                 <input type="checkbox" name="tables[]" value="estimates" class="sr-only peer"
                                     <%= (settings.tables && settings.tables.includes('estimates')) ? 'checked' : '' %>>
                                 <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-amber-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-600"></div>
                             </label>
                        </div>
                        
                        <!-- Toggle: Sales Orders -->
                        <div class="flex items-center justify-between p-4 border rounded-lg hover:bg-gray-50">
                             <div class="flex items-center">
                                 <span class="bg-indigo-100 text-indigo-600 p-2 rounded-lg mr-4">
                                     <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                                 </span>
                                 <div>
                                     <h3 class="font-medium text-gray-900">Sales Orders</h3>
                                     <p class="text-xs text-gray-500">Sync confirmed orders.</p>
                                 </div>
                             </div>
                             <label class="relative inline-flex items-center cursor-pointer">
                                 <input type="checkbox" name="tables[]" value="salesorders" class="sr-only peer"
                                     <%= (settings.tables && settings.tables.includes('salesorders')) ? 'checked' : '' %>>
                                 <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-indigo-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                             </label>
                        </div>
                        <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors shadow-sm">
                            Save Configuration
                        </button>
                    </div>
                </form>
            </div>

            <!-- Tab: Preview -->
            <div x-show="activeTab === 'preview'" class="bg-white border rounded-xl shadow-sm p-6" style="display: none;">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-bold text-gray-900">Live Data Preview</h2>
                    <div class="flex space-x-2">
                        <select id="previewEntity" class="bg-gray-50 border border-gray-300 text-gray-700 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block px-3 py-2">
                            <option value="invoices">Invoices</option>
                            <option value="items">Items / Products</option>
                            <option value="estimates">Estimates</option>
                            <option value="salesorders">Sales Orders</option>
                            <option value="purchaseorders">Purchase Orders</option>
                            <option value="bills">Bills</option>
                            <option value="payments">Payments</option>
                            <option value="contacts">Contacts</option>
                        </select>
                        <button @click="fetchPreview(true)" class="bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 rounded-lg text-sm font-medium flex items-center shadow-sm">
                            <svg x-show="!loading" class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            <svg x-show="loading" class="animate-spin -ml-1 mr-3 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            Refresh Data
                        </button>
                    </div>
                </div>

                <div x-show="lastSynced" class="mb-4 text-xs text-gray-400 italic">
                    Showing cached results as of <span x-text="lastSynced" class="font-bold text-gray-500"></span>. Click Refresh for live sync.
                </div>

                <!-- Results -->
                <div class="bg-white border rounded-lg overflow-hidden min-h-[300px]">
                    <!-- Placeholder -->
                    <div x-show="!previewData && !loading" class="text-gray-400 text-center py-20 flex flex-col items-center">
                        <svg class="w-12 h-12 mb-3 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                        <p class="text-sm">Select an entity and click "Fetch Live Data" to test the connection.</p>
                    </div>

                    <!-- Loading State -->
                    <div x-show="loading" class="py-20 flex flex-col items-center">
                        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-purple-600"></div>
                        <p class="mt-4 text-sm text-gray-500">Fetching live data from <%= integrationDefinition.name %>...</p>
                    </div>

                    <!-- Success Toast -->
                    <% if (typeof success !== 'undefined' || (typeof req !== 'undefined' && req.query.success)) { %>
                    <div class="mb-6 bg-green-50 border border-green-200 text-green-700 p-4 rounded-xl flex items-center shadow-sm animate-pulse">
                        <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                        <span class="font-medium">Changes saved successfully!</span>
                    </div>
                    <% } %>

                    <!-- Error State -->
                    <div x-show="previewData?.error" class="bg-red-50 p-6 text-center">
                        <svg class="w-12 h-12 text-red-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        <h3 class="text-red-800 font-bold mb-1">Data Fetch Failed</h3>
                        <p class="text-red-600 text-sm" x-text="previewData?.error"></p>
                    </div>

                    <!-- Data Table -->
                    <div x-show="previewData && !previewData?.error && Array.isArray(previewData)" class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-gray-50 border-b border-gray-100">
                                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider" x-text="getHeaders().ref"></th>
                                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider" x-text="getHeaders().name"></th>
                                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Date</th>
                                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider" x-text="getHeaders().val"></th>
                                    <th class="px-6 py-3 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-50">
                                <template x-for="item in previewData" :key="item.id || item.externalId">
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="font-mono text-xs text-gray-600 bg-gray-100 px-2 py-1 rounded" x-text="item.externalId || item.number || item.id"></span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex flex-col">
                                                <span class="text-sm font-bold text-gray-900" x-text="item.contactName || item.customerName || item.name || 'N/A'"></span>
                                                <span class="text-xs text-gray-500 capitalize" x-text="item.type || 'unknown'"></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600" x-text="new Date(item.date).toLocaleDateString() || 'N/A'"></td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900" x-text="'£' + (item.total || item.amount || 0).toFixed(2)"></td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                                            <span :class="{
                                                'bg-green-100 text-green-700': ['paid', 'active', 'sent'].includes(item.status),
                                                'bg-amber-100 text-amber-700': ['pending', 'draft'].includes(item.status),
                                                'bg-gray-100 text-gray-700': !['paid', 'active', 'sent', 'pending', 'draft'].includes(item.status)
                                            }" class="px-2.5 py-1 rounded-full text-xs font-bold uppercase" x-text="item.status || 'unknown'"></span>
                                        </td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>

                    <!-- Raw JSON Toggle -->
                    <div x-show="previewData && !previewData.error" class="p-4 border-t bg-gray-50">
                        <details class="group">
                            <summary class="text-xs text-gray-500 cursor-pointer hover:text-blue-600 flex items-center">
                                <svg class="w-3 h-3 mr-1 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                View Raw JSON Response
                            </summary>
                            <pre class="mt-4 p-4 bg-gray-900 text-green-400 font-mono text-xs rounded-lg overflow-x-auto" x-text="JSON.stringify(previewData, null, 2)"></pre>
                        </details>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
