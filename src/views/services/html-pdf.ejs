            </div> <!-- Close max-w container -->
        </div> <!-- Close flex-1 wrapper -->


        
        <!-- Styles Extracted to /css/services/html-pdf.css -->

        <script nonce="<%= nonce %>">
            // ============================================================
            // SERVICE CONFIGURATION (Injected from server, sanitized)
            // Contains: actions, features, limits - NO sensitive data
            // ============================================================
            window.SERVICE_CONFIG = JSON.parse(decodeURIComponent("<%- encodeURIComponent(JSON.stringify(serviceConfig || {})) %>"));
            
            document.addEventListener('DOMContentLoaded', () => {
                // --- Navigation Tab Intelligence ---
                const serviceTabs = document.querySelectorAll('[data-service-tab]');
                const serviceTabContents = document.querySelectorAll('.service-tab-content');

                serviceTabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        const tabName = tab.dataset.serviceTab;
                        serviceTabContents.forEach(el => el.classList.add('hidden'));
                        
                        const targetContent = document.getElementById('tab-content-' + tabName);
                        if (targetContent) targetContent.classList.remove('hidden');

                        serviceTabs.forEach(btn => {
                            btn.classList.remove('nav-tab-active');
                            btn.classList.add('border-transparent', 'text-gray-400');
                        });

                        tab.classList.add('nav-tab-active');
                        tab.classList.remove('border-transparent', 'text-gray-400');
                    });
                });

                // Deep Link Resolution
                const urlParams = new URLSearchParams(window.location.search);
                const activeTab = urlParams.get('tab');
                if (activeTab) {
                    const tabBtn = document.querySelector(`[data-service-tab="${activeTab}"]`);
                    if (tabBtn) tabBtn.click();
                }

                // --- Sidebar Tab Logic ---
                const sidebarTabs = document.querySelectorAll('[data-sidebar-tab]');
                const sidebarContents = document.querySelectorAll('.sidebar-content');

                sidebarTabs.forEach(tab => {
                    tab.addEventListener('click', () => {
                        const target = tab.dataset.sidebarTab;
                        sidebarContents.forEach(c => c.classList.add('hidden'));
                        document.getElementById(`sidebar-tab-${target}`).classList.remove('hidden');
                        
                        sidebarTabs.forEach(t => {
                            t.classList.remove('sidebar-tab-active', 'text-blue-600', 'border-blue-600', 'bg-white');
                            t.classList.add('text-slate-400', 'border-transparent');
                        });
                        
                        tab.classList.add('sidebar-tab-active', 'text-blue-600', 'border-blue-600', 'bg-white');
                        tab.classList.remove('text-slate-400', 'border-transparent');
                    });
                });

                // --- Custom Select Synchronizers ---
                const sidebarAppId = document.getElementById('sidebarAppId');
                const syncAppId = document.getElementById('syncAppId');
                if (sidebarAppId && syncAppId) {
                    sidebarAppId.addEventListener('change', () => {
                        syncAppId.value = sidebarAppId.value;
                    });
                }

                // Paper dimension constants (at 96 DPI)
                window.PAPER_DIMENSIONS = {
                    A4: { portrait: { width: 794, height: 1123 }, landscape: { width: 1123, height: 794 } },
                    Letter: { portrait: { width: 816, height: 1056 }, landscape: { width: 1056, height: 816 } },
                    Legal: { portrait: { width: 816, height: 1344 }, landscape: { width: 1344, height: 816 } }
                };

                // Update canvas dimensions based on current format and orientation
                window.updateCanvasDimensions = function() {
                    const canvasArea = document.getElementById('previewCanvasArea');
                    if (!canvasArea) return;
                    
                    const format = document.getElementById('syncFormat')?.value || 'A4';
                    const isLandscape = document.getElementById('syncLandscape')?.value === 'true';
                    
                    // Update data attributes - CSS will handle the rest
                    canvasArea.dataset.format = format;
                    canvasArea.dataset.landscape = isLandscape.toString();
                    
                    // Recalculate fit after dimension change
                    setTimeout(() => window.fitToWidth(), 50);
                };

                window.selectFormat = (el, val) => {
                    document.getElementById('syncFormat').value = val;
                    document.querySelectorAll('.format-badge').forEach(b => {
                        b.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                        b.classList.add('border-slate-100', 'text-slate-400');
                    });
                    el.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                    el.classList.remove('border-slate-100', 'text-slate-400');
                    
                    // Update canvas dimensions
                    window.updateCanvasDimensions();
                };

                window.selectOrientation = (el, val) => {
                    document.getElementById('syncLandscape').value = val;
                    document.querySelectorAll('.orientation-badge').forEach(b => {
                        b.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                        b.classList.add('border-slate-100', 'text-slate-400');
                    });
                    el.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                    el.classList.remove('border-slate-100', 'text-slate-400');
                    
                    // Update canvas dimensions
                    window.updateCanvasDimensions();
                };

                // --- Analytics Visualization (Chart.js) ---
                (function() {
                    const dataElement = document.getElementById('usage-data');
                    if (!dataElement) return;

                    let dailyUsage = {};
                    try {
                        dailyUsage = JSON.parse(dataElement.textContent);
                    } catch (e) { console.error('Data Corruption in Analytics Block'); }

                    const ctx = document.getElementById('usageChart');
                    if (ctx) {
                        const chartCtx = ctx.getContext('2d');
                        const labels = [];
                        const dataCount = [];
                        const today = new Date();

                        for (let i = 29; i >= 0; i--) {
                            const d = new Date();
                            d.setDate(today.getDate() - i);
                            const dateStr = d.toISOString().split('T')[0];
                            labels.push(d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }));
                            dataCount.push(dailyUsage[dateStr]?.count || 0);
                        }

                        new Chart(chartCtx, {
                            type: 'bar',
                            data: {
                                labels: labels,
                                datasets: [{
                                    label: 'Requests',
                                    data: dataCount,
                                    backgroundColor: '#3b82f6',
                                    borderRadius: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        ticks: { precision: 0, font: { size: 9 } },
                                        grid: { color: '#f1f5f9' }
                                    },
                                    x: { display: false }
                                },
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        backgroundColor: '#0f172a',
                                        titleFont: { size: 10 },
                                        bodyFont: { size: 10 },
                                        padding: 8,
                                        displayColors: false
                                    }
                                }
                            }
                        });
                    }
                })();

                // --- App Bridge Logic ---
                document.querySelectorAll('.app-toggle').forEach(toggle => {
                    toggle.addEventListener('change', async (e) => {
                        const appId = e.target.dataset.appId;
                        const enable = e.target.checked;
                        try {
                            const response = await fetch('/services/html-to-pdf/toggle-app', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ appId, enable })
                            });
                            if (!response.ok) throw new Error('Protocol update failed');
                            window.location.reload();
                        } catch (error) {
                            console.error(error);
                            e.target.checked = !enable;
                            if (window.showError) window.showError('Failed to update app bridge access.');
                        }
                    });
                });

                // --- Generation Provisioner Logic ---
                const urlGroup = document.getElementById('urlInputGroup');
                const htmlGroup = document.getElementById('htmlInputGroup');
                const tabUrl = document.getElementById('tabUrl');
                const tabHtml = document.getElementById('tabHtml');
                const urlInput = document.querySelector('input[name="url"]');
                const previewImg = document.getElementById('pdfPreview');
                const previewIframe = document.getElementById('htmlPreviewIframe');
                const emptyState = document.getElementById('emptyState');
                const loadingPreview = document.getElementById('loadingPreview');
                const errorAlert = document.getElementById('errorAlert');
                const openPdfBtn = document.getElementById('openPdfBtn');
                const convertBtn = document.getElementById('convertBtn');
                const canvasArea = document.getElementById('previewCanvasArea');

                // Tab Logic (Input modes)
                const inputTabs = document.querySelectorAll('[data-input-tab]');
                inputTabs.forEach(tab => {
                    tab.addEventListener('click', (e) => {
                        e.preventDefault();
                        const mode = tab.dataset.inputTab;
                        
                        inputTabs.forEach(t => {
                            t.classList.remove('border-blue-600', 'text-blue-600', 'bg-white');
                            t.classList.add('text-slate-400', 'border-transparent');
                        });
                        tab.classList.add('border-blue-600', 'text-blue-600', 'bg-white');
                        tab.classList.remove('text-slate-400', 'border-transparent');

                        if (mode === 'url') {
                            urlGroup.classList.remove('hidden');
                            htmlGroup.classList.add('hidden');
                            previewIframe.classList.add('hidden');
                            if (urlInput.value && urlInput.value.startsWith('http')) {
                                if (previewImg.src && !previewImg.src.includes('undefined')) {
                                    emptyState.classList.add('hidden');
                                    canvasArea.classList.remove('hidden');
                                    previewImg.classList.remove('hidden');
                                } else {
                                    updateUrlPreview();
                                }
                            } else {
                                emptyState.classList.remove('hidden');
                                canvasArea.classList.add('hidden');
                            }
                        } else {
                            urlGroup.classList.add('hidden');
                            htmlGroup.classList.remove('hidden');
                            previewImg.classList.add('hidden');
                            updateHtmlPreview();
                        }
                    });
                });

                // Zoom Implementation
                window.currentZoom = 1;

                async function updateUrlPreview() {
                    const url = urlInput.value.trim();
                    const appId = document.getElementById('sidebarAppId')?.value;

                    if (!url || !url.startsWith('http')) {
                        if (tabUrl.classList.contains('border-blue-600')) {
                            emptyState.classList.remove('hidden');
                            canvasArea.classList.add('hidden');
                        }
                        return;
                    }

                    emptyState.classList.add('hidden');
                    loadingPreview.classList.remove('hidden');
                    canvasArea.classList.add('hidden');
                    previewImg.classList.add('hidden');

                    const fullPage = document.getElementById('fullPageToggle')?.checked || false;
                    const removeSelectors = document.getElementById('removeSelectors')?.value || '';

                    try {
                        const response = await fetch('/services/html-to-pdf/preview', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ url, appId, fullPage, removeSelectors })
                        });

                        if (!response.ok) {
                            const err = await response.json().catch(() => ({}));
                            throw new Error(err.error || 'Preview failed');
                        }

                        const blob = await response.blob();
                        const objectUrl = URL.createObjectURL(blob);
                        
                        previewImg.src = objectUrl;
                        previewImg.classList.remove('hidden');
                        canvasArea.classList.remove('hidden');
                        loadingPreview.classList.add('hidden');
                        
                        // Enable final conversion button
                        const finalBtn = document.getElementById('finalConvertBtn');
                        if (finalBtn) {
                            finalBtn.disabled = false;
                            finalBtn.classList.remove('hidden');
                        }

                        fitToWidth();
                        if (window.showToast) window.showToast('Preview Ready', 'Visual draft generated successfully', 'success');
                    } catch (error) {
                        console.error('Preview Error:', error);
                        loadingPreview.classList.add('hidden');
                        if (tabUrl.classList.contains('border-blue-600')) {
                            emptyState.classList.remove('hidden');
                        }
                    }
                }

                urlInput.addEventListener('change', () => {
                   if (tabUrl.classList.contains('border-blue-600')) updateUrlPreview();
                });

                urlInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        if (tabUrl.classList.contains('border-blue-600')) updateUrlPreview();
                    }
                });

                window.applyZoom = function() {
                    const area = document.getElementById('previewCanvasArea');
                    const zoomValue = document.getElementById('zoomValue');
                    const zoomRange = document.getElementById('zoomRange');
                    if (area) {
                        area.style.transform = `scale(${window.currentZoom})`;
                        if (zoomValue) zoomValue.textContent = `${Math.round(window.currentZoom * 100)}%`;
                        if (zoomRange) zoomRange.value = window.currentZoom * 100;
                    }
                };

                window.fitToWidth = function() {
                    const container = document.getElementById('previewContainer');
                    const area = document.getElementById('previewCanvasArea');
                    if (!container || !area) return;
                    
                    // Get current paper dimensions from data attributes
                    const format = area.dataset.format || 'A4';
                    const isLandscape = area.dataset.landscape === 'true';
                    const dims = window.PAPER_DIMENSIONS?.[format]?.[isLandscape ? 'landscape' : 'portrait'] || { width: 794 };
                    
                    // Calculate scale to fit container (with padding)
                    const availableWidth = container.clientWidth - 48; // 24px padding each side
                    const availableHeight = container.clientHeight - 48;
                    
                    // Scale based on both width and height to ensure full canvas is visible
                    const scaleByWidth = availableWidth / dims.width;
                    const scaleByHeight = availableHeight / dims.height;
                    
                    // Use the smaller scale to ensure canvas fits entirely
                    const scale = Math.min(scaleByWidth, scaleByHeight, 1);
                    
                    window.currentZoom = Math.max(0.3, scale); // Minimum 30% zoom
                    window.applyZoom();
                }

                // HTML Preview Engine
                async function updateHtmlPreview() {
                    const html = document.querySelector('textarea[name="html"]').value.trim();
                    if (!html || tabUrl.classList.contains('border-blue-600')) {
                        if (tabHtml.classList.contains('border-blue-600')) {
                            emptyState.classList.remove('hidden');
                            canvasArea.classList.add('hidden');
                        }
                        return;
                    }
                    emptyState.classList.add('hidden');
                    loadingPreview.classList.remove('hidden');
                    canvasArea.classList.add('hidden');
                    
                    setTimeout(() => {
                        previewIframe.srcdoc = html;
                        canvasArea.classList.remove('hidden');
                        previewIframe.classList.remove('hidden');
                        loadingPreview.classList.add('hidden');
                        
                        // Enable final conversion button
                        const finalBtn = document.getElementById('finalConvertBtn');
                        if (finalBtn) {
                            finalBtn.disabled = false;
                            finalBtn.classList.remove('hidden');
                        }

                        fitToWidth();
                        if (window.showToast) window.showToast('Preview Ready', 'HTML structure rendered', 'success');
                    }, 100);
                }

                const htmlTextarea = document.querySelector('textarea[name="html"]');
                if (htmlTextarea) {
                    let timeout;
                    htmlTextarea.addEventListener('input', () => {
                        clearTimeout(timeout);
                        timeout = setTimeout(() => {
                            if (tabHtml.classList.contains('border-blue-600')) updateHtmlPreview();
                        }, 800);
                    });
                }

                // Execution Protocol (Renamed to Preview Trigger)
                document.getElementById('pdfForm').addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const tabUrlIndicator = document.querySelector('[data-input-tab="url"]');
                    if (tabUrlIndicator && tabUrlIndicator.classList.contains('border-blue-600')) {
                        await updateUrlPreview();
                    } else {
                        await updateHtmlPreview();
                    }
                });

                // New Full Conversion Logic
                window.startFullConversion = async () => {
                    window.hideError();
                    
                    const finalBtn = document.getElementById('finalConvertBtn');
                    const originalHtml = finalBtn.innerHTML;
                    
                    finalBtn.disabled = true;
                    finalBtn.innerHTML = `<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i> Processing...`;
                    if (typeof lucide !== 'undefined') lucide.createIcons();

                    const form = document.getElementById('pdfForm');
                    const formData = new FormData(form);
                    const data = Object.fromEntries(formData.entries());
                    
                    if (!data.appId) data.appId = document.getElementById('sidebarAppId').value;
                    
                    // Specific syncing from hidden fields
                    data.landscape = document.getElementById('syncLandscape').value === 'true';
                    data.format = document.getElementById('syncFormat').value;
                    
                    // Add capture optimization flags
                    data.fullPage = document.getElementById('fullPageToggle')?.checked || false;
                    data.removeSelectors = document.getElementById('removeSelectors')?.value || '';

                    try {
                        const response = await fetch('/services/html-to-pdf/convert', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });
                        const res = await response.json();
                        if (!response.ok) throw new Error(res.error || 'Protocol Failure');
                        
                        if (res.jobId) {
                            const apiKey = document.getElementById('sidebarAppId').querySelector('option:checked')?.dataset.apiKey;
                            await pollJob(res.jobId, apiKey);
                        }
                    } catch (error) {
                        window.showError(error.message);
                        finalBtn.disabled = false;
                        finalBtn.innerHTML = originalHtml;
                        if (typeof lucide !== 'undefined') lucide.createIcons();
                    }
                };

                window.pollJob = async function(jobId, apiKey) {
                    const finalBtn = document.getElementById('finalConvertBtn');
                    const originalHtml = `<i data-lucide="file-down" class="w-3.5 h-3.5"></i> Generate PDF`;
                    
                    let attempts = 0;
                    while (attempts < 60) {
                        try {
                            const res = await fetch(`/api/jobs/${jobId}`, { headers: { 'X-API-Key': apiKey } });
                            
                            // Check if response is PDF (Success)
                            if (res.headers.get('content-type')?.includes('application/pdf')) {
                                const blob = await res.blob();
                                const url = URL.createObjectURL(blob);
                                
                                // Open PDF in background tab
                                const newWindow = window.open(url, '_blank');
                                if (newWindow) {
                                    window.focus(); // Try to keep focus on generator
                                }

                                // Trigger automatic download
                                const downloadLink = document.createElement('a');
                                downloadLink.href = url;
                                downloadLink.download = 'generated-document.pdf';
                                document.body.appendChild(downloadLink);
                                downloadLink.click();
                                document.body.removeChild(downloadLink);
                                window.focus();
                                
                                // Update UI
                                const openPdfBtn = document.getElementById('openPdfBtn');
                                if (openPdfBtn) {
                                    openPdfBtn.href = url;
                                    openPdfBtn.classList.remove('hidden');
                                }
                                
                                finalBtn.disabled = false;
                                finalBtn.innerHTML = originalHtml;
                                if (typeof lucide !== 'undefined') lucide.createIcons();
                                
                                if (window.showToast) {
                                    window.showToast('PDF Generated', 'File is downloading and saved to Drive. Shared as owner. Deleted from servers in 7 days.', 'success');
                                }
                                
                                window.dispatchEvent(new CustomEvent('job-completed'));
                                return; // Exit loop on success
                            }

                            // Not PDF yet - Check for failure in JSON
                            const data = await res.json().catch(() => ({}));
                            if (data.status === 'failed') {
                                throw new Error(data.error || 'Job generation failed');
                            }
                            
                            // Pending - Wait and Retry
                            attempts++;
                            await new Promise(r => setTimeout(r, 2000));
                            
                        } catch (err) { 
                            // Handle Errors
                            console.error('Polling Error:', err);
                            finalBtn.disabled = false;
                            finalBtn.innerHTML = originalHtml;
                            if (typeof lucide !== 'undefined') lucide.createIcons();
                            
                            if (window.showError) window.showError(err.message);
                            return; // Stop polling on error
                        }
                    }
                    
                    // Timeout
                    if (window.showError) window.showError('Generation timeout');
                    finalBtn.disabled = false;
                    finalBtn.innerHTML = originalHtml;
                };

                // Global Error Handling
                window.showError = (msg) => {
                    const errEl = document.getElementById('errorMessage');
                    if (errEl) {
                        errEl.textContent = msg;
                        errorAlert.classList.remove('hidden');
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                };
                window.hideError = () => errorAlert?.classList.add('hidden');
                document.getElementById('closeErrorBtn')?.addEventListener('click', window.hideError);
                
                if (typeof lucide !== 'undefined') lucide.createIcons();
                
                // Initialize canvas dimensions and fit
                window.updateCanvasDimensions();
                window.fitToWidth();
                
                // Re-fit on window resize
                window.addEventListener('resize', () => {
                    clearTimeout(window._resizeTimer);
                    window._resizeTimer = setTimeout(() => window.fitToWidth(), 150);
                });
            });
        </script>
        
