<%- include('../partials/head', { title: 'HTML to PDF Converter - Floovioo ', additionalCss: '/css/services/html-pdf.css' }) %>

<body class="bg-gray-100 min-h-screen font-sans">
    <%- include('../partials/sidebar') %>

    <div id="mainContent" class="flex flex-col min-h-screen ">
        <%- include('../partials/dashboard-header', {title: 'HTML to PDF Converter' , user: user }) %>

        <div class="flex-1 flex flex-col min-w-0 bg-gray-50/50">
            <main class="flex-1 flex flex-col relative overflow-hidden">
                <!-- Header Row (High Level CTAs) -->
                <div class="bg-white border-b border-slate-200 sticky top-0 lg:static z-30">
                    <div class="max-w-[100rem] mx-auto px-6 lg:px-8 py-3 flex flex-row flex-wrap items-center justify-between gap-3 font-mono">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 rounded-lg">
                                <i data-lucide="file-code" class="w-5 h-5 text-blue-600"></i>
                            </div>
                            <div>
                                <h1 class="text-xl font-bold text-gray-900 tracking-tight">HTML to PDF</h1>
                            <div class="flex items-center gap-2">
                                <p class="text-sm font-medium text-slate-500">Professional conversion engine</p>
                                <!-- Quota Badge (Managed by ServiceCore) -->
                                <span id="quotaDisplay" class="hidden px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-[0.625rem] font-bold">
                                    Checking Quota...
                                </span>
                            </div>
                            </div>
                        </div>
                        <!-- Settings / More Actions Menu -->
                        <div class="relative" id="header-settings-container">
                            <button id="header-settings-btn" class="p-2 sm:px-2.5 sm:py-2 bg-slate-50 text-slate-500 border border-slate-200 rounded-lg hover:bg-white hover:text-blue-600 hover:border-blue-200 transition-all shadow-sm group" aria-label="Service Settings">
                                <i data-lucide="settings-2" class="w-5 h-5 group-hover:rotate-45 transition-transform duration-500 ease-out"></i>
                            </button>

                            <!-- Dropdown Menu -->
                            <div id="header-settings-dropdown" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl ring-1 ring-slate-200 py-1 z-50 animate-in fade-in slide-in-from-top-1 duration-200 origin-top-right">
                                <button onclick="openActionModal('about')" class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                    <i data-lucide="info" class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                    About Service
                                </button>
                                <button onclick="openActionModal('api')" class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                    <i data-lucide="code-2" class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                    API Documentation
                                </button>
                                <div class="h-px bg-slate-100 my-1 mx-2"></div>
                                <button onclick="openActionModal('support')" class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                    <i data-lucide="help-circle" class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                    Get Support
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dropdown Logic -->
                <script nonce="<%= nonce %>">
                    document.addEventListener('DOMContentLoaded', () => {
                        const settingsBtn = document.getElementById('header-settings-btn');
                        const settingsDropdown = document.getElementById('header-settings-dropdown');
                        const settingsContainer = document.getElementById('header-settings-container');
                        
                        // Check if elements exist (in case of partial loading or multiple headers)
                        if (settingsBtn && settingsDropdown && settingsContainer) {
                            settingsBtn.addEventListener('click', (e) => {
                                e.stopPropagation();
                                settingsDropdown.classList.toggle('hidden');
                            });

                            document.addEventListener('click', (e) => {
                                if (!settingsContainer.contains(e.target)) {
                                    settingsDropdown.classList.add('hidden');
                                }
                            });
                        }
                    });
                </script>

                <!-- Service Navigation (Compact) -->
                <div class="bg-white border-b border-slate-100 sticky top-0 z-20">
                    <div class="max-w-[100rem] mx-auto px-6 lg:px-8">
                        <nav class="-mb-px flex flex-nowrap overflow-x-auto no-scrollbar gap-4 sm:gap-6 justify-start">
                            <button data-service-tab="home" id="nav-home" 
                                class="nav-tab-active flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 font-semibold text-sm transition-all">
                                Workspace
                            </button>
                            <button data-service-tab="history" id="nav-history" 
                                class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                Activity
                            </button>
                            <button data-service-tab="usage" id="nav-usage" 
                                class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                Usage
                            </button>
                            <button data-service-tab="apps" id="nav-apps" 
                                class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                Apps
                            </button>
                        </nav>
                    </div>
                </div>

                <!-- Scrollable Body -->
                <div class="flex-1 overflow-y-auto lg:overflow-hidden flex flex-col">
                    <div class="max-w-[100rem] w-full mx-auto px-6 lg:px-8 py-3 flex-1 flex flex-col">
                    <!-- Tab Content: Home (Service Workspace) -->
                    <div id="tab-content-home" class="service-tab-content flex-1 flex flex-col min-h-0">
                        <% if (locals.accessDenied) { %>
                             <div class="flex-1 flex items-center justify-center min-h-[500px]">
                                <%- include('../partials/service-access-blocker') %>
                             </div>
                        <% } else { %>
                             <!-- Service UI -->
                                
                                <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-stretch flex-1 min-h-0">
                                    <!-- Wide Column: Service UI Workspace (9/12) -->
                                    <div class="lg:col-span-9 space-y-4 flex flex-col min-h-0 min-w-0">
                                        <!-- Workspace Sub-Header / Step Flow -->
                                        <div class="minimal-card px-4 py-2 border-b border-slate-100 bg-white flex flex-wrap gap-2 items-center justify-between sm:flex-nowrap flex-shrink-0">
                                            <div class="flex items-center gap-4 overflow-x-auto no-scrollbar max-w-full">
                                                <div class="flex-shrink-0 flex items-center px-4 py-1.5 rounded-md text-[0.8125rem] font-black uppercase tracking-widest transition-all bg-slate-50 border border-slate-200 text-blue-600">
                                                    Workspace
                                                </div>
                                            </div>
                                            <div class="flex items-center gap-3 flex-shrink-0 ml-auto sm:ml-0">
                                                <div class="flex items-center gap-1.5 text-slate-400">
                                                    <div class="w-1.5 h-1.5 bg-blue-500 rounded-full shadow-[0_0_5px_rgba(59,130,246,0.5)]"></div>
                                                    <span class="text-[0.75rem] font-bold uppercase tracking-widest">Ready</span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Error Alert -->
                                        <div id="errorAlert" class="hidden flex-shrink-0">
                                            <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm flex items-start">
                                                <div class="flex-shrink-0">
                                                    <i data-lucide="alert-circle" class="h-5 w-5 text-red-500"></i>
                                                </div>
                                                <div class="ml-3 flex-1">
                                                    <p id="errorMessage" class="text-sm font-bold text-red-800 uppercase tracking-tight">Could not create PDF</p>
                                                </div>
                                                <button id="closeErrorBtn" class="ml-auto text-red-400 hover:text-red-500">
                                                    <i data-lucide="x" class="h-4 w-4"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Workspace UI (2-Column side-by-side) -->
                                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 mb-6 items-stretch flex-1 min-h-0 overflow-visible lg:overflow-hidden">
                                            <!-- Column 1: Config/Form (5/12) -->
                                            <div class="lg:col-span-5 flex flex-col">
                                                <div class="minimal-card flex-1 flex flex-col bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                                                        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between bg-white">
                                                            <div class="flex items-center gap-2">
                                                                <i data-lucide="settings-2" class="w-3.5 h-3.5 text-blue-600"></i>
                                                                <h2 class="text-[0.8125rem] font-bold text-gray-900 uppercase tracking-widest leading-none">Source HTML</h2>
                                                            </div>
                                                        </div>
                                                        
                                                        <div class="bg-white border-b border-slate-100 flex flex-wrap items-center justify-between gap-3">
                                                            <div class="flex flex-wrap gap-2 w-full sm:w-auto">
                                                                <button id="tabUrl" type="button"
                                                                    class="flex-1 sm:flex-none px-6 py-3 font-black text-[0.8125rem] uppercase tracking-widest focus:outline-none border-b-2 border-blue-600 text-blue-600 bg-white"
                                                                    data-input-tab="url">URL</button>
                                                                <button id="tabHtml" type="button"
                                                                    class="flex-1 sm:flex-none px-6 py-3 font-black text-[0.8125rem] uppercase tracking-widest text-slate-400 hover:text-slate-600 focus:outline-none border-b-2 border-transparent transition-all"
                                                                    data-input-tab="html">Source Code</button>
                                                            </div>
                                                        </div>
    
                                                        <form id="pdfForm" class="flex-1 flex flex-col min-h-0">
                                                            <div class="p-6 space-y-5 flex-1 overflow-y-auto">
                                                                <div id="urlInputGroup">
                                                                    <label class="block text-[0.75rem] font-black text-slate-400 uppercase tracking-widest mb-2 flex items-center gap-2">
                                                                        <i data-lucide="globe" class="w-3 h-3"></i>
                                                                        Enter URL
                                                                    </label>
                                                                    <input type="url" name="url" id="urlInput" placeholder="https://example.com"
                                                                        class="w-full bg-slate-50 border border-slate-100 rounded-lg p-3 text-sm font-bold outline-none focus:ring-1 focus:ring-blue-500 transition-all"
                                                                        <%=connectedApps.length===0 ? 'disabled' : '' %>>
                                                                    <p class="mt-1.5 text-[0.625rem] font-medium text-slate-400 uppercase tracking-widest leading-relaxed">Enter the full web address with https:// for capture</p>
                                                                    
                                                                    <div class="mt-4 flex items-center gap-3 p-3 bg-slate-50 rounded-xl border border-slate-100">
                                                                        <div class="relative inline-flex items-center cursor-pointer group">
                                                                            <input type="checkbox" id="fullPageToggle" class="sr-only peer">
                                                                            <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[0.125rem] after:left-[0.125rem] rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                                                                            <span class="ml-3 text-[0.6875rem] font-black text-slate-600 uppercase tracking-widest group-hover:text-blue-600 transition-all">Capture Full Page</span>
                                                                        </div>
                                                                        <i data-lucide="info" class="w-3 h-3 text-slate-300 hover:text-blue-500 cursor-help transition-all ml-auto" title="Scrolls the entire page to trigger lazy-loaded content before capturing"></i>
                                                                    </div>
                                                                </div>
    
                                                                <div id="htmlInputGroup" class="hidden h-full flex flex-col min-h-0">
                                                                    <div class="flex items-center justify-between mb-2">
                                                                        <label class="text-[0.75rem] font-black text-slate-400 uppercase tracking-widest flex items-center gap-2">
                                                                            <i data-lucide="code-2" class="w-3 h-3"></i>
                                                                            Document Content (HTML)
                                                                        </label>
                                                                    </div>
                                                                    <textarea name="html" id="htmlInput" class="flex-1 w-full bg-slate-900 border border-slate-800 rounded-lg p-4 font-mono text-[0.8125rem] text-blue-100 outline-none focus:ring-1 focus:ring-blue-500 transition-all shadow-xl resize-none min-h-[18.75rem] max-h-[31.25rem]"
                                                                    placeholder="<h1>Hello World</h1>" <%=connectedApps.length===0 ? 'disabled' : '' %>><!DOCTYPE html>
<html>
<head>
<style nonce="<%= nonce %>">
  body { font-family: 'Helvetica', sans-serif; margin: 0; padding: 40px; color: #333; background: #fff; }
  .header { text-align: center; border-bottom: 2px solid #2563eb; padding-bottom: 20px; margin-bottom: 40px; }
  .logo { font-size: 24px; font-weight: bold; color: #2563eb; text-transform: uppercase; letter-spacing: 2px; }
</style>
</head>
<body>
  <div class="header">
    <div class="logo">Floovioo </div>
  </div>
  <h1>Document Generated!</h1>
  <p>Your conversion protocol is active and stable.</p>
</textarea>
                                                                <p class="mt-1.5 text-[0.625rem] font-medium text-slate-400 uppercase tracking-widest leading-relaxed">Paste your raw HTML code here to render directly to PDF</p>
                                                            </div>

                                                            <!-- Syncing Area -->
                                                            <div class="hidden">
                                                                <select name="appId" id="syncAppId">
                                                                    <% if (locals.connectedApps && connectedApps.length > 0) { %>
                                                                        <% connectedApps.filter(item => item.app.isActive).forEach((item, index) => { %>
                                                                            <option value="<%= item.app.id %>" <%= item.isEnabled ? 'selected' : '' %>
                                                                                data-api-key="<%= item.app.apiKey %>" <%= index === 0 ? 'selected' : '' %>>
                                                                                <%= item.app.name %>
                                                                            </option>
                                                                        <% }); %>
                                                                    <% } %>
                                                                </select>
                                                                <input type="hidden" name="format" id="syncFormat" value="A4">
                                                                <input type="hidden" name="landscape" id="syncLandscape" value="false">
                                                            </div>
                                                        </div>

                                                        <div class="px-4 py-3 sm:px-6 sm:py-4 bg-slate-50/50 border-t border-slate-100 flex flex-wrap items-center justify-between gap-4">
                                                            <p class="text-[0.6875rem] font-black text-slate-400 uppercase tracking-widest">
                                                                Cost: <span class="text-blue-600">$<%= locals.service ? service.pricePerRequest.toFixed(2) : '0.00' %></span>
                                                            </p>
                                                            <button type="submit" id="convertBtn"
                                                                class="w-full sm:w-auto bg-blue-600 text-white py-2.5 px-6 rounded-lg hover:bg-blue-700 transition-all flex items-center justify-center font-black text-[0.8125rem] uppercase tracking-widest shadow-minimal active:scale-95 <%= connectedApps.length === 0 ? 'opacity-50 cursor-not-allowed' : '' %>"
                                                                <%=connectedApps.length===0 ? 'disabled' : '' %>>
                                                                <span id="btnText">Generate Preview</span>
                                                                <i id="btnSpinner" data-lucide="loader-2" class="animate-spin ml-3 w-4 h-4 hidden"></i>
                                                            </button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <!-- Column 2: Visual Preview (7/12) -->
                                            <div class="lg:col-span-7 flex flex-col">
                                                <div class="minimal-card flex-1 flex flex-col bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                                                    <div class="px-4 py-3 border-b border-slate-100 flex flex-wrap items-center justify-between bg-white sticky top-0 z-10 gap-3">
                                                        <div class="flex items-center gap-2.5 min-w-0">
                                                            <i data-lucide="eye" class="w-4 h-4 text-blue-600 flex-shrink-0"></i>
                                                            <h3 class="text-[0.8125rem] font-black text-gray-900 uppercase tracking-widest leading-none truncate">Output Preview</h3>
                                                        </div>
                                                        <div class="flex items-center gap-1.5 sm:gap-3 overflow-x-auto no-scrollbar ml-auto sm:ml-0 max-w-full">
                                                            <button id="finalConvertBtn" onclick="startFullConversion()" disabled
                                                                class="hidden md:flex items-center gap-2 px-4 py-1.5 bg-blue-600 text-white rounded-lg text-[0.75rem] font-black uppercase tracking-widest hover:bg-blue-700 transition-all shadow-minimal active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:bg-slate-200 disabled:text-slate-400 whitespace-nowrap">
                                                                <i data-lucide="file-down" class="w-3.5 h-3.5"></i>
                                                                Generate PDF
                                                            </button>
                                                            <div class="h-6 w-px bg-slate-100 hidden md:block"></div>
                                                            <a id="openPdfBtn" href="#" target="_blank"
                                                                class="hidden text-[0.6875rem] text-blue-600 hover:text-blue-800 font-black uppercase tracking-widest flex items-center group whitespace-nowrap">
                                                                <i data-lucide="external-link" class="w-3 h-3 mr-1 opacity-70 group-hover:opacity-100 transition-opacity"></i>
                                                                Source
                                                            </a>
                                                            <div class="flex items-center gap-1.5 sm:gap-3 bg-slate-50 px-2 py-1 sm:px-3 sm:py-1.5 border border-slate-200 rounded-lg shadow-inner flex-shrink-0">
                                                                <div class="flex items-center gap-1 sm:gap-2">
                                                                    <button type="button" onclick="window.currentZoom = Math.max(0.5, window.currentZoom - 0.1); window.applyZoom();" class="p-0.5 sm:p-1 rounded hover:bg-white hover:shadow-sm text-slate-400 hover:text-blue-600 transition-all">
                                                                        <i data-lucide="minus-circle" class="w-3.5 h-3.5 sm:w-4 h-4"></i>
                                                                    </button>
                                                                    <input type="range" id="zoomRange" min="50" max="150" value="100" oninput="window.currentZoom = this.value / 100; window.applyZoom();" class="w-16 sm:w-24 h-1 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-600">
                                                                    <button type="button" onclick="window.currentZoom = Math.min(1.5, window.currentZoom + 0.1); window.applyZoom();" class="p-0.5 sm:p-1 rounded hover:bg-white hover:shadow-sm text-slate-400 hover:text-blue-600 transition-all">
                                                                        <i data-lucide="plus-circle" class="w-3.5 h-3.5 sm:w-4 h-4"></i>
                                                                    </button>
                                                                </div>
                                                                <span id="zoomValue" class="text-[0.6875rem] font-black text-slate-600 min-w-[3.5ch] text-center">100%</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="flex-1 bg-slate-50/50 overflow-hidden relative group subtle-grid">
                                                        <div id="previewContainer" class="w-full h-full overflow-auto flex justify-center p-6">
                                                            <!-- Empty State -->
                                                            <div id="emptyState" class="m-auto text-center p-12 max-w-sm">
                                                                <div class="w-14 h-14 bg-white rounded-2xl shadow-sm flex items-center justify-center mx-auto mb-6 text-slate-200 border border-slate-100">
                                                                    <i data-lucide="file-search-2" class="w-7 h-7 opacity-40"></i>
                                                                </div>
                                                                <h3 class="text-[0.8125rem] font-black text-slate-900 uppercase tracking-[0.1em] mb-2">No Preview Available</h3>
                                                                <p class="text-[0.75rem] font-bold text-slate-400 uppercase tracking-widest leading-loose">Start a conversion to see the results here.</p>
                                                            </div>
                                                            
                                                            <div id="loadingPreview" class="hidden m-auto text-center">
                                                                <div class="inline-block animate-spin rounded-full h-8 w-8 border-2 border-blue-600 border-t-transparent mb-4"></div>
                                                                <p class="text-[0.75rem] font-black text-blue-600 uppercase tracking-widest">Building Preview...</p>
                                                            </div>
                                                            
                                                            <div class="bg-white shadow-2xl relative transition-all duration-200 origin-top hidden" id="previewCanvasArea" data-format="A4" data-landscape="false">
                                                                <img id="pdfPreview" class="w-full h-auto" src="" />
                                                                <iframe id="htmlPreviewIframe" class="hidden w-full h-full border-none" style="width: 100%; height: 100%;"></iframe>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="py-1.5 bg-white border-t border-slate-100 flex justify-center">
                                                        <p class="text-[0.625rem] text-slate-400 font-bold uppercase tracking-widest leading-none">Results Preview</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Narrow Column: Service Configuration Sidebar (3/12) -->
                                    <div class="lg:col-span-3 space-y-4">
                                        <div class="minimal-card flex flex-col bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm sticky top-[3.75rem]">
                                            <!-- Sidebar Tabs -->
                                            <div class="flex border-b border-slate-100 bg-slate-50/50">
                                                <button data-sidebar-tab="properties" class="sidebar-tab-active flex-1 py-3 text-[0.75rem] font-black uppercase tracking-widest border-b-2 border-blue-600 text-blue-600 bg-white">Settings</button>
                                                <button data-sidebar-tab="assistance" class="flex-1 py-3 text-[0.75rem] font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">Help</button>
                                                <button data-sidebar-tab="assets" class="flex-1 py-3 text-[0.75rem] font-black uppercase tracking-widest border-b-2 border-transparent text-slate-400 hover:text-slate-600 transition-all">Resources</button>
                                            </div>
                                            
                                            <!-- Sidebar Tab Content -->
                                            <div class="p-5 space-y-6 overflow-y-auto max-h-[calc(100vh-250px)]">
                                                <!-- Properties Tab Content -->
                                                <div id="sidebar-tab-properties" class="sidebar-content space-y-6">
                                                    <div class="flex items-center justify-between pb-2 border-b border-slate-50">
                                                        <div class="flex items-center gap-2">
                                                            <i data-lucide="sliders-horizontal" class="w-3.5 h-3.5 text-blue-600"></i>
                                                            <h4 class="text-[0.8125rem] font-black text-gray-900 uppercase tracking-widest">Configuration</h4>
                                                        </div>
                                                        <i data-lucide="shield-check" class="w-3 h-3 text-green-500 opacity-60"></i>
                                                    </div>

                                                <div class="space-y-5">
                                                    <!-- Run as App Selector -->
                                                    <div class="space-y-2">
                                                        <p class="text-[0.75rem] font-black text-slate-400 uppercase tracking-widest flex items-center justify-between">
                                                            Active App
                                                            <i data-lucide="info" class="w-2.5 h-2.5 opacity-40 hover:opacity-100 cursor-help transition-opacity"></i>
                                                        </p>
                                                        <select id="sidebarAppId" class="w-full text-sm font-black text-gray-700 border border-slate-200 rounded-lg py-2.5 px-3 focus:ring-1 focus:ring-blue-500 outline-none bg-slate-50/50 transition-all uppercase tracking-tight">
                                                            <% if (locals.connectedApps && connectedApps.length > 0) { %>
                                                                <% connectedApps.filter(item => item.app.isActive).forEach((item, index) => { %>
                                                                    <option value="<%= item.app.id %>" <%= item.isEnabled ? 'selected' : '' %>
                                                                        data-api-key="<%= item.app.apiKey %>">
                                                                        <%= item.app.name %>
                                                                    </option>
                                                                <% }); %>
                                                            <% } else { %>
                                                                <option value="" disabled selected>No apps found</option>
                                                            <% } %>
                                                        </select>
                                                    </div>

                                                    <!-- Paper Format -->
                                                    <div class="space-y-2">
                                                        <label class="text-[0.75rem] font-black text-slate-400 uppercase tracking-widest">Page Size</label>
                                                        <div class="grid grid-cols-3 gap-1.5">
                                                            <% ['A4', 'Letter', 'Legal'].forEach(f => { %>
