    <script src="/assets/js/service-core.js" nonce="<%= nonce %>"></script>
    <%- include('../partials/nav-guard') %>
    <script nonce="<%= nonce %>">
        // [CORE] Initialize Service Core
        window.SERVICE_CONTEXT = <%- typeof serviceContext !== 'undefined' && serviceContext ? JSON.stringify(serviceContext) : 'null' %>;
        
        const serviceCore = new ServiceCore({
            formId: 'pdfForm'
        });

        // [UX] Tab Switching Logic
        document.addEventListener('DOMContentLoaded', () => {
            // [NavGuard] Explicitly track dirty state for PDF tool inputs
            const inputs = ['urlInput', 'htmlInput'];
            inputs.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener('input', () => { 
                        if (!window.isWorkDirty) console.log('📝 [PDF-Tool] Work started on:', id);
                        window.isWorkDirty = true; 
                    });
                }
            });

            const serviceTabs = document.querySelectorAll('[data-service-tab]');
            
            serviceTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const tabName = tab.dataset.serviceTab;
                    
                    // Hide all tab contents
                    document.querySelectorAll('.service-tab-content').forEach(el => {
                        el.classList.add('hidden');
                        el.classList.remove('flex'); // Ensure flex is removed if used
                    });

                    // Show selected tab content
                    const selectedContent = document.getElementById('tab-content-' + tabName);
                    if (selectedContent) {
                        selectedContent.classList.remove('hidden');
                        // Restore flex for standard layout tabs
                        if (tabName !== 'history' && tabName !== 'usage') {
                             selectedContent.classList.add('flex');
                        }
                    }

                    // Update Tab Styles
                    serviceTabs.forEach(btn => {
                        btn.classList.remove('nav-tab-active', 'border-b-2');
                        // Reset to inactive style
                        btn.classList.add('border-transparent', 'text-gray-400'); 
                        btn.classList.remove('text-gray-900', 'border-blue-600');
                    });
                    
                    // Set Active Style
                    tab.classList.add('nav-tab-active', 'border-b-2', 'border-blue-600', 'text-gray-900');
                    tab.classList.remove('border-transparent', 'text-gray-400');
                });
            });
        });
    </script>
    <%- include('../partials/sidebar-script') %>
