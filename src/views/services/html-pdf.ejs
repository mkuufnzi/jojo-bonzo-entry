             <%- include('../partials/usage-block', { dailyUsage: dailyUsage, stats: stats }) %>
        </div>

        <!-- Tab Content: Apps -->
        <div id="tab-content-apps" class="service-tab-content hidden flex-1 flex flex-col">
            <div class="max-w-4xl mx-auto w-full p-6">
                 <%- include('../partials/connected-apps-list', { connectedApps: connectedApps }) %>
