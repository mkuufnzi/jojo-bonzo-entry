            <!-- Styles Extracted to /css/services/pdf-converter.css -->

            <script nonce="<%= nonce %>">
                document.addEventListener('DOMContentLoaded', () => {
                    // Zoom Implementation
                window.currentZoom = 1;
                window.applyZoom = function() {
                    const area = document.getElementById('previewCanvasArea');
                    const zoomValue = document.getElementById('zoomValue');
                    const zoomRange = document.getElementById('zoomRange');
                    if (area) {
                        area.style.transform = `scale(${window.currentZoom})`;
                        if (zoomValue) zoomValue.textContent = `${Math.round(window.currentZoom * 100)}%`;
                        if (zoomRange) zoomRange.value = window.currentZoom * 100;
                    }
                };

                    // Navigation
                    const serviceTabs = document.querySelectorAll('[data-service-tab]');
                    const serviceTabContents = document.querySelectorAll('.service-tab-content');

                    serviceTabs.forEach(tab => {
                        tab.addEventListener('click', () => {
                            const tabName = tab.dataset.serviceTab;
                            serviceTabContents.forEach(el => el.classList.add('hidden'));
                            document.getElementById('tab-content-' + tabName).classList.remove('hidden');

                            serviceTabs.forEach(btn => {
                                btn.classList.remove('nav-tab-active');
                                btn.classList.add('border-transparent', 'text-gray-400');
                            });
                            tab.classList.add('nav-tab-active');
                            tab.classList.remove('border-transparent', 'text-gray-400');
                        });
                    });

                    // Sidebar sync
                    const sidebarAppId = document.getElementById('sidebarAppId');
                    const syncAppId = document.getElementById('syncAppId');
                    if (sidebarAppId && syncAppId) {
                        sidebarAppId.addEventListener('change', () => {
                            syncAppId.value = sidebarAppId.value;
                        });
                    }

                    window.selectFormat = (el, val) => {
                        document.getElementById('syncFormat').value = val;
                        document.querySelectorAll('.format-badge').forEach(b => {
                            b.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                            b.classList.add('border-slate-100', 'text-slate-400');
                        });
                        el.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                        el.classList.remove('border-slate-100', 'text-slate-400');
                    };

                    window.selectOrientation = (el, val) => {
                        document.getElementById('syncLandscape').value = val;
                        document.querySelectorAll('.orientation-badge').forEach(b => {
                            b.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                            b.classList.add('border-slate-100', 'text-slate-400');
                        });
                        el.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-600', 'shadow-sm');
                        el.classList.remove('border-slate-100', 'text-slate-400');
                    };

                    // Input tabs
                    const inputTabs = document.querySelectorAll('[data-input-tab]');
                    inputTabs.forEach(tab => {
                        tab.addEventListener('click', () => {
                            const mode = tab.dataset.inputTab;
                            inputTabs.forEach(t => {
                                t.classList.remove('border-blue-600', 'text-blue-600', 'bg-white');
                                t.classList.add('text-slate-400', 'border-transparent');
                            });
                            tab.classList.add('border-blue-600', 'text-blue-600', 'bg-white');
                            tab.classList.remove('text-slate-400', 'border-transparent');

                            document.getElementById('urlInputGroup').classList.toggle('hidden', mode !== 'url');
                            document.getElementById('htmlInputGroup').classList.toggle('hidden', mode !== 'html');
                        });
                    });

                    // Form
                    const form = document.getElementById('pdfForm');
                    form.addEventListener('submit', async (e) => {
                        e.preventDefault();
                        const btnText = document.getElementById('btnText');
                        const spinner = document.getElementById('btnSpinner');
                        const btn = document.getElementById('convertBtn');

                        btn.disabled = true;
                        btnText.textContent = 'EXECUTING...';
                        spinner.classList.remove('hidden');

                        const formData = new FormData(form);
                        const data = Object.fromEntries(formData.entries());
                        data.appId = document.getElementById('sidebarAppId').value;
                        data.landscape = data.landscape === 'true';

                        try {
                            const res = await fetch('/services/html-to-pdf/convert', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(data)
                            });
                            const result = await res.json();
                            if (!res.ok) throw new Error(result.error || 'Conversion failed');
                            if (result.jobId) {
                                pollJob(result.jobId, document.querySelector(`#sidebarAppId option[value="${data.appId}"]`).dataset.apiKey);
                            }
                        } catch (err) {
                            showError(err.message);
                            btn.disabled = false;
                            btnText.textContent = 'EXECUTE PROTOCOL';
                            spinner.classList.add('hidden');
                        }
                    });

                    async function pollJob(jobId, apiKey) {
                        let attempts = 0;
                        while (attempts < 60) {
                            try {
                                const res = await fetch(`/api/jobs/${jobId}`, { headers: { 'X-API-Key': apiKey } });
                                if (res.headers.get('content-type')?.includes('application/pdf')) {
                                    const blob = await res.blob();
                                    const url = URL.createObjectURL(blob);
                                    window.open(url, '_blank');
                                    document.getElementById('openPdfBtn').href = url;
                                    document.getElementById('openPdfBtn').classList.remove('hidden');
                                    document.getElementById('pdfPreview').src = url;
                                    document.getElementById('pdfPreview').classList.remove('hidden');
                                    document.getElementById('emptyState').classList.add('hidden');
                                    
                                    const btnText = document.getElementById('btnText');
                                    const spinner = document.getElementById('btnSpinner');
                                    const btn = document.getElementById('convertBtn');
                                    btn.disabled = false;
                                    btnText.textContent = 'Convert to PDF';
                                    spinner.classList.add('hidden');
                                    return;
                                }
                                attempts++;
                                await new Promise(r => setTimeout(r, 2000));
                            } catch (e) { break; }
                        }
                    }

                    // Analytics
                    (function() {
                        const dataEl = document.getElementById('usage-data');
                        if (!dataEl) return;
                        const usage = JSON.parse(dataEl.textContent);
                        const ctx = document.getElementById('usageChart')?.getContext('2d');
                        if (!ctx) return;
                        const labels = [];
                        const data = [];
                        const today = new Date();
                        for (let i = 29; i >= 0; i--) {
                            const d = new Date(); d.setDate(today.getDate() - i);
                            const ds = d.toISOString().split('T')[0];
                            labels.push(d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }));
                            data.push(usage[ds]?.count || 0);
                        }
                        new Chart(ctx, {
                            type: 'bar',
                            data: {
                                labels,
                                datasets: [{ label: 'Signals', data, backgroundColor: '#3b82f6', borderRadius: 4 }]
                            },
                            options: {
                                responsive: true, maintainAspectRatio: false,
                                scales: { y: { beginAtZero: true, ticks: { font: { size: 9 } } }, x: { display: false } },
                                plugins: { legend: { display: false } }
                            }
                        });
                    })();

                    function showError(msg) {
                        const err = document.getElementById('errorMessage');
                        err.textContent = msg;
                        document.getElementById('errorAlert').classList.remove('hidden');
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    }
                    document.getElementById('closeErrorBtn')?.addEventListener('click', () => document.getElementById('errorAlert').classList.add('hidden'));
                    
                    if (typeof lucide !== 'undefined') lucide.createIcons();
                });
            </script>
            <%- include('../partials/sidebar-script') %>

            <!-- Action Modals -->
            <div id="actionModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 bg-slate-900/40 backdrop-blur-sm transition-all">
                <div class="bg-white border border-slate-200 rounded-2xl w-full max-w-lg shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
                    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                        <div class="flex items-center gap-3">
                            <div id="modalIconContainer" class="p-2 bg-blue-50 rounded-lg text-blue-600">
                                <i data-lucide="info" class="w-4 h-4" id="modalIcon"></i>
                            </div>
                            <h3 id="modalTitle" class="text-xs font-black text-slate-900 uppercase tracking-widest">About This Tool</h3>
                        </div>
                        <button onclick="closeActionModal()" class="p-2 hover:bg-white hover:shadow-sm rounded-lg text-slate-400 hover:text-slate-600 transition-all">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>
                    <div class="p-6">
                        <div id="modalBody" class="space-y-4">
                            <!-- Dynamic Content -->
                        </div>
                    </div>
                    <div class="px-6 py-4 border-t border-slate-50 bg-slate-50/30 flex justify-end">
                        <button onclick="closeActionModal()" class="px-4 py-2 bg-slate-900 text-white rounded-lg text-[0.625rem] font-black uppercase tracking-widest hover:bg-slate-800 transition-all">
                            Close
                        </button>
                    </div>
                </div>
            </div>

            <script nonce="<%= nonce %>">
                const modalContent = {
                    about: {
                        title: 'About File Converter',
                        icon: 'info',
                        body: `
                            <div class="space-y-4">
                                <p class="text-[0.6875rem] font-bold text-slate-600 uppercase tracking-widest leading-relaxed">
                                    Our high-performance engine ensures 100% fidelity.
                                </p>
                                <div class="grid grid-cols-2 gap-3">
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                                        <p class="text-[0.5rem] font-black text-slate-400 uppercase tracking-widest mb-1">Engine</p>
                                        <p class="text-[0.625rem] font-black text-blue-600 uppercase">Pro Logic v1.2</p>
                                    </div>
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100">
                                        <p class="text-[0.5rem] font-black text-slate-400 uppercase tracking-widest mb-1">Status</p>
                                        <p class="text-[0.625rem] font-black text-green-600 uppercase tracking-widest">Online</p>
                                    </div>
                                </div>
                            </div>
                        `
                    },
                    api: {
                        title: 'API Integration',
                        icon: 'code-2',
                        body: `
                            <div class="space-y-4">
                                <p class="text-[0.6875rem] font-bold text-slate-600 uppercase tracking-widest mb-3">cURL Implementation</p>
                                <div class="bg-slate-900 rounded-xl p-4 font-mono text-[0.625rem] text-blue-100 overflow-x-auto shadow-inner">
                                    <pre>curl -X POST /api/v1/convert \\
  -H "X-API-Key: YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"url": "https://example.com"}'</pre>
                                </div>
                                <p class="text-[0.5625rem] font-bold text-slate-400 uppercase tracking-widest leading-relaxed">
                                    Refer to documentation for full parameter list including custom formats.
                                </p>
                            </div>
                        `
                    },
                    support: {
                        title: 'How can we help?',
                        icon: 'help-circle',
                        body: `
                            <div class="space-y-4">
                                <p class="text-[0.6875rem] font-bold text-slate-600 uppercase tracking-widest leading-relaxed">
                                    Need help with your documents or account?
                                </p>
                                <div class="space-y-2">
                                    <a href="#" class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-blue-200 transition-all group">
                                        <span class="text-[0.625rem] font-black text-slate-600 uppercase tracking-widest">View Guidebook</span>
                                        <i data-lucide="arrow-right" class="w-3.5 h-3.5 text-slate-300 group-hover:text-blue-500 transition-all"></i>
                                    </a>
                                    <a href="#" class="flex items-center justify-between p-3 bg-slate-50 rounded-xl border border-slate-100 hover:border-blue-200 transition-all group">
                                        <span class="text-[0.625rem] font-black text-slate-600 uppercase tracking-widest">Contact Support</span>
                                        <i data-lucide="arrow-right" class="w-3.5 h-3.5 text-slate-300 group-hover:text-blue-500 transition-all"></i>
                                    </a>
                                </div>
                            </div>
                        `
                    }
                };

                function openActionModal(type) {
                    const modal = document.getElementById('actionModal');
                    const title = document.getElementById('modalTitle');
                    const icon = document.getElementById('modalIcon');
                    const body = document.getElementById('modalBody');
                    const content = modalContent[type];

                    if (content) {
                        title.textContent = content.title;
                        icon.setAttribute('data-lucide', content.icon);
                        body.innerHTML = content.body;
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        if (typeof lucide !== 'undefined') lucide.createIcons();
                    }
                }

                function closeActionModal() {
                    const modal = document.getElementById('actionModal');
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }

                // Close on backdrop click
                document.getElementById('actionModal').addEventListener('click', (e) => {
                    if (e.target.id === 'actionModal') closeActionModal();
                });
            </script>
            <%- include('../partials/sidebar-script') %>
            <%- include('../partials/nav-guard') %>
            <%- include('../partials/toast') %>
    </div>
</body>
