<%- include('../partials/head', { title: 'Services - Floovioo ' }) %>
                <body class="bg-gray-100 min-h-screen font-sans">

                    <%- include('../partials/sidebar') %>

                    <div id="mainContent" class="flex flex-col min-h-screen ">
                        <%- include('../partials/dashboard-header', {title: 'Services', user: user }) %>

                        <main class="flex-1">
                            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                                <div class="mb-8">
                                    <p class="text-gray-600 mt-1">Explore available tools and services.</p>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
                                <% 
                                    services.forEach(service => { 
                                        const isImplemented = ['html-to-pdf', 'ai-doc-generator'].includes(service.slug);
                                        
                                        // FAIL-SAFE: Default to locked/unauthorized
                                        let canOpen = false;
                                        let statusLabel = null;
                                        let statusColor = 'gray';
                                        let lockReason = isImplemented ? 'upgrade' : 'coming_soon';
                                        let actionText = isImplemented ? 'Upgrade to Unlock' : 'Coming Soon';
                                        let actionLink = '#';

                                        if (service.isActive && isImplemented) {
                                            // 1. Authorization: Does the user's plan include this feature?
                                            const featureKey = service.requiredFeatureKey;
                                            const hasFeature = !featureKey || (user.subscription?.plan?.planFeatures || []).some(pf => pf.feature.key === featureKey && pf.isEnabled);
                                            
                                            // 2. Exhaustion: Has the user reached their quota for this feature?
                                            let isExhausted = false;
                                            if (featureKey === 'ai_generation') isExhausted = !!user.aiLimitReached;
                                            if (featureKey === 'pdf_conversion') isExhausted = !!user.pdfLimitReached;

                                            if (!hasFeature) {
                                                canOpen = false;
                                                lockReason = 'upgrade';
                                                statusLabel = 'Pro';
                                                statusColor = 'indigo';
                                                actionText = 'Upgrade to Unlock';
                                                actionLink = `/billing?upgrade=true&feature=${service.slug}`;
                                            } else if (isExhausted) {
                                                canOpen = true; // Allow opening to see history/usage, but workspace will be locked
                                                lockReason = 'exhausted';
                                                statusLabel = 'Limit Hit';
                                                statusColor = 'red';
                                                actionText = 'Open Tool (Locked)';
                                                actionLink = `/services/${service.slug}`;
                                            } else {
                                                canOpen = true;
                                                actionText = 'Open Tool';
                                                actionLink = `/services/${service.slug}`;
                                            }
                                        }
                                %>
                    <div class="minimal-card p-6 flex flex-col transition-all group <%= !canOpen ? 'opacity-75 grayscale-[0.5]' : '' %>">
                        <div class="w-10 h-10 <%= canOpen ? 'bg-blue-100 text-blue-600' : 'bg-gray-100 text-gray-400' %> rounded-lg flex items-center justify-center mb-4 transition-colors">
                            <% if (service.slug === 'html-to-pdf') { %>
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                            <% } else if (service.slug === 'ai-doc-generator') { %>
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            <% } else { %>
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                            <% } %>
                        </div>
                        <div class="flex items-center justify-between mb-2">
                            <h3 class="text-sm font-bold uppercase tracking-widest <%= canOpen ? 'text-gray-900 font-black' : 'text-gray-500' %>"><%= service.name %></h3>
                            <div class="flex gap-2">
                                <% if (statusLabel) { %>
                                    <span class="px-2 py-0.5 text-[0.5rem] font-bold text-<%= statusColor %>-600 bg-<%= statusColor %>-50 border border-<%= statusColor %>-100 rounded uppercase tracking-wider"><%= statusLabel %></span>
                                <% } %>
                            </div>
                        </div>
                        <p class="text-gray-500 text-xs mb-6 flex-1"><%= service.description %></p>
                        
                        <% if (canOpen) { %>
                            <a href="<%= actionLink %>" class="inline-flex items-center text-blue-600 hover:text-blue-700 font-bold text-[0.625rem] uppercase tracking-widest">
                                <%= actionText %> <i data-lucide="arrow-right" class="w-3 h-3 ml-2 group-hover:translate-x-1 transition-transform"></i>
                            </a>
                        <% } else if (lockReason === 'coming_soon') { %>
                            <span class="inline-flex items-center text-gray-400 font-medium text-sm cursor-not-allowed italic">
                                <%= actionText %>
                            </span>
                        <% } else { %>
                            <a href="<%= actionLink %>" class="inline-flex items-center text-<%= statusColor %>-600 hover:text-<%= statusColor %>-700 font-bold text-sm group">
                                <svg class="w-4 h-4 mr-1 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                                <%= actionText %> <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                            </a>
                        <% } %>
                    </div>
                    <% }); %>
                                </div>
                            </div>
                        </main>
                    </div>

                    <%- include('../partials/sidebar-script') %>

                    <!-- Pro Upgrade Modal -->
                    <div id="upgradeModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
                        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
                            <!-- Background overlay, show/hide based on modal state. -->
                            <div class="fixed inset-0 bg-gray-900 bg-opacity-75 transition-opacity backdrop-blur-sm" aria-hidden="true" onclick="closeUpgradeModal()"></div>

                            <!-- This element is to trick the browser into centering the modal contents. -->
                            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

                            <!-- Modal panel -->
                            <div class="inline-block align-bottom bg-white rounded-2xl text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
                                
                                <!-- Decorative Header -->
                                <div class="relative bg-gray-900 px-4 py-8 sm:px-10 overflow-hidden">
                                    <!-- Decorative Accents -->
                                    <div class="absolute -top-24 -right-24 w-32 h-32 bg-blue-500 rounded-full blur-[100px] opacity-20"></div>
                                    <div class="absolute -bottom-24 -left-24 w-32 h-32 bg-indigo-500 rounded-full blur-[100px] opacity-20"></div>

                                    <div class="relative z-10">
                                        <div class="absolute top-0 right-0">
                                            <button type="button" class="bg-white/10 rounded-xl p-2 inline-flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/20 focus:outline-none transition-all" onclick="closeUpgradeModal()">
                                                <span class="sr-only">Close</span>
                                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                                </svg>
                                            </button>
                                        </div>
                                        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-xs font-bold uppercase tracking-widest border border-blue-500/20 mb-4">
                                            Premium Access
                                        </div>
                                        <h3 class="text-3xl font-extrabold text-white mb-2" id="modal-title">
                                            Unlock Pro Power
                                        </h3>
                                        <p class="text-gray-400 text-base leading-relaxed max-w-md">
                                            This tool is part of our professional suite. Upgrade now for instant access and higher limits.
                                        </p>
                                    </div>
                                </div>

                                <div class="px-4 pt-8 pb-8 sm:px-10 sm:pb-10 bg-white">
                                    
                                    <!-- Plan Display (Assuming Pro is the target) -->
                                    <% 
                                        const proPlan = plans.find(p => p.price > 0 && (p.name.toLowerCase().includes('pro') || p.price >= 10)) || plans[1] || plans[0]; 
                                    %>

                                    <% if (proPlan) { %>
                                        <div class="rounded-3xl border border-gray-100 bg-gray-50/50 p-8 flex flex-col items-center sm:flex-row sm:items-start sm:justify-between mb-8 transition-all hover:bg-gray-50">
                                            <div class="text-center sm:text-left mb-6 sm:mb-0">
                                                <h4 class="text-2xl font-black text-gray-900"><%= proPlan.name %> Plan</h4>
                                                <p class="mt-2 text-gray-500 text-sm leading-relaxed max-w-xs">
                                                    Get unlimited access to AI Document Generator, Docx-to-PDF, and priority processing.
                                                </p>
                                                <div class="mt-6 flex flex-wrap gap-2 justify-center sm:justify-start">
                                                   <% 
                                                      try {
                                                          const features = JSON.parse(proPlan.features || '[]');
                                                          features.slice(0, 3).forEach(f => {
                                                   %>
                                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-wider bg-white text-gray-600 border border-gray-200">
                                                            <%= f.replace(/-/g, ' ') %>
                                                        </span>
                                                   <% 
                                                          });
                                                      } catch(e){}
                                                   %>
                                                </div>
                                            </div>
                                            <div class="text-center bg-white p-4 rounded-2xl shadow-sm border border-gray-100 min-w-[7.5rem]">
                                                <span class="text-4xl font-black text-gray-900"><%= proPlan.currency === 'GBP' ? '£' : '$' %><%= proPlan.price %></span>
                                                <span class="block text-xs font-bold text-gray-400 uppercase tracking-widest mt-1">/mo</span>
                                            </div>
                                        </div>

                                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                                            <form action="/subscription/upgrade" method="POST" class="w-full">
                                                <input type="hidden" name="planId" value="<%= proPlan.id %>">
                                                <button type="submit" class="w-full inline-flex justify-center items-center rounded-2xl border border-transparent shadow-xl px-8 py-4 bg-gray-900 text-lg font-bold text-white hover:bg-black focus:outline-none transition-all transform hover:-translate-y-1">
                                                    Upgrade Now
                                                </button>
                                            </form>
                                            <button type="button" class="w-full inline-flex justify-center items-center rounded-2xl border border-gray-300 px-8 py-4 bg-white text-lg font-bold text-gray-600 hover:bg-gray-50 transition-all shadow-sm" onclick="closeUpgradeModal()">
                                                Maybe Later
                                            </button>
                                        </div>
                                        
                                        <p class="mt-4 text-xs text-center text-gray-400">
                                            Secure payment via Stripe. You can cancel anytime.
                                        </p>

                                    <% } else { %>
                                        <div class="text-center">
                                            <p class="text-gray-500">Plans are currently unavailable. Please check back later.</p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <script nonce="<%= nonce %>">
                        // Check for error params
                        const urlParams = new URLSearchParams(window.location.search);
                        const error = urlParams.get('error');
                        const service = urlParams.get('service');

                        if (error === 'upgrade_required') {
                            const modal = document.getElementById('upgradeModal');
                            modal.classList.remove('hidden');
                        }

                        function closeUpgradeModal() {
                            document.getElementById('upgradeModal').classList.add('hidden');
                            // Clean URL
                            const url = new URL(window.location);
                            url.searchParams.delete('error');
                            url.searchParams.delete('service');
                            window.history.pushState({}, '', url);
                        }
                    </script>
                </body>
            </html>
