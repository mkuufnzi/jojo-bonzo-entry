<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= service.name %> - Coming Soon | Floovioo </title>
    <script src="https://cdn.tailwindcss.com" nonce="<%= nonce %>"></script>
    <script src="https://unpkg.com/lucide@latest" nonce="<%= nonce %>"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/layouts/sidebar.css" nonce="<%= nonce %>">
    <link rel="stylesheet" href="/css/services/status-pages.css" nonce="<%= nonce %>">
</head>
<body class="bg-[#F8FAFC] min-h-screen">
    <%- include('../partials/sidebar') %>

    <div id="mainContent" class="flex flex-col min-h-screen ">
        <%- include('../partials/dashboard-header', { title: 'Coming Soon', user: user }) %>

        <main class="flex-1 flex items-center justify-center p-6 bg-gradient-to-br from-blue-50/50 via-white to-indigo-50/50">
            <div class="max-w-4xl w-full grid md:grid-cols-2 gap-12 items-center">
                <!-- Text Content -->
                <div class="space-y-8">
                    <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-[0.625rem] font-bold uppercase tracking-widest border border-blue-100">
                        ⚡ Under Development
                    </div>
                    
                    <h1 class="text-5xl font-bold text-gray-900 leading-tight">
                        <span class="text-blue-600"><%= service.name %></span> is almost here.
                    </h1>
                    
                    <p class="text-lg text-gray-500 leading-relaxed">
                        We're building the most powerful <span class="text-gray-900 font-medium"><%= service.name.toLowerCase() %></span> engine for developers and enterprises. Get notified the moment we launch our beta.
                    </p>

                    <% 
                        const toolFeatures = {
                            'docx-to-pdf': [
                                'Preserve Styles & Formatting Perfectly',
                                'Batch Process Multiple Documents',
                                'Secure Document Encryption',
                                'Custom Header/Footer Injection'
                            ],
                            'pdf-optimizer': [
                                'Reduce File Size by up to 90%',
                                'Remove Sensitive Metadata',
                                'Repair Corrupted PDF Structures',
                                'Bulk Optimization API'
                            ],
                            'default': [
                                'Built-in API & SDK Integration',
                                'Enterprise-grade Security & Encryption',
                                'Scalable High-Performance Processing',
                                'Zero-Log Privacy Policy'
                            ]
                        };
                        const features = toolFeatures[service.slug] || toolFeatures.default;
                    %>

                    <div class="space-y-4">
                        <% features.forEach(feature => { %>
                        <div class="flex items-start space-x-3">
                            <div class="mt-1 w-5 h-5 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
                                <svg class="w-3 h-3 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            </div>
                            <p class="text-sm text-gray-600"><%= feature %></p>
                        </div>
                        <% }); %>
                    </div>

                    <!-- Lead Form -->
                    <form id="leadForm" class="relative group max-w-md">
                        <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
                        <div class="relative flex p-1 bg-white rounded-2xl shadow-xl">
                            <input type="hidden" name="serviceSlug" value="<%= service.slug %>">
                            <input type="email" id="email" required placeholder="Enter your email" 
                                   class="flex-1 px-4 py-3 text-sm focus:outline-none rounded-xl text-gray-900">
                            <button type="submit" id="submitBtn" class="bg-blue-600 text-white px-6 py-3 rounded-xl text-sm font-semibold hover:bg-blue-700 transition-all flex items-center gap-2">
                                <span>Get Early Access</span>
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                        </div>
                        <div id="formMsg" class="mt-3 text-xs text-center hidden"></div>
                    </form>
                </div>

                <!-- Visual Element -->
                <div class="hidden md:block relative">
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-blue-400 rounded-full blur-[7.5rem] opacity-20 animate-pulse"></div>
                    <div class="relative glass p-8 rounded-[2.5rem] shadow-2xl border-white/50 animate-float">
                        <div class="aspect-square bg-white rounded-[2rem] overflow-hidden flex items-center justify-center p-12">
                            <!-- Premium Icon Representation -->
                            <div class="w-full h-full border-4 border-dashed border-gray-100 rounded-[1.75rem] flex items-center justify-center relative">
                                <div class="absolute top-4 right-4 w-4 h-4 rounded-full bg-blue-100"></div>
                                <div class="absolute bottom-6 left-8 w-12 h-2 rounded-full bg-gray-50"></div>
                                <div class="absolute bottom-10 left-8 w-20 h-2 rounded-full bg-gray-50"></div>
                                <svg class="w-32 h-32 text-blue-500/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script nonce="<%= nonce %>">
        document.getElementById('leadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const serviceSlug = '<%= service.slug %>';
            const btn = document.getElementById('submitBtn');
            const msg = document.getElementById('formMsg');

            try {
                btn.disabled = true;
                btn.innerHTML = '<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';

                const response = await fetch('/services/lead-capture', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, serviceSlug, interest: `Waitlist: ${serviceSlug}` })
                });

                const data = await response.json();

                if (!response.ok) throw new Error(data.error || 'Failed to join waitlist');

                msg.textContent = '🎉 You are on the list! We will reach out soon.';
                msg.className = 'mt-3 text-xs text-center font-bold text-green-600 flex items-center justify-center gap-1';
                msg.classList.remove('hidden');
                document.getElementById('email').value = '';
                btn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>';
            } catch (error) {
                msg.textContent = '⚠️ ' + error.message;
                msg.className = 'mt-3 text-xs text-center font-bold text-red-600';
                msg.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = '<span>Get Early Access</span>';
            }
        });
        
        // Initialize Icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    </script>
    <%- include('../partials/sidebar-script') %>
</body>
</html>
