                                    async function pollJob(jobId) {
                                        console.log(`🔄 [pollJob] Starting poll for job: ${jobId}`);
                                        let pollCount = 0;
                                        const maxPolls = 60; // 2 minutes max

                                        const poll = setInterval(async () => {
                                            pollCount++;
                                            console.log(`🔄 [pollJob] Poll #${pollCount} for job ${jobId}`);

                                            try {
                                                const res = await fetch(`/services/ai-doc-generator/jobs/${jobId}`);
                                                const contentType = res.headers.get('content-type');
                                                console.log(`📥 [pollJob] Response status: ${res.status}, Content-Type: ${contentType}`);

                                                if (contentType?.includes('application/pdf')) {
                                                    console.log(`✅ [pollJob] Got PDF! Downloading...`);
                                                    clearInterval(poll);
                                                    const blob = await res.blob();
                                                    console.log(`📥 [pollJob] PDF blob size: ${blob.size} bytes`);
                                                    const url = URL.createObjectURL(blob);
                                                    const a = document.createElement('a');
                                                    a.href = url;
                                                    a.download = `document_${jobId}.pdf`;
                                                    a.click();
                                                    const btn = document.getElementById('convertBtn');
                                                    btn.disabled = false;
                                                    btn.textContent = 'Generate PDF';
                                                    console.log(`✅ [pollJob] Download triggered!`);
                                                    console.groupEnd();
                                                } else if (contentType?.includes('application/json')) {
                                                    const data = await res.json();
                                                    console.log(`📥 [pollJob] JSON response:`, data);

                                                    if (data.status === 'failed') {
                                                        console.error(`❌ [pollJob] Job failed:`, data.error);
                                                        clearInterval(poll);
                                                        showError(data.error || 'PDF generation failed');
                                                        const btn = document.getElementById('convertBtn');
                                                        btn.disabled = false;
                                                        btn.textContent = 'Generate PDF';
                                                    } else if (data.status === 'completed') {
                                                        // This shouldn't happen if PDF is returned correctly, but handle just in case
                                                        console.warn(`⚠️ [pollJob] Got completed JSON instead of PDF binary. Result:`, data.result);
                                                        clearInterval(poll);
                                                        showError('Unexpected response format from server');
                                                        const btn = document.getElementById('convertBtn');
                                                        btn.disabled = false;
                                                        btn.textContent = 'Generate PDF';
                                                    }
                                                    // else keep polling (pending/active/waiting)
                                                }

                                                if (pollCount >= maxPolls) {
                                                    console.error(`❌ [pollJob] Max polls reached, giving up`);
                                                    clearInterval(poll);
                                                    showError('PDF generation timed out');
                                                    const btn = document.getElementById('convertBtn');
                                                    btn.disabled = false;
                                                    btn.textContent = 'Generate PDF';
                                                }
                                            } catch (e) {
                                                console.error(`❌ [pollJob] Fetch error:`, e);
                                                clearInterval(poll);
                                                showError('Failed to check job status');
                                                const btn = document.getElementById('convertBtn');
                                                btn.disabled = false;
                                                btn.textContent = 'Generate PDF';
                                            }
                                        }, 2000);
                                    }

                                    function showError(msg) {
                                        const el = document.getElementById('errorMessage');
                                        if (el) { el.textContent = msg; document.getElementById('errorAlert').classList.remove('hidden'); }
                                    }
                                    document.getElementById('closeErrorBtn')?.addEventListener('click', () => document.getElementById('errorAlert').classList.add('hidden'));
                                </script>

