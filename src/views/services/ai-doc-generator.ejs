                                    <script nonce="<%= nonce %>">
                                        // Initialize ServiceCore after library loads
                                        if (typeof ServiceCore !== 'undefined' && window.SERVICE_CONTEXT) {

                                            // [DEBUG] Manual HTML Sync & Main Editor Sync
                                            // Moved from global usage inside nested block
                                            const syncHtmlInput = (e) => {
                                                const val = e.target.value;
                                                const hiddenInput = document.getElementById('hiddenHtmlInput');
                                                if (hiddenInput && hiddenInput.value !== val) {
                                                    hiddenInput.value = val;
                                                    window.updatePreview();
                                                }
                                            };

                                            document.getElementById('mainHtmlEditor')?.addEventListener('input', syncHtmlInput);
                                            document.getElementById('debugHtmlEditor')?.addEventListener('input', syncHtmlInput);

                                            // Initialize Preview on Load if content exists
                                            if (document.getElementById('hiddenHtmlInput')?.value) {
                                                window.updatePreview();
                                            }

                                            window.serviceCore = new ServiceCore({ formId: 'aiGenerateForm' });

                                            // [FIX] Listen for App Toggles from Partial
                                            window.addEventListener('service-access-changed', (e) => {
                                                console.log('🔄 [Service Access] Update received:', e.detail);
                                                const { appId, enabled } = e.detail;

                                                // Update if the toggled app matches our current context
                                                // Access last known state or default from context
                                                const lastState = window.serviceCore.lastState || {};

                                                // If we don't have a lastState appId, try to get it from the DOM or context
                                                const currentAppId = lastState.appId || document.getElementById('generatorAppId')?.value;

                                                if (!currentAppId || currentAppId === appId) {
                                                    const newState = {
                                                        ...lastState,
                                                        isEnabled: enabled,
                                                        appId: appId // Ensure appId is present
                                                    };

                                                    // Force update UI
                                                    window.serviceCore.updateAccessState(newState);

                                                    // If enabled, ensure we aren't showing the 'no_app_context' error mistakenly
                                                    if (enabled) {
                                                        window.serviceCore.hideBlocker();
                                                    }
                                                }
                                            });
                                        }
                                    </script>

