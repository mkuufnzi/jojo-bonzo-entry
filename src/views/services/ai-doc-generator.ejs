                                        // Update Text
                                        if (titleDisplay) titleDisplay.textContent = 'AI Agent Working';
                                        if (stepDisplay) stepDisplay.textContent = initialStep;

                                        // Animation Loop (Fake Progress + Real Timer)
                                        let progress = 0;
                                        jobTimerInterval = setInterval(() => {
                                            const elapsed = Math.floor((Date.now() - jobStartTime) / 1000);
                                            const mins = String(Math.floor(elapsed / 60)).padStart(2, '0');
                                            const secs = String(elapsed % 60).padStart(2, '0');

                                            if (timerDisplay) timerDisplay.textContent = `${mins}:${secs}`;

                                            // Fake log scale progress (fast start, slow finish)
                                            if (progress < 90) {
