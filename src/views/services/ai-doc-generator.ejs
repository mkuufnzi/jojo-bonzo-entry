                                    async function pollForAnalysisOnly(jobId) {
                                        console.log('🔍 [Poll] Starting Analysis Poll for Job:', jobId);
                                        return new Promise((resolve, reject) => {
                                            let pollAttempts = 0;
                                            const pollInterval = setInterval(async () => {
                                                pollAttempts++;
                                                try {
                                                    if (pollAttempts > 60) {
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error('Analysis timed out.'));
                                                    }
                                                    const res = await fetch(`/services/ai-doc-generator/jobs/${jobId}`);
                                                    if (!res.ok) throw new Error('Status check failed');
                                                    const data = await res.json();
                                                    console.log('🔍 [Poll] Status:', data.status);

                                                    if (data.status === 'completed' || data.status === 'pending_hil') {
                                                        clearInterval(pollInterval);
                                                        // Handle both wrapped 'result' (standard) and flat (HITL) responses
                                                        let result = data.result || data;

                                                        // [FIX] Handle Array wrapping (N8N sometimes returns array)
                                                        if (Array.isArray(result) && result.length > 0) {
                                                            console.log('⚠️ [Frontend] Unwrapping array result in Analysis:', result);
                                                            result = result[0];
                                                        }

                                                        console.log('🔍 [Poll] Job Ready (Phase 1). Result keys:', Object.keys(result));
                                                        console.log('🔍 [Poll] result.jobId:', result.jobId);
                                                        console.log('🔍 [Poll] result.requestId:', result.requestId);

                                                        // Store N8N's IDs for Phase 2 (/generate) call
                                                        // N8N provides jobId and requestId in its response
                                                        // RELAXED CHECK: Accept any string ID, don't enforce UUID format (some providers use different formats)
                                                        if (result.jobId && (typeof result.jobId === 'string' || typeof result.jobId === 'number')) {
                                                            window.currentJobId = String(result.jobId);
                                                            console.log('💾 [Context] Set window.currentJobId:', window.currentJobId);
                                                        } else {
                                                            console.warn('⚠️ [Context] result.jobId is missing or invalid:', result.jobId);
                                                        }

                                                        if (result.requestId && (typeof result.requestId === 'string' || typeof result.requestId === 'number')) {
                                                            window.currentRequestId = String(result.requestId);
                                                            console.log('💾 [Context] Set window.currentRequestId:', window.currentRequestId);
                                                        } else if (!window.currentRequestId && window.currentJobId) {
                                                            window.currentRequestId = window.currentJobId; // Fallback
                                                        } else {
                                                            console.warn('⚠️ [Context] result.requestId is missing or invalid:', result.requestId);
                                                        }
                                                        console.log('💾 [Context] Final N8N IDs - jobId:', window.currentJobId, 'requestId:', window.currentRequestId);

                                                        // Extract summary from new HITL response structure
                                                        let msg = "Ready to generate.";
                                                        if (result.requestAnalysis?.review?.summary) {
                                                            msg = result.requestAnalysis.review.summary;
                                                        } else if (result.clarificationMessage) {
                                                            msg = result.clarificationMessage; // Fallback for old format
                                                        } else if (result.summary) {
                                                            msg = result.summary; // Fallback for old format
                                                        }

                                                        console.log('🔍 [Poll] Showing Modal with summary:', msg);

                                                        document.getElementById('reviewContent').innerHTML = msg;
                                                        document.getElementById('summaryInput').value = msg; // Set for Phase 2

                                                        const modal = document.getElementById('reviewModal');
                                                        if (modal) {
                                                            modal.classList.remove('hidden');
                                                            modal.classList.add('flex');
                                                            console.log('🔍 [Poll] Modal classes updated:', modal.className);

                                                            // Show Reopen Button
                                                            const reopenBtn = document.getElementById('reopenReviewBtn');
                                                            if (reopenBtn) reopenBtn.classList.remove('hidden');
                                                            const headerReopenPlanBtn = document.getElementById('headerReopenPlanBtn');
                                                            if (headerReopenPlanBtn) headerReopenPlanBtn.classList.remove('hidden');

                                                            // Initialize Lucide icons for modal content
                                                            if (typeof lucide !== 'undefined') lucide.createIcons();

                                                            // Reset Button State for new interaction
                                                            const confirmBtn = document.getElementById('confirmGenerateBtn');
                                                            if (confirmBtn) {
                                                                confirmBtn.disabled = false;
                                                                confirmBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                                                                // Fix: Reset button text
                                                                confirmBtn.innerHTML = `<span>Generate Draft</span><i data-lucide="arrow-right" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform"></i>`;
                                                                if (typeof lucide !== 'undefined') lucide.createIcons();
                                                            }
                                                        } else {
                                                            console.error('❌ [Poll] Critical: reviewModal element not found!');
                                                        }
                                                        stopJobTimer(true);
                                                        resolve();
                                                    } else if (data.status === 'failed') {
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error(data.error || 'Analysis failed'));
                                                    }
                                                } catch (e) {
                                                    console.error('❌ [Poll] Error:', e);
                                                    clearInterval(pollInterval);
                                                    reject(e);
                                                }
                                            }, 2000);
                                        });
                                    }

                                    async function pollForGeneration(jobId) {
                                        return new Promise((resolve, reject) => {
                                            let pollAttempts = 0;
                                            const pollInterval = setInterval(async () => {
                                                pollAttempts++;
                                                try {
                                                    if (pollAttempts > 300) {
                                                        clearInterval(pollInterval);
                                                        reject(new Error('Generation timed out.'));
                                                    }
                                                    const res = await fetch(`/services/ai-doc-generator/jobs/${jobId}`);
                                                    if (!res.ok) throw new Error('Status check failed');
                                                    const data = await res.json();

                                                    if (data.status === 'completed') {
                                                        clearInterval(pollInterval);
                                                        let result = data.result;

                                                        // Fix: Handle Array wrapping (N8N sometimes returns array)
                                                        if (Array.isArray(result) && result.length > 0) {
                                                            console.log('⚠️ [Frontend] Unwrapping array result:', result);
                                                            result = result[0];
                                                        }

                                                        // Fix: Handle Double-Encoded JSON or Markdown in 'html' field
                                                        if (result && typeof result.html === 'string') {
                                                            let rawHtml = result.html.trim();

                                                            // 1. Try Regex Extraction first (Most Robust for HTML)
                                                            const htmlMatch = rawHtml.match(/(<!DOCTYPE html[\s\S]*<\/html>|<html[\s\S]*<\/html>)/i);
                                                            if (htmlMatch) {
                                                                console.log('✅ [Frontend] Extracted raw HTML via Regex');
                                                                result.html = htmlMatch[0];
                                                            }
                                                            else {
                                                                // 2. Check if it looks like a JSON object inside string
                                                                if (rawHtml.startsWith('{') || rawHtml.startsWith('"{\\"')) {
                                                                    try {
                                                                        console.log('⚠️ [Frontend] Detected potential JSON in HTML field, attempting parse...');
                                                                        let parsed = JSON.parse(rawHtml);

                                                                        // Double unwrap if needed (some LLMs over-escape)
                                                                        if (typeof parsed === 'string') {
                                                                            try { parsed = JSON.parse(parsed); } catch (e) { /* ignore secondary parse error */ }
                                                                        }

                                                                        if (parsed && parsed.html) {
                                                                            console.log('✅ [Frontend] Successfully extracted HTML from JSON wrapper');
                                                                            result.html = parsed.html;
                                                                        }
                                                                    } catch (e) {
                                                                        console.warn('⚠️ [Frontend] JSON parse failed, using raw value:', e);
                                                                    }
                                                                }
                                                            }
                                                        }

                                                        // [FIX] Ensure result.html is a string before assignment
                                                        let finalHtmlString = result.html;
                                                        if (typeof finalHtmlString === 'object' && finalHtmlString !== null) {
                                                            console.warn('⚠️ [Frontend] HTML is object, unwrapping/stringifying...');
                                                            finalHtmlString = finalHtmlString.html || finalHtmlString.content || JSON.stringify(finalHtmlString);
                                                        }

                                                        document.getElementById('hiddenHtmlInput').value = finalHtmlString || '';

                                                        // Update both editors to keep them in sync
                                                        const mainEditor = document.getElementById('mainHtmlEditor');
                                                        const debugEditor = document.getElementById('debugHtmlEditor');
                                                        if (mainEditor) mainEditor.value = finalHtmlString || '';
                                                        if (debugEditor) debugEditor.value = finalHtmlString || '';

                                                        document.getElementById('pdfAppId').value = document.getElementById('generatorAppId').value;

                                                        window.switchTab('editor');
                                                        window.updateUIStates();
                                                        setBtnState(false);

                                                        // Clear summary for next run
                                                        document.getElementById('summaryInput').value = '';
                                                        resolve();
                                                    } else if (data.status === 'failed') {
                                                        clearInterval(pollInterval);
                                                        reject(new Error(data.error || 'Generation failed'));
                                                    }
                                                } catch (e) { clearInterval(pollInterval); reject(e); }
                                            }, 2000);
                                        });
                                    }

