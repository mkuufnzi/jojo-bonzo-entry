                            <%- include('../partials/toast') %>

                                <!-- Styles Extracted to /css/services/ai-doc-generator.css -->

                                <script nonce="<%= nonce %>">
                                    // ============================================================
                                    // SERVICE CONFIGURATION (Injected from server, sanitized)
                                    // Contains: actions, features, limits - NO sensitive data
                                    // ============================================================
                                    window.SERVICE_CONFIG = JSON.parse(decodeURIComponent("<%- encodeURIComponent(JSON.stringify(serviceConfig || {})) %>"));

                                    const aiLimitReached = '<%= user.aiLimitReached %>' === 'true';

                                    // --- UI Transitions ---
                                    window.toggleEditor = function () {
                                        const side = document.getElementById('editorSide');
                                        const main = document.getElementById('previewSide');
                                        const btn = document.getElementById('editorToggleBtn');

                                        if (side.classList.contains('hidden')) {
                                            side.classList.remove('hidden');
                                            side.classList.add('flex');
                                            main.classList.remove('lg:col-span-12');
                                            main.classList.add('lg:col-span-7');
                                            btn.classList.add('bg-blue-50', 'text-blue-600', 'border-blue-500');
                                        } else {
                                            side.classList.add('hidden');
                                            side.classList.remove('flex');
                                            main.classList.remove('lg:col-span-7');
                                            main.classList.add('lg:col-span-12');
                                            btn.classList.remove('bg-blue-50', 'text-blue-600', 'border-blue-500');
                                        }
                                        if (typeof lucide !== 'undefined') lucide.createIcons();
                                    }

                                    window.applyMagicSuggestion = function (type) {
                                        const input = document.getElementById('documentTypeInput');
                                        if (input) input.value = type;

                                        // Trigger Smart Defaults for PDF
                                        if (window.applySmartDefaults) window.applySmartDefaults();

                                        const promptInput = document.getElementById('promptInput');
                                        const contextInput = document.getElementById('contextInput');
                                        const template = docTemplates[type] || { prompt: docTemplates.other, context: '' };

                                        // Temporarily pause dirty tracking for template application
                                        const wasDirty = window.isWorkDirty;
                                        window.isWorkDirty = false;

                                        if (promptInput) {
                                            promptInput.value = typeof template === 'string' ? template : template.prompt;
                                            promptInput.dispatchEvent(new Event('input'));
                                        }
                                        if (contextInput) {
                                            contextInput.value = template.context || '';
                                            contextInput.dispatchEvent(new Event('input'));
                                        }

                                        // Restore previous dirty state but don't set dirty from template
                                        window.isWorkDirty = wasDirty;

                                        window.scrollTo({ top: 0, behavior: 'smooth' });
                                    }

                                    // --- Zoom Dynamics ---
                                    window.currentZoom = 1;
                                    window.isAutoFit = true;

                                    window.applyZoom = function () {
                                        const area = document.getElementById('previewArea');
                                        const zoomValue = document.getElementById('zoomValue');
                                        const zoomRange = document.getElementById('zoomRange');

                                        if (area) {
                                            area.style.transform = `scale(${window.currentZoom})`;

                                            // Update visual indicators
                                            if (zoomValue) zoomValue.textContent = `${Math.round(window.currentZoom * 100)}%`;
                                            if (zoomRange) zoomRange.value = window.currentZoom * 100;

                                            // Adjust container height to account for scale
                                            const scaledHeight = area.getBoundingClientRect().height;
                                            area.parentElement.style.minHeight = `${scaledHeight + 100}px`;
                                        }
                                    }

                                    window.autoFitPreview = function () {
                                        const container = document.getElementById('previewContainer');
                                        const area = document.getElementById('previewArea');

                                        if (!container || !area) return;

