<%- include('../partials/head', { title: 'AI Document Generator - Floovioo ', additionalCss: '/css/services/ai-doc-generator.css' }) %>

    <body class="bg-gray-100 min-h-screen font-sans">
        <%- include('../partials/sidebar') %>

            <div id="mainContent" class="flex flex-col min-h-screen ">
                <%- include('../partials/dashboard-header', { title: 'AI Document Generator' , user: user }) %>

                    <!-- Header Row (Compact) -->
                    <div class="bg-white border-b border-slate-200 sticky top-0 lg:static z-30">
                        <div
                            class="max-w-[100rem] mx-auto px-4 lg:px-8 py-3 flex flex-row flex-nowrap items-center justify-between gap-3">
                            <div class="flex items-center gap-3 min-w-0 flex-1">
                                <div class="p-1.5 bg-blue-50 rounded-md flex-shrink-0">
                                    <i data-lucide="sparkles" class="w-4 h-4 text-blue-600"></i>
                                </div>
                                <div class="flex flex-col min-w-0">
                                    <h1 class="text-lg sm:text-xl font-bold text-slate-900 leading-none flex items-center gap-2 truncate">
                                        AI Document Generator
                                        <span id="quotaDisplay"
                                            class="hidden px-2 py-0.5 rounded text-[0.625rem] font-bold bg-blue-50 text-blue-600 border border-blue-100 flex-shrink-0">
                                            Checking...
                                        </span>
                                    </h1>
                                    <p class="text-sm font-medium text-slate-500 mt-1 truncate">Automated document generation &
                                        design</p>
                                </div>
                            </div>

                            <!-- Settings / More Actions Menu -->
                            <div class="relative" id="header-settings-container">
                                <button id="header-settings-btn"
                                    class="p-2 sm:px-2.5 sm:py-2 bg-slate-50 text-slate-500 border border-slate-200 rounded-lg hover:bg-white hover:text-blue-600 hover:border-blue-200 transition-all shadow-sm group"
                                    aria-label="Service Settings">
                                    <i data-lucide="settings-2"
                                        class="w-5 h-5 group-hover:rotate-45 transition-transform duration-500 ease-out"></i>
                                </button>

                                <!-- Dropdown Menu -->
                                <div id="header-settings-dropdown"
                                    class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl ring-1 ring-slate-200 py-1 z-50 animate-in fade-in slide-in-from-top-1 duration-200 origin-top-right">
                                    <button onclick="openActionModal('about')"
                                        class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                        <i data-lucide="info"
                                            class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                        About Service
                                    </button>
                                    <button onclick="openActionModal('api')"
                                        class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                        <i data-lucide="code-2"
                                            class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                        API Documentation
                                    </button>
                                    <div class="h-px bg-slate-100 my-1 mx-2"></div>
                                    <button onclick="openActionModal('support')"
                                        class="w-full text-left px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50 hover:text-blue-600 flex items-center gap-3 transition-colors group/item">
                                        <i data-lucide="help-circle"
                                            class="w-4 h-4 text-slate-400 group-hover/item:text-blue-500"></i>
                                        Get Support
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dropdown Logic -->
                    <script nonce="<%= nonce %>">
                        document.addEventListener('DOMContentLoaded', () => {
                            const settingsBtn = document.getElementById('header-settings-btn');
                            const settingsDropdown = document.getElementById('header-settings-dropdown');
                            const settingsContainer = document.getElementById('header-settings-container');

                            if (settingsBtn && settingsDropdown && settingsContainer) {
                                settingsBtn.addEventListener('click', (e) => {
                                    e.stopPropagation();
                                    settingsDropdown.classList.toggle('hidden');
                                });

                                document.addEventListener('click', (e) => {
                                    if (!settingsContainer.contains(e.target)) {
                                        settingsDropdown.classList.add('hidden');
                                    }
                                });
                            }
                        });
                    </script>

                    <!-- Service Navigation (Compact) -->
                    <div class="bg-white border-b border-slate-100 sticky top-[56px] md:top-0 z-20">
                        <div class="max-w-[100rem] mx-auto px-6 lg:px-8">
                            <nav
                                class="-mb-px flex flex-nowrap overflow-x-auto no-scrollbar gap-4 sm:gap-6 justify-start">
                                <button data-service-tab="home" id="nav-home"
                                    class="nav-tab-active flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 font-semibold text-sm transition-all">
                                    Workspace
                                </button>
                                <button data-service-tab="history" id="nav-history"
                                    class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                    Activity
                                </button>
                                <button data-service-tab="usage" id="nav-usage"
                                    class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                    Usage
                                </button>
                                <button data-service-tab="apps" id="nav-apps"
                                    class="flex-shrink-0 whitespace-nowrap py-3 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-medium text-sm transition-all">
                                    API Keys
                                </button>
                            </nav>
                        </div>
                    </div>

                    <main class="flex-1 flex flex-col relative overflow-hidden min-w-0">

                        <!-- Scrollable Body -->
                        <div class="flex-1 overflow-y-auto flex flex-col">
                            <div class="max-w-[100rem] w-full mx-auto px-6 lg:px-8 py-3 flex-1 flex flex-col">

                                <!-- Tab Content: Home (Service Workspace) -->
                                <div id="tab-content-home"
                                    class="service-tab-content flex-1 flex flex-col relative text-left min-w-0">

                                    <!-- Persistent Blockers -->
                                    <div id="accessBlocker"
                                        class="<%= locals.accessDenied ? 'flex' : 'hidden' %> w-full flex-1 z-50 bg-white justify-center items-start">
                                        <%- include('../partials/service-access-blocker') %>
                                    </div>
                                    <div id="limitBlocker"
                                        class="<%= locals.limitReached ? 'flex' : 'hidden' %> w-full flex-1 z-50 bg-white justify-center items-start">
                                        <%- include('../partials/limit-reached-block') %>
                                    </div>

                                    <% if (!locals.accessDenied && !locals.limitReached) { %>
                                        <!-- Standard 2-Column Workspace Layout -->
                                        <div
                                            class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 flex-1 min-h-0 lg:min-h-[37.5rem] items-stretch min-w-0">

                                            <!-- Wide Column: Service UI Workspace (9/12) -->
                                            <div class="lg:col-span-9 space-y-4 flex flex-col flex-1 min-w-0">

                                                <!-- Workspace Sub-Header / Step Flow -->
                                                <div
                                                    class="minimal-card px-4 py-2 border-b border-slate-100 bg-white flex flex-wrap gap-2 items-center justify-between sm:flex-nowrap">
                                                    <div
                                                        class="flex items-center gap-4 overflow-x-auto no-scrollbar max-w-full">
                                                        <button id="tabGenerator"
                                                            onclick="window.switchTab('generator')"
                                                            class="flex-shrink-0 flex items-center px-4 py-1.5 rounded-md text-[0.8125rem] font-black uppercase tracking-widest transition-all bg-slate-50 border border-slate-200 text-blue-600">
                                                            Generate
                                                        </button>
                                                        <div class="h-4 w-px bg-slate-100 flex-shrink-0"></div>
                                                        <button id="tabEditor" onclick="window.switchTab('editor')"
                                                            class="flex-shrink-0 flex items-center px-4 py-1.5 rounded-md text-[0.8125rem] font-black uppercase tracking-widest transition-all border border-transparent text-gray-400 opacity-50 cursor-not-allowed">
                                                            Preview
                                                        </button>
                                                    </div>
                                                    <div class="flex items-center gap-3 flex-shrink-0 ml-auto sm:ml-0">
                                                        <div class="flex items-center gap-1.5">
                                                            <div
                                                                class="w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse shadow-[0_0_0.3125rem_rgba(59,130,246,0.5)]">
                                                            </div>
                                                            <span
                                                                class="text-[0.75rem] font-bold text-slate-400 uppercase tracking-widest">Ready</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Error Alert -->
                                                <div id="errorAlert" class="hidden">
                                                    <div
                                                        class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-xl shadow-sm flex items-start">
                                                        <div class="flex-shrink-0">
                                                            <i data-lucide="alert-circle"
                                                                class="h-5 w-5 text-red-500"></i>
                                                        </div>
                                                        <div class="ml-3 flex-1">
                                                            <p id="errorMessage"
                                                                class="text-sm font-bold text-red-800 uppercase tracking-tight">
                                                            </p>
                                                        </div>
                                                        <button id="closeErrorBtn"
                                                            class="ml-auto text-red-400 hover:text-red-500">
                                                            <i data-lucide="x" class="h-4 w-4"></i>
                                                        </button>
                                                    </div>
                                                </div>

                                                <!-- Generator Dashboard -->
                                                <div id="generatorGroup" class="min-w-0 w-full">
                                                    <div class="space-y-4 min-w-0 w-full">
                                                        <!-- Document Drafting -->
                                                        <div
                                                            class="minimal-card relative overflow-hidden flex flex-col min-h-[31.25rem] min-w-0 w-full">
                                                            <div
                                                                class="px-4 py-3 border-b border-slate-100 flex items-center justify-between bg-white">
                                                                <div class="flex items-center gap-2.5">
                                                                    <i data-lucide="pen-tool"
                                                                        class="w-4 h-4 text-blue-600"></i>
                                                                    <h2
                                                                        class="text-[0.8125rem] font-bold text-gray-900 uppercase tracking-widest">
                                                                        Document Prompt</h2>
                                                                </div>
                                                                <button type="button" id="headerReopenDraftBtn"
                                                                    onclick="reopenLastDraft()"
                                                                    class="hidden text-[0.625rem] font-black text-emerald-600 uppercase tracking-widest hover:bg-emerald-50 px-2 py-1 rounded transition-colors flex items-center gap-1.5">
                                                                    <i data-lucide="rotate-ccw" class="w-3 h-3"></i>
                                                                    View Draft
                                                                </button>
                                                            </div>

                                                            <!-- Blueprint Selection (Horizontal Scroll) -->
                                                            <div
                                                                class="bg-slate-50/50 border-b border-slate-100 px-4 py-3">
                                                                <p
                                                                    class="text-[0.625rem] font-black text-slate-400 uppercase tracking-[0.15em] mb-2.5 ml-1">
                                                                    Document Templates</p>
                                                                <div
                                                                    class="flex flex-nowrap gap-2 overflow-x-auto no-scrollbar pb-1">
                                                                    <% const blueprints=[ { id: 'resume' ,
                                                                        label: 'Resume' , icon: 'user' }, {
                                                                        id: 'cover_letter' , label: 'Cover Letter' ,
                                                                        icon: 'file-text' }, { id: 'invoice' ,
                                                                        label: 'Invoice' , icon: 'receipt' }, {
                                                                        id: 'proposal' , label: 'Proposal' ,
                                                                        icon: 'briefcase' }, { id: 'contract' ,
                                                                        label: 'Contract' , icon: 'pen-tool' }, {
                                                                        id: 'letter' , label: 'Letter' , icon: 'mail' },
                                                                        { id: 'receipt' , label: 'Receipt' ,
                                                                        icon: 'file-check' }, { id: 'report' ,
                                                                        label: 'Report' , icon: 'clipboard-list' }, {
                                                                        id: 'memo' , label: 'Memo' , icon: 'sticker' },
                                                                        { id: 'presentation' , label: 'Presentation' ,
                                                                        icon: 'monitor-play' } ] %>
                                                                        <% blueprints.forEach(bp=> { %>
                                                                            <button type="button"
                                                                                onclick="applyMagicSuggestion('<%= bp.id %>')"
                                                                                class="flex-shrink-0 flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg hover:border-blue-300 hover:bg-white hover:shadow-minimal transition-all group active:scale-95">
                                                                                <i data-lucide="<%= bp.icon %>"
                                                                                    class="w-3.5 h-3.5 text-slate-300 group-hover:text-blue-500 transition-colors"></i>
                                                                                <span
                                                                                    class="text-[0.6875rem] font-black text-slate-500 group-hover:text-blue-600 uppercase tracking-widest whitespace-nowrap">
                                                                                    <%= bp.label %>
                                                                                </span>
                                                                            </button>
                                                                            <% }) %>
                                                                </div>
                                                            </div>

                                                            <form id="aiGenerateForm"
                                                                class="flex-1 flex flex-col relative transition-opacity duration-300">
                                                                <!-- Hidden Data for JS Context -->
                                                                <script type="application/json"
                                                                    id="service-context-data" nonce="<%= nonce %>">
                                                    <%- typeof serviceContext !== 'undefined' && serviceContext ? JSON.stringify(serviceContext) : 'null' %>
                                                </script>
                                                                <!-- Scrollable Accordion Container -->
                                                                <div class="p-4 flex-1 space-y-2 overflow-y-auto">

                                                                    <!-- Section 1: Document Description (Expanded by default) -->
                                                                    <div class="accordion-section bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200"
                                                                        data-section="prompt">
                                                                        <button type="button"
                                                                            onclick="toggleAccordion('prompt')"
                                                                            class="w-full px-4 py-3 bg-slate-50 border-b border-slate-100 flex items-center justify-between hover:bg-slate-100 transition-colors group">
                                                                            <label
                                                                                class="text-[0.75rem] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2 cursor-pointer group-hover:text-blue-600">
                                                                                <i data-lucide="message-square"
                                                                                    class="w-3.5 h-3.5"></i>
                                                                                Describe Your Document
                                                                            </label>
                                                                            <div class="flex items-center gap-2">
                                                                                <span id="prompt-preview"
                                                                                    class="text-[0.625rem] font-medium text-slate-300 truncate max-w-[10rem] hidden"></span>

                                                                                <div id="headerReopenPlanBtn"
                                                                                    onclick="event.stopPropagation(); reopenReviewModal()"
                                                                                    class="hidden cursor-pointer text-[0.625rem] font-black text-indigo-600 uppercase tracking-widest hover:bg-indigo-50 px-2 py-1 rounded transition-colors flex items-center gap-1.5 mr-2">
                                                                                    <i data-lucide="sparkles"
                                                                                        class="w-3 h-3"></i> View Plan
                                                                                </div>

                                                                                <i data-lucide="chevron-down"
                                                                                    class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-transform accordion-icon"
                                                                                    id="icon-prompt"></i>
                                                                            </div>
                                                                        </button>
                                                                        <div class="accordion-content px-4 pb-4 pt-2"
                                                                            id="content-prompt">
                                                                            <textarea id="promptInput" name="prompt"
                                                                                rows="6"
                                                                                class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-y placeholder:text-slate-400 text-sm"
                                                                                placeholder="Describe what you want to create..."></textarea>
                                                                            <p
                                                                                class="mt-1.5 text-[0.5625rem] font-medium text-slate-400 uppercase tracking-widest">
                                                                                Purpose, tone, and key points for the AI
                                                                            </p>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Section 2: Source Data / Context (Collapsed by default) -->
                                                                    <div class="accordion-section bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200"
                                                                        data-section="context">
                                                                        <button type="button"
                                                                            onclick="toggleAccordion('context')"
                                                                            class="w-full px-4 py-3 bg-slate-50 border-b border-slate-100 flex items-center justify-between hover:bg-slate-100 transition-colors group">
                                                                            <label
                                                                                class="text-[0.75rem] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2 cursor-pointer group-hover:text-blue-600">
                                                                                <i data-lucide="database"
                                                                                    class="w-3.5 h-3.5"></i>
                                                                                Source Data / Context
                                                                            </label>
                                                                            <div class="flex items-center gap-2">
                                                                                <span id="context-preview"
                                                                                    class="text-[0.625rem] font-medium text-slate-300 truncate max-w-[10rem] hidden"></span>
                                                                                <i data-lucide="chevron-down"
                                                                                    class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-transform accordion-icon"
                                                                                    id="icon-context"></i>
                                                                            </div>
                                                                        </button>
                                                                        <div class="accordion-content px-4 pb-4 pt-2"
                                                                            id="content-context">
                                                                            <textarea id="contextInput" name="context"
                                                                                rows="6"
                                                                                class="w-full px-4 py-3 bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-y placeholder:text-slate-400 text-sm font-mono min-h-[10rem]"
                                                                                placeholder="Paste any data, text, or context here..."></textarea>
                                                                            <p
                                                                                class="mt-1.5 text-[0.5625rem] font-medium text-slate-400 uppercase tracking-widest">
                                                                                Raw data for the AI to use in generation
                                                                            </p>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Section 3: Attach Files (Collapsed by default) -->
                                                                    <div class="accordion-section bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200"
                                                                        data-section="files">
                                                                        <button type="button"
                                                                            onclick="toggleAccordion('files')"
                                                                            class="w-full px-4 py-3 bg-slate-50 border-b border-slate-100 flex items-center justify-between hover:bg-slate-100 transition-colors group">
                                                                            <label
                                                                                class="text-[0.75rem] font-black text-slate-500 uppercase tracking-widest flex items-center gap-2 cursor-pointer group-hover:text-blue-600">
                                                                                <i data-lucide="paperclip"
                                                                                    class="w-3.5 h-3.5"></i>
                                                                                Attach Files
                                                                            </label>
                                                                            <div class="flex items-center gap-2">
                                                                                <span id="files-preview"
                                                                                    class="text-[0.625rem] font-medium text-slate-300">No
                                                                                    files</span>
                                                                                <i data-lucide="chevron-down"
                                                                                    class="w-4 h-4 text-slate-300 group-hover:text-blue-500 transition-transform accordion-icon rotate-[-90deg]"
                                                                                    id="icon-files"></i>
                                                                            </div>
                                                                        </button>
                                                                        <div class="accordion-content px-4 pb-4 pt-2 hidden"
                                                                            id="content-files">
                                                                            <div class="flex items-center gap-3">
                                                                                <button type="button"
                                                                                    onclick="document.getElementById('fileInput').click()"
                                                                                    class="px-4 py-2 bg-white text-slate-600 border border-slate-200 rounded-lg text-[0.75rem] font-black uppercase tracking-widest hover:border-blue-300 hover:text-blue-600 transition-all flex items-center gap-2 group">
                                                                                    <i data-lucide="upload"
                                                                                        class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100"></i>
                                                                                    Choose Files
                                                                                </button>
                                                                                <input type="file" id="fileInput"
                                                                                    multiple class="hidden"
                                                                                    data-ignore-dirty>
                                                                                <span id="selectedFilesCount"
                                                                                    class="text-[0.625rem] font-bold text-slate-400 uppercase tracking-widest">No
                                                                                    files selected</span>
                                                                            </div>
                                                                            <div id="fileList"
                                                                                class="mt-3 space-y-1 text-[0.5625rem] font-medium text-slate-400 uppercase tracking-widest">
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <!-- Hidden State Management -->
                                                                    <input type="hidden" name="type"
                                                                        id="documentTypeInput" value="report">
                                                                    <input type="hidden" name="tone" id="toneInput"
                                                                        value="professional">
                                                                    <input type="hidden" name="theme" id="themeInput"
                                                                        value="modern">
                                                                    <input type="hidden" name="summary"
                                                                        id="summaryInput">
                                                                </div>

                                                                <!-- Sticky Footer with Generate Button -->
                                                                <div
                                                                    class="px-4 py-3 bg-gradient-to-t from-white via-white to-transparent border-t border-slate-100 flex flex-wrap items-center justify-between gap-3 sticky bottom-0 z-10">
                                                                    <div class="flex flex-wrap items-center gap-2">
                                                                        <div id="fileStatus"
                                                                            class="hidden items-center px-2.5 py-1 bg-blue-50 border border-blue-100 rounded-md text-[0.5rem] font-black text-blue-600 uppercase tracking-widest">
                                                                            <i data-lucide="paperclip"
                                                                                class="w-2.5 h-2.5 mr-1.5"></i>
                                                                            <span id="fileCountText">0 Files</span>
                                                                        </div>
                                                                        <button type="button" id="reopenReviewBtn"
                                                                            onclick="reopenReviewModal()"
                                                                            class="hidden px-3 py-1 bg-indigo-50 text-indigo-600 border border-indigo-100 rounded-md text-[0.625rem] font-black uppercase tracking-widest hover:bg-indigo-100 transition-all flex items-center gap-2">
                                                                            <i data-lucide="sparkles"
                                                                                class="w-3 h-3"></i> View Plan
                                                                        </button>
                                                                        <button type="button" id="reopenDraftBtnGen"
                                                                            onclick="reopenLastDraft()"
                                                                            class="hidden px-3 py-1 bg-emerald-50 text-emerald-600 border border-emerald-100 rounded-md text-[0.625rem] font-black uppercase tracking-widest hover:bg-emerald-100 transition-all flex items-center gap-2">
                                                                            <i data-lucide="file-text"
                                                                                class="w-3 h-3"></i> View Draft
                                                                        </button>
                                                                    </div>

                                                                    <button type="submit" id="generateBtn"
                                                                        class="w-full sm:w-auto px-6 py-2.5 bg-blue-600 text-white rounded-lg font-black text-[0.6875rem] uppercase tracking-widest shadow-lg shadow-blue-500/20 hover:bg-blue-700 hover:shadow-xl transition-all flex items-center justify-center group active:scale-[0.98]">
                                                                        <span id="btnText">Generate Document</span>
                                                                        <i id="btnIcon" data-lucide="sparkles"
                                                                            class="ml-2 w-3.5 h-3.5 fill-white group-hover:scale-110 transition-transform"></i>
                                                                        <div id="btnSpinner" class="hidden ml-2">
                                                                            <div
                                                                                class="w-3.5 h-3.5 border-2 border-white/30 border-t-white rounded-full animate-spin">
                                                                            </div>
                                                                        </div>
                                                                    </button>
                                                                </div>
                                                            </form>
                                                        </div>


                                                    </div>
                                                </div>

                                                <div id="editorGroup"
                                                    class="hidden animate-in fade-in duration-500 flex flex-col flex-1">
                                                    <!-- Action Bar (Compact) -->
                                                    <div
                                                        class="flex flex-col md:flex-row gap-4 justify-between items-start md:items-center minimal-card px-4 py-3 bg-white border-b border-slate-100 mb-4">
                                                        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                                                            <button onclick="window.switchTab('generator')"
                                                                class="group flex items-center text-[0.75rem] font-black text-slate-500 bg-slate-50 border border-slate-200 px-4 py-2 rounded-lg hover:bg-white hover:text-blue-600 transition-all uppercase tracking-widest whitespace-nowrap">
                                                                <i data-lucide="chevron-left"
