                                                    class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <!-- Draft Review Modal (Phase 2 HITL) -->
                                <div id="draftModal"
                                    class="fixed inset-0 z-[120] hidden items-center justify-center p-4 bg-slate-900/60 backdrop-blur-md transition-all">
                                    <div
                                        class="bg-white border border-slate-200 rounded-2xl w-full max-w-3xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
                                        <div
                                            class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-emerald-50/50">
                                            <div class="flex items-center gap-3">
                                                <div class="p-2 bg-emerald-100 rounded-lg text-emerald-600">
                                                    <i data-lucide="file-text" class="w-4 h-4"></i>
                                                </div>
                                                <div>
                                                    <h3
                                                        class="text-xs font-black text-slate-900 uppercase tracking-widest">
                                                        Review Draft</h3>
                                                    <p
                                                        class="text-[0.625rem] font-bold text-emerald-600 uppercase tracking-wide">
                                                        Generated Content</p>
                                                </div>
                                            </div>
                                            <button onclick="closeDraftModal()"
                                                class="p-2 hover:bg-white hover:shadow-sm rounded-lg text-slate-400 hover:text-slate-600 transition-all">
                                                <i data-lucide="x" class="w-4 h-4"></i>
                                            </button>
                                        </div>

                                        <!-- Modal Tabs -->
                                        <div class="px-6 border-b border-slate-200 bg-white flex items-center gap-6">
                                            <button onclick="switchDraftTab('preview')" id="tab-preview"
                                                class="py-3 text-xs font-bold uppercase tracking-wider text-emerald-600 border-b-2 border-emerald-500 transition-all">
                                                Document Preview
                                            </button>
                                            <button onclick="switchDraftTab('json')" id="tab-json"
                                                class="py-3 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-slate-600 border-b-2 border-transparent transition-all">
                                                Raw Data
                                            </button>
                                        </div>

                                        <div class="p-0 overflow-y-auto flex-1 bg-slate-100/50">
                                            <!-- Tab 1: Document Preview (Reading Mode) -->
                                            <div id="draftPreviewTab"
                                                class="p-8 flex flex-col items-center gap-4 animate-in fade-in duration-300">
                                                <!-- A4 Page Simulation -->
                                                <article id="draftPreviewContent"
                                                    class="w-full max-w-[210mm] min-h-[297mm] bg-white shadow-lg border border-slate-200 rounded-sm p-[12mm] md:p-[20mm] text-slate-800 leading-relaxed font-serif relative">
                                                    <!-- Dynamic Content injected here -->
                                                    <div
                                                        class="flex flex-col items-center justify-center h-full opacity-50 space-y-2">
                                                        <i data-lucide="loader-2"
                                                            class="w-6 h-6 animate-spin text-slate-400"></i>
                                                        <p class="text-xs text-slate-400 uppercase tracking-widest">
                                                            Rendering Document...</p>
                                                    </div>
                                                </article>
                                                <p class="text-[0.6rem] text-slate-400 uppercase tracking-widest">End of
                                                    Draft</p>
                                            </div>

                                            <!-- Tab 2: Raw JSON (Developer) -->
                                            <div id="draftJsonTab" class="hidden p-6 animate-in fade-in duration-300">
                                                <div
                                                    class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                                                    <div
                                                        class="px-4 py-2 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
                                                        <span
                                                            class="text-[0.625rem] font-bold text-slate-500 uppercase tracking-widest">Draft
                                                            Data</span>
                                                        <button onclick="copyDraftJson()"
                                                            class="text-[0.625rem] text-blue-600 font-bold hover:underline">Copy
                                                            JSON</button>
                                                    </div>
                                                    <pre id="draftContent"
                                                        class="p-4 text-xs font-mono text-slate-700 overflow-x-auto whitespace-pre-wrap max-h-[400px]"></pre>
                                                </div>
                                            </div>
                                        </div>

                                        <div
                                            class="px-6 py-4 border-t border-slate-50 bg-white flex justify-between items-center gap-4">
                                            <button onclick="closeDraftModal()"
                                                class="px-4 py-2.5 bg-white border border-slate-200 text-slate-600 rounded-lg text-[0.625rem] font-black uppercase tracking-widest hover:bg-slate-50 hover:text-slate-900 transition-all shadow-sm">
                                                Reject & Edit
                                            </button>
                                            <div class="flex gap-3">
                                                <button onclick="downloadDraft()"
                                                    class="px-4 py-2.5 bg-white border border-slate-200 text-slate-700 rounded-lg text-[0.625rem] font-black uppercase tracking-widest hover:bg-slate-50 hover:text-slate-900 transition-all shadow-sm flex items-center gap-2">
                                                    <i data-lucide="download" class="w-3.5 h-3.5"></i>
                                                    Download PDF
                                                </button>
                                                <button id="confirmFormatBtn"
                                                    class="px-6 py-2.5 bg-emerald-600 text-white rounded-lg text-[0.625rem] font-black uppercase tracking-widest hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed transition-all shadow-lg shadow-emerald-200 flex items-center gap-2 group">
                                                    <span>Format Document</span>
                                                    <i data-lucide="check-circle"
                                                        class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Print Styles Extracted to /css/services/ai-doc-generator.css -->



                                <script nonce="<%= nonce %>">
                                    // --- Helper: Action Modal Handlers ---
                                    // Phase 2: User Approves Analysis -> Start Drafting
                                    document.getElementById('confirmGenerateBtn')?.addEventListener('click', async () => {
                                        const btn = document.getElementById('confirmGenerateBtn');
                                        if (btn.disabled) return; // Prevent double click
                                        const originalText = btn.innerHTML;

                                        // 1. Lock UI
                                        btn.disabled = true;
                                        window.isWorkDirty = true; // [NavGuard] Lock navigation
                                        startJobTimer('Generating Draft...');
                                        btn.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i> Drafting...';
                                        if (typeof lucide !== 'undefined') lucide.createIcons();

                                        // 2. Prepare Payload with Context
                                        const payload = {
                                            prompt: document.getElementById('promptInput').value, // Use original prompt
                                            summary: document.getElementById('summaryInput').value,
                                            jobId: window.currentJobId, // Critical: Backend Context
                                            requestId: window.currentRequestId, // Critical: Backend Context,
                                            appId: document.getElementById('generatorAppId').value,
                                            documentType: document.getElementById('documentTypeInput')?.value || 'General',
                                            tone: document.getElementById('toneSelect')?.value,
                                            theme: document.getElementById('themeSelect')?.value,
                                            files: attachedFiles.map(f => ({ name: f.name, type: f.type, data: f.data }))
                                        };

                                        // [CRITICAL] HITL Context Check
                                        if (!payload.jobId || !payload.requestId) {
                                            console.error('❌ [Frontend] Missing Context - JobId:', payload.jobId, 'RequestId:', payload.requestId);
                                            throw new Error("Session context lost. Please re-analyze.");
                                        }

                                        console.log('🚀 [Frontend] Confirm Draft - Payload Context:',
                                            { jobId: payload.jobId, requestId: payload.requestId });

                                        try {
                                            // 3. Call Drafting Endpoint (Phase 2)
                                            // Was: /generate -> Now: /draft
                                            const res = await fetch('/services/ai-doc-generator/draft', {
                                                method: 'POST',
                                                headers: { 'Content-Type': 'application/json' },
                                                body: JSON.stringify(payload)
                                            });

                                            const data = await res.json();
                                            if (!res.ok) throw new Error(data.error || 'Drafting failed');

                                            // 4. Start Polling for Draft
                                            closeReviewModal();
                                            setBtnState(true, 'Generating Draft...');

                                            await pollForDraft(data.jobId);

                                            // [FIX] Reset Button State on Success so it's ready if modal is reopened
                                            btn.disabled = false;
                                            btn.innerHTML = originalText;


                                        } catch (error) {
                                            console.error('❌ [Frontend] Draft Error:', error);
                                            window.showError(error.message);
                                            setBtnState(false); // Reset main button
                                            stopJobTimer(false);
                                            // Reset Modal Button
                                            btn.disabled = false;
                                            btn.innerHTML = originalText;
                                        }
                                    });

                                    // Phase 2.5: Poll for Draft Result
                                    async function pollForDraft(jobId) {
                                        console.log('⏳ [Poll] Waiting for Draft...');
                                        return new Promise((resolve, reject) => {
                                            let pollAttempts = 0;
                                            const pollInterval = setInterval(async () => {
                                                pollAttempts++;
                                                try {
                                                    if (pollAttempts > 300) { // 10 mins max
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error('Drafting timed out.'));
                                                    }
                                                    const res = await fetch(`/services/ai-doc-generator/jobs/${jobId}`);
                                                    if (res.status === 400 || res.status === 404) {
                                                        console.error('❌ [Poll] Fatal Error:', res.status);
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error('Job not found or invalid (Fatal)'));
                                                        return;
                                                    }
                                                    if (res.status === 403) {
                                                        // Ignore quota blocks on polling, keep trying
                                                        console.warn('⚠️ [Poll] 403 Received. Retrying...');
                                                        return;
                                                    }
                                                    if (!res.ok) throw new Error('Status check failed');
                                                    const data = await res.json();

                                                    if (data.status === 'completed') {
                                                        clearInterval(pollInterval);
                                                        const result = data.result;

                                                        console.log('✅ [Poll] Draft Ready. Keys:', Object.keys(result));

                                                        // Show Draft Modal
                                                        let draftData = result.draft || result;

                                                        // Handle array wrapper if present (common in n8n)
                                                        if (Array.isArray(draftData) && draftData.length > 0) draftData = draftData[0];

                                                        // [FIX] Robust Error Recovery for Triple-Quoted JSON (LLM Artifact) or Double-Quoted (SQL/CSV style)
                                                        if (draftData) {
                                                            // 0. Unwrap "cleanedData" or "contract.cleanedData" if present
                                                            // This handles the specific failure case user reported where N8N returns an error object with the data
                                                            if (typeof draftData === 'object' && draftData !== null) {
                                                                // Specific Key check for user's case
                                                                try {
                                                                    const innerKeys = Object.keys(draftData);
                                                                    for (const key of innerKeys) {
                                                                        if (draftData[key] && draftData[key].cleanedData) {
                                                                            console.warn(`⚠️ [Poll] Found 'cleanedData' inside '${key}'. Using it.`);
                                                                            draftData = draftData[key].cleanedData;
                                                                            break;
                                                                        }
                                                                    }
                                                                    // Direct check
                                                                    if (typeof draftData === 'object' && draftData && draftData.cleanedData) {
                                                                        console.warn("⚠️ [Poll] Found top-level 'cleanedData'. Using it.");
                                                                        draftData = draftData.cleanedData;
                                                                    }
                                                                } catch (e) {
                                                                    console.warn('⚠️ [Poll] Object key traversal failed:', e);
                                                                }
                                                            }

                                                            // 1. Try treating as string first (clean or dirty)
                                                            if (typeof draftData === 'string') {
                                                                let rawString = draftData.trim();

                                                                // Sanitize: Fix SQL/CSV style double-double quotes (""key"": ""value"")
                                                                if (rawString.includes('""')) {
                                                                    console.warn('⚠️ [Poll] Detected double-double quotes. Sanitizing...');
                                                                    rawString = rawString.replace(/""/g, '"');
                                                                }

                                                                try {
                                                                    // Fast path: It might be just a valid JSON string
                                                                    const parsed = JSON.parse(rawString);
                                                                    draftData = parsed;
                                                                    console.log('✅ [Poll] Successfully parsed JSON string');
                                                                } catch (e) {
                                                                    // 2. If valid parse fails, check for specific "dirty" issues
                                                                    if (rawString.includes('"""') || rawString.includes('CLEANEDDATA')) {
                                                                        console.warn('⚠️ [Poll] Parsing failed, detecting triple-quotes or bad keys. Attempting recovery...');
                                                                        // Fix Triple Quotes
                                                                        let sanitized = rawString.replace(/"""/g, '"');
                                                                        try {
                                                                            draftData = JSON.parse(sanitized);
                                                                            console.log('✅ [Poll] Recovered JSON from triple-quoted string');
                                                                        } catch (err) {
                                                                            console.error('❌ [Poll] Recovery Failed:', err);
                                                                            // Keep draftData as sanitized string so we can at least show it
                                                                            draftData = sanitized;
                                                                        }
                                                                    } else {
                                                                        console.error('❌ [Poll] JSON Parse failed, assuming raw string:', e);
                                                                        // draftData remains as string
                                                                        draftData = rawString;
                                                                    }
                                                                }
                                                            }
                                                        }

                                                        stopJobTimer(true);

                                                        // Persist Draft Data & Show Reopen Button
                                                        window.lastDraftData = draftData;

                                                        // [FIX] Update Context JobId for next phase (Format)
                                                        if (result.jobId) {
                                                            window.currentJobId = result.jobId;
                                                            console.log('🔄 [Frontend] Updated Context JobId:', window.currentJobId);
                                                        }

                                                        console.log('💾 [Context] Draft saved for reopening');
                                                        const reopenBtn = document.getElementById('reopenDraftBtn');
                                                        if (reopenBtn) reopenBtn.classList.remove('hidden');
                                                        const reopenBtnGen = document.getElementById('reopenDraftBtnGen');
                                                        if (reopenBtnGen) reopenBtnGen.classList.remove('hidden');
                                                        const headerReopenDraftBtn = document.getElementById('headerReopenDraftBtn');
                                                        if (headerReopenDraftBtn) headerReopenDraftBtn.classList.remove('hidden');

                                                        openDraftModal(draftData);
                                                        window.dispatchEvent(new CustomEvent('job-completed'));
                                                        resolve(result);
                                                    } else if (data.status === 'failed') {
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error(data.error || 'Drafting failed'));
                                                    }
                                                } catch (error) {
                                                    console.error('Poll Error:', error);
                                                    // Clean up on fatal error
                                                    if (pollAttempts > 300) {
                                                        clearInterval(pollInterval);
                                                        reject(error);
                                                    }
                                                }
                                            }, 2000);
                                        });
                                    }

                                    // Feature: Reopen Last Draft
                                    window.reopenLastDraft = function () {
                                        if (window.lastDraftData) {
                                            console.log('🔙 [Frontend] Reopening last draft');
                                            openDraftModal(window.lastDraftData);
                                        } else {
                                            if (window.showToast) window.showToast('Info', 'No recent draft found.', 'info');
                                        }
                                    }

                                    // --- Draft Modal Logic (Phase 2) ---
                                    function openDraftModal(draftData) {
                                        const modal = document.getElementById('draftModal');
                                        const content = document.getElementById('draftContent');

                                        // [Smart Defaults] Restore Type and Settings if available
                                        if (draftData && (draftData.documentType || draftData.type)) {
                                            const type = draftData.documentType || draftData.type;
                                            const input = document.getElementById('documentTypeInput');
                                            if (input) input.value = type;
                                            if (window.applySmartDefaults) window.applySmartDefaults();
                                        }

                                        // 1. Populate Raw JSON
                                        content.textContent = typeof draftData === 'object' ? JSON.stringify(draftData, null, 2) : draftData;

                                        // 2. Render Reading Mode
                                        renderDraftPreview(draftData);

                                        // 3. Reset to Preview Tab
                                        switchDraftTab('preview');

                                        modal.classList.remove('hidden');
                                        modal.classList.add('flex');
                                    }

                                    function closeDraftModal() {
                                        const modal = document.getElementById('draftModal');
                                        modal.classList.add('hidden');
                                        modal.classList.remove('flex');
                                    }

                                    function switchDraftTab(tabName) {
                                        const previewTab = document.getElementById('draftPreviewTab');
                                        const jsonTab = document.getElementById('draftJsonTab');
                                        const btnPreview = document.getElementById('tab-preview');
                                        const btnJson = document.getElementById('tab-json');

                                        if (tabName === 'preview') {
                                            previewTab.style.display = 'flex';
                                            jsonTab.style.display = 'none'; // Use display none/flex instead of hidden class to ensure proper init

                                            // Update classes
                                            previewTab.classList.remove('hidden');
                                            jsonTab.classList.add('hidden');

                                            btnPreview.className = "py-3 text-xs font-bold uppercase tracking-wider text-emerald-600 border-b-2 border-emerald-500 transition-all";
                                            btnJson.className = "py-3 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-slate-600 border-b-2 border-transparent transition-all";
                                        } else {
                                            previewTab.style.display = 'none';
                                            jsonTab.style.display = 'block';

                                            previewTab.classList.add('hidden');
                                            jsonTab.classList.remove('hidden');

                                            btnPreview.className = "py-3 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-slate-600 border-b-2 border-transparent transition-all";
                                            btnJson.className = "py-3 text-xs font-bold uppercase tracking-wider text-emerald-600 border-b-2 border-emerald-500 transition-all";
                                        }
                                    }

                                    function renderDraftPreview(data) {
                                        const container = document.getElementById('draftPreviewContent');
                                        if (!data) return;

                                        // Reset Content
                                        container.innerHTML = '';

                                        // [FIX] Handle String Data (Fallback for failed parse)
                                        if (typeof data === 'string') {
                                            const alert = document.createElement('div');
                                            alert.className = "p-4 bg-yellow-50 border border-yellow-100 rounded-lg text-sm text-yellow-800 mb-4 whitespace-pre-wrap font-mono";
                                            alert.textContent = data; // Safe text

                                            const header = document.createElement('h3');
                                            header.className = "font-bold text-yellow-900 mb-2 uppercase tracking-wide text-xs";
                                            header.textContent = "Raw Content (Parsing Failed)";

                                            container.appendChild(header);
                                            container.appendChild(alert);
                                            return;
                                        }

                                        // 1. Detect Document Root (Handling wrapped or flat N8N responses)
                                        // Filter out system keys that shouldn't be treated as content
                                        const systemKeys = ['userId', 'appId', 'jobId', 'requestId', 'action', 'analyzeRequestId', 'formatRequestId', 'documentType', 'local', 'analysis', 'created_at'];

                                        // If data has a 'sections' key, use it. Otherwise, use data as the root but filter keys.
                                        // Or if data has a clear wrapper key like 'proposal' or 'resume', attempt to unwrap.
                                        let doc = data;
                                        const potentialRoot = Object.keys(data).find(k =>
                                            typeof data[k] === 'object' && !Array.isArray(data[k]) && !systemKeys.includes(k) && (data[k].title || data[k].sections)
                                        );
                                        if (potentialRoot && !data.sections) doc = data[potentialRoot];

                                        // Reset Content
                                        container.innerHTML = '';

                                        // Create Content Wrapper
                                        const wrapper = document.createElement('div');
                                        wrapper.className = "w-full";
                                        let html = '';

                                        // --- Helper: Generic Value Renderer ---
                                        const renderValue = (val, level = 3, key = '') => {
                                            if (!val) return '';
                                            // Cap heading level at 6
                                            const currentLevel = Math.min(level, 6);

                                            if (typeof val === 'string') {
                                                // Handle multiline strings as paragraphs or list items
                                                return val.split('\n').filter(p => p.trim()).map(p => {
                                                    const clean = p.trim();
                                                    if (clean.startsWith('* ') || clean.startsWith('- ')) {
                                                        return `<li class="ml-4 list-disc text-slate-700 text-sm mb-1 pl-2 marker:text-emerald-400">${clean.replace(/^[\*\-]\s*/, '')}</li>`;
                                                    }
                                                    return `<p class="text-sm text-slate-600 leading-relaxed mb-2 text-justify">${clean}</p>`;
                                                }).join('');
                                            }
                                            else if (Array.isArray(val)) {
                                                // Check if array of strings (simple list) or objects (complex list)
                                                const isSimple = val.every(i => typeof i === 'string');
                                                if (isSimple) {
                                                    // --- INTELLIGENT RENDERING HEURISTICS ---
                                                    const lowerKey = key.toLowerCase();

                                                    // 1. Force Paragraph Mode for known text blocks
                                                    const paragraphKeys = ['body', 'summary', 'description', 'intro', 'conclusion', 'abstract'];
                                                    if (paragraphKeys.some(k => lowerKey.includes(k))) {
                                                        return `<div class="space-y-2 mb-3">${val.map(item => `<p class="text-sm text-slate-600 leading-relaxed text-justify">${item}</p>`).join('')}</div>`;
                                                    }

                                                    // 2. Force List Mode for known list items
                                                    const listKeys = ['bullets', 'skills', 'items', 'suggestions', 'missing', 'what_we_have'];
                                                    if (listKeys.some(k => lowerKey.includes(k))) {
                                                        return `<ul class="space-y-1 mb-2">${val.map(item =>
                                                            `<li class="flex items-start gap-2 text-sm text-slate-700"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>${item}</li>`
                                                        ).join('')}</ul>`;
                                                    }

                                                    // 3. Heuristic fallback: Length check
                                                    // If items are long paragraphs (> 80 chars avg), treat as text. otherwise list.
                                                    const avgLength = val.reduce((acc, str) => acc + str.length, 0) / val.length;
                                                    if (avgLength > 80) {
                                                        return `<div class="space-y-2 mb-3">${val.map(item => `<p class="text-sm text-slate-600 leading-relaxed text-justify">${item}</p>`).join('')}</div>`;
                                                    }

                                                    // Default to List
                                                    return `<ul class="space-y-1 mb-2">${val.map(item =>
                                                        `<li class="flex items-start gap-2 text-sm text-slate-700"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>${item}</li>`
                                                    ).join('')}</ul>`;
                                                } else {
                                                    // Complex List (Experience, Timeline, milestones)
                                                    return `<div class="space-y-3">${val.map(item => {
                                                        if (typeof item === 'object') {
                                                            // Render generic object card
                                                            return `<div class="p-4 bg-slate-50 border border-slate-100 rounded-lg text-sm space-y-1">
                                         ${Object.entries(item).map(([k, v]) => {
                                                                const displayKey = k.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
                                                                if (Array.isArray(v)) return `<div class="mt-2"><strong class="text-slate-500 text-xs uppercase tracking-wide block mb-1">${displayKey}</strong>${renderValue(v, currentLevel + 1, k)}</div>`;
                                                                return `<div class="flex gap-2"><strong class="text-slate-700 min-w-[100px]">${displayKey}:</strong> <span class="text-slate-600">${renderValue(v, currentLevel + 1, k)}</span></div>`;
                                                            }).join('')}
                                     </div>`;
                                                        }
                                                        return `<div class="p-2 border border-slate-100 rounded">${item}</div>`;
                                                    }).join('')}</div>`;
                                                }
                                            } else if (typeof val === 'object') {
                                                // Check for Pricing Table Structure
                                                if (val.total && val.breakdown && Array.isArray(val.breakdown)) {
                                                    let tableHtml = `<div class="bg-slate-50 border border-slate-200 rounded-lg p-6 font-sans">`;
                                                    tableHtml += `<table class="w-full text-sm mb-4">`;
                                                    val.breakdown.forEach(item => {
                                                        tableHtml += `<tr class="border-b border-slate-200/50 hover:bg-white transition-colors">
                                     <td class="py-3 pr-4 text-slate-700 font-medium">${item.item || item.description}</td>
                                     <td class="py-3 text-right font-mono text-slate-500">$${item.cost || item.price}</td>
                                   </tr>`;
                                                    });
                                                    tableHtml += `</table>`;
                                                    if (val.total) {
                                                        tableHtml += `<div class="flex justify-between items-center pt-4 border-t-2 border-slate-300">
                                     <span class="font-bold uppercase text-xs tracking-widest text-slate-500">Total Estimate</span>
                                     <span class="text-xl font-bold text-emerald-600 font-mono">$${val.total}</span>
                                  </div>`;
                                                    }
                                                    tableHtml += `</div>`;
                                                    return tableHtml;
                                                }

                                                // Generic Nested Object with Dynamic Heading Levels
                                                return Object.entries(val).map(([k, v]) => {
                                                    const title = k.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
                                                    // Generate h3, h4, h5, h6 based on depth
                                                    return `<div class="mb-4">
                                <h${currentLevel} class="font-bold text-slate-500 uppercase tracking-wider mb-2 font-sans border-b border-slate-100 pb-1 ${currentLevel > 3 ? 'text-[0.65rem]' : 'text-xs'}">
                                    ${title}
                                </h${currentLevel}>
                                ${renderValue(v, currentLevel + 1, k)}
                             </div>`;
                                                }).join('');
                                            }
                                            return String(val);
                                        };

                                        // --- 2. Header Rendering ---
                                        if (doc.title) {
                                            html += `<h1 class="text-3xl font-bold text-slate-900 mb-6 text-center font-serif leading-tight">${doc.title}</h1>`;
                                        }

                                        if (doc.prepared_for || doc.prepared_by) {
                                            html += `<div class="grid grid-cols-2 gap-8 mb-12 text-xs text-slate-500 border-b border-slate-100 pb-8 uppercase tracking-widest font-sans">`;
                                            if (doc.prepared_for) {
                                                const clientName = typeof doc.prepared_for === 'string' ? doc.prepared_for : (doc.prepared_for.client_name || doc.prepared_for.company_name);
                                                html += `<div><strong class="block text-slate-400 mb-1">Prepared For</strong>${clientName || 'Client'}</div>`;
                                            }
                                            if (doc.prepared_by) {
                                                const author = typeof doc.prepared_by === 'string' ? doc.prepared_by : (doc.prepared_by.name || doc.prepared_by.company);
                                                html += `<div class="text-right"><strong class="block text-slate-400 mb-1">Prepared By</strong>${author || 'Us'}</div>`;
                                            }
                                            html += `</div>`;
                                        }

                                        // --- 3. Main Content Loop ---
                                        // Prefer 'sections' object, otherwise use root object but filtered
                                        const contentSource = doc.sections || doc;

                                        if (contentSource && typeof contentSource === 'object') {
                                            Object.entries(contentSource).forEach(([key, value]) => {
                                                // Expanded Exclusion List for Root Keys
                                                if (systemKeys.includes(key) || ['title', 'prepared_for', 'prepared_by', 'sections'].includes(key)) return;

                                                const sectionTitle = key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

                                                html += `<section class="mb-8 keep-together">`;
                                                html += `<h2 class="text-lg font-bold text-slate-800 mb-3 uppercase tracking-wide border-l-4 border-emerald-500 pl-3 font-sans">${sectionTitle}</h2>`;
                                                html += renderValue(value);
                                                html += `</section>`;
                                            });
                                        }

                                        wrapper.innerHTML = html;
                                        container.appendChild(wrapper);

                                        if (typeof lucide !== 'undefined') lucide.createIcons();
                                    }

                                    window.closeDraftModal = closeDraftModal;

                                    window.copyDraftJson = function () {
                                        const content = document.getElementById('draftContent').innerText;
                                        navigator.clipboard.writeText(content).then(() => {
                                            if (window.showToast) window.showToast('Copied', 'JSON data copied to clipboard', 'success');
                                        }).catch(err => {
                                            console.error('Failed to copy keys: ', err);
                                            if (window.showToast) window.showToast('Error', 'Failed to copy JSON', 'error');
                                        });
                                    }

                                    window.downloadDraft = function () {
                                        // Ensure preview tab is active
                                        switchDraftTab('preview');
                                        // Allow render to settle then print
                                        setTimeout(() => {
                                            window.print();
                                        }, 100);
                                    };

                                    // Phase 3: User Approves Draft -> Format HTML
                                    document.getElementById('confirmFormatBtn')?.addEventListener('click', async () => {
                                        const btn = document.getElementById('confirmFormatBtn');
                                        if (btn.disabled) return;
                                        const originalText = btn.innerHTML;

                                        // 1. Immediate UI Feedback
                                        btn.disabled = true;
                                        closeDraftModal(); // [FIX] Close immediately to reveal overlay

                                        startJobTimer('Formatting Document (This may take a minute)...');
                                        btn.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i> Formatting...';
                                        if (typeof lucide !== 'undefined') lucide.createIcons();

                                        try {
                                            const payload = {
                                                jobId: window.currentJobId,
                                                requestId: window.currentRequestId,
                                                appId: document.getElementById('generatorAppId').value,
                                                documentType: document.getElementById('documentTypeInput')?.value || 'General'
                                            };

                                            console.log('🚀 [Frontend] Requesting Format - Context:', payload);

                                            const res = await fetch('/services/ai-doc-generator/format', {
                                                method: 'POST',
                                                headers: { 'Content-Type': 'application/json' },
                                                body: JSON.stringify(payload)
                                            });

                                            const data = await res.json();
                                            if (!res.ok) throw new Error(data.error || 'Formatting failed');

                                            // closeDraftModal(); // Moved up
                                            setBtnState(true, 'Formatting Document...');
                                            setBtnState(true, 'Formatting Document...');

                                            await pollForFinalHtml(data.jobId);

                                            // [FIX] Reset Button State on Success
                                            btn.disabled = false;
                                            btn.innerHTML = originalText;

                                        } catch (error) {
                                            console.error('❌ [Frontend] Format Error:', error);
                                            window.showError(error.message);

                                            // Recovery: Re-open modal so user can try again
                                            if (window.lastDraftData) openDraftModal(window.lastDraftData);

                                            btn.innerHTML = originalText;
                                            stopJobTimer(false); // Stop the overlay
                                            setBtnState(false);
                                        }
                                    });

                                    // Polling for Final HTML (Phase 3)
                                    async function pollForFinalHtml(jobId) {
                                        console.log('⏳ [Poll] Waiting for Final HTML (Job ' + jobId + ')...');
                                        return new Promise((resolve, reject) => {
                                            let pollAttempts = 0;
                                            const pollInterval = setInterval(async () => {
                                                pollAttempts++;
                                                try {
                                                    if (pollAttempts > 300) {
                                                        clearInterval(pollInterval);
                                                        reject(new Error('Generation timed out.'));
                                                    }
                                                    const res = await fetch(`/services/ai-doc-generator/jobs/${jobId}`);
                                                    if (res.status === 400 || res.status === 404) {
                                                        clearInterval(pollInterval);
                                                        reject(new Error('Job not found or invalid (Fatal)'));
                                                        return;
                                                    }
                                                    if (!res.ok) throw new Error('Status check failed');
                                                    const data = await res.json();

                                                    if (data.status === 'completed') {
                                                        clearInterval(pollInterval);
                                                        let result = data.result;

                                                        // [FIX] Handle Markdown Wrappers (```json ... ```)
                                                        if (typeof result === 'string') {
                                                            const raw = result.trim();

                                                            // 1. Try Regex Extraction first (User Suggestion - Most Robust for HTML)
                                                            // Look for <!DOCTYPE html> ... </html> OR <html> ... </html>
                                                            const htmlMatch = raw.match(/(<!DOCTYPE html[\s\S]*<\/html>|<html[\s\S]*<\/html>)/i);
                                                            if (htmlMatch) {
                                                                console.log('✅ [Poll] Extracted raw HTML via Regex');
                                                                result = { html: htmlMatch[0] };
                                                            }
                                                            else if (raw.startsWith('```')) {
                                                                console.log('⚠️ [Poll] Detected Markdown wrapper, stripping...');
                                                                const clean = raw.replace(/^```json\s*|^```\s*|```$/g, '');
                                                                try {
                                                                    result = JSON.parse(clean);
                                                                } catch (e) {
                                                                    console.error('❌ [Poll] Parse error from markdown strip:', e);
                                                                }
                                                            } else if (raw.startsWith('{')) {
                                                                try { result = JSON.parse(raw); } catch (e) { }
                                                            }
                                                        }

                                                        console.log('✅ [Poll] Formatting Complete. Result Keys:', typeof result === 'object' ? Object.keys(result) : 'string');

                                                        let finalHtml = result.html || result;

                                                        // [FIX] Double-check if HTML is still a stringified JSON (common double-encoding)
                                                        if (typeof finalHtml === 'string') {
                                                            // 1. Try Regex Extraction ALWAYS (User Suggestion - Most Robust)
                                                            const htmlMatch = finalHtml.match(/(<!DOCTYPE html[\s\S]*<\/html>|<html[\s\S]*<\/html>)/i);
                                                            if (htmlMatch) {
                                                                console.log('✅ [Poll] Extracted raw HTML via Regex from finalHtml');
                                                                finalHtml = htmlMatch[0];
                                                            }
                                                            // 2. If no regex match, try JSON parse if it looks like JSON
                                                            else if (finalHtml.trim().startsWith('{') || finalHtml.trim().startsWith('"{\\"')) {
                                                                try {
                                                                    const parsed = JSON.parse(finalHtml);
                                                                    if (parsed.html) finalHtml = parsed.html;
                                                                } catch (e) { console.warn('JSON Re-parse failed', e); }
                                                            }
                                                        }

                                                        // [FIX] Ensure finalHtml is a string before assignment
                                                        if (typeof finalHtml === 'object' && finalHtml !== null) {
                                                            console.warn('⚠️ [Poll] Final HTML is object, unwrapping/stringifying...');
                                                            finalHtml = finalHtml.html || finalHtml.content || JSON.stringify(finalHtml);
                                                        }

                                                        document.getElementById('hiddenHtmlInput').value = finalHtml || '';
                                                        // Fix: Use correct element IDs (mainHtmlEditor/debugHtmlEditor instead of non-existent htmlEditor)
                                                        const mainEditorEl = document.getElementById('mainHtmlEditor');
                                                        const debugEditorEl = document.getElementById('debugHtmlEditor');
                                                        if (mainEditorEl) mainEditorEl.value = finalHtml || '';
                                                        if (debugEditorEl) debugEditorEl.value = finalHtml || '';
                                                        document.getElementById('pdfAppId').value = document.getElementById('generatorAppId').value;

                                                        window.switchTab('editor');
                                                        window.updateUIStates();
                                                        setBtnState(false);

                                                        // Clean up & Success Feedback
                                                        stopJobTimer(true);
                                                        window.dispatchEvent(new CustomEvent('job-completed'));

                                                        // Show Success Message
                                                        if (window.showToast) window.showToast('Document Ready', 'Your document has been sent to your email and is available in the Activity tab.', 'success');

                                                        // --- CRITICAL STATE RESET ---
                                                        // Reset Workspace for next document so it starts a FRESH flow
                                                        console.log('🧹 [Frontend] Resetting Workspace State');
                                                        document.getElementById('summaryInput').value = '';
                                                        document.getElementById('promptInput').value = '';
                                                        if (document.getElementById('contextInput')) document.getElementById('contextInput').value = '';

                                                        // Clear Technical State Variables to prevent sticking to 'Format' or old Jobs
                                                        window.currentJobId = null;
                                                        window.currentRequestId = null;
                                                        window.lastDraftData = null;

                                                        // Hide resumable buttons
                                                        const reopenDraftBtn = document.getElementById('reopenDraftBtn');
                                                        if (reopenDraftBtn) reopenDraftBtn.classList.add('hidden');
                                                        const reopenReviewBtn = document.getElementById('reopenReviewBtn');
                                                        if (reopenReviewBtn) reopenReviewBtn.classList.add('hidden');

                                                        document.getElementById('headerReopenDraftBtn')?.classList.add('hidden');
                                                        document.getElementById('headerReopenPlanBtn')?.classList.add('hidden');

                                                        attachedFiles = []; renderFiles();

                                                        resolve();
                                                    } else if (data.status === 'failed') {
                                                        clearInterval(pollInterval);
                                                        stopJobTimer(false);
                                                        reject(new Error(data.error || 'Generation failed'));
                                                    }
                                                } catch (e) { clearInterval(pollInterval); reject(e); }
                                            }, 2000);
                                        });
                                    }

                                    // --- Unload Warning ---
                                    // --- Unload Warning ---
                                    // [DISABLED] Per user strict request: "never ever use browser alert"
                                    // The nav-guard partial will handle in-app navigation warnings instead.
                                    /*
                                    window.addEventListener('beforeunload', (e) => {
                                        if (window.currentJobId || (document.getElementById('promptInput')?.value && !document.getElementById('hiddenHtmlInput')?.value)) {
                                            e.preventDefault();
                                            e.returnValue = 'You have unfinished work. Are you sure you want to leave?';
                                            return e.returnValue;
                                        }
                                    });
                                    */

                                    // Prevent Modals from closing on Backdrop Click
                                    ['reviewModal', 'draftModal'].forEach(id => {
                                        const el = document.getElementById(id);
                                        if (el) {
                                            el.addEventListener('click', (e) => {
                                                // If user clicks the backdrop (the element itself), do NOTHING.
                                                // Only close via buttons.
                                                if (e.target === el) {
                                                    e.stopPropagation();
                                                    e.preventDefault();
                                                    console.log('🛡️ [Modal] Backdrop click ignored (use buttons to close)');
                                                }
                                            });
                                        }
                                    });

                                    // Reopen Analysis Modal Feature
                                    window.reopenReviewModal = function () {
                                        const summary = document.getElementById('summaryInput').value;
                                        if (summary) {
                                            const modal = document.getElementById('reviewModal');
                                            const content = document.getElementById('reviewContent');
                                            if (modal && content) {
                                                content.innerHTML = summary;
                                                modal.classList.remove('hidden');
                                                modal.classList.add('flex');
                                            }
                                        } else {
                                            if (window.showToast) window.showToast('Info', 'No analysis plan to review.', 'info');
                                        }
                                    }



                                    // --- Zoom & Preview Scaling ---
                                    window.currentZoom = 1.0;

                                    window.applyZoom = function () {
                                        const frame = document.getElementById('previewFrame');
                                        const range = document.getElementById('zoomRange');
                                        const valueDisplay = document.getElementById('zoomValue');

                                        if (range) range.value = Math.round(window.currentZoom * 100);
                                        if (valueDisplay) valueDisplay.textContent = Math.round(window.currentZoom * 100) + '%';

                                        if (frame && frame.contentDocument && frame.contentDocument.body) {
                                            // Standard A4 Width @ 96DPI = 794px
                                            // We scale based on user zoom relative to A4
                                            const docBody = frame.contentDocument.body;
                                            docBody.style.transform = `scale(${window.currentZoom})`;
                                            docBody.style.transformOrigin = 'top left';

                                            // Ensure body dimensions are locked for print fidelity before scaling
                                            docBody.style.width = '210mm';
                                            docBody.style.minHeight = '297mm';
                                        }
                                    }

                                    // Auto-Fit on Load/Resize
                                    window.fitPreviewToContainer = function () {
                                        const container = document.getElementById('previewArea');
                                        const frame = document.getElementById('previewFrame');

                                        if (container && frame) {
                                            const availableWidth = container.clientWidth;
                                            const a4WidthPx = 794; // 210mm approximate

                                            // Logic: If container is smaller than A4, scale down.
                                            // If container is larger, keep at 100% or user preference? 
                                            // Let's set default zoom to fit.

                                            let newZoom = availableWidth / a4WidthPx;
                                            // Cap max auto-zoom at 1.0 (actual size) to avoid blur, allow user to zoom in manually
                                            newZoom = Math.min(1.0, newZoom - 0.05); // 5% padding

                                            window.currentZoom = newZoom;
                                            window.applyZoom();
                                        }
                                    }

                                    // Listeners
                                    window.addEventListener('resize', window.fitPreviewToContainer);
                                    // Trigger loop to catch iframe load
                                    setInterval(() => {
                                        const frame = document.getElementById('previewFrame');
                                        if (frame && frame.contentDocument && frame.contentDocument.body && !frame.dataset.fitted) {
                                            window.fitPreviewToContainer();
                                            frame.dataset.fitted = 'true';
                                            // Re-add listener for dynamic content changes
                                            frame.addEventListener('load', window.fitPreviewToContainer);
                                        }
                                    }, 1000);
                                </script>

