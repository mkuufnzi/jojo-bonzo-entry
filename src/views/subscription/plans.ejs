<%- include('../partials/head', { title: 'Subscription Plans - Floovioo ' }) %>

<body class="bg-gray-100">
    <div class="flex h-screen">

        <%- include('../partials/sidebar', {path: '/subscription' }) %>

            <!-- Main Content -->
            <div id="mainContent" class="flex flex-col min-h-screen ">
                <%- include('../partials/dashboard-header', {title: 'Upgrade Plans' , user: user }) %>

                    <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100">
                        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                             <!-- Back to Link -->
                             <div class="mb-6">
                                <a href="/subscription" class="text-sm text-gray-500 hover:text-gray-900 flex items-center gap-2 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                                    Back to Dashboard
                                </a>
                            </div>

                            <% if (typeof success !=='undefined' && success) { %>
                                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
                                    <span class="block sm:inline"><%= success %></span>
                                </div>
                            <% } %>

                            <% if (typeof error !=='undefined' && error) { %>
                                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                                    <span class="block sm:inline"><%= error %></span>
                                </div>
                            <% } %>

                            <!-- Available Plans -->
                            <div class="" id="upgrade-plans">
                                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Available Plans</h3>
                                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                                    <% plans.forEach(plan=> { %>
                                        <div class="bg-white shadow-sm rounded-xl overflow-hidden flex flex-col border border-gray-200 hover:shadow-md transition-shadow duration-200 <%= user.subscription && user.subscription.planId === plan.id ? 'ring-2 ring-indigo-500 border-indigo-500' : '' %>">
                                            <div class="px-6 py-6 flex-1">
                                                <div class="flex items-center justify-between mb-2">
                                                    <h4 class="text-lg font-bold text-gray-900"><%= plan.name %></h4>
                                                    <% if (user.subscription && user.subscription.planId === plan.id) { %>
                                                        <span class="px-2 py-0.5 rounded text-xs font-bold bg-indigo-100 text-indigo-700">Current</span>
                                                    <% } %>
                                                </div>
                                                <p class="mt-2 flex items-baseline gap-1">
                                                    <span class="text-3xl font-extrabold text-gray-900"><%= plan.currency === 'GBP' ? '£' : '$' %><%= plan.price %></span>
                                                    <span class="text-sm font-medium text-gray-500">/mo</span>
                                                </p>
                                                <p class="mt-2 text-xs text-gray-500 font-medium tracking-wide uppercase">
                                                    <%= plan.requestLimit %> requests / month
                                                </p>
                                                
                                                <hr class="my-6 border-gray-100">

                                                <ul class="space-y-4">
                                                    <% JSON.parse(plan.features).filter(f => !f.match(/^[a-z0-9-]+$/) || f.includes(' ')).forEach(feature=> { %>
                                                        <li class="flex items-start">
                                                            <div class="flex-shrink-0">
                                                                <svg class="h-5 w-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                                </svg>
                                                            </div>
                                                            <p class="ml-3 text-sm text-gray-600"><%= feature %></p>
                                                        </li>
                                                    <% }); %>
                                                </ul>
                                            </div>
                                            <div class="px-6 py-4 bg-gray-50 border-t border-gray-100">
                                                <% if (user.subscription && user.subscription.planId===plan.id) { %>
                                                    <button disabled class="w-full bg-gray-200 text-gray-500 font-bold py-2.5 px-4 rounded-lg cursor-not-allowed text-sm">
                                                        <%= user.subscription.status==='canceling' ? 'Canceling...' : 'Current Plan' %>
                                                    </button>
                                                <% } else { %>
                                                    <form action="/subscription/upgrade" method="POST" class="subscription-form" data-plan-name="<%= plan.name %>" data-plan-price="<%= plan.price %>" data-current-price="<%= user.subscription?.plan?.price || 0 %>">
                                                        <input type="hidden" name="planId" value="<%= plan.id %>">
                                                        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 px-4 rounded-lg text-sm transition-colors shadow-sm hover:shadow">
                                                            <%= plan.price > (user.subscription?.plan?.price || 0) ? 'Upgrade' : 'Downgrade' %>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            </div>

                        </div>
                    </main>
            </div>
    </div>
    <%- include('../partials/sidebar-script') %>
</body>
</html>
