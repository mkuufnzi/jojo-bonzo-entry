<%- include('../partials/head', { title: 'Analytics & Subscription - Floovioo ' }) %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<body class="bg-gray-50">
    <div class="flex h-screen overflow-hidden">

        <%- include('../partials/sidebar', {path: '/subscription' }) %>

        <!-- Main Content -->
        <div id="mainContent" class="flex flex-col flex-1 min-w-0 overflow-hidden">
            <%- include('../partials/dashboard-header', {title: 'Analytics Hub' , user: user }) %>

            <main class="flex-1 overflow-y-auto focus:outline-none p-6">
                <div class="max-w-7xl mx-auto space-y-6">

                    <!-- Alerts -->
                    <% if (typeof success !=='undefined' && success) { %>
                        <div class="rounded-lg bg-green-50 p-4 border-l-4 border-green-400">
                            <div class="flex">
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-green-800">Success</h3>
                                    <div class="text-sm text-green-700 mt-2"><%= success %></div>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="rounded-lg bg-red-50 p-4 border-l-4 border-red-400">
                            <div class="flex">
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-red-800">Attention Needed</h3>
                                    <div class="text-sm text-red-700 mt-2"><%= error %></div>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <!-- 1. High-Level Metrics Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Total Requests -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:shadow-md transition-shadow">
                            <div>
                                <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Total Requests</p>
                                <div class="mt-2 flex items-baseline gap-2">
                                    <h3 class="text-3xl font-extrabold text-gray-900"><%= locals.stats ? locals.stats.totalRequests.toLocaleString() : 0 %></h3>
                                    <span class="text-xs font-medium text-green-600 bg-green-100 px-2 py-0.5 rounded-full">+12%</span>
                                </div>
                            </div>
                            <div class="mt-4 h-1 w-full bg-gray-100 rounded-full overflow-hidden">
                                <div class="h-full bg-indigo-500 w-3/4 rounded-full"></div>
                            </div>
                        </div>

                        <!-- Est Cost -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:shadow-md transition-shadow">
                            <div>
                                <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Est. Cost (MTD)</p>
                                <h3 class="text-3xl font-extrabold text-gray-900 mt-2">
                                    $<%= (locals.stats && locals.stats.costBreakdown) ? locals.stats.costBreakdown.reduce((a, b) => a + b.cost, 0).toFixed(2) : '0.00' %>
                                </h3>
                            </div>
                            <p class="text-xs text-gray-400 mt-4">Forecast: $<%= (locals.stats && locals.stats.costBreakdown) ? (locals.stats.costBreakdown.reduce((a, b) => a + b.cost, 0) * 1.2).toFixed(2) : '0.00' %></p>
                        </div>

                        <!-- Current Plan -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:shadow-md transition-shadow">
                            <div>
                                <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Current Plan</p>
                                <div class="flex items-center justify-between mt-2">
                                    <h3 class="text-2xl font-bold text-gray-800"><%= (user.subscription && user.subscription.plan) ? user.subscription.plan.name : 'No Plan' %></h3>
                                    <% if (user.subscription && user.subscription.status === 'active') { %>
                                        <span class="h-3 w-3 rounded-full bg-green-500 ring-4 ring-green-100"></span>
                                    <% } else { %>
                                        <span class="h-3 w-3 rounded-full bg-yellow-500 ring-4 ring-yellow-100"></span>
                                    <% } %>
                                </div>
                            </div>
                            <a href="/subscription/plans" class="mt-4 w-full text-center bg-indigo-50 text-indigo-700 text-sm font-medium py-2 rounded-lg hover:bg-indigo-100 transition-colors">
                                Upgrade Plan
                            </a>
                        </div>

                        <!-- Active Keys -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col justify-between hover:shadow-md transition-shadow">
                            <div>
                                <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Active Credentials</p>
                                <h3 class="text-3xl font-extrabold text-gray-900 mt-2"><%= locals.apiKeys ? locals.apiKeys.length : 0 %></h3>
                            </div>
                            <div class="flex items-center -space-x-2 mt-4 overflow-hidden">
                                <span class="inline-block h-8 w-8 rounded-full bg-gray-100 border-2 border-white flex items-center justify-center text-xs font-bold text-gray-500">Key</span>
                                <span class="inline-block h-8 w-8 rounded-full bg-indigo-100 border-2 border-white flex items-center justify-center text-xs font-bold text-indigo-500">+</span>
                            </div>
                        </div>
                    </div>

                    <!-- 2. Charts Row -->
                    <% if (locals.analytics) { %>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <!-- Main Usage Trend -->
                        <div class="bg-white lg:col-span-2 rounded-xl shadow-sm border border-gray-100 p-6">
                            <h3 class="text-lg font-bold text-gray-900 mb-4">Request Volume (Last 7 Days)</h3>
                            <div class="relative h-64 w-full">
                                <canvas id="usageTrendChart"></canvas>
                            </div>
                        </div>

                        <!-- Service Distribution -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col">
                            <h3 class="text-lg font-bold text-gray-900 mb-4">Cost Distribution</h3>
                            <div class="relative h-48 w-full flex-1 flex items-center justify-center">
                                <canvas id="distributionChart"></canvas>
                            </div>
                            <div class="mt-4 space-y-2">
                                <% locals.analytics.serviceDistribution.forEach(item => { %>
                                    <div class="flex items-center justify-between text-sm">
                                        <div class="flex items-center gap-2">
                                            <span class="w-3 h-3 rounded-full" style="background-color: <%= item.color %>"></span>
                                            <span class="text-gray-600"><%= item.label %></span>
                                        </div>
                                        <span class="font-medium text-gray-900"><%= item.value %>%</span>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    <% } %>

                    <!-- 3. Lower Section: Quotas & Activity -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        
                        <!-- Detailed Quotas -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                            <h3 class="text-lg font-bold text-gray-900 mb-6">Service Quotas</h3>
                            
                            <% if (locals.stats && locals.stats.pdf) { %>
                            <!-- PDF -->
                            <div class="mb-6">
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-sm font-medium text-gray-700 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                                        PDF Conversions
                                    </span>
                                    <span class="text-xs font-bold text-gray-500"><%= locals.stats.pdf.used %> / <%= locals.stats.pdf.limit %></span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                                    <% const pdfPct = Math.min(100, (locals.stats.pdf.used / locals.stats.pdf.limit) * 100); %>
                                    <div class="bg-gradient-to-r from-red-400 to-red-600 h-2.5 rounded-full" style="width: <%= pdfPct %>%"></div>
                                </div>
                            </div>
                            <% } %>

                            <% if (locals.stats && locals.stats.ai) { %>
                            <!-- AI -->
                            <div class="mb-6">
                                <div class="flex justify-between items-center mb-2">
                                    <span class="text-sm font-medium text-gray-700 flex items-center gap-2">
                                        <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                                        AI Generations
                                    </span>
                                    <span class="text-xs font-bold text-gray-500"><%= locals.stats.ai.used %> / <%= locals.stats.ai.limit %></span>
                                </div>
                                <div class="w-full bg-gray-100 rounded-full h-2.5 overflow-hidden">
                                    <% const aiPct = Math.min(100, (locals.stats.ai.used / locals.stats.ai.limit) * 100); %>
                                    <div class="bg-gradient-to-r from-purple-400 to-purple-600 h-2.5 rounded-full" style="width: <%= aiPct %>%"></div>
                                </div>
                            </div>
                            <% } %>

                            <a href="/subscription/plans" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1 mt-4">
                                Increase Limits &rarr;
                            </a>
                        </div>

                        <!-- Recent Activity -->
                        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 overflow-hidden">
                            <h3 class="text-lg font-bold text-gray-900 mb-4">Recent Activity</h3>
                            <% if (locals.analytics && locals.analytics.recentActivity.length > 0) { %>
                                <div class="flow-root">
                                    <ul class="-my-5 divide-y divide-gray-100">
                                        <% locals.analytics.recentActivity.forEach(activity => { %>
                                        <li class="py-4">
                                            <div class="flex items-center space-x-4">
                                                <div class="flex-shrink-0">
                                                    <% if (activity.status === 'success') { %>
                                                        <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-green-100">
                                                            <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                                        </span>
                                                    <% } else { %>
                                                        <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-red-100">
                                                            <svg class="h-5 w-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                                        </span>
                                                    <% } %>
                                                </div>
                                                <div class="flex-1 min-w-0">
                                                    <p class="text-sm font-medium text-gray-900 truncate">
                                                        <%= activity.service %>
                                                    </p>
                                                    <p class="text-xs text-gray-500 truncate">
                                                        <%= activity.time %>
                                                    </p>
                                                </div>
                                                <div>
                                                    <span class="inline-flex items-center shadow-sm px-2.5 py-0.5 border border-gray-300 text-xs font-medium rounded-full text-gray-700 bg-white hover:bg-gray-50">
                                                        <%= activity.cost %>
                                                    </span>
                                                </div>
                                            </div>
                                        </li>
                                        <% }); %>
                                    </ul>
                                </div>
                            <% } else { %>
                                <p class="text-sm text-gray-500 italic">No recent activity found.</p>
                            <% } %>
                        </div>
                    </div>

                    <!-- API Keys Table (Collapsible or Bottom) -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                        <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                            <h3 class="text-lg font-bold text-gray-900">API Access Keys</h3>
                            <div class="flex gap-2">
                                <form action="/subscription/seed" method="POST">
                                    <button type="submit" class="text-xs bg-gray-100 text-gray-600 px-3 py-2 rounded-lg hover:bg-gray-200 transition-colors" title="Populate with Dummy Data">
                                        ⚡ Seed Data
                                    </button>
                                </form>
                                <button onclick="document.getElementById('createKeyModal').classList.remove('hidden')" class="text-sm bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors">
                                    + Create Key
                                </button>
                            </div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm text-gray-600">
                                <thead class="bg-gray-50 text-gray-500 font-medium uppercase tracking-wider text-xs">
                                    <tr>
                                        <th class="px-6 py-3">Name</th>
                                        <th class="px-6 py-3">Key Prefix</th>
                                        <th class="px-6 py-3">Scopes</th>
                                        <th class="px-6 py-3">Created</th>
                                        <th class="px-6 py-3 text-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% if (locals.apiKeys && locals.apiKeys.length > 0) { %>
                                        <% locals.apiKeys.forEach(key => { %>
                                            <tr class="hover:bg-gray-50/50 transition-colors">
                                                <td class="px-6 py-4 font-medium text-gray-900">
                                                    <% if (key.type === 'app' && key.id) { %>
                                                        <a href="/apps/<%= key.id %>" class="text-indigo-600 hover:text-indigo-900 hover:underline flex items-center gap-2">
                                                            <%= key.name %>
                                                            <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                                                        </a>
                                                    <% } else { %>
                                                        <%= key.name %>
                                                    <% } %>
                                                </td>
                                                <td class="px-6 py-4 font-mono text-xs text-gray-500">
                                                    <%= key.key.substring(0, 12) %>...
                                                </td>
                                                <td class="px-6 py-4">
                                                    <span class="bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded text-xs font-medium border border-indigo-100">
                                                        <%= key.scopes.substring(0, 15) %><%= key.scopes.length > 15 ? '...' : '' %>
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4"><%= new Date(key.createdAt).toLocaleDateString() %></td>
                                                <td class="px-6 py-4 text-right">
                                                    <% if (key.type === 'app' && key.id) { %>
                                                        <a href="/apps/<%= key.id %>" class="text-gray-400 hover:text-indigo-600 transition-colors" title="Manage App">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                                        </a>
                                                    <% } else { %>
                                                        <button class="text-gray-400 hover:text-red-500 transition-colors">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                                        </button>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    <% } else { %>
                                        <tr><td colspan="5" class="px-6 py-8 text-center text-gray-400">No keys found.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </div>
    <%- include('../partials/sidebar-script') %>

    <!-- Charts Initialization -->
    <% if (locals.analytics) { %>
    <script>
        // Data passed from server
        const dailyData = <%- JSON.stringify(locals.analytics.dailyUsage) %>;
        const distData = <%- JSON.stringify(locals.analytics.serviceDistribution) %>;

        // 1. Line Chart
        const ctxTrend = document.getElementById('usageTrendChart').getContext('2d');
        const gradient = ctxTrend.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(99, 102, 241, 0.5)'); // Indigo
        gradient.addColorStop(1, 'rgba(99, 102, 241, 0.0)');

        new Chart(ctxTrend, {
            type: 'line',
            data: {
                labels: dailyData.map(d => d.date),
                datasets: [{
                    label: 'Requests',
                    data: dailyData.map(d => d.count),
                    borderColor: '#6366f1',
                    backgroundColor: gradient,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, grid: { display: true, borderDash: [5, 5] } },
                    x: { grid: { display: false } }
                }
            }
        });

        // 2. Donut Chart
        const ctxDist = document.getElementById('distributionChart').getContext('2d');
        new Chart(ctxDist, {
            type: 'doughnut',
            data: {
                labels: distData.map(d => d.label),
                datasets: [{
                    data: distData.map(d => d.value),
                    backgroundColor: distData.map(d => d.color),
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
    <% } %>


    <!-- Create Key Modal -->
    <div id="createKeyModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50">
        <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
            <div class="mt-3 text-center">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Create New API Key</h3>
                <form class="mt-4 text-left" action="/subscription/keys/create" method="POST">
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-bold mb-2" for="keyName">
                            Friendly Name
                        </label>
                        <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" id="keyName" name="name" type="text" placeholder="e.g. My Website Integration" required>
                    </div>
                    <div class="flex items-center justify-end gap-2">
                        <button type="button" onclick="document.getElementById('createKeyModal').classList.add('hidden')" class="px-4 py-2 bg-gray-200 text-gray-800 text-base font-medium rounded-md shadow-sm hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-gray-300">
                            Cancel
                        </button>
                        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white text-base font-medium rounded-md shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            Create Key
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Click outside to close -->
    <script>
        window.onclick = function(event) {
            const modal = document.getElementById('createKeyModal');
            if (event.target == modal) {
                modal.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
