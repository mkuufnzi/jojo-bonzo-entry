generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  password             String               @default("")
  name                 String?
  isActive             Boolean              @default(true)
  emailVerified        DateTime?
  verificationToken    String?
  googleId             String?              @unique
  facebookId           String?              @unique
  linkedinId           String?              @unique
  avatar               String?
  stripeCustomerId     String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  twitterId            String?              @unique
  isAdmin              Boolean              @default(false)
  role                 String               @default("USER")
  isTwoFactorEnabled   Boolean              @default(false)
  twoFactorCodeExpires DateTime?
  twoFactorCurrentCode String?
  twoFactorSecret      String?
  businessId           String?
  adminLogs            AdminLog[]
  apiKeys              ApiKey[]
  apps                 App[]
  debtCollectionTasks  DebtCollectionTask[]
  invoices             Invoice[]
  loginHistory         LoginHistory[]
  notifications        Notification[]
  notificationConfig   NotificationConfig?
  paymentMethods       PaymentMethod[]
  smartDocuments       SmartDocument[]
  subscription         Subscription?
  logs                 UsageLog[]
  business             Business?            @relation(fields: [businessId], references: [id])
  devices              UserDevice[]
  profile              UserProfile?
}

model Business {
  id                             String                          @id @default(uuid())
  name                           String
  sector                         String?
  address                        String?
  city                           String?
  state                          String?
  zip                            String?
  country                        String?
  taxId                          String?
  website                        String?
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  metadata                       Json?
  currentOnboardingStep          Int                             @default(0)
  onboardingStatus               OnboardingStatus                @default(NOT_STARTED)
  analyticsEvents                AnalyticsEvent[]
  brandingProfiles               BrandingProfile[]
  businessMetrics                BusinessMetric[]
  campaigns                      Campaign[]
  contacts                       Contact[]
  debtCollectionActions          DebtCollectionAction[]
  debtCollectionClusters         DebtCollectionCluster[]
  debtCollectionCustomers        DebtCollectionCustomer[]
  debtCollectionCustomerProfiles DebtCollectionCustomerProfile[]
  debtCollectionInvoices         DebtCollectionInvoice[]
  debtCollectionTemplates        DebtCollectionMessageTemplate[]
  debtCollectionSequences        DebtCollectionSequence[]
  debtCollectionSessions         DebtCollectionSession[]
  debtCollectionTasks            DebtCollectionTask[]
  externalDocuments              ExternalDocument[]
  integrations                   Integration[]
  processedDocuments             ProcessedDocument[]
  products                       Product[]
  recommendationRules            RecommendationRule[]
  unifiedCustomers               UnifiedCustomer[]
  unifiedEstimates               UnifiedEstimate[]
  unifiedInvoices                UnifiedInvoice[]
  unifiedOrders                  UnifiedOrder[]
  unifiedPayments                UnifiedPayment[]
  unifiedProducts                UnifiedProduct[]
  unifiedShippingNotes           UnifiedShippingNote[]
  unifiedSyncJobs                UnifiedSyncJob[]
  users                          User[]
  userTemplates                  UserTemplate[]
  workflows                      Workflow[]
}

model UserDevice {
  id        String   @id @default(uuid())
  userId    String
  userAgent String
  ipAddress String
  lastLogin DateTime @default(now())
  isTrusted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String
  userAgent String
  status    String
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model NotificationConfig {
  id            String   @id @default(uuid())
  userId        String   @unique
  emailEnabled  Boolean  @default(true)
  inAppEnabled  Boolean  @default(true)
  toolSuccess   Boolean  @default(true)
  toolFailure   Boolean  @default(true)
  billingAlert  Boolean  @default(true)
  paymentAction Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                  String      @id @default(uuid())
  userId              String      @unique
  firstName           String
  lastName            String
  phoneNumber         String?
  profession          String?
  accountType         AccountType @default(INDIVIDUAL)
  onboardingCompleted Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Integration {
  id                   String                @id @default(uuid())
  provider             String
  name                 String?
  accessToken          String?
  refreshToken         String?
  expiresAt            DateTime?
  status               String                @default("connected")
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  businessId           String
  settings             Json?
  externalDocuments    ExternalDocument[]
  business             Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  unifiedCustomers     UnifiedCustomer[]
  unifiedEstimates     UnifiedEstimate[]
  unifiedInvoices      UnifiedInvoice[]
  unifiedOrders        UnifiedOrder[]
  unifiedPayments      UnifiedPayment[]
  unifiedProducts      UnifiedProduct[]
  unifiedShippingNotes UnifiedShippingNote[]
  unifiedSyncJobs      UnifiedSyncJob[]

  @@unique([businessId, provider])
  @@index([businessId])
}

model IntegrationDefinition {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  category    String
  isPopular   Boolean  @default(false)
  status      String   @default("active")
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandingProfile {
  id               String   @id @default(uuid())
  name             String   @default("Default Brand")
  isDefault        Boolean  @default(false)
  logoUrl          String?
  faviconUrl       String?
  brandColors      Json?
  fontSettings     Json?
  templates        Json?
  upsellConfig     Json?
  supportConfig    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  businessId       String
  metadata         Json?
  voiceProfile     Json?
  activeTemplateId String   @default("smart_invoice_v1")
  components       Json?
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Contact {
  id         String   @id @default(uuid())
  businessId String
  externalId String
  source     String
  name       String
  email      String?
  phone      String?
  type       String   @default("customer")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, source, externalId])
  @@index([businessId])
}

model Product {
  id          String   @id @default(uuid())
  businessId  String
  externalId  String
  source      String
  name        String
  sku         String?
  description String?
  price       Float?
  currency    String   @default("USD")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, source, externalId])
  @@index([businessId])
}

model UserTemplate {
  id             String   @id @default(uuid())
  businessId     String
  name           String
  documentType   String
  htmlContent    String?
  source         String   @default("system")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  baseTemplateId String?
  config         Json?
  isDefault      Boolean  @default(false)
  business       Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([businessId, documentType])
}

model Workflow {
  id            String                 @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean                @default(true)
  triggerType   String
  triggerConfig Json?
  actionConfig  Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  businessId    String
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  executionLogs WorkflowExecutionLog[]

  @@index([businessId])
}

model WorkflowExecutionLog {
  id         String   @id @default(uuid())
  workflowId String
  status     String
  inputData  Json?
  outputData Json?
  error      String?
  duration   Int?
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model DocumentType {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  schema    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id            String         @id @default(uuid())
  name          String         @unique
  price         Float
  stripePriceId String?
  requestLimit  Int
  pdfQuota      Int            @default(0)
  aiQuota       Int            @default(0)
  features      String
  currency      String         @default("USD")
  planFeatures  PlanFeature[]
  subscriptions Subscription[]
}

model Feature {
  id           String        @id @default(uuid())
  key          String        @unique
  name         String
  description  String?
  category     String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  planFeatures PlanFeature[]
}

model PlanFeature {
  id        String   @id @default(uuid())
  planId    String
  featureId String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String    @unique
  planId               String
  stripeSubscriptionId String?   @unique
  status               String    @default("active")
  startDate            DateTime  @default(now())
  endDate              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  invoices             Invoice[]
  plan                 Plan      @relation(fields: [planId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])
}

model PaymentMethod {
  id               String    @id @default(uuid())
  userId           String
  type             String
  provider         String
  providerMethodId String?
  last4            String?
  expiry           String?
  isDefault        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invoices         Invoice[]
  user             User      @relation(fields: [userId], references: [id])
}

model Invoice {
  id              String         @id @default(uuid())
  userId          String
  subscriptionId  String?
  paymentMethodId String?
  stripeInvoiceId String?        @unique
  amount          Float
  currency        String         @default("USD")
  status          String
  paidAt          DateTime?
  createdAt       DateTime       @default(now())
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  subscription    Subscription?  @relation(fields: [subscriptionId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
}

model App {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  apiKey             String              @unique
  apiKeyExpiresAt    DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userId             String
  user               User                @relation(fields: [userId], references: [id])
  services           AppService[]
  processedDocuments ProcessedDocument[]
  logs               UsageLog[]
}

model ApiKey {
  id         String    @id @default(uuid())
  key        String    @unique
  name       String    @default("Default Key")
  scopes     String    @default("*")
  status     String    @default("active")
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Service {
  id                 String       @id @default(uuid())
  name               String       @unique
  slug               String       @unique
  description        String?
  pricePerRequest    Float        @default(0.0)
  executionType      String       @default("local")
  endpointUrl        String?
  config             Json?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  requiredFeatureKey String?
  defaultConfig      Json?
  defaultScopes      Json?
  dependencies       Json?
  endpoints          Json?
  healthCheckUrl     String?
  provides           Json?
  requires           Json?
  scalingConfig      Json?
  tier               String       @default("core")
  apps               AppService[]
  logs               UsageLog[]

  @@index([tier, slug])
}

model AppService {
  appId     String
  serviceId String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appId, serviceId])
}

model UsageLog {
  id           String   @id @default(uuid())
  userId       String?
  appId        String?
  serviceId    String?
  action       String
  resourceType String?
  status       String
  statusCode   Int?
  duration     Int
  cost         Float    @default(0.0)
  ipAddress    String?
  userAgent    String?
  errorMessage String?
  metadata     String?
  createdAt    DateTime @default(now())
  app          App?     @relation(fields: [appId], references: [id])
  service      Service? @relation(fields: [serviceId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model ApiRequestLog {
  id         String   @id @default(uuid())
  method     String
  path       String
  statusCode Int
  duration   Int
  ipAddress  String?
  userAgent  String?
  userId     String?
  appId      String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([appId])
  @@index([createdAt])
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  ip        String?
  details   Json?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("info")
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  source    String?
  interest  String?
  createdAt DateTime @default(now())
}

model IpBan {
  id        String    @id @default(uuid())
  ipAddress String    @unique
  reason    String?
  bannedBy  String
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([ipAddress])
  @@index([expiresAt])
}

model ExternalDocument {
  id            String      @id @default(uuid())
  businessId    String
  integrationId String
  externalId    String
  type          String
  data          Json
  normalized    Json?
  hash          String?
  syncedAt      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalId, type])
  @@index([businessId, type])
  @@index([syncedAt])
}

model RecommendationRule {
  id              String   @id @default(uuid())
  businessId      String
  name            String
  triggerSku      String?
  triggerCategory String?
  targetSku       String
  aiPromptContext String?
  copyTemplate    String?
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, triggerSku])
}

model Campaign {
  id           String   @id @default(uuid())
  businessId   String
  name         String
  startDate    DateTime
  endDate      DateTime
  promotedSku  String
  discountCode String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model DebtCollectionSequence {
  id                          String                       @id @default(uuid())
  businessId                  String
  name                        String                       @default("Default Recovery")
  steps                       Json
  settings                    Json?
  isActive                    Boolean                      @default(true)
  isDefault                   Boolean                      @default(false)
  rules                       Json?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  cluster                     DebtCollectionCluster?
  business                    Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  debtCollectionSequenceRules DebtCollectionSequenceRule[]
  debtCollectionSequenceSteps DebtCollectionSequenceStep[]
  sessions                    DebtCollectionSession[]

  @@index([businessId])
}

model DebtCollectionSession {
  id                           String                       @id @default(uuid())
  businessId                   String
  sequenceId                   String
  externalInvoiceId            String
  customerId                   String?
  customerName                 String?
  status                       String                       @default("ACTIVE")
  currentStepIndex             Int                          @default(0)
  nextActionAt                 DateTime?
  metadata                     Json?
  createdAt                    DateTime                     @default(now())
  updatedAt                    DateTime                     @updatedAt
  actions                      DebtCollectionAction[]
  debtCollectionAuditLogs      DebtCollectionAuditLog[]
  debtCollectionDisputes       DebtCollectionDispute[]
  debtCollectionPromiseToPays  DebtCollectionPromiseToPay[]
  business                     Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sequence                     DebtCollectionSequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  debtCollectionStateHistories DebtCollectionStateHistory[]
  debtCollectionTasks          DebtCollectionTask[]

  @@unique([businessId, externalInvoiceId, status])
  @@index([businessId, externalInvoiceId])
  @@index([businessId, customerId])
}

model DebtCollectionCustomer {
  id             String                         @id @default(uuid())
  businessId     String
  externalId     String
  name           String
  email          String?
  phone          String?
  lifetimeValue  Float                          @default(0)
  totalInvoices  Int                            @default(0)
  unpaidInvoices Int                            @default(0)
  riskScore      String                         @default("Unknown")
  metadata       Json?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt
  isActive       Boolean                        @default(true)
  business       Business                       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  profile        DebtCollectionCustomerProfile?
  invoices       DebtCollectionInvoice[]

  @@unique([businessId, externalId])
  @@index([businessId])
}

model DebtCollectionCustomerProfile {
  id                   String                 @id @default(uuid())
  debtCustomerId       String                 @unique
  businessId           String
  lifetimeValue        Float                  @default(0)
  totalPurchases       Int                    @default(0)
  paymentFrequencyDays Float?
  creditLimit          Float?
  riskScore            String                 @default("LOW")
  clusterId            String?
  lastEnrichedAt       DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  business             Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  cluster              DebtCollectionCluster? @relation(fields: [clusterId], references: [id])
  customer             DebtCollectionCustomer @relation(fields: [debtCustomerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([clusterId])
}

model DebtCollectionCluster {
  id          String                          @id @default(uuid())
  businessId  String
  name        String
  description String?
  ruleLogic   Json
  sequenceId  String?                         @unique
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt
  business    Business                        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sequence    DebtCollectionSequence?         @relation(fields: [sequenceId], references: [id])
  profiles    DebtCollectionCustomerProfile[]

  @@index([businessId])
}

model DebtCollectionInvoice {
  id            String                 @id @default(uuid())
  businessId    String
  customerId    String
  externalId    String                 @unique
  invoiceNumber String?
  amount        Float                  @default(0)
  balance       Float                  @default(0)
  status        String
  dueDate       DateTime?
  issuedDate    DateTime?
  metadata      Json?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      DebtCollectionCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([businessId, externalId])
  @@index([businessId, customerId])
}

model DebtCollectionAction {
  id                             String                          @id @default(uuid())
  businessId                     String
  sessionId                      String?
  externalInvoiceId              String
  actionType                     String
  status                         String
  aiGeneratedCopy                String?
  metadata                       Json?
  sentAt                         DateTime?
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @default(now()) @updatedAt
  business                       Business                        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  session                        DebtCollectionSession?          @relation(fields: [sessionId], references: [id])
  debtCollectionCommunicationLog DebtCollectionCommunicationLog?

  @@index([businessId, externalInvoiceId])
}

model DebtCollectionSequenceStep {
  id              String                         @id @default(uuid())
  sequenceId      String
  dayOffset       Int
  actionType      String
  templateId      String?
  escalationLevel Int                            @default(0)
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt
  sequence        DebtCollectionSequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template        DebtCollectionMessageTemplate? @relation(fields: [templateId], references: [id])

  @@index([sequenceId])
}

model DebtCollectionSequenceRule {
  id             String                 @id @default(uuid())
  sequenceId     String
  conditionField String
  operator       String
  value          String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  sequence       DebtCollectionSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model DebtCollectionMessageTemplate {
  id             String                       @id @default(uuid())
  businessId     String
  name           String
  channel        String
  subject        String?
  body           String
  mergeVariables Json?
  tone           String                       @default("Neutral")
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  business       Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  steps          DebtCollectionSequenceStep[]

  @@index([businessId])
}

model DebtCollectionCommunicationLog {
  id               String               @id @default(uuid())
  actionId         String               @unique
  event            String
  providerResponse Json?
  timestamp        DateTime             @default(now())
  action           DebtCollectionAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
}

model DebtCollectionTask {
  id              String                @id @default(uuid())
  businessId      String
  sessionId       String
  assignedUserId  String?
  taskType        String
  status          String                @default("PENDING")
  dueDate         DateTime?
  resolutionNotes String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  assignedUser    User?                 @relation(fields: [assignedUserId], references: [id])
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  session         DebtCollectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([sessionId])
}

model DebtCollectionDispute {
  id                 String                 @id @default(uuid())
  invoiceExternalId  String
  customerExternalId String?
  sessionId          String?
  status             String                 @default("OPEN")
  reasonCategoryId   String?
  details            String
  resolutionNotes    String?
  openedAt           DateTime               @default(now())
  resolvedAt         DateTime?
  session            DebtCollectionSession? @relation(fields: [sessionId], references: [id])

  @@index([invoiceExternalId, status])
}

model DebtCollectionPromiseToPay {
  id                String                @id @default(uuid())
  sessionId         String
  invoiceExternalId String
  status            String                @default("ACTIVE")
  promisedAmount    Float
  promisedDate      DateTime
  terms             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  session           DebtCollectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([invoiceExternalId])
}

model DebtCollectionPartialPayment {
  id                String   @id @default(uuid())
  invoiceExternalId String
  amount            Float
  paymentMethod     String?
  recordedAt        DateTime @default(now())
  syncStatus        String   @default("LOCAL")

  @@index([invoiceExternalId])
}

model DebtCollectionAuditLog {
  id        String                @id @default(uuid())
  sessionId String
  actorType String
  actorId   String?
  event     String
  reason    String?
  timestamp DateTime              @default(now())
  session   DebtCollectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
}

model DebtCollectionStateHistory {
  id             String                @id @default(uuid())
  sessionId      String
  previousStatus String
  newStatus      String
  reason         String?
  triggerSource  String                @default("SYSTEM")
  timestamp      DateTime              @default(now())
  session        DebtCollectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  businessId String
  userId     String?
  type       String
  amount     Float?
  currency   String   @default("USD")
  metadata   Json?
  timestamp  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, type])
  @@index([timestamp])
}

model BusinessMetric {
  id           String   @id @default(uuid())
  businessId   String
  metricKey    String
  value        Float
  metadata     Json?
  calculatedAt DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, metricKey])
  @@index([calculatedAt])
}

model SmartDocument {
  id             String   @id @default(uuid())
  userId         String
  type           String
  status         String   @default("DRAFT")
  documentNumber String
  issuedAt       DateTime @default(now())
  data           Json
  theme          Json
  config         Json
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId, type])
}

/// ProcessedDocument tracks all documents through the branding/email pipeline
model ProcessedDocument {
  id               String   @id @default(uuid())
  businessId       String
  appId            String
  userId           String
  provider         String
  resourceType     String
  resourceId       String
  eventType        String
  status           String   @default("pending")
  flooviooId       String?  @unique
  n8nExecutionId   String?
  brandedUrl       String?
  emailSent        Boolean  @default(false)
  emailRecipient   String?
  emailMessageId   String?
  processingTimeMs Int?
  errorMessage     String?
  retryCount       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  app              App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt(sort: Desc)])
  @@index([status])
  @@index([appId])
  @@index([userId])
}

/// AuditLog provides universal audit trail for all API calls and n8n dispatches
model AuditLog {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  userId         String?
  appId          String?
  businessId     String?
  actionType     String
  serviceId      String?
  eventType      String?
  requestPayload Json?
  requestId      String?
  responseStatus Int?
  responseData   Json?
  durationMs     Int?
  success        Boolean
  errorMessage   String?

  @@index([userId, timestamp(sort: Desc)])
  @@index([businessId, timestamp(sort: Desc)])
  @@index([eventType])
  @@index([actionType])
  @@index([requestId])
}

model UnifiedCustomer {
  id            String            @id @default(uuid())
  businessId    String
  integrationId String
  externalId    String
  name          String
  email         String?
  phone         String?
  source        String
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  integration   Integration       @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  estimates     UnifiedEstimate[]
  invoices      UnifiedInvoice[]
  orders        UnifiedOrder[]
  payments      UnifiedPayment[]

  @@unique([businessId, integrationId, externalId])
  @@index([businessId])
}

model UnifiedInvoice {
  id            String          @id @default(uuid())
  businessId    String
  integrationId String
  customerId    String
  externalId    String
  invoiceNumber String?
  amount        Float           @default(0)
  balance       Float           @default(0)
  status        String
  dueDate       DateTime?
  issuedDate    DateTime?
  source        String
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      UnifiedCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  integration   Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([businessId, integrationId, externalId])
  @@index([businessId, customerId])
}

model UnifiedProduct {
  id            String      @id @default(uuid())
  businessId    String
  integrationId String
  externalId    String
  name          String
  sku           String?
  description   String?
  price         Float?
  currency      String      @default("USD")
  source        String
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([businessId, integrationId, externalId])
  @@index([businessId])
}

model UnifiedOrder {
  id            String                @id @default(uuid())
  businessId    String
  integrationId String
  customerId    String
  externalId    String
  orderNumber   String?
  amount        Float                 @default(0)
  status        String
  orderDate     DateTime?
  source        String
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  business      Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      UnifiedCustomer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  integration   Integration           @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  shippingNotes UnifiedShippingNote[]

  @@unique([businessId, integrationId, externalId])
  @@index([businessId, customerId])
}

model UnifiedPayment {
  id            String          @id @default(uuid())
  businessId    String
  integrationId String
  customerId    String
  externalId    String
  amount        Float           @default(0)
  method        String?
  status        String
  paymentDate   DateTime?
  source        String
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      UnifiedCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  integration   Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([businessId, integrationId, externalId])
  @@index([businessId, customerId])
}

model UnifiedShippingNote {
  id            String       @id @default(uuid())
  businessId    String
  integrationId String
  orderId       String
  externalId    String
  trackingId    String?
  carrier       String?
  status        String
  shippedDate   DateTime?
  source        String
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  integration   Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  order         UnifiedOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([businessId, integrationId, externalId])
  @@index([businessId, orderId])
}

model UnifiedEstimate {
  id            String          @id @default(uuid())
  businessId    String
  integrationId String
  customerId    String
  externalId    String
  estimateNum   String?
  amount        Float           @default(0)
  status        String
  estimateDate  DateTime?
  expiryDate    DateTime?
  source        String
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      UnifiedCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  integration   Integration     @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([businessId, integrationId, externalId])
  @@index([businessId, customerId])
}

model UnifiedSyncJob {
  id            String      @id @default(uuid())
  businessId    String
  integrationId String
  entityType    String
  status        String      @default("PENDING")
  startedAt     DateTime?
  completedAt   DateTime?
  recordsSynced Int         @default(0)
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([businessId, integrationId, entityType])
  @@index([status])
}

