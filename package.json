{
  "name": "afs_doc_tools",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "dotenv -e environments/.env.docker.local -- concurrently \"node dist/index.js\" \"npm run worker:prod\" \"prisma studio --browser none\"",
    "dev": "dotenv -e environments/.env.development -- concurrently \"nodemon ./src/index.ts\" \"prisma studio --browser none\"",
    "dev:all": "dotenv -e environments/.env.development -- concurrently \"nodemon ./src/index.ts\" \"nodemon ./src/workers/index.ts\" \"prisma studio --port 5555 --browser none\"",
    "worker": "nodemon ./src/workers/index.ts",
    "worker:prod": "node ./dist/workers/index.js",
    "build": "tsc -p ./tsconfig.json && npm run build:css && shx rm -rf dist/views && shx cp -r src/views dist/views",
    "build:css": "npx tailwindcss -i ./src/styles/main.css -o ./public/assets/css/style.css --minify",
    "watch:css": "npx tailwindcss -i ./src/styles/main.css -o ./public/assets/css/style.css --watch",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:backup": "ts-node scripts/backup-db.ts",
    "db:prune": "ts-node scripts/prune-logs.ts",
    "test:concurrency": "ts-node scripts/verify-quota-race.ts",
    "preflight": "node scripts/preflight.js",
    "docker:dev": "npm run preflight && docker-compose -f docker-compose.dev.yml up --build",
    "docker:local-prod": "npm run preflight && docker-compose -f docker-compose.local-prod.yml up --build",
    "docker:prod": "npm run preflight && docker-compose up -d --build",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
