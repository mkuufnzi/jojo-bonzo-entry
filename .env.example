# Application Configuration
NODE_ENV=production
PORT=3002
APP_URL=https://your-domain.com

# Database Configuration (PostgreSQL)
# Use 'postgres' as host if running in Docker with db_net
DB_HOST=postgres
DB_PORT=5432
DB_NAME=n8n
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SCHEMA=application
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}"

# Redis Configuration
# Use 'redis' as host if running in Docker with db_net
REDIS_URL=redis://redis:6379

# Session Configuration
SESSION_SECRET=change_this_to_a_secure_random_string

# Email Configuration
FROM_EMAIL=no-reply@your-domain.com
FROM_NAME='Floovioo '
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
NOTIFICATION_EMAILS=admin@your-domain.com

# AI Generation Configuration
AI_GENERATION_TIMEOUT=30000
AI_WEBHOOK_SECRET=your_webhook_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Security Configuration
ALLOWED_ORIGINS=https://your-domain.com

# Social Auth Configuration (Optional)
# Leave blank or remove to disable specific providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_KEY=
LINKEDIN_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

ADMIN_EMAIL=admin@your-domain.com
